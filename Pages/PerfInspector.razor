<!--/* In the name of God, the Merciful, the Compassionate */-->
@page "/perf-inspector"

@using SQLTriage.Data.Services
@using SQLTriage.Data.Models
@inject PerformanceInspectorService PerfService

<h2>Performance Inspector</h2>

@if (Traces.Any())
{
    <p>Last load: @LastLoadTraces.Count() panels, total @LastLoadTraces.Sum(t => t.TotalDuration.TotalSeconds):#.2f s</p>

    <h3>Waterfall (Last Load)</h3>
    <div style="position:relative; height:400px; border:1px solid #ccc;">
        @foreach (var trace in LastLoadTraces.OrderBy(t => t.EnqueuedAt))
        {
            var left = (trace.EnqueuedAt - LastLoadTraces.Min(t => t.EnqueuedAt)).TotalMilliseconds / 100;
            var width = trace.TotalDuration.TotalMilliseconds / 100;
            var top = LastLoadTraces.OrderBy(t => t.EnqueuedAt).ToList().IndexOf(trace) * 20;
            <div style="position:absolute; left:@left px; top:@top px; width:@width px; height:15px; background:blue; color:white; font-size:10px;" title="@trace.PanelId - @trace.TotalDuration.TotalSeconds s">@trace.PanelId</div>
        }
    </div>

    <h3>Dominant Bucket</h3>
    <p>@GetDominantBucket()</p>

    <h3>All Traces</h3>
    <table class="results-table">
        <thead>
            <tr>
                <th>Dashboard</th>
                <th>Panel</th>
                <th>Query</th>
                <th>Server</th>
                <th>Cache Tier</th>
                <th>Rows</th>
                <th>Queue Wait (s)</th>
                <th>SQL (s)</th>
                <th>Cache Write (s)</th>
                <th>Render (s)</th>
                <th>Total (s)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var trace in Traces.OrderByDescending(t => t.EnqueuedAt))
            {
                <tr>
                    <td>@trace.DashboardId</td>
                    <td>@trace.PanelId</td>
                    <td>@trace.QueryId</td>
                    <td>@trace.ServerName</td>
                    <td>@trace.CacheHitTier</td>
                    <td>@trace.RowCount</td>
                    <td>@trace.QueueWait.TotalSeconds.ToString("F2")</td>
                    <td>@trace.SqlDuration.TotalSeconds.ToString("F2")</td>
                    <td>@trace.CacheWrite.TotalSeconds.ToString("F2")</td>
                    <td>@trace.RenderDuration.TotalSeconds.ToString("F2")</td>
                    <td>@trace.TotalDuration.TotalSeconds.ToString("F2")</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No traces available. Enable in Settings and load a dashboard.</p>
}

@code {
    private IReadOnlyList<PanelTrace> Traces => PerfService.GetRecentTraces();
    private IEnumerable<PanelTrace> LastLoadTraces => PerfService.GetLastLoadTraces("live"); // Assuming /live

    private string GetDominantBucket()
    {
        var avgQueue = LastLoadTraces.Average(t => t.QueueWait.TotalSeconds);
        var avgSql = LastLoadTraces.Average(t => t.SqlDuration.TotalSeconds);
        var avgCache = LastLoadTraces.Average(t => t.CacheWrite.TotalSeconds);
        var avgRender = LastLoadTraces.Average(t => t.RenderDuration.TotalSeconds);

        var max = Math.Max(Math.Max(avgQueue, avgSql), Math.Max(avgCache, avgRender));

        if (max == avgQueue) return "Queue Wait (orchestrator backpressure)";
        if (max == avgSql) return "SQL Execution (query performance)";
        if (max == avgCache) return "Cache Write (serialization/batching)";
        return "Render (Blazor/ApexCharts)";
    }
}