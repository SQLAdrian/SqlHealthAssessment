<!--/* In the name of God, the Merciful, the Compassionate */-->
@page "/governance-report"
@using SQLTriage.Data.Services
@using SQLTriage.Data.Models
@inject IReportService ReportService
@inject ServerConnectionManager ConnectionManager
@inject ToastService Toast
@inject NavigationManager Navigation

<PageTitle>Governance Report - SQLTriage</PageTitle>

@if (!_pageAuthorised)
{
    <AccessDenied Message="The Governance Report is currently restricted to the maintainer workstation." />
    return;
}

<div class="page-container">
    <div class="page-header">
        <h1><i class="fa-solid fa-file-pdf"></i> Governance Report</h1>
        <p>Generate a printable PDF governance assessment for your SQL Server instances.</p>
    </div>

    <div class="card">
        <h2>Report Configuration</h2>
        <div class="form-group">
            <label>Server Instance</label>
            <select class="form-control" @bind="_selectedInstance">
                <option value="">-- Select instance --</option>
                @foreach (var conn in ConnectionManager.GetConnections())
                {
                    @foreach (var server in conn.GetServerList())
                    {
                        <option value="@server">@server</option>
                    }
                }
            </select>
        </div>

        <div class="form-group">
            <label class="checkbox-label">
                <input type="checkbox" @bind="_includeAllFindings" />
                Include all findings (default: top 10 failed only)
            </label>
        </div>

        <div class="actions">
            <button class="btn btn-primary" @onclick="GenerateReport" disabled="@_generating">
                @if (_generating)
                {
                    <span><i class="fa-solid fa-spinner fa-spin"></i> Generating</span>
                }
                else
                {
                    <span><i class="fa-solid fa-file-pdf"></i> Generate PDF</span>
                }
            </button>
        </div>

        @if (!string.IsNullOrEmpty(_statusMessage))
        {
            <div class="alert alert-info" style="margin-top: 12px;">@_statusMessage</div>
        }
    </div>

    @if (_pdfBytes != null)
    {
        <div class="card">
            <h2>Preview</h2>
            <p>The report has been generated. You can download it below.</p>
            <button class="btn btn-primary" @onclick="DownloadPdf">
                <i class="fa-solid fa-download"></i> Download PDF
            </button>
        </div>
    }
</div>

<!-- Styles extracted to wwwroot/css/GovernanceReport.css 2026-05-11 (CLAUDE.md convention). -->

@code {
    // Gate: page is hidden from nav/palette + redirects unauthorised users (2026-05-12).
    private static readonly bool _pageAuthorised =
        string.Equals(Environment.MachineName, "MSI",   StringComparison.OrdinalIgnoreCase) &&
        string.Equals(Environment.UserName,    "afsul", StringComparison.OrdinalIgnoreCase);

    private string _selectedInstance = "";
    private bool _includeAllFindings = false;
    private bool _generating = false;
    private string _statusMessage = "";
    private byte[]? _pdfBytes;

    private async Task GenerateReport()
    {
        if (string.IsNullOrWhiteSpace(_selectedInstance))
        {
            Toast.ShowWarning("Select a server", "Please choose a SQL Server instance to generate the report.");
            return;
        }

        _generating = true;
        _statusMessage = "Generating report...";
        _pdfBytes = null;
        StateHasChanged();

        try
        {
            // In a real implementation, fetch actual check results from the database
            // For now, generate with mock/empty results to demonstrate the pipeline
            var mockResults = new List<CheckResult>();
            _pdfBytes = await ReportService.GenerateGovernanceReportAsync(_selectedInstance, mockResults);
            _statusMessage = $"Report generated: {_pdfBytes.Length:N0} bytes";
        }
        catch (Exception ex)
        {
            _statusMessage = $"Failed to generate report: {ex.Message}";
            Toast.ShowError("Report generation failed", ex.Message);
        }
        finally
        {
            _generating = false;
        }
    }

    private void DownloadPdf()
    {
        if (_pdfBytes == null) return;
        var fileName = $"SQLTriage-Governance-{_selectedInstance.Replace("\\", "-")}-{DateTime.Now:yyyyMMdd}.pdf";
        // Use JS interop for download in real implementation
        // For Blazor Hybrid, write to temp and open
        var tempPath = Path.Combine(Path.GetTempPath(), fileName);
        File.WriteAllBytes(tempPath, _pdfBytes);
        _statusMessage = $"Saved to: {tempPath}";
        Toast.ShowSuccess("Report saved", tempPath);
    }
}
