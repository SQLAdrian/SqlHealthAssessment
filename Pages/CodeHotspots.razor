<!--/* In the name of God, the Merciful, the Compassionate */-->
@page "/code-hotspots"
@inject IJSRuntime JS
@inject ServerConnectionManager ConnectionManager
@inject SQLTriage.Data.Services.CodeHotspotsService Service
@using SQLTriage.Data
@using SQLTriage.Data.Models
@implements IAsyncDisposable

<div class="hot-page">

    <!-- Slim top toolbar: source, metric, mode -->
    <div class="hot-toolbar">
        <div class="hot-toolbar-left">
            <i class="fa-solid fa-fire" style="color:var(--orange);font-size:16px;"></i>
            <span class="hot-title">Code Hotspots</span>
            @if (!_useMock && !string.IsNullOrEmpty(_selectedServer))
            {
                <span class="hot-source-pill"><i class="fa-solid fa-bolt"></i> @ServerDisplayName(_selectedServer)</span>
            }
            else if (_useMock)
            {
                <span class="hot-source-pill is-mock"><i class="fa-solid fa-flask"></i> Mock data</span>
            }
        </div>
        <div class="hot-toolbar-right">
            @if (!_useMock)
            {
                <select class="hot-server-select" @bind="_selectedServer" @bind:after="OnServerChangedAsync"
                        title="SQL Server connection for live data">
                    <option value="">— pick server —</option>
                    @foreach (var s in _availableServers)
                    {
                        <option value="@s.Key">@s.Display</option>
                    }
                </select>
            }
            <button class="hot-mode-toggle @(_useMock ? "is-mock" : "is-live")" @onclick="ToggleMockAsync"
                    title="Toggle between mocked sample data and live DMV">
                <i class="fa-solid @(_useMock ? "fa-flask" : "fa-bolt")"></i>
                @(_useMock ? "Mock" : "Live")
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="hot-error">
            <i class="fa-solid fa-triangle-exclamation"></i> @_errorMessage
            <button class="hot-error-close" @onclick="() => _errorMessage = string.Empty">×</button>
        </div>
    }

    <div class="hot-body">

        <!-- ── Left rail: drilldown navigator ──────────────────────── -->
        <aside class="hot-rail">
            <div class="hot-rail-head">
                <i class="fa-solid fa-list-tree"></i>
                <span>Drill down</span>
            </div>

            @if (!_useMock && string.IsNullOrEmpty(_selectedServer))
            {
                <div class="hot-rail-empty">
                    <i class="fa-solid fa-server"></i>
                    <p>Pick a server in the toolbar to begin.</p>
                </div>
            }
            else if (_loading && _dbs.Count == 0)
            {
                <div class="hot-rail-empty">
                    <i class="fa-solid fa-spinner fa-spin"></i>
                    <p>Loading databases…</p>
                </div>
            }
            else if (_dbs.Count == 0)
            {
                <div class="hot-rail-empty">
                    <i class="fa-solid fa-circle-info"></i>
                    <p>No data yet.</p>
                </div>
            }
            else
            {
                <div class="hot-rail-section-label">@_dbs.Count Databases</div>
                <div class="hot-rail-list">
                    @foreach (var db in _dbs)
                    {
                        var isOpen = _drillDb == db.Name && _level >= 1;
                        var isActive = _drillDb == db.Name;
                        <div class="hot-rail-item-wrap">
                            <button class="hot-rail-item lvl-db @(isActive ? "active" : "")"
                                    @onclick="() => OnDbClicked(db.Name)">
                                <i class="fa-solid @(isOpen ? "fa-folder-open" : "fa-database")"></i>
                                <span class="hot-rail-name">@db.Name</span>
                                <span class="hot-rail-bar" style="--w: @PctOfMaxDb(db)%"></span>
                                <span class="hot-rail-stat">@FormatMs(db.TotalCpuMs)</span>
                            </button>

                            @if (isOpen)
                            {
                                @if (_loading && _objs.Count == 0)
                                {
                                    <div class="hot-rail-sub-loading"><i class="fa-solid fa-spinner fa-spin"></i> Loading…</div>
                                }
                                else
                                {
                                    @foreach (var obj in _objs)
                                    {
                                        var objIsActive = _drillObj == obj.Name && _level == 2;
                                        var objIsOpen = _drillObj == obj.Name && _level >= 2;
                                        <div class="hot-rail-item-wrap">
                                            <button class="hot-rail-item lvl-obj @(objIsActive ? "active" : "")"
                                                    @onclick="() => OnObjClicked(obj.Name)">
                                                <i class="fa-solid @ObjIcon(obj.Kind)"></i>
                                                <span class="hot-rail-name" title="@obj.Name">@TruncateMid(obj.Name, 28)</span>
                                                <span class="hot-rail-bar" style="--w: @PctOfMaxObj(obj)%"></span>
                                                <span class="hot-rail-stat">@FormatMs(obj.TotalCpuMs)</span>
                                            </button>

                                            @if (objIsOpen)
                                            {
                                                @if (_loading && _stmts.Count == 0)
                                                {
                                                    <div class="hot-rail-sub-loading"><i class="fa-solid fa-spinner fa-spin"></i> Loading…</div>
                                                }
                                                else
                                                {
                                                    @foreach (var s in _stmts)
                                                    {
                                                        var stmtIsActive = _selectedLeaf?.Name == s.Name;
                                                        <button class="hot-rail-item lvl-stmt @(stmtIsActive ? "active" : "")"
                                                                @onclick="() => OnStmtClicked(s)">
                                                            <i class="fa-solid fa-code"></i>
                                                            <span class="hot-rail-name" title="@s.Name">@TruncateMid(s.Name, 32)</span>
                                                            <span class="hot-rail-bar" style="--w: @PctOfMaxStmt(s)%"></span>
                                                            <span class="hot-rail-stat">@FormatMs(s.TotalCpuMs)</span>
                                                        </button>
                                                    }
                                                }
                                            }
                                        </div>
                                    }
                                }
                            }
                        </div>
                    }
                </div>
            }
        </aside>

        <!-- ── Right pane: treemap + detail ────────────────────────── -->
        <main class="hot-main">
            <div class="hot-main-head">
                <span class="hot-main-title">
                    @if (_level == 0) { <text>CPU breakdown by database</text> }
                    else if (_level == 1) { <text>CPU breakdown of objects in <b>@_drillDb</b></text> }
                    else { <text>CPU breakdown of statements in <b>@_drillObj</b></text> }
                </span>
                <div class="hot-metric-switch" title="Click a metric to re-pack tiles by that value">
                    @foreach (var m in _metrics)
                    {
                        <button class="hot-metric-btn @(_metric == m.Key ? "active" : "")"
                                @onclick="() => SetMetric(m.Key)" title="@m.Tip">
                            <i class="@m.Icon"></i> <span class="hot-metric-label">@m.Label</span>
                        </button>
                    }
                </div>
            </div>

            <div class="hot-canvas-wrap">
                <div id="hot-treemap" class="hot-canvas"></div>

                @if (HasNoData())
                {
                    <div class="hot-canvas-empty">
                        <i class="fa-solid fa-arrow-left"></i>
                        <p><b>Pick a level on the left to drill in.</b></p>
                        <p class="hot-canvas-empty-sub">
                            @if (!_useMock && string.IsNullOrEmpty(_selectedServer))
                            {
                                <text>You'll need to pick a SQL Server connection first.</text>
                            }
                            else
                            {
                                <text>Hover a row to preview, click to drill in. Switch metric (top right) to change what 'biggest' means.</text>
                            }
                        </p>
                    </div>
                }

                @if (_selectedLeaf is not null)
                {
                    <aside class="hot-detail">
                        <div class="hot-detail-head">
                            <span class="hot-detail-kind">@_selectedLeaf.Kind</span>
                            <span class="hot-detail-name">@_selectedLeaf.Name</span>
                            <button class="hot-detail-close" @onclick="() => _selectedLeaf = null">×</button>
                        </div>
                        @if (!string.IsNullOrEmpty(_selectedLeaf.Snippet))
                        {
                            <pre class="hot-detail-sql">@_selectedLeaf.Snippet</pre>
                        }
                        <div class="hot-detail-grid">
                            <div><span class="hot-k">Executions</span><span class="hot-v">@_selectedLeaf.Execs.ToString("N0")</span></div>
                            <div><span class="hot-k">Total CPU</span><span class="hot-v">@FormatMs(_selectedLeaf.TotalCpuMs)</span></div>
                            <div><span class="hot-k">Avg CPU</span><span class="hot-v">@FormatMs(_selectedLeaf.AvgCpuMs)</span></div>
                            <div><span class="hot-k">Total Reads</span><span class="hot-v">@_selectedLeaf.Reads.ToString("N0")</span></div>
                            <div><span class="hot-k">Total Writes</span><span class="hot-v">@_selectedLeaf.Writes.ToString("N0")</span></div>
                            <div><span class="hot-k">% of CPU</span><span class="hot-v">@_selectedLeaf.PctOfTotal.ToString("F2")%</span></div>
                        </div>
                    </aside>
                }
            </div>
        </main>
    </div>
</div>

@code {

    private int _level = 0;
    private string _drillDb = "";
    private string _drillObj = "";
    private string _metric = "cpu";
    private bool _useMock = false;
    private LeafInfo? _selectedLeaf;
    private DotNetObjectReference<CodeHotspots>? _dotNetRef;
    private bool _jsReady;

    private string _selectedServer = "";
    private string _errorMessage = "";
    private bool _loading;
    private List<ServerOpt> _availableServers = new();

    private List<SQLTriage.Data.Services.CodeHotspotsService.DbRow> _dbs = new();
    private List<SQLTriage.Data.Services.CodeHotspotsService.ObjRow> _objs = new();
    private List<SQLTriage.Data.Services.CodeHotspotsService.StatementRow> _stmts = new();

    private record ServerOpt(string Key, string Display, ServerConnection Conn, string Server);
    private record MetricDef(string Key, string Label, string Icon, string Tip);
    private readonly MetricDef[] _metrics = new[]
    {
        new MetricDef("cpu",     "CPU",        "fa-solid fa-microchip",       "Sized by total worker time"),
        new MetricDef("reads",   "Reads",      "fa-solid fa-book-open",       "Sized by total logical reads"),
        new MetricDef("writes",  "Writes",     "fa-solid fa-pen-to-square",   "Sized by total logical writes"),
        new MetricDef("execs",   "Execs",      "fa-solid fa-play",            "Sized by execution count"),
        new MetricDef("avgcpu",  "Avg CPU",    "fa-solid fa-stopwatch",       "Sized by avg CPU per execution"),
    };

    public sealed class LeafInfo
    {
        public string Kind { get; set; } = "";
        public string Name { get; set; } = "";
        public string? Snippet { get; set; }
        public long Execs { get; set; }
        public double TotalCpuMs { get; set; }
        public double AvgCpuMs { get; set; }
        public long Reads { get; set; }
        public long Writes { get; set; }
        public double PctOfTotal { get; set; }
    }

    protected override void OnInitialized()
    {
        _availableServers = ConnectionManager.GetEnabledConnections()
            .SelectMany(c => c.GetServerList().Select(s => new ServerOpt(c.Id + "|" + s, s, c, s)))
            .ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("codeHotspots.init", "hot-treemap", _dotNetRef);
            _jsReady = true;
            await ReloadCurrentLevelAsync();
        }
    }

    private async Task ReloadCurrentLevelAsync()
    {
        if (_useMock)
        {
            if (_dbs.Count == 0) _dbs = MockData.Databases();
            if (_level >= 1 && _objs.Count == 0) _objs = MockData.Objects(_drillDb);
            if (_level >= 2 && _stmts.Count == 0) _stmts = MockData.Statements(_drillDb, _drillObj);
            await PushDataAsync();
            StateHasChanged();
            return;
        }

        if (string.IsNullOrEmpty(_selectedServer))
        {
            _dbs.Clear(); _objs.Clear(); _stmts.Clear();
            await PushDataAsync();
            return;
        }

        var opt = _availableServers.FirstOrDefault(o => o.Key == _selectedServer);
        if (opt is null) { _errorMessage = "Selected server not found."; return; }

        _loading = true;
        _errorMessage = "";
        StateHasChanged();
        try
        {
            if (_level == 0 || _dbs.Count == 0)
            {
                _dbs = await Service.GetDatabasesAsync(opt.Conn, opt.Server);
            }
            if (_level >= 1 && _objs.Count == 0)
            {
                _objs = await Service.GetObjectsAsync(opt.Conn, opt.Server, _drillDb);
            }
            if (_level >= 2 && _stmts.Count == 0)
            {
                _stmts = await Service.GetStatementsAsync(opt.Conn, opt.Server, _drillDb, _drillObj);
            }
            await PushDataAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Live query failed: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task PushDataAsync()
    {
        if (!_jsReady) return;
        var nodes = BuildNodes();
        await JS.InvokeVoidAsync("codeHotspots.render", "hot-treemap", nodes, _metric);
    }

    private async Task SetMetric(string key)
    {
        if (_metric == key) return;
        _metric = key;
        await PushDataAsync();
    }

    private async Task ToggleMockAsync()
    {
        _useMock = !_useMock;
        _level = 0; _drillDb = ""; _drillObj = "";
        _selectedLeaf = null;
        _dbs.Clear(); _objs.Clear(); _stmts.Clear();
        _errorMessage = "";
        await ReloadCurrentLevelAsync();
    }

    private async Task OnServerChangedAsync()
    {
        _level = 0; _drillDb = ""; _drillObj = "";
        _selectedLeaf = null;
        _dbs.Clear(); _objs.Clear(); _stmts.Clear();
        await ReloadCurrentLevelAsync();
    }

    private async Task OnDbClicked(string dbName)
    {
        if (_drillDb == dbName && _level >= 1)
        {
            // Already open — collapse back to root level
            _drillDb = "";
            _drillObj = "";
            _level = 0;
            _objs.Clear();
            _stmts.Clear();
        }
        else
        {
            _drillDb = dbName;
            _drillObj = "";
            _level = 1;
            _objs.Clear();
            _stmts.Clear();
        }
        _selectedLeaf = null;
        await ReloadCurrentLevelAsync();
    }

    private async Task OnObjClicked(string objName)
    {
        if (_drillObj == objName && _level >= 2)
        {
            _drillObj = "";
            _level = 1;
            _stmts.Clear();
        }
        else
        {
            _drillObj = objName;
            _level = 2;
            _stmts.Clear();
        }
        _selectedLeaf = null;
        await ReloadCurrentLevelAsync();
    }

    private void OnStmtClicked(SQLTriage.Data.Services.CodeHotspotsService.StatementRow s)
    {
        _selectedLeaf = new LeafInfo
        {
            Kind = "Statement", Name = s.Name, Snippet = s.Snippet,
            Execs = s.Execs, TotalCpuMs = s.TotalCpuMs, AvgCpuMs = s.AvgCpuMs,
            Reads = s.Reads, Writes = s.Writes, PctOfTotal = s.PctOfTotal
        };
        StateHasChanged();
    }

    [JSInvokable]
    public async Task OnTileClicked(string nodeId, string nodeName, string nodeKind)
    {
        if (nodeKind == "db" && _level == 0) await OnDbClicked(nodeName);
        else if (nodeKind == "obj" && _level == 1) await OnObjClicked(nodeName);
        else if (nodeKind == "stmt")
        {
            var s = _stmts.FirstOrDefault(x => x.Name == nodeName);
            if (s != null) OnStmtClicked(s);
        }
    }

    private bool HasNoData()
    {
        if (_level == 0) return _dbs.Count == 0;
        if (_level == 1) return _objs.Count == 0;
        return _stmts.Count == 0;
    }

    private object[] BuildNodes()
    {
        if (_level == 0)
        {
            if (_dbs.Count == 0) return Array.Empty<object>();
            var maxAvg = Math.Max(1, _dbs.Max(d => d.AvgCpuMs));
            return _dbs.Select(d => new
            {
                id     = "db:" + d.Name,
                name   = d.Name,
                kind   = "db",
                value  = MetricVal(d.Execs, d.TotalCpuMs, d.AvgCpuMs, d.Reads, d.Writes),
                color  = HeatColor(d.AvgCpuMs, 0, maxAvg),
                tip    = $"<b>{d.Name}</b><br/>Objects: {d.Objects}<br/>Execs: {d.Execs:N0}<br/>CPU: {FormatMs(d.TotalCpuMs)}<br/>Reads: {d.Reads:N0}<br/>Writes: {d.Writes:N0}"
            }).Cast<object>().ToArray();
        }
        if (_level == 1)
        {
            if (_objs.Count == 0) return Array.Empty<object>();
            var maxAvg = Math.Max(1, _objs.Max(o => o.AvgCpuMs));
            return _objs.Select(o => new
            {
                id     = "obj:" + o.Name,
                name   = o.Name,
                kind   = "obj",
                value  = MetricVal(o.Execs, o.TotalCpuMs, o.AvgCpuMs, o.Reads, o.Writes),
                color  = HeatColor(o.AvgCpuMs, 0, maxAvg),
                tip    = $"<b>{o.Name}</b><br/><i>{o.Kind}</i><br/>Statements: {o.Statements}<br/>Execs: {o.Execs:N0}<br/>CPU: {FormatMs(o.TotalCpuMs)}<br/>Avg: {FormatMs(o.AvgCpuMs)}/exec"
            }).Cast<object>().ToArray();
        }
        if (_stmts.Count == 0) return Array.Empty<object>();
        var maxStmt = Math.Max(1, _stmts.Max(s => s.AvgCpuMs));
        return _stmts.Select(s => new
        {
            id     = "stmt:" + s.Name,
            name   = s.Name,
            kind   = "stmt",
            value  = MetricVal(s.Execs, s.TotalCpuMs, s.AvgCpuMs, s.Reads, s.Writes),
            color  = HeatColor(s.AvgCpuMs, 0, maxStmt),
            tip    = $"<pre style='margin:0;font-size:10px;max-width:280px;white-space:pre-wrap'>{System.Web.HttpUtility.HtmlEncode(s.Snippet ?? s.Name)}</pre><br/>CPU: {FormatMs(s.TotalCpuMs)}<br/>Avg: {FormatMs(s.AvgCpuMs)}/exec<br/>Reads: {s.Reads:N0}"
        }).Cast<object>().ToArray();
    }

    private double MetricVal(long execs, double totCpu, double avgCpu, long rds, long wrs) => _metric switch
    {
        "execs"  => execs,
        "reads"  => rds,
        "writes" => wrs,
        "avgcpu" => avgCpu,
        _        => totCpu
    };

    private double PctOfMaxDb(SQLTriage.Data.Services.CodeHotspotsService.DbRow d)
    {
        if (_dbs.Count == 0) return 0;
        var max = _dbs.Max(x => x.TotalCpuMs);
        return max <= 0 ? 0 : Math.Min(100, d.TotalCpuMs / max * 100);
    }
    private double PctOfMaxObj(SQLTriage.Data.Services.CodeHotspotsService.ObjRow o)
    {
        if (_objs.Count == 0) return 0;
        var max = _objs.Max(x => x.TotalCpuMs);
        return max <= 0 ? 0 : Math.Min(100, o.TotalCpuMs / max * 100);
    }
    private double PctOfMaxStmt(SQLTriage.Data.Services.CodeHotspotsService.StatementRow s)
    {
        if (_stmts.Count == 0) return 0;
        var max = _stmts.Max(x => x.TotalCpuMs);
        return max <= 0 ? 0 : Math.Min(100, s.TotalCpuMs / max * 100);
    }

    private string ServerDisplayName(string key)
    {
        var opt = _availableServers.FirstOrDefault(o => o.Key == key);
        return opt?.Display ?? key;
    }

    private static string HeatColor(double avgMs, double lo, double hi)
    {
        var t = Math.Clamp((avgMs - lo) / Math.Max(0.001, hi - lo), 0, 1);
        var bucket = t < 0.20 ? "cold" : t < 0.45 ? "cool" : t < 0.65 ? "mid" : t < 0.85 ? "warm" : "hot";
        return $"var(--hot-{bucket})";
    }

    private static string ObjIcon(string kind) => kind switch
    {
        "StoredProc" => "fa-cube",
        "ScalarFn"   => "fa-superscript",
        "TableFn"    => "fa-table",
        "InlineFn"   => "fa-bolt",
        "Trigger"    => "fa-arrow-right-arrow-left",
        "View"       => "fa-eye",
        _            => "fa-code"
    };

    private static string TruncateMid(string s, int maxLen)
    {
        if (string.IsNullOrEmpty(s) || s.Length <= maxLen) return s;
        var keep = (maxLen - 1) / 2;
        return s[..keep] + "…" + s[^keep..];
    }

    private static string FormatMs(double ms)
    {
        if (ms < 1) return $"{ms:F2} ms";
        if (ms < 1000) return $"{ms:F0} ms";
        if (ms < 60000) return $"{ms/1000.0:F1} s";
        return $"{ms/60000.0:F1} min";
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("codeHotspots.dispose", "hot-treemap"); } catch { }
        _dotNetRef?.Dispose();
    }

    // ── Mock data ──────────────────────────────────────────────────
    private static class MockData
    {
        public static List<SQLTriage.Data.Services.CodeHotspotsService.DbRow> Databases() => new()
        {
            new() { Name="SQLWATCH",       Objects=16,  Execs=15_966, TotalCpuMs=130_673, AvgCpuMs=8.2,  Reads=6_598_020, Writes=69_045 },
            new() { Name="msdb",           Objects=42,  Execs=22_148, TotalCpuMs= 38_902, AvgCpuMs=1.8,  Reads=  214_881, Writes=11_402 },
            new() { Name="WideWorldImporters", Objects=87, Execs= 4_551, TotalCpuMs= 21_307, AvgCpuMs=4.7, Reads=1_038_412, Writes=82_119 },
            new() { Name="AdventureWorks", Objects=51,  Execs= 1_982, TotalCpuMs=  9_133, AvgCpuMs=4.6,  Reads=  448_029, Writes= 6_810 },
            new() { Name="ContosoSales",   Objects=23,  Execs=   711, TotalCpuMs=  3_204, AvgCpuMs=4.5,  Reads=   88_114, Writes= 2_117 },
            new() { Name="tempdb (adhoc)", Objects=8,   Execs=   612, TotalCpuMs=  1_088, AvgCpuMs=1.8,  Reads=   12_488, Writes=   801 },
        };

        public static List<SQLTriage.Data.Services.CodeHotspotsService.StatementRow> Statements(string dbName, string objName)
        {
            if (dbName == "SQLWATCH" && objName.StartsWith("usp_sqlwatch_logger_performance"))
            {
                return new()
                {
                    new() { Name="INSERT @target FROM sys.dm_os_performance_counters", Snippet="INSERT INTO @target\nSELECT counter_name, instance_name, cntr_value\nFROM sys.dm_os_performance_counters\nWHERE counter_name IN (...)", Execs=174,  TotalCpuMs=54_144, AvgCpuMs=311.2, Reads=413_223, Writes=6_490, PctOfTotal=41.43 },
                    new() { Name="INSERT logger_perfmon SELECT ... perf_counters_history", Snippet="INSERT INTO dbo.logger_perfmon\nSELECT ... FROM dbo.perf_counters_history\nWHERE snapshot_time > @last", Execs=654,  TotalCpuMs=13_679, AvgCpuMs=20.9,  Reads=231_431, Writes=144,    PctOfTotal=10.47 },
                    new() { Name="UPDATE wait_stats baseline diff", Snippet="UPDATE w SET wait_time_ms = w.wait_time_ms - p.wait_time_ms\nFROM dbo.logger_wait_stats w\nJOIN dbo.logger_wait_stats_prev p ON w.wait_type = p.wait_type", Execs=1075, TotalCpuMs=12_498, AvgCpuMs=11.6, Reads=639_690, Writes=3_434, PctOfTotal=9.56 },
                    new() { Name="MERGE logger_disk_usage", Snippet="MERGE dbo.logger_disk_usage target\nUSING (SELECT ... FROM sys.dm_io_virtual_file_stats(NULL,NULL)) src\nON ...", Execs=1075, TotalCpuMs=10_757, AvgCpuMs=10.0, Reads=438_815, Writes=8_040, PctOfTotal=8.23 },
