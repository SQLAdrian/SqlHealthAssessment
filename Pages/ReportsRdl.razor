@page "/reports-rdl"
@using SqlHealthAssessment.Data.Services
@using Microsoft.AspNetCore.Components.Web
@using System.Data
@using System.IO
@using Microsoft.Reporting.NETCore
@inject RdlReportService RdlReportService
@inject NavigationManager Navigation

<PageTitle>RDL Reports - SQLHealthAssessment</PageTitle>

<div class="reports-rdl-page">
    <div class="page-header">
        <div>
            <h2><i class="fa-solid fa-file-pdf"></i> RDL Report Viewer</h2>
            <p class="page-description">
                View and generate reports from RDL (Report Definition Language) files.
            </p>
        </div>
    </div>

    <!-- Step 1: Select Report -->
    <div class="report-section">
        <div class="section-header">
            <h3>1. Select Report Template</h3>
        </div>
        <div class="report-selection">
            @if (_availableReports.Any())
            {
                <select @bind="_selectedReport" class="form-input">
                    <option value="">-- Select a Report Template --</option>
                    @foreach (var report in _availableReports)
                    {
                        <option value="@report">@report</option>
                    }
                </select>
            }
            else
            {
                <p>No RDL report templates found in the Reports directory.</p>
            }
        </div>
    </div>

    <!-- Step 2: Select Data Source -->
    @if (!string.IsNullOrEmpty(_selectedReport))
    {
        <div class="report-section">
            <div class="section-header">
                <h3>2. Select Data Source</h3>
            </div>
            <div class="data-source-selection">
                @if (_availableCsvFiles.Any())
                {
                    <select @bind="_selectedCsvFile" class="form-input">
                        <option value="">-- Select a CSV Data Source --</option>
                        @foreach (var file in _availableCsvFiles)
                        {
                            <option value="@file">@file</option>
                        }
                    </select>
                    <button class="btn btn-sm btn-primary" @onclick="LoadCsvData">
                        <i class="fa-solid fa-table"></i> Load Data
                    </button>
                }
                else
                {
                    <p>No CSV data files found in the output directory.</p>
                }
            </div>
        </div>

        <!-- Step 3: Configure Parameters (if needed) -->
        @if (_loadedDataTable != null)
        {
            <div class="report-section">
                <div class="section-header">
                    <h3>3. Report Parameters</h3>
                </div>
                <div class="parameters-section">
                    <p>No parameters required for this report.</p>
                </div>
            </div>
        }
    }

    <!-- Step 4: Generate and View Report -->
    @if (_loadedDataTable != null && !string.IsNullOrEmpty(_selectedReport))
    {
        <div class="report-section">
            <div class="section-header">
                <h3>4. Generate Report</h3>
            </div>
            <div class="report-actions">
                <button class="btn btn-primary" @onclick="GenerateAndViewReport" disabled="@_isGenerating">
                    @if (_isGenerating)
                    {
                        <span><i class="fa-solid fa-spinner fa-spin"></i> Generating...</span>
                    }
                    else
                    {
                        <span><i class="fa-solid fa-eye"></i> View Report</span>
                    }
                </button>
                <button class="btn btn-secondary" @onclick="ExportReport" disabled="@_isGenerating || _reportBytes == null">
                    <i class="fa-solid fa-file-download"></i> Download PDF
                </button>
            </div>
        </div>
    }

    <!-- Report Viewer -->
    @if (_reportBytes != null)
    {
        <div class="report-section">
            <div class="section-header">
                <h3>5. Report Preview</h3>
            </div>
            <ReportViewer 
                ReportName="@_selectedReport.Replace(".rdl", "")" 
                DataSources="@_dataSourcesForViewer" />
        </div>
    }

    <!-- Error Message -->
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-error">
            <i class="fa-solid fa-exclamation-triangle"></i> @_errorMessage
        </div>
    }
</div>

@code {
    private List<string> _availableReports = new();
    private List<string> _availableCsvFiles = new();
    private string _selectedReport = string.Empty;
    private string _selectedCsvFile = string.Empty;
    private DataTable? _loadedDataTable;
    private Dictionary<string, DataTable> _dataSourcesForViewer = new();
    private byte[]? _reportBytes;
    private bool _isGenerating = false;
    private string _errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadAvailableReports();
        await LoadAvailableCsvFiles();
    }

    private Task LoadAvailableReports()
    {
        try
        {
            _availableReports = RdlReportService.GetAvailableReports();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading reports: {ex.Message}";
        }
        return Task.CompletedTask;
    }

    private Task LoadAvailableCsvFiles()
    {
        try
        {
            // Look for CSV files in output directory
            var outputDir = Path.Combine(AppContext.BaseDirectory, "output");
            if (Directory.Exists(outputDir))
            {
                _availableCsvFiles = Directory.GetFiles(outputDir, "*.csv")
                    .Select(f => Path.GetFileName(f))
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading CSV files: {ex.Message}";
        }
        return Task.CompletedTask;
    }

    private async void LoadCsvData()
    {
        if (string.IsNullOrEmpty(_selectedCsvFile))
            return;

        try
        {
            var filePath = Path.Combine(AppContext.BaseDirectory, "output", _selectedCsvFile);
            if (!File.Exists(filePath))
            {
                _errorMessage = $"CSV file not found: {filePath}";
                return;
            }

            _loadedDataTable = await Task.Run(() => LoadCsvToDataTable(filePath));
            _dataSourcesForViewer = new Dictionary<string, DataTable> { { "DataSet1", _loadedDataTable } };
            _errorMessage = string.Empty;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading CSV data: {ex.Message}";
        }
    }

    private DataTable LoadCsvToDataTable(string filePath)
    {
        var table = new DataTable();
        using (var reader = new StreamReader(filePath))
        {
            string? headerLine = reader.ReadLine();
            if (headerLine == null) return table;

            var headers = headerLine.Split(',');
            foreach (var header in headers)
            {
                table.Columns.Add(header.Trim());
            }

            while (!reader.EndOfStream)
            {
                var line = reader.ReadLine();
                if (string.IsNullOrWhiteSpace(line)) continue;

                var fields = ParseCsvLine(line);
                if (fields.Length >= headers.Length)
                {
                    var row = table.NewRow();
                    for (int i = 0; i < headers.Length; i++)
                    {
                        row[i] = fields[i]?.Trim() ?? "";
                    }
                    table.Rows.Add(row);
                }
            }
        }
        return table;
    }

    private async void GenerateAndViewReport()
    {
        if (_loadedDataTable == null || string.IsNullOrEmpty(_selectedReport))
            return;

        _isGenerating = true;
        _errorMessage = string.Empty;
        _reportBytes = null;

        try
        {
            _reportBytes = await Task.Run(() => 
                RdlReportService.GeneratePdfReport(_selectedReport, "DataSet1", _loadedDataTable));
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error generating report: {ex.Message}";
        }
        finally
        {
            _isGenerating = false;
        }
    }

    private void ExportReport()
    {
        if (_reportBytes == null) return;

        try
        {
            var outputDir = RdlReportService.GetOutputDirectory();
            var fileName = $"Report_{DateTime.Now:yyyyMMdd_HHmmss}.pdf";
            var filePath = Path.Combine(outputDir, fileName);
            File.WriteAllBytes(filePath, _reportBytes);
            _errorMessage = $"Report saved to: {filePath}";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error exporting report: {ex.Message}";
        }
    }

    // CSV parsing helper
    private static string[] ParseCsvLine(string line)
    {
        var fields = new List<string>();
        var i = 0;

        while (i < line.Length)
        {
            if (line[i] == '"')
            {
                i++; // skip opening quote
                var sb = new System.Text.StringBuilder();
                while (i < line.Length)
                {
                    if (line[i] == '"')
                    {
                        if (i + 1 < line.Length && line[i + 1] == '"')
                        {
                            sb.Append('"');
                            i += 2;
                        }
                        else
                        {
                            i++; // skip closing quote
                            break;
                        }
                    }
                    else
                    {
                        sb.Append(line[i]);
                        i++;
                    }
                }
                fields.Add(sb.ToString());
                if (i < line.Length && line[i] == ',') i++; // skip comma
            }
            else
            {
                var end = line.IndexOf(',', i);
                if (end < 0) end = line.Length;
                fields.Add(line[i..end]);
                i = end + 1;
            }
        }

        return fields.ToArray();
    }
}

<style>
    .reports-rdl-page {
        padding: 20px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .page-header {
        margin-bottom: 30px;
    }

    .page-header h2 {
        color: var(--text-primary);
        margin-bottom: 8px;
    }

    .page-description {
        color: var(--text-secondary);
    }

    .report-section {
        background: var(--bg-panel);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 20px;
    }

    .section-header h3 {
        color: var(--accent);
        margin-top: 0;
        margin-bottom: 15px;
    }

    .report-selection, .data-source-selection {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
    }

    .form-input {
        flex: 1;
        min-width: 200px;
        padding: 8px 12px;
        border: 1px solid var(--border);
        border-radius: 4px;
        background: var(--bg-input);
        color: var(--text-primary);
    }

    .report-actions {
        display: flex;
        gap: 10px;
    }

    .btn {
        padding: 10px 20px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-weight: 500;
        transition: all 0.2s ease;
    }

    .btn-primary {
        background: var(--accent);
        color: white;
    }

    .btn-primary:hover {
        opacity: 0.9;
    }

    .btn-primary:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .btn-secondary {
        background: var(--bg-card);
        color: var(--text-primary);
        border: 1px solid var(--border);
    }

    .btn-secondary:hover {
        background: var(--border);
    }

    .btn-secondary:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .btn-sm {
        padding: 6px 12px;
        font-size: 0.9em;
    }

    .alert {
        padding: 12px 16px;
        border-radius: 4px;
        margin-top: 20px;
    }

    .alert-error {
        background: rgba(220, 53, 69, 0.1);
        border: 1px solid #dc3545;
        color: #dc3545;
    }

    @@media (max-width: 768px) {
        .reports-rdl-page {
            padding: 10px;
        }
        
        .report-section {
            padding: 15px;
        }
        
        .report-actions {
            flex-direction: column;
        }
    }
</style>