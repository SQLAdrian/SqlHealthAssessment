    private void OpenTemplateEditor(string channelKey)
    {
        var t = Templates.Config;
        _editingTemplate = channelKey switch
        {
            "email"      => Clone(t.Email),
            "teams"      => Clone(t.Teams),
            "slack"      => Clone(t.Slack),
            "webhook"    => Clone(t.Webhook),
            "pagerduty"  => Clone(t.PagerDuty),
            "servicenow" => Clone(t.ServiceNow),
            _ => new ChannelTemplate()
        };
        _editingTemplateKey = channelKey;
    }

    private static ChannelTemplate Clone(ChannelTemplate src)
        => new() { Subject = src.Subject, Body = src.Body, Description = src.Description };

    private void CloseTemplateEditor()
    {
        _editingTemplate = null;
        _editingTemplateKey = "";
    }

    private void SaveTemplate()
    {
        if (_editingTemplate == null) return;
        var t = Templates.Config;
        switch (_editingTemplateKey)
        {
            case "email":      t.Email      = _editingTemplate; break;
            case "teams":      t.Teams      = _editingTemplate; break;
            case "slack":      t.Slack      = _editingTemplate; break;
            case "webhook":    t.Webhook    = _editingTemplate; break;
            case "pagerduty":  t.PagerDuty  = _editingTemplate; break;
            case "servicenow": t.ServiceNow = _editingTemplate; break;
        }
        Templates.Update(t);
        Toast.ShowSuccess($"{_templateCards.FirstOrDefault(c => c.ChannelKey == _editingTemplateKey)?.Label ?? _editingTemplateKey} template saved.");
        CloseTemplateEditor();
    }

