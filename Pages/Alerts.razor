    private static string GetSeverityColor(string severity) => severity.ToLower() switch
    {
        "critical" => "var(--red)",
        "high" => "var(--orange)",
        "warning" or "medium" => "var(--yellow)",
        _ => "var(--accent)"
    };

    private static string GetStatusBadgeClass(string status) => status switch
    {
        "Active" => "severity-warning",
        "Acknowledged" => "severity-info",
        "Resolved" => "",
        _ => ""
    };

    private string GetCategoryName(string categoryId) =>
        _categories.FirstOrDefault(c => c.Id == categoryId)?.Name ?? categoryId;

    private static string FormatUnit(string unit) => unit switch
    {
        "percent" => "%",
        "seconds" => "sec",
        "milliseconds" => "ms",
        "megabytes" => "MB",
        "hours" => "hrs",
        "minutes" => "min",
        "count" => "#",
        "per_second" => "/s",
        "per_minute" => "/m",
        "event" => "evt",
        _ => unit
    };

    private static string FormatFrequency(int seconds)
    {
        if (seconds < 60) return $"{seconds}s";
        if (seconds < 3600) return $"{seconds / 60}m";
        if (seconds < 86400) return $"{seconds / 3600}h";
        return $"{seconds / 86400}d";
    }

    private async Task DeployComprehensiveSession()
    {
        var connection = ConnectionManager.GetConnections().FirstOrDefault();
        if (connection == null)
        {
            Toast.ShowError("No server connection configured");
            return;
        }

        try
        {
            var connStr = connection.GetConnectionString(connection.ServerNames, "master");
            var result = await XEventService.CreateSessionAsync(connStr, "ComprehensiveMonitor", "error_reported", "severity >= 17");
            if (result.StartsWith("Error"))
            {
                Toast.ShowError(result);
            }
            else
            {
                Toast.ShowSuccess("Comprehensive XE session deployed");
                await XEventService.StartSessionAsync(connStr, "ComprehensiveMonitor");
            }
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to deploy session: {ex.Message}");
        }
    }

