        { Toast.ShowWarning("Insufficient permissions. Operator role required."); return; }
        Engine.AcknowledgeAlert(alert.AlertId, alert.ServerName);
        _activeAlerts = Engine.ActiveAlerts.ToList();
        _activeAlertCount = Engine.ActiveCount;
    }

