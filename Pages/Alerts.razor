    private void EditAlert(AlertDefinition alert)
    {
        // Clone for editing
        _editingAlert = new AlertDefinition
        {
            Id = alert.Id,
            Name = alert.Name,
            Description = alert.Description,
            Category = alert.Category,
            Enabled = alert.Enabled,
            Severity = alert.Severity,
            Thresholds = new AlertThresholds { Warning = alert.Thresholds.Warning, Critical = alert.Thresholds.Critical },
            Unit = alert.Unit,
            Operator = alert.Operator,
            DurationSeconds = alert.DurationSeconds,
            FrequencySeconds = alert.FrequencySeconds,
            CooldownMinutes = alert.CooldownMinutes,
            Query = alert.Query,
            QueryMode = alert.QueryMode,
            Remediation = alert.Remediation,
            AlwaysAlert = alert.AlwaysAlert,
            PrimaryChannel = alert.PrimaryChannel,
            SendEmail = alert.SendEmail,
            NextAlertDelayMinutes = alert.NextAlertDelayMinutes,
            IncludeInDailySummary = alert.IncludeInDailySummary,
            Escalate = alert.Escalate,
            EscalationThresholdEvents = alert.EscalationThresholdEvents,
            EscalationWindowMinutes = alert.EscalationWindowMinutes,
            EscalationAfterMinutes = alert.EscalationAfterMinutes,
            EscalationChannel = alert.EscalationChannel,
            BaselineDeviationPercent = alert.BaselineDeviationPercent,
            BaselineQueryId = alert.BaselineQueryId,
            BaselineSeries = alert.BaselineSeries,
        };
        _editWarning = alert.Thresholds.Warning;
        _editCritical = alert.Thresholds.Critical;
        _editNextAlertDelayMinutes = alert.NextAlertDelayMinutes ?? alert.CooldownMinutes;
        _editEscalationMode = alert.EscalationThresholdEvents > 0 ? "events" : "time";
        _testQueryResult = null;
        _testQueryError = null;
        _showAllFields = false;
    }

    private void SaveEdit()
    {
        if (_editingAlert == null) return;
        _editingAlert.Thresholds.Warning = _editWarning;
        _editingAlert.Thresholds.Critical = _editCritical;
        _editingAlert.NextAlertDelayMinutes = _editNextAlertDelayMinutes;
        _editingAlert.CooldownMinutes = _editNextAlertDelayMinutes; // keep legacy field in sync
        if (_editEscalationMode == "time") { _editingAlert.EscalationThresholdEvents = 0; _editingAlert.EscalationWindowMinutes = 0; }
        Definitions.UpdateAlert(_editingAlert);
        _allAlerts = Definitions.GetAllAlerts();
        _editingAlert = null;
        Toast.ShowSuccess("Alert definition saved");
    }

    private void CancelEdit()
    {
        _editingAlert = null;
        _testQueryResult = null;
        _testQueryError = null;
    }

    private async Task TestQuery()
    {
        if (_editingAlert == null || string.IsNullOrWhiteSpace(_editingAlert.Query)) return;

        var server = ConnectionManager.CurrentServer;
        if (server == null)
        {
            Toast.ShowWarning("No server selected — go to Servers and connect first");
            return;
        }

        _testingQuery = true;
        _testQueryResult = null;
        _testQueryError = null;
        StateHasChanged();

        var sw = System.Diagnostics.Stopwatch.StartNew();
        try
        {
            var connString = server.GetConnectionString(server.ServerNames, "master");
            var dt = new DataTable();

            await Task.Run(async () =>
            {
                using var conn = new SqlConnection(connString);
                await conn.OpenAsync();
                using var cmd = new SqlCommand(_editingAlert.Query, conn) { CommandTimeout = 15 };
                using var reader = await cmd.ExecuteReaderAsync();
                dt.Load(reader);
            });

            sw.Stop();
            _testQueryElapsed = sw.ElapsedMilliseconds < 1000
                ? $"{sw.ElapsedMilliseconds}ms"
                : $"{sw.Elapsed.TotalSeconds:F1}s";

            // Limit to 50 rows for display
            if (dt.Rows.Count > 50)
            {
                var trimmed = dt.Clone();
                for (int i = 0; i < 50; i++)
                    trimmed.ImportRow(dt.Rows[i]);
                _testQueryResult = trimmed;
                _testQueryElapsed += " (showing first 50)";
            }
            else
            {
                _testQueryResult = dt;
            }
        }
        catch (SqlException ex)
        {
            sw.Stop();
            _testQueryError = $"SQL Error {ex.Number}: {ex.Message}";
        }
        catch (Exception ex)
        {
            sw.Stop();
            _testQueryError = ex.Message;
        }
        finally
        {
            _testingQuery = false;
            StateHasChanged();
        }
    }

    private void AcknowledgeOne(AlertState alert)
    {
