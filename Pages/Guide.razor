@code {
    private void GoToSQLTriage() => Navigation.NavigateTo("/dashboard/live");
    private void GoToInstanceOverview() => Navigation.NavigateTo(RouteConstants.DashboardInstance);
    private void GoToWaitEvents() => Navigation.NavigateTo(RouteConstants.DashboardLiveWaits);
    private void GoToRepository() => Navigation.NavigateTo(RouteConstants.DashboardRepository);
    private void GoToResourceHealth() => Navigation.NavigateTo(RouteConstants.DashboardPmHealth);
    private void GoToSecurity() => Navigation.NavigateTo(RouteConstants.DashboardSecurity);
    private void GoToExpensiveQueries() => Navigation.NavigateTo(RouteConstants.DashboardLongQueries);
    private void GoToIndexHealth() => Navigation.NavigateTo(RouteConstants.DashboardLiveIndexes);
    private void GoToQueryStore() => Navigation.NavigateTo(RouteConstants.DashboardQueryStore);
    private void GoToQuickCheck() => Navigation.NavigateTo(RouteConstants.QuickCheck);
    private void GoToFullAudit() => Navigation.NavigateTo(RouteConstants.FullAudit);
    private void GoToVulnerabilityAssessment() => Navigation.NavigateTo(RouteConstants.VulnerabilityAssessment);
    private void GoToDeploySqlwatch() => Navigation.NavigateTo(RouteConstants.DeploySqlWatch);
    private void GoToDeployDarlingPm() => Navigation.NavigateTo(RouteConstants.DeployDarlingPm);
    private void GoToSettings() => Navigation.NavigateTo(RouteConstants.Settings);
    private void GoToDashboardEditor() => Navigation.NavigateTo(RouteConstants.DashboardEditor);
    private void GoToServers() => Navigation.NavigateTo(RouteConstants.Servers);
    private void GoToAlerting() => Navigation.NavigateTo(RouteConstants.AlertingConfig);
    private void GoToServiceManagement() => Navigation.NavigateTo(RouteConstants.ServiceManagement);
    private void GoToAbout() => Navigation.NavigateTo(RouteConstants.About);
}

