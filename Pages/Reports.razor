<!--/* In the name of God, the Merciful, the Compassionate */-->
@page "/reports"

@using SqlHealthAssessment.Data.Models
@using SqlHealthAssessment.Data.Services
@using Microsoft.Extensions.Logging

@inject ReportService ReportSvc
@inject ILogger<Reports> Logger

<PageTitle>Reports - SQLHealthAssessment</PageTitle>

<div class="reports-page">
    <div class="page-header">
        <div>
            <h2><i class="fa-solid fa-file-pdf"></i> Report Generator</h2>
            <p class="page-description">
                Generate professional Executive Summary PDF reports from Vulnerability Assessment CSV data.
            </p>
        </div>
    </div>

    <!-- Step 1: Data Source -->
    <div class="report-section">
        <div class="section-header">
            <h3>1. Data Source</h3>
        </div>
        <div class="source-controls">
            @if (!string.IsNullOrEmpty(_selectedFile))
            {
                <div class="selected-file-display">
                    <i class="fa-solid fa-file-csv"></i>
                    <span class="selected-file-name">@System.IO.Path.GetFileName(_selectedFile)</span>
                    <span class="selected-file-rows">@_parsedData.Count rows</span>
                    <button class="btn btn-sm btn-secondary" @onclick="OpenFileSelector">Change</button>
                </div>
            }
            else
            {
                <button class="btn btn-primary" @onclick="OpenFileSelector">
                    <i class="fa-solid fa-folder-open"></i> Select CSV File
                </button>
            }

            @if (_parsedData.Any())
            {
                <div class="source-summary">
                    <span class="stat-pill critical">@_parsedData.Count(r => r.Severity == "Error" && r.Status == "Failed") Critical</span>
                    <span class="stat-pill warning">@_parsedData.Count(r => r.Severity == "Warning" && r.Status == "Failed") Warning</span>
                    <span class="stat-pill info">@_parsedData.Count(r => r.Severity == "Information" && r.Status == "Failed") Info</span>
                    <span class="stat-pill pass">@_parsedData.Count(r => r.Status == "Passed") Passed</span>
                </div>
            }
        </div>
    </div>

    <!-- Step 2: Report Configuration -->
    @if (_parsedData.Any())
    {
        <div class="report-section">
            <div class="section-header">
                <h3>2. Report Configuration</h3>
                <button class="btn btn-sm btn-secondary" @onclick="ToggleConfig">
                    <i class="fa-solid @(_showConfig ? "fa-chevron-up" : "fa-chevron-down")"></i>
                    @(_showConfig ? "Hide" : "Customise")
                </button>
            </div>

            @if (_showConfig)
            {
                <div class="config-grid">
                    <!-- Branding -->
                    <div class="config-group">
                        <h4>Branding</h4>
                        <div class="config-field">
                            <label>Company Name</label>
                            <input type="text" @bind="_config.CompanyName" class="form-input" />
                        </div>
                        <div class="config-field">
                            <label>Report Title</label>
                            <input type="text" @bind="_config.ReportTitle" class="form-input" />
                        </div>
                        <div class="config-field">
                            <label>Subtitle</label>
                            <input type="text" @bind="_config.ReportSubtitle" class="form-input" />
                        </div>
                        <div class="config-field">
                            <label>Prepared By</label>
                            <input type="text" @bind="_config.PreparedBy" class="form-input" />
                        </div>
                    </div>

                    <!-- Sections -->
                    <div class="config-group">
                        <h4>Sections</h4>
                        <div class="config-toggle">
                            <label><input type="checkbox" @bind="_config.ShowCoverPage" /> Cover Page</label>
                        </div>
                        <div class="config-toggle">
                            <label><input type="checkbox" @bind="_config.ShowExecutiveSummary" /> Executive Summary</label>
                        </div>
                        <div class="config-toggle">
                            <label><input type="checkbox" @bind="_config.ShowSeverityBreakdown" /> Severity Breakdown</label>
                        </div>
                        <div class="config-toggle">
                            <label><input type="checkbox" @bind="_config.ShowCategoryBreakdown" /> Category Breakdown</label>
                        </div>
                        <div class="config-toggle">
                            <label><input type="checkbox" @bind="_config.ShowDetailedFindings" /> Detailed Findings</label>
                        </div>
                        <div class="config-toggle">
                            <label><input type="checkbox" @bind="_config.ShowPassedChecks" /> Include Passed Checks</label>
                        </div>
                        <div class="config-toggle">
                            <label><input type="checkbox" @bind="_config.ShowRecommendations" /> Recommendations</label>
                        </div>
                    </div>

                    <!-- Filters -->
                    <div class="config-group">
                        <h4>Filters</h4>
                        <div class="config-field">
                            <label>Severity</label>
                            <select @bind="_config.SeverityFilter" class="form-input">
                                <option value="All">All Severities</option>
                                <option value="Error">Critical / Error</option>
                                <option value="Warning">Warning</option>
                                <option value="Information">Information</option>
                            </select>
                        </div>
                        <div class="config-field">
                            <label>Status</label>
                            <select @bind="_config.StatusFilter" class="form-input">
                                <option value="All">All</option>
                                <option value="Failed">Failed Only</option>
                                <option value="Passed">Passed Only</option>
                            </select>
                        </div>
                        <div class="config-field">
                            <label>Category</label>
                            <select @bind="_config.CategoryFilter" class="form-input">
                                <option value="All">All Categories</option>
                                @foreach (var cat in _uniqueCategories)
                                {
                                    <option value="@cat">@cat</option>
                                }
                            </select>
                        </div>
                    </div>

                    <!-- Layout -->
                    <div class="config-group">
                        <h4>Layout & Colors</h4>
                        <div class="config-toggle">
                            <label><input type="checkbox" @bind="_config.LandscapeOrientation" /> Landscape Orientation</label>
                        </div>
                        <div class="config-field">
                            <label>Margin (mm)</label>
                            <input type="number" @bind="_config.MarginMm" min="5" max="40" class="form-input" style="width:80px" />
                        </div>
                        <div class="config-colors">
                            <div class="color-field">
                                <label>Primary</label>
                                <input type="color" @bind="_config.PrimaryColor" />
                            </div>
                            <div class="color-field">
                                <label>Accent</label>
                                <input type="color" @bind="_config.AccentColor" />
                            </div>
                            <div class="color-field">
                                <label>Critical</label>
                                <input type="color" @bind="_config.CriticalColor" />
                            </div>
                            <div class="color-field">
                                <label>Warning</label>
                                <input type="color" @bind="_config.WarningColor" />
                            </div>
                            <div class="color-field">
                                <label>Pass</label>
                                <input type="color" @bind="_config.PassColor" />
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Step 3: Generate -->
        <div class="report-section">
            <div class="section-header">
                <h3>3. Generate Report</h3>
            </div>
            <div class="generate-controls">
                <button class="btn btn-primary btn-generate" @onclick="GenerateReport" disabled="@_isGenerating">
                    @if (_isGenerating)
                    {
                        <span><i class="fa-solid fa-spinner fa-spin"></i> Generating...</span>
                    }
                    else
                    {
                        <span><i class="fa-solid fa-file-pdf"></i> Generate Executive Summary PDF</span>
                    }
                </button>

                @if (!string.IsNullOrEmpty(_statusMessage))
                {
                    <div class="generate-status @_statusClass">
                        @if (_statusClass == "status-success")
                        {
                            <i class="fa-solid fa-check-circle"></i>
                        }
                        else
                        {
                            <i class="fa-solid fa-exclamation-circle"></i>
                        }
                        <span>@_statusMessage</span>
                    </div>
                }
            </div>
        </div>
    }
</div>

<SqlHealthAssessment.Components.Shared.FileSelectModal @ref="_fileModal"
    Title="Select Vulnerability Assessment CSV"
    Description="Choose a CSV file from the output directory to use as report data source."
    OnFileSelected="OnFileSelected"
    OnClose="OnModalClose" />

@code {
    private SqlHealthAssessment.Components.Shared.FileSelectModal _fileModal = default!;
    private ReportConfig _config = new();
    private List<AssessmentRow> _parsedData = new();
    private string? _selectedFile;
    private bool _showConfig = false;
    private bool _isGenerating = false;
    private string _statusMessage = "";
    private string _statusClass = "";

    private List<string> _uniqueCategories => _parsedData
        .SelectMany(r => r.Category.Split(", ", StringSplitOptions.RemoveEmptyEntries))
        .Select(t => t.Trim())
        .Where(t => t.Length > 0 && t != "DefaultRuleset")
        .Distinct()
        .OrderBy(t => t)
        .ToList();

    private void OpenFileSelector()
    {
        var files = ReportSvc.GetAvailableCsvFiles();
        _fileModal.Show(files);
    }

    private void OnFileSelected(string filePath)
    {
        _selectedFile = filePath;
        _parsedData = ReportSvc.ParseCsv(filePath);
        _statusMessage = "";
        StateHasChanged();
    }

    private void OnModalClose()
    {
        StateHasChanged();
    }

    private void ToggleConfig()
    {
        _showConfig = !_showConfig;
    }

    private async Task GenerateReport()
    {
        if (!_parsedData.Any()) return;

        _isGenerating = true;
        _statusMessage = "Generating report...";
        _statusClass = "";
        StateHasChanged();

        try
        {
            var path = await Task.Run(() => ReportSvc.GenerateReport(_parsedData, _config));
            _statusMessage = $"Report saved: {path}";
            _statusClass = "status-success";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Report generation failed");
            _statusMessage = $"Generation failed: {ex.Message}";
            _statusClass = "status-error";
        }
        finally
        {
            _isGenerating = false;
            StateHasChanged();
        }
    }
}
