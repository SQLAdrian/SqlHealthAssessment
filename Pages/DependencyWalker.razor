<!--/* In the name of God, the Merciful, the Compassionate */-->
@page "/dependencywalker"

@using SqlHealthAssessment.Data
@using SqlHealthAssessment.Data.Models
@using SqlHealthAssessment.Data.Services
@using Microsoft.Extensions.Logging
@inject ServerConnectionManager ConnectionManager
@inject DependencyWalkerService DepSvc
@inject ILogger<DependencyWalker> Logger
@inject IJSRuntime JSRuntime

<PageTitle>Dependency Walker - SQLHealthAssessment</PageTitle>

<div class="dependencywalker-page">
    <div class="page-header">
        <div>
            <h2><i class="fa-solid fa-sitemap"></i> Dependency Walker</h2>
            <p class="page-description">
                Analyze object dependencies and generate safe drop scripts.
            </p>
        </div>
    </div>

    <!-- Server Selection -->
    <div class="server-selection-section">
        <div class="section-header">
            <h3>Select Target Server</h3>
        </div>
        
        <div class="server-selection-controls">
            <select @bind="SelectedConnectionId" @bind:after="OnServerSelected" class="server-select">
                <option value="">-- Select a server connection --</option>
                @foreach (var conn in Connections)
                {
                    <option value="@conn.Id">
                        @conn.ServerNames (@conn.AuthenticationDisplay)
                    </option>
                }
            </select>
        </div>
    </div>

    <!-- Object Selection -->
    <div class="object-selection-section">
        <div class="section-header">
            <h3>Analyze Object Dependencies</h3>
        </div>
        
        <div class="object-form">
            <div class="form-row">
                <div class="form-group">
                    <label>Database</label>
                    <select @bind="SelectedDatabase" class="form-control" disabled="@string.IsNullOrEmpty(SelectedConnectionId)">
                        <option value="">-- Select database --</option>
                        @foreach (var db in Databases)
                        {
                            <option value="@db">@db</option>
                        }
                    </select>
                </div>
                
                <div class="form-group">
                    <label>Search Object</label>
                    <input type="text" @bind="SearchPattern" @bind:after="SearchObjects" 
                           placeholder="Type to search..." class="form-control" />
                </div>
            </div>
            
            <div class="form-row">
                <div class="form-group">
                    <label>Or Select from List</label>
                    <select @bind="SelectedObjectName" class="form-control" disabled="@string.IsNullOrEmpty(SelectedDatabase)">
                        <option value="">-- Select object --</option>
                        @foreach (var obj in Objects)
                        {
                            <option value="@obj.ObjectName">[@obj.SchemaName].[@obj.ObjectName] (@obj.ObjectType)</option>
                        }
                    </select>
                </div>
            </div>
            
            <div class="action-row">
                <button class="btn btn-primary" @onclick="AnalyzeDependencies" 
                        disabled="@string.IsNullOrEmpty(SelectedConnectionId) || string.IsNullOrEmpty(SelectedDatabase) || string.IsNullOrEmpty(SelectedObjectName)">
                    <i class="fa-solid fa-magnifying-glass"></i> Analyze Dependencies
                </button>
                <button class="btn btn-secondary" @onclick="LoadDatabases" 
                        disabled="@string.IsNullOrEmpty(SelectedConnectionId)">
                    <i class="fa-solid fa-refresh"></i> Refresh
                </button>
            </div>
        </div>
    </div>

    <!-- Results -->
    @if (IsLoading)
    {
        <div class="loading">
            <p>Analyzing dependencies...</p>
        </div>
    }
    else if (Dependents.Any() || References.Any())
    {
        <div class="results-section">
            <div class="root-info">
                <h3>Object: [@SelectedSchema].[@SelectedObjectName]</h3>
            </div>

            <!-- Tab Navigation -->
            <div class="tabs">
                <button class="tab-btn @(ActiveTab == "dependents" ? "active" : "")" @onclick='() => ActiveTab = "dependents"'>
                    <i class="fa-solid fa-arrow-up"></i> What Depends On This (@(Dependents.Count))
                </button>
                <button class="tab-btn @(ActiveTab == "references" ? "active" : "")" @onclick='() => ActiveTab = "references"'>
                    <i class="fa-solid fa-arrow-down"></i> What This Depends On (@(References.Count))
                </button>
                <button class="tab-btn @(ActiveTab == "safe-drop" ? "active" : "")" @onclick='() => ActiveTab = "safe-drop"'>
                    <i class="fa-solid fa-trash"></i> Safe Drop Script
                </button>
            </div>

            <!-- Dependents Tab -->
            @if (ActiveTab == "dependents")
            {
                <div class="tab-content">
                    @if (Dependents.Any())
                    {
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Dependent Object</th>
                                    <th>Schema</th>
                                    <th>Type</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var dep in Dependents)
                                {
                                    <tr>
                                        <td><strong>@dep.ObjectName</strong></td>
                                        <td>@dep.SchemaName</td>
                                        <td>@dep.ObjectType</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="empty-state">
                            <p>No objects depend on this object.</p>
                        </div>
                    }
                </div>
            }

            <!-- References Tab -->
            @if (ActiveTab == "references")
            {
                <div class="tab-content">
                    @if (References.Any())
                    {
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Referenced Object</th>
                                    <th>Schema</th>
                                    <th>Type</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var refObj in References)
                                {
                                    <tr>
                                        <td><strong>@refObj.ObjectName</strong></td>
                                        <td>@refObj.SchemaName</td>
                                        <td>@refObj.ObjectType</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="empty-state">
                            <p>This object doesn't reference any other objects.</p>
                        </div>
                    }
                </div>
            }

            <!-- Safe Drop Tab -->
            @if (ActiveTab == "safe-drop")
            {
                <div class="tab-content">
                    @if (Dependents.Any())
                    {
                        <div class="warning-box">
                            <i class="fa-solid fa-exclamation-triangle"></i>
                            <strong>Cannot safely drop this object!</strong>
                            <p>The following objects depend on this and must be dropped first:</p>
                            <ul>
                                @foreach (var dep in Dependents)
                                {
                                    <li>[@dep.SchemaName].[@dep.ObjectName] (@dep.ObjectType)</li>
                                }
                            </ul>
                        </div>
                    }
                    else
                    {
                        <div class="success-box">
                            <i class="fa-solid fa-check-circle"></i>
                            <strong>Safe to drop</strong>
                            <p>No dependent objects found. You can safely drop this object.</p>
                        </div>
                    }
                    
                    <div class="script-section">
                        <h4>Generated Drop Script</h4>
                        <div class="script-preview">
                            <pre>@SafeDropScript</pre>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .dependencywalker-page { padding: 20px; }
    .dependencywalker-page h2 { margin-bottom: 8px; }
    .page-description { color: #666; margin-bottom: 20px; }
    .server-selection-section, .object-selection-section { background: #f8f9fa; padding: 20px; border-radius: 8px; margin-bottom: 20px; }
    .section-header h3 { margin: 0 0 16px 0; font-size: 16px; }
    .server-selection-controls { display: flex; gap: 16px; flex-wrap: wrap; }
    .server-select { padding: 8px 12px; border: 1px solid #ddd; border-radius: 4px; min-width: 250px; }
    .object-form { display: flex; flex-direction: column; gap: 16px; }
    .form-row { display: flex; gap: 16px; flex-wrap: wrap; }
    .form-group { flex: 1; min-width: 200px; }
    .form-group label { display: block; margin-bottom: 6px; font-weight: 600; }
    .form-control { width: 100%; padding: 8px 12px; border: 1px solid #ddd; border-radius: 4px; }
    .btn { padding: 8px 16px; border: none; border-radius: 4px; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; }
    .btn-primary { background: #007bff; color: #fff; }
    .btn-primary:hover { background: #0056b3; }
    .btn-primary:disabled { background: #ccc; cursor: not-allowed; }
    .btn-secondary { background: #6c757d; color: #fff; }
    .action-row { display: flex; gap: 12px; }
    .results-section { background: #fff; border-radius: 8px; overflow: hidden; }
    .root-info { padding: 16px 20px; background: #f8f9fa; border-bottom: 1px solid #ddd; }
    .root-info h3 { margin: 0; }
    .tabs { display: flex; border-bottom: 1px solid #ddd; background: #f8f9fa; }
    .tab-btn { padding: 12px 24px; border: none; background: transparent; cursor: pointer; display: flex; align-items: center; gap: 8px; }
    .tab-btn:hover { background: #e9ecef; }
    .tab-btn.active { background: #fff; border-bottom: 2px solid #007bff; }
    .tab-content { padding: 20px; }
    .data-table { width: 100%; border-collapse: collapse; }
    .data-table th, .data-table td { padding: 10px; text-align: left; border-bottom: 1px solid #ddd; }
    .data-table th { background: #f8f9fa; font-weight: 600; }
    .data-table tr:hover { background: #f8f9fa; }
    .warning-box, .success-box { padding: 16px; border-radius: 8px; margin-bottom: 20px; }
    .warning-box { background: #fff3cd; border: 1px solid #ffc107; }
    .warning-box i { color: #856404; }
    .success-box { background: #d4edda; border: 1px solid #28a745; }
    .success-box i { color: #155724; }
    .warning-box strong, .success-box strong { display: block; margin-bottom: 8px; }
    .warning-box ul { margin: 8px 0 0 0; padding-left: 20px; }
    .script-section h4 { margin: 0 0 12px 0; }
    .script-preview { background: #1e1e1e; color: #d4d4d4; padding: 16px; border-radius: 4px; max-height: 300px; overflow-y: auto; }
    .script-preview pre { margin: 0; white-space: pre-wrap; font-family: 'Consolas', monospace; }
    .empty-state { text-align: center; padding: 40px; color: #666; }
    .loading { text-align: center; padding: 40px; color: #666; }
</style>

@code {
    private List<ServerConnection> Connections = new();
    private string? SelectedConnectionId;
    private string ActiveTab = "dependents";
    private bool IsLoading;
    
    private List<string> Databases = new();
    private List<SchemaObject> Objects = new();
    private string SelectedDatabase = "";
    private string SelectedSchema = "";
    private string SelectedObjectName = "";
    private string SearchPattern = "";
    
    private List<DependencyInfo> Dependents = new();
    private List<DependencyInfo> References = new();
    private string SafeDropScript = "";

    protected override void OnInitialized()
    {
        Connections = ConnectionManager.GetConnections().ToList();
        
        var firstEnabled = Connections.FirstOrDefault(c => c.IsEnabled);
        if (firstEnabled != null)
        {
            SelectedConnectionId = firstEnabled.Id;
            _ = OnServerSelected();
        }
    }

    private async Task OnServerSelected()
    {
        if (!string.IsNullOrEmpty(SelectedConnectionId))
        {
            await LoadDatabases();
        }
    }

    private async Task LoadDatabases()
    {
        if (string.IsNullOrEmpty(SelectedConnectionId)) return;
        
        Databases.Clear();
        Objects.Clear();
        SelectedDatabase = "";
        SelectedObjectName = "";
        
        try
        {
            var conn = ConnectionManager.GetConnection(SelectedConnectionId);
            if (conn != null)
            {
                var serverName = conn.ServerNames.Split(',').First().Trim();
                var connString = conn.GetConnectionString(serverName, "master");
                var objs = await DepSvc.SearchObjectsAsync(connString, "master", "%");
                Databases = objs.Select(o => o.ObjectName).Distinct().ToList();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading databases");
        }
    }

    private async Task SearchObjects()
    {
        if (string.IsNullOrEmpty(SelectedConnectionId) || string.IsNullOrEmpty(SelectedDatabase)) return;
        
        try
        {
            var conn = ConnectionManager.GetConnection(SelectedConnectionId);
            if (conn != null)
            {
                var serverName = conn.ServerNames.Split(',').First().Trim();
                var connString = conn.GetConnectionString(serverName, "master");
                var pattern = string.IsNullOrEmpty(SearchPattern) ? "%" : $"%{SearchPattern}%";
                Objects = await DepSvc.SearchObjectsAsync(connString, SelectedDatabase, pattern);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error searching objects");
        }
    }

    private async Task AnalyzeDependencies()
    {
        if (string.IsNullOrEmpty(SelectedConnectionId) || string.IsNullOrEmpty(SelectedDatabase) || string.IsNullOrEmpty(SelectedObjectName)) return;
        
        IsLoading = true;
        try
        {
            var conn = ConnectionManager.GetConnection(SelectedConnectionId);
            if (conn != null)
            {
                var serverName = conn.ServerNames.Split(',').First().Trim();
                var connString = conn.GetConnectionString(serverName, "master");
                
                var selectedObj = Objects.FirstOrDefault(o => o.ObjectName == SelectedObjectName);
                SelectedSchema = selectedObj?.SchemaName ?? "dbo";
                
                Dependents = await DepSvc.GetDependentsAsync(connString, SelectedDatabase, SelectedSchema, SelectedObjectName);
                References = await DepSvc.GetDependenciesAsync(connString, SelectedDatabase, SelectedSchema, SelectedObjectName);
                SafeDropScript = await DepSvc.GenerateSafeDropScriptAsync(connString, SelectedDatabase, SelectedSchema, SelectedObjectName);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error analyzing dependencies");
        }
        finally
        {
            IsLoading = false;
        }
    }
}
