<!--/* In the name of God, the Merciful, the Compassionate */-->
@page "/cio"
@using SQLTriage.Data
@using SQLTriage.Data.Models
@using SQLTriage.Data.Services
@using static SQLTriage.Data.Services.GovernanceService
@using Microsoft.Extensions.Logging
@inject IGovernanceService GovernanceService
@inject GovernanceHistoryService HistoryService
@inject ExecutiveHealthService HealthService
@inject CheckExecutionService CheckExecutor
@inject ServerConnectionManager ConnectionManager
@inject ConnectionHealthService ConnectionHealth
@inject NavigationManager Navigation
@inject ToastService Toast
@inject UserSettingsService UserSettings
@inject LicensingEstimator LicensingEstimator
@inject RemediationWeightStore WeightStore
@inject IPrintService PrintSvc
@inject IJSRuntime JS
@inject ILogger<CioDashboard> Logger

<PageTitle>CIO Dashboard - SQLTriage</PageTitle>

@if (!_pageAuthorised)
{
    <AccessDenied Message="The CIO Dashboard is currently restricted to the maintainer workstation." />
    return;
}

<div class="cio-container">

    @if (_loading)
    {
        <div class="cio-loading">
            <div class="cio-spinner"></div>
            <span class="cio-loading-text">@_loadingMessage</span>
        </div>
    }
    else if (!_hasServers)
    {
        <div class="cio-empty-state">
            <i class="fa-solid fa-server cio-empty-icon"></i>
            <h2 class="cio-empty-title">No Servers Configured</h2>
            <p class="cio-empty-text">Connect to a SQL Server instance to see your governance score, compliance coverage, and risk heatmap.</p>
            <div class="cio-empty-actions">
                <a href="/servers" class="cio-empty-link">
                    <i class="fa-solid fa-plus"></i> Add Server
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- Header -->
        <div class="cio-header">
            <div class="cio-header-icon">
                <i class="fa-solid fa-chart-line"></i>
            </div>
            <div>
                <h1 class="cio-header-title">CIO Dashboard</h1>
                <p class="cio-header-subtitle">Executive overview of SQL Server governance and risk</p>
            </div>
        </div>

        <!-- Overall Governance Score (Hero) -->
        @if (_governanceScore != null)
        {
            <div class="cio-score-card">
                <div class="cio-score-label">Overall Governance Score</div>
                <div class="cio-score-value" style="color:@ScoreColor(_governanceScore.Overall);">
                    @_governanceScore.Overall.ToString("F0")
                </div>
                <div class="cio-score-band">
                    @_governanceScore.Band
                </div>
                <div class="cio-dimension-score">
                    @{
                        var starCount = (int)Math.Floor(_governanceScore.Overall / 20);
                        var totalStars = 5;
                    }
                    @for (int i = 0; i < totalStars; i++)
                    {
                        <i class="fa-solid fa-star @(i < starCount ? "cio-dimension-star-filled" : "cio-dimension-star-empty")"></i>
                    }
                    <span class="cio-dimension-label">@starCount/@totalStars stars</span>
                </div>
                <div style="margin-top:12px;">
                    <span class="cio-assessment-badge" style="@AssessmentBadgeStyle()">
                        @(_governanceScore.IsIndicative ? "Indicative" : "Full Assessment")
                    </span>
                </div>
                <div class="cio-score-updated">
                    Last updated: @_lastUpdated.ToString("MMM dd, yyyy HH:mm")
                </div>
            </div>
        }

        <!-- Category Breakdown -->
        @if (_governanceScore?.Categories?.Count > 0)
        {
            <div class="cio-category-grid">
                @foreach (var cat in _orderedCategories)
                {
                    var color = CategoryColor(cat.PassRate);
                    <div class="cio-category-card">
                        <div class="cio-category-header">
                            <span class="cio-category-name">@cat.Dimension</span>
                            <span class="cio-category-weight">@((cat.Weight * 100).ToString("F0"))%</span>
                        </div>
                        <div class="cio-category-score" style="color:@color;">
                            @cat.CappedScore.ToString("F0")
                        </div>
                        <div class="cio-bar-track">
                            <div class="cio-bar-fill" style="width:@Math.Min(100, cat.CappedScore)%; background:@color;"></div>
                        </div>
                        <div class="cio-category-footer">
                            <span class="cio-category-pass" style="color:@color;">@cat.PassRate.ToString("F0")% pass</span>
                            <span class="cio-category-findings">@cat.FindingCount findings</span>
                        </div>
                    </div>
                }
            </div>

            <!-- Remediation Cost Estimate -->
            @if (ShowRemediationCost && _projectMidpoint > 0)
            {
                <div class="cio-cost-estimate">
                    <div class="cio-cost-header">
                        <i class="fa-solid fa-calculator"></i> Expected Remediation Cost
                    </div>
                    <div class="cio-cost-value">
                        $@_costLow.ToString("N0") <span class="cio-cost-range-sep">-</span> $@_costHigh.ToString("N0")
                    </div>
                    <div class="cio-cost-detail">
                        <span>@_pricedCheckCount findings across @_serversInLastRun server@(_serversInLastRun == 1 ? "" : "s")@(string.IsNullOrEmpty(ComplianceTierDisplay) ? "" : " · " + ComplianceTierDisplay)</span>
                    </div>
                    @if (_rawLabourCost > 0)
                    {
                        <div class="cio-cost-rawline">
                            Raw technical labour: ~@_rawLabourHours.ToString("N0") hours @@ @HourlyRate.ToString("C0")/hr = $@_rawLabourCost.ToString("N0")
                        </div>
                    }
                    @{
                        var consultancy = UserSettings.GetConsultancyName();
                        var duration = UserSettings.GetEngagementDuration();
                    }
                    @if (!string.IsNullOrWhiteSpace(consultancy))
                    {
                        <div class="cio-cost-pitch">
                            <i class="fa-solid fa-handshake"></i>
                            Engagement with <strong>@consultancy</strong>@(string.IsNullOrWhiteSpace(duration) ? "" : $" typically delivers in {duration}") at significant savings.
                        </div>
                    }
                    <div class="cio-cost-note">
                        <i class="fa-solid fa-circle-info"></i>
                        Failed items above could potentially void your SQL support SLA.
                        Project cost covers compliance overhead, change management, peer review, and audit-ready evidence.
                        Raw labour is the technical DBA work alone. Adjust rate and compliance tier in Settings.
                    </div>
                </div>
            }

            <!-- License & Cost Position -->
            @if (ShowRemediationCost && _licensingEstimate != null && _licensingEstimate.PerServer.Count > 0)
            {
                <div class="cio-cost-estimate cio-license-position">
                    <div class="cio-cost-header">
                        <i class="fa-solid fa-id-card"></i> License &amp; Cost Position
                    </div>

                    <table class="cio-license-table">
                        <thead>
                            <tr>
                                <th>Server</th>
                                <th>Role</th>
                                <th>Edition</th>
                                <th class="cio-num">Cores (phys / lic)</th>
                                <th class="cio-num">Annual licensing (USD)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in _licensingEstimate.PerServer)
                            {
                                <tr class="@(s.IsPassiveSecondary ? "cio-license-passive" : "")">
                                    <td>@s.ServerName</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(s.AgRole))
                                        {
                                            <span class="cio-ag-badge cio-ag-@s.AgRole.ToLowerInvariant()">
                                                AG @s.AgRole.ToLowerInvariant()
                                            </span>
                                        }
                                    </td>
                                    <td>@s.Edition</td>
                                    <td class="cio-num">@s.PhysicalCores / @s.LicensedCores</td>
                                    <td class="cio-num">
                                        @if (s.IsPassiveSecondary)
                                        {
                                            <span class="cio-license-free">free under SA</span>
                                        }
                                        else
                                        {
                                            <text>$@s.AnnualLicensingUSD.ToString("N0")</text>
                                        }
                                    </td>
                                </tr>
                                @if (!string.IsNullOrEmpty(s.Notes))
                                {
                                    <tr class="cio-license-note-row">
                                        <td colspan="5"><i class="fa-solid fa-circle-info"></i> @s.Notes</td>
                                    </tr>
                                }
                            }
                            <tr class="cio-license-total">
                                <td colspan="4"><strong>Total annual licensing</strong></td>
                                <td class="cio-num"><strong>$@_licensingEstimate.TotalAnnualCostUSD.ToString("N0")</strong></td>
                            </tr>
                        </tbody>
                    </table>

                    @if (_licensingEstimate.PotentialAnnualSavingUSD > 0)
                    {
                        <div class="cio-license-saving">
                            <div class="cio-license-saving-line">
                                <i class="fa-solid fa-piggy-bank"></i>
                                It looks like there could be performance-driven licensing savings of
                                <strong>~$@_licensingEstimate.PotentialAnnualSavingUSD.ToString("N0") per year</strong>
                                here.
                            </div>
                            <div class="cio-license-saving-confidence">
                                Confidence: <span class="cio-confidence-@_licensingEstimate.SavingsConfidence.ToLowerInvariant()">@_licensingEstimate.SavingsConfidence</span>
                                <span class="cio-license-disclaimer"> &mdash; requires a full SQL assessment to verify.</span>
                            </div>
                        </div>
                    }

                    @{
                        var opex = UserSettings.GetMonthlyOpexPerServerNZD();
                        var serverCount = _licensingEstimate.PerServer.Count;
                        var threeYearOpex = opex * 36 * serverCount;
                        var threeYearLicensing = _licensingEstimate.TotalAnnualCostUSD * 3;
                        var threeYearTCO = threeYearOpex + threeYearLicensing;
                    }
                    <div class="cio-license-tco">
                        <div class="cio-license-tco-line">
                            <span class="cio-license-tco-label">3-year TCO estimate</span>
                            <span class="cio-license-tco-value">$@threeYearTCO.ToString("N0")</span>
                        </div>
                        <div class="cio-license-tco-breakdown">
                            Includes operational management (NZ$@opex.ToString("N0")/mo × 36 × @serverCount servers)
                            plus 3 years of licensing.
                        </div>
                    </div>

                    <div class="cio-cost-note">
                        <i class="fa-solid fa-circle-info"></i>
                        Assumes Open Value + Software Assurance, passive HA/DR replicas free under SA.
                        Adjust monthly OPEX and pricing tier in Settings.
                    </div>
                </div>
            }
        }

        <!-- ── Health Score & Risk Rating (Strategic #7) ───────────────────── -->
        @if (_serverScores.Count > 0)
        {
            <div class="cio-health-score-section">
                <div class="cio-section-header">
                    <i class="fa-solid fa-heart-pulse" style="color:var(--accent);"></i>
                    <h3 class="cio-section-title">Health Score &amp; Risk Rating</h3>
                    <a href="/health" class="cio-health-view-full">
                        <i class="fa-solid fa-arrow-up-right-from-square"></i> Full breakdown
                    </a>
                </div>

                @foreach (var kvp in _serverScores)
                {
                    var hs      = kvp.Value;
                    var sevCls  = hs.Severity.ToString().ToLower();
                    var bd      = hs.Breakdown;

                    <div class="cio-health-server-card">
                        <!-- Hero row -->
                        <div class="cio-health-hero">
                            <span class="cio-health-server-name">
                                <i class="fa-solid fa-database"></i> @kvp.Key
                            </span>
                            <span class="cio-health-score sev-@sevCls">@hs.Score</span>
                            <span class="cio-health-band">@CioScoreBand(hs.Score)</span>
                            <span class="cio-health-trend" title="Trend vs yesterday">
                                @switch (hs.Trend)
                                {
                                    case HealthTrend.Improving:
                                        <i class="fa-solid fa-arrow-trend-up" style="color:var(--green);"></i>
                                        break;
                                    case HealthTrend.Degrading:
                                        <i class="fa-solid fa-arrow-trend-down" style="color:var(--red);"></i>
                                        break;
                                    default:
                                        <i class="fa-solid fa-equals" style="color:var(--text-muted);"></i>
                                        break;
                                }
                            </span>
                        </div>

                        <!-- Dimension mini-bars -->
                        <div class="cio-health-dims">
                            @foreach (var dim in bd.Dimensions)
                            {
                                var barPct  = Math.Max(2, dim.Score);
                                var dimCol  = CioDimColor(dim.Score);
                                <div class="cio-health-dim" title="@dim.Tooltip">
                                    <span class="cio-health-dim-label">@dim.Name</span>
                                    <div class="cio-health-dim-track">
                                        <div class="cio-health-dim-fill"
                                             style="width:@barPct%;background:@dimCol;">
                                        </div>
                                    </div>
                                    <span class="cio-health-dim-score" style="color:@dimCol;">
                                        @dim.Score
                                    </span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Server Risk Heatmap -->
        @if (_serverScores.Count > 0)
        {
            <div class="cio-heatmap-section">
                <div class="cio-section-header">
                    <i class="fa-solid fa-table-cells cio-heatmap-icon"></i>
                    <h3 class="cio-section-title">Server Risk Heatmap</h3>
                </div>
                <div class="cio-heatmap-scroll">
                    <table class="cio-heatmap-table">
                        <thead>
                            <tr>
                                <th class="cio-heatmap-th">Server</th>
                                <th class="cio-heatmap-th cio-heatmap-th-center">Connection</th>
                                <th class="cio-heatmap-th cio-heatmap-th-center">CPU</th>
                                <th class="cio-heatmap-th cio-heatmap-th-center">Memory</th>
                                <th class="cio-heatmap-th cio-heatmap-th-center">Disk</th>
                                <th class="cio-heatmap-th cio-heatmap-th-center">TempDB</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in _serverScores)
                            {
                                var connStatus = ConnectionHealth.GetStatus(entry.Key);
                                var connColor = SeverityColor(connStatus.Status == ConnectionHealthService.ServerStatus.Online ? HealthSeverity.Healthy : connStatus.Status == ConnectionHealthService.ServerStatus.Offline ? HealthSeverity.Critical : HealthSeverity.Unknown);
                                var overallSev = entry.Value.Severity;
                                <tr class="cio-heatmap-row" @onclick="() => NavigateToServer(entry.Key)">
                                    <td class="cio-heatmap-td cio-heatmap-td-server">
                                        <i class="fa-solid fa-database"></i>@entry.Key
                                    </td>
                                    <td class="cio-heatmap-td cio-heatmap-td-center">
                                        <span class="cio-heatmap-cell" style="background:@connColor;">
                                            @{
                                                 var isOnline = connStatus.Status == ConnectionHealthService.ServerStatus.Online;
                                                 var isOffline = connStatus.Status == ConnectionHealthService.ServerStatus.Offline;
                                             }
                                             @if (isOnline) { <i class="fa-solid fa-check"></i> } else if (isOffline) { <i class="fa-solid fa-xmark"></i> } else { <text>?</text> }
                                        </span>
                                    </td>
                                    <td class="cio-heatmap-td cio-heatmap-td-center">
                                        <span class="cio-heatmap-cell" style="background:@SeverityColor(overallSev);">
                                        </span>
                                    </td>
                                    <td class="cio-heatmap-td cio-heatmap-td-center">
                                        <span class="cio-heatmap-cell" style="background:@SeverityColor(overallSev);">
                                        </span>
                                    </td>
                                    <td class="cio-heatmap-td cio-heatmap-td-center">
                                        <span class="cio-heatmap-cell" style="background:@SeverityColor(overallSev);">
                                        </span>
                                    </td>
                                    <td class="cio-heatmap-td cio-heatmap-td-center">
                                        <span class="cio-heatmap-cell" style="background:@SeverityColor(overallSev);">
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="cio-legend">
                    <span><span class="cio-legend-swatch" style="background:var(--green);"></span> Healthy</span>
                    <span><span class="cio-legend-swatch" style="background:var(--yellow);"></span> Warning</span>
                    <span><span class="cio-legend-swatch" style="background:var(--red);"></span> Critical</span>
                    <span><span class="cio-legend-swatch" style="background:var(--text-muted);"></span> Unknown</span>
                </div>
            </div>
        }

        <!-- Top Risks -->
        <div class="cio-risks-section">
            <div class="cio-section-header">
                <i class="fa-solid fa-triangle-exclamation cio-risks-icon"></i>
                <h3 class="cio-section-title">Top Risks</h3>
            </div>
            @if (_topRisks.Count > 0)
            {
                <div class="cio-risks-list">
                    @foreach (var risk in _topRisks)
                    {
                        var sevColor = risk.Severity?.ToLower() switch
                        {
                            "critical" => "var(--red)",
                            "high" => "var(--orange)",
                            "medium" => "var(--yellow)",
                            "low" => "var(--green)",
                            _ => "var(--text-muted)"
                        };
                        var ops = RiskOps(risk.Severity);
                        <div class="cio-risk-item" style="border-left-color:@sevColor;">
                            <span class="cio-risk-badge" style="background:@(sevColor)22; color:@sevColor;">
                                @risk.Severity
                            </span>
                            <div class="cio-risk-content">
                                <div class="cio-risk-name">@risk.CheckName</div>
                                <div class="cio-risk-server">
                                    <i class="fa-solid fa-server"></i>@risk.InstanceName
                                </div>
                                @if (!string.IsNullOrEmpty(risk.RecommendedAction))
                                {
                                    <div class="cio-risk-action">
                                        <i class="fa-solid fa-arrow-right"></i>@risk.RecommendedAction
                                    </div>
                                }
                                <div class="cio-risk-ops">
                                    <span class="cio-risk-op">
                                        <span class="cio-risk-op-label">Next step</span>
                                        <span class="cio-risk-op-value">@ops.NextStep</span>
                                    </span>
                                    <span class="cio-risk-op">
                                        <span class="cio-risk-op-label">Assigned to</span>
                                        <span class="cio-risk-op-value">@ops.AssignedTo</span>
                                    </span>
                                    <span class="cio-risk-op">
                                        <span class="cio-risk-op-label">Escalation</span>
                                        <span class="cio-risk-op-value">@ops.Escalation</span>
                                    </span>
                                    <span class="cio-risk-op">
                                        <span class="cio-risk-op-label">Review by</span>
                                        <span class="cio-risk-op-value">@ops.Review</span>
                                    </span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="cio-risks-empty">
                    <i class="fa-solid fa-shield-halved cio-risks-empty-icon"></i>
                    Run Quick Check to see top risks
                </div>
            }
        </div>

        <!-- Quick Actions -->
        <div class="cio-actions">
            <button class="cio-action-btn" @onclick='() => Navigation.NavigateTo("/quickcheck")'>
                <i class="fa-solid fa-bolt-lightning"></i> Run Quick Check
            </button>
            <button class="cio-action-btn-secondary" @onclick='() => Navigation.NavigateTo("/fullaudit")'>
                <i class="fa-solid fa-clipboard-check"></i> Full Audit
            </button>
            <button class="cio-action-btn-secondary" @onclick='() => Navigation.NavigateTo("/governance-report")'>
                <i class="fa-solid fa-file-lines"></i> View Governance Report
            </button>
            <button class="cio-action-btn-secondary" @onclick='() => Navigation.NavigateTo("/compliance-map")'>
                <i class="fa-solid fa-map"></i> Compliance Map
            </button>
            <button class="cio-action-btn-export" @onclick="ExportPdf" disabled="@(_isExporting)">
                <i class="fa-solid fa-file-pdf"></i> @(_isExporting ? "Exporting..." : "Export PDF Report")
            </button>
            <button class="cio-action-btn-secondary" @onclick='() => Navigation.NavigateTo("/servers")'>
                <i class="fa-solid fa-plus"></i> Add Server
            </button>
        </div>

        <!-- Governance Trend -->
        @if (_trendData.Count > 1)
        {
            <div class="cio-section" style="margin-top:24px;">
                <div class="cio-section-header">
                    <i class="fa-solid fa-chart-line" style="color:var(--accent);"></i>
                    <h3 class="cio-section-title">Governance Trend</h3>
                    <div class="cio-trend-toggle">
                        <button class="@(_trendView == "weekly" ? "cio-trend-btn-active" : "cio-trend-btn")" @onclick='() => SetTrendView("weekly")'>Weekly</button>
                        <button class="@(_trendView == "daily" ? "cio-trend-btn-active" : "cio-trend-btn")" @onclick='() => SetTrendView("daily")'>Daily</button>
                    </div>
                </div>
                <div class="cio-trend-chart">
                    @foreach (var point in _trendData)
                    {
                        var heightPct = Math.Max(5, point.OverallScore);
                        var color = ScoreColor(point.OverallScore);
                        <div class="cio-trend-bar-wrapper" title="@point.RecordedAt: @point.OverallScore:F1 (@point.Band)">
                            <div class="cio-trend-bar" style="height:@(heightPct)%; background:@color;"></div>
                            <div class="cio-trend-label">@TrendLabel(point.RecordedAt)</div>
                        </div>
                    }
                </div>
                @if (_trendDelta != 0)
                {
                    <div class="cio-trend-delta">
                        <i class="fa-solid @(_trendDelta > 0 ? "fa-arrow-trend-up" : "fa-arrow-trend-down")" style="color:@(_trendDelta > 0 ? "var(--green)" : "var(--red)");"></i>
                        <span>@(_trendDelta > 0 ? "+" : "")@_trendDelta:F1 points over @_trendPeriod</span>
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    // Gate: page is hidden from nav/palette + redirects unauthorised users (2026-05-12).
    private static readonly bool _pageAuthorised =
        string.Equals(Environment.MachineName, "MSI",   StringComparison.OrdinalIgnoreCase) &&
        string.Equals(Environment.UserName,    "afsul", StringComparison.OrdinalIgnoreCase);

    private bool _loading = true;
    private bool _hasServers = false;
    private string _loadingMessage = "Loading CIO Dashboard...";
    private GovernanceScore? _governanceScore;
    private Dictionary<string, ExecutiveHealthScore> _serverScores = new(StringComparer.OrdinalIgnoreCase);
    private List<CheckResult> _topRisks = new();
    private List<CategoryScore> _orderedCategories = new();
    // ─── Pricing model (2026-05-13: replaces reverse-from-governance) ──
    // Project cost = Σ(EffortHours_override_or_baseline × HourlyRate) × ComplianceFactor.
    // Per-check effort tuned in /remediation-tuner → Config/sql-check-weights-override.json.
    // Compliance tier still multiplies (audit overhead, change mgmt, evidence).
    // Methodology: .claude/docs/pricing-methodology.md
    private const double RangeSpread = 0.35;          // ±35% around midpoint (per pricing-methodology.md)

    private static double ComplianceFactor(string tier) => tier switch
    {
        "SOC2" or "ISO27001" => 1.7,
        "PCI" or "SOX"       => 2.4,
        "HIPAA"              => 2.6,
        _                    => 1.0,  // "None"
    };

    // Severity → (NextStep, AssignedTo, EscalationPath, ReviewPeriod).
    // Mirrors the Alliance Group risk-matrix layout — operationalises each
    // finding with owner, escalation, and review cadence.
    private static (string NextStep, string AssignedTo, string Escalation, string Review) RiskOps(string? severity) =>
        (severity ?? "").ToLowerInvariant() switch
        {
            "critical" => ("Urgent attention", "Senior Management", "Executive team",  "1 month"),
            "high"     => ("Plan intervention", "Senior Management", "General Manager", "3 months"),
            "medium"   => ("Actively manage",   "BU Manager",        "Senior Management", "6 months"),
            "low"      => ("Monitor",           "DBA",                "BU Manager",       "6 months"),
            _          => ("Review",            "DBA",                "BU Manager",       "6 months"),
        };

    // IsBad gates costing — only checks flagged bad:1 in YAML incur remediation cost.
    // Scoring uses all non-SKIP results; costing uses IsBad failures only.
    private IEnumerable<CheckResult> _failed => _lastCheckResults.Where(r => !r.Passed && r.IsBad);

    private int _serversInLastRun => _lastCheckResults
        .Select(r => r.InstanceName)
        .Where(n => !string.IsNullOrEmpty(n))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Count();

    // Σ(effort × times-failed) — each row in _failed is one (server, check) failure,
    // so summing per-row effort is mathematically equivalent to grouping by CheckId
    // and multiplying by TimesFailed. WeightStore returns override if set, else baseline.
    private double _remediationLabourHours =>
        _failed.Sum(r => WeightStore.GetEffort(r.CheckId, r.EffortHours));

    private double _remediationLabourCost => _remediationLabourHours * HourlyRate;

    private double _projectMidpoint =>
        _remediationLabourCost * ComplianceFactor(UserSettings.GetComplianceTier());

    private double _costLow  => _projectMidpoint * (1 - RangeSpread);
    private double _costHigh => _projectMidpoint * (1 + RangeSpread);

    // Raw technical labour line — same labour figure without the compliance multiplier
    private double _rawLabourHours => _remediationLabourHours;
    private double _rawLabourCost  => _remediationLabourCost;

    private int _pricedCheckCount => _failed.Count(r => r.IsBad);
    private DateTime _lastUpdated = DateTime.Now;
    private List<CheckResult> _lastCheckResults = new();
    private LicensingEstimate? _licensingEstimate;
    private List<GovernanceTrendPoint> _trendData = new();
    private string _trendView = "weekly";
    private double HourlyRate => UserSettings.GetRemediationHourlyRate();
    private bool ShowRemediationCost => UserSettings.GetShowRemediationCost();
    private string ComplianceTierDisplay => UserSettings.GetComplianceTier() switch
    {
        "SOC2"     => "SOC 2",
        "ISO27001" => "ISO 27001",
        "PCI"      => "PCI-DSS",
        "SOX"      => "SOX",
        "HIPAA"    => "HIPAA",
        _          => "",
    };
    private double _trendDelta;
    private string _trendPeriod = "";
    private bool _isExporting;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _loadingMessage = "Loading server connections...";
            var connections = ConnectionManager.GetEnabledConnections();
            if (connections.Count == 0)
            {
                _hasServers = false;
                _loading = false;
                return;
            }
            _hasServers = true;

            var allServers = connections.SelectMany(c => c.GetServerList()).Distinct(StringComparer.OrdinalIgnoreCase).ToList();
            if (allServers.Count == 0)
            {
                _hasServers = false;
                _loading = false;
                return;
            }

            _loadingMessage = "Computing health scores...";
            StateHasChanged();

            foreach (var server in allServers)
            {
                try
                {
                    var score = await HealthService.GetHealthScoreAsync(server);
                    _serverScores[server] = score;
                }
                catch (Exception ex)
                {
                    _serverScores[server] = new ExecutiveHealthScore
                    {
                        Score = 0,
                        Severity = HealthSeverity.Unknown,
                        Trend = HealthTrend.Stable,
                        Message = ex.Message
                    };
                }
            }

            _loadingMessage = "Loading check results...";
            StateHasChanged();

            foreach (var server in allServers)
            {
                try
                {
                    // Try persisted results (survive restarts)
                    var persisted = HistoryService.LoadLatestCheckResults(server, 7);
                    if (persisted.Count > 0 && persisted.Any(r => r.EffortHours > 0))
                    {
                        _lastCheckResults.AddRange(persisted);
                        continue;
                    }
                }
                catch { /* fall through to live data */ }

                try
                {
                    // Fall back to live in-memory results (has EffortHours)
                    var results = CheckExecutor.GetResults(server, 500);
                    if (results.Count > 0)
                        _lastCheckResults.AddRange(results);
                }
                catch { /* non-fatal */ }
            }

            _loadingMessage = "Computing governance score...";
            StateHasChanged();

            if (_lastCheckResults.Count > 0)
            {
                _governanceScore = await GovernanceService.ComputeIndicativeAsync(_lastCheckResults);

                // Record to history for trending
                try
                {
                    foreach (var conn in ConnectionManager.GetEnabledConnections())
                    {
                        foreach (var server in conn.GetServerList())
                        {
                            HistoryService.RecordGovernanceScore(server, _governanceScore);
                        }
                    }
                }
                catch { /* non-fatal — history recording is best-effort */ }

                _topRisks = _lastCheckResults
                    .Where(r => !r.Passed)
                    .OrderByDescending(r => SeverityRank(r.Severity))
                    .Take(5)
                    .ToList();

                // Licensing probe — fire-and-forget, refreshes UI when done
                _ = Task.Run(async () =>
                {
                    try
                    {
                        var distinctServers = _lastCheckResults
                            .Select(r => r.InstanceName)
                            .Where(n => !string.IsNullOrEmpty(n))
                            .Distinct(StringComparer.OrdinalIgnoreCase)
                            .ToList();

                        var facts = new List<ServerLicensingFacts>();
                        foreach (var srv in distinctServers)
                        {
                            var f = await LicensingEstimator.ProbeServerAsync(srv);
                            if (f != null) facts.Add(f);
                        }

                        if (facts.Count > 0)
                        {
                            _licensingEstimate = LicensingEstimator.Estimate(facts, _governanceScore?.Overall ?? 0);
                            await InvokeAsync(StateHasChanged);
                        }
                    }
                    catch { /* non-fatal — licensing panel just won't show */ }
                });
            }
            else
            {
                _governanceScore = new GovernanceScore
                {
                    IsIndicative = true,
                    Overall = 0,
                    Band = ScoreBand.Emerging,
                    Categories = new Dictionary<string, CategoryScore>(StringComparer.OrdinalIgnoreCase),
                    TotalFindings = 0,
                    PassedFindings = 0,
                    FailedFindings = 0
                };

                var defaultCategories = new[] { "Security", "Performance", "Reliability", "Compliance", "Cost" };
                var weights = new[] { 0.25, 0.20, 0.20, 0.20, 0.15 };
                for (int i = 0; i < defaultCategories.Length; i++)
                {
                    _governanceScore.Categories[defaultCategories[i]] = new CategoryScore
                    {
                        Dimension = defaultCategories[i],
                        Weight = weights[i],
                        RawScore = 0,
                        CappedScore = 0,
                        Ceiling = 100,
                        FindingCount = 0,
                        PassedCount = 0
                    };
                }
            }

            _orderedCategories = _governanceScore.Categories.Values
                .OrderByDescending(c => c.Weight)
                .ToList();

            _lastUpdated = DateTime.Now;

            // Load trend data
            try
            {
                var firstServer = allServers.FirstOrDefault() ?? "";
                if (!string.IsNullOrEmpty(firstServer))
                {
                    _trendData = HistoryService.GetTrend(firstServer, 90);
                    if (_trendData.Count >= 2)
                    {
                        _trendDelta = _trendData.Last().OverallScore - _trendData.First().OverallScore;
                        var days = (DateTime.Parse(_trendData.Last().RecordedAt) - DateTime.Parse(_trendData.First().RecordedAt)).Days;
                        _trendPeriod = days > 30 ? $"{days / 30} months" : $"{days} days";
                    }
                }
            }
            catch { /* trend is best-effort */ }
        }
        catch (Exception ex)
        {
            Toast.ShowError("Failed to load CIO Dashboard", ex.Message);
        }
        finally
        {
            _loading = false;
        }
    }

    private void NavigateToServer(string serverName)
    {
        Navigation.NavigateTo($"/dashboard/instance?server={Uri.EscapeDataString(serverName)}");
    }

    private string ScoreColor(double score)
    {
        if (score >= 71) return "var(--green)";   // Gold + Platinum
        if (score >= 51) return "var(--yellow)";  // Silver
        if (score >= 31) return "var(--orange)";  // Bronze
        return "var(--red)";                      // Emerging
    }

    private string AssessmentBadgeStyle()
    {
        if (_governanceScore == null) return "";
        return _governanceScore.IsIndicative
            ? "background:rgba(99,102,241,0.12);color:var(--accent);border:1px solid rgba(99,102,241,0.3)"
            : "background:rgba(34,197,94,0.12);color:var(--green);border:1px solid rgba(34,197,94,0.3)";
    }

    // ── Health Score helpers (Strategic #7) ──────────────────────────────────
    private static string CioScoreBand(int score) => score switch
    {
        >= 86 => "Platinum",
        >= 71 => "Gold",
        >= 51 => "Silver",
        >= 31 => "Bronze",
        _     => "Emerging"
    };

    private static string CioDimColor(int score) =>
        score >= 80 ? "var(--green)"
        : score >= 60 ? "var(--yellow)"
        : score >= 40 ? "var(--orange)"
        : "var(--red)";
    // ─────────────────────────────────────────────────────────────────────────

    private static string SeverityColor(HealthSeverity? sev)
    {
        return sev switch
        {
            HealthSeverity.Healthy => "var(--green)",
            HealthSeverity.Warning => "var(--yellow)",
            HealthSeverity.Critical => "var(--red)",
            _ => "var(--text-muted)"
        };
    }

    private static int SeverityRank(string? severity) => severity?.ToLower() switch
    {
        "critical" => 4, "high" => 3, "medium" => 2, "low" => 1, _ => 0
    };

    private void SetTrendView(string view)
    {
        _trendView = view;
        var firstServer = _serverScores.Keys.FirstOrDefault() ?? "";
        if (!string.IsNullOrEmpty(firstServer))
        {
            if (view == "weekly")
                _trendData = HistoryService.GetWeeklyAverages(firstServer, 12).Select(w => new GovernanceTrendPoint { RecordedAt = w.Week, OverallScore = w.AvgScore }).ToList();
            else
                _trendData = HistoryService.GetTrend(firstServer, 90);
            StateHasChanged();
        }
    }

    private string CategoryColor(double passRate)
    {
        if (passRate >= 80) return "var(--green)";
        if (passRate >= 50) return "var(--yellow)";
        return "var(--red)";
    }

    private static string WaitVerdict(string waitMessage)
    {
        if (string.IsNullOrEmpty(waitMessage)) return "No wait data available.";
        
        // Try parse "category|pct" format from SQL message
        var parts = waitMessage.Split('|');
        if (parts.Length >= 2 && double.TryParse(parts[1].Trim(), out var pct))
        {
            var cat = parts[0].Trim();
            return cat switch
            {
                "Disk I/O" when pct > 30 => $"Disk I/O is {pct:F0}% of wait time — storage upgrade recommended (4-6 hour engagement).",
                "Locking" when pct > 20 => $"Locking is {pct:F0}% of wait time — query/index tuning recommended (6-8 hour engagement).",
                "CPU Pressure" when pct > 40 => $"CPU pressure at {pct:F0}% of wait time — query optimization recommended (8-12 hour engagement).",
                "Memory Pressure" when pct > 15 => $"Memory pressure at {pct:F0}% — memory configuration review recommended (4-6 hour engagement).",
                "Transaction Log" when pct > 15 => $"Transaction log waits at {pct:F0}% — log drive performance review recommended (2-4 hour engagement).",
                "Parallelism" when pct > 20 => $"Parallelism waits at {pct:F0}% — MAXDOP and CTFP tuning recommended (2-4 hour engagement).",
                _ => $"{cat} at {pct:F0}% of wait time. Performance review recommended."
            };
        }
        
        // Fallback: show generic performance health
        return "Performance snapshot available — run Quick Check for dominant wait category with engagement estimate.";
    }

    private string TrendLabel(string recordedAt)
    {
        if (DateTime.TryParse(recordedAt, out var dt))
        {
            return _trendView == "weekly"
                ? dt.ToString("MM/dd")
                : dt.ToString("dd");
        }
        return recordedAt.Length > 5 ? recordedAt[^5..] : recordedAt;
    }

    // Renders the live CIO Dashboard view to PDF via WebView2 (CoreWebView2.PrintToPdfAsync),
    // not QuestPDF, so no Community-licensing constraint applies. Mirrors the pattern used
    // by DiagnosticsRoadmap.razor — hide chrome, expand sections, capture, restore.
    private async Task ExportPdf(MouseEventArgs e)
    {
        if (_isExporting) return;
        try
        {
            _isExporting = true;
            StateHasChanged();

            var firstServer = _serverScores.Keys.FirstOrDefault() ?? "CIO";
            var fileName = $"CIO_Dashboard_{firstServer.Replace("\\", "_").Replace("/", "_")}_{DateTime.UtcNow:yyyyMMdd_HHmmssZ}.pdf";

            await JS.InvokeVoidAsync("eval",
                "document.querySelectorAll('.nav-menu,.dashboard-toolbar,.cio-action-bar,[class*=\"server-mode\"]').forEach(e => { e.dataset.printHidden='1'; e.style.display='none'; });" +
                "document.body.classList.add('printing-active');");
            await Task.Delay(200);

            // Watermark: apply if any displayed server is non-production or unset.
            var cioEnvs = ConnectionManager.GetEnabledConnections().Select(c => c.Environment);
            var cioWatermark = ServerEnvironment.RequiresWatermark(cioEnvs);
            if (cioWatermark)
                await JS.InvokeVoidAsync("eval", "document.body.classList.add('has-draft-watermark');");

            var (success, path, error) = await PrintSvc.PrintToPdfAsync(fileName,
                printBackgrounds: true,
                orientation: Microsoft.Web.WebView2.Core.CoreWebView2PrintOrientation.Portrait,
                headerTitle: null,
                footerUri: null);

            if (cioWatermark)
                await JS.InvokeVoidAsync("eval", "document.body.classList.remove('has-draft-watermark');");
            await JS.InvokeVoidAsync("eval",
                "document.querySelectorAll('[data-print-hidden=\"1\"]').forEach(e => { e.style.display=''; delete e.dataset.printHidden; });" +
                "document.body.classList.remove('printing-active');");

            if (success && !string.IsNullOrEmpty(path))
            {
                Logger.LogInformation("CIO Dashboard PDF exported: {File}", path);
                System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo
                {
                    FileName = path,
                    UseShellExecute = true
                });
                Toast.ShowSuccess("PDF exported", $"Saved to {System.IO.Path.GetDirectoryName(path)}");
            }
            else
            {
                Toast.ShowError("PDF export failed", error ?? "Unknown error");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "CIO Dashboard PDF export failed");
            Toast.ShowError("PDF export failed", ex.Message);
        }
        finally
        {
            _isExporting = false;
            StateHasChanged();
        }
    }
