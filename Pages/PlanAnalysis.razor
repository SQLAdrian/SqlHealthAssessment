@* In the name of God, the Merciful, the Compassionate *@
@page "/plan-analysis"
@using PlanViewer.Core.Services
@using PlanViewer.Core.Models
@using PlanViewer.Core.Output

<div class="p-4 max-w-[1400px] mx-auto">
    <div class="flex items-center gap-3 mb-4">
        <i class="fa-solid fa-diagram-project text-2xl text-blue-400"></i>
        <h2 class="text-xl font-semibold text-white m-0">Execution Plan Analyzer</h2>
        <span class="text-xs text-gray-400 ml-2">Powered by <a href="https://github.com/erikdarlingdata/PerformanceStudio" target="_blank" class="text-blue-400 hover:underline">PerformanceStudio</a> by Erik Darling</span>
    </div>

    @* Input Section *@
    <div class="bg-[#1e1e2e] border border-[#333] rounded-lg p-4 mb-4">
        <div class="flex items-center gap-3 mb-3">
            <label class="text-sm text-gray-300 font-medium">Paste execution plan XML (.sqlplan)</label>
            <button class="px-3 py-1 text-xs bg-[#333] text-gray-300 rounded hover:bg-[#444] border border-[#555]"
                    @onclick="LoadSample" title="Load a sample plan for testing">
                <i class="fa-solid fa-flask"></i> Sample
            </button>
            <button class="px-3 py-1 text-xs bg-red-900/40 text-red-300 rounded hover:bg-red-900/60 border border-red-800"
                    @onclick="Clear" disabled="@(string.IsNullOrEmpty(_planXml) && _result == null)">
                <i class="fa-solid fa-trash"></i> Clear
            </button>
        </div>

        <textarea @bind="_planXml" @bind:event="oninput"
                  class="w-full h-40 bg-[#0d1117] text-green-300 font-mono text-xs p-3 rounded border border-[#333] resize-y"
                  placeholder="Paste your .sqlplan XML here, or click 'Sample' to load a test plan..."></textarea>

        <div class="flex items-center gap-3 mt-3">
            <button class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 font-medium disabled:opacity-50"
                    @onclick="AnalyzePlan" disabled="@(_analyzing || string.IsNullOrEmpty(_planXml))">
                @if (_analyzing)
                {
                    <i class="fa-solid fa-spinner fa-spin mr-1"></i> <span>Analyzing...</span>
                }
                else
                {
                    <i class="fa-solid fa-magnifying-glass-chart mr-1"></i> <span>Analyze Plan</span>
                }
            </button>
            @if (_result != null)
            {
                <span class="text-xs text-gray-400">
                    Analyzed in @_analysisDurationMs ms
                </span>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="bg-red-900/30 border border-red-700 rounded-lg p-3 mb-4 text-red-300 text-sm">
            <i class="fa-solid fa-triangle-exclamation mr-1"></i> @_error
        </div>
    }

    @if (_result != null)
    {
        @* Summary Cards *@
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
            <div class="bg-[#1e1e2e] border border-[#333] rounded-lg p-3 text-center">
                <div class="text-2xl font-bold text-white">@_result.Summary.TotalStatements</div>
                <div class="text-xs text-gray-400">Statements</div>
            </div>
            <div class="bg-[#1e1e2e] border border-[#333] rounded-lg p-3 text-center">
                <div class="text-2xl font-bold @(_result.Summary.CriticalWarnings > 0 ? "text-red-400" : _result.Summary.TotalWarnings > 0 ? "text-yellow-400" : "text-green-400")">
                    @_result.Summary.TotalWarnings
                </div>
                <div class="text-xs text-gray-400">Warnings (@_result.Summary.CriticalWarnings critical)</div>
            </div>
            <div class="bg-[#1e1e2e] border border-[#333] rounded-lg p-3 text-center">
                <div class="text-2xl font-bold text-orange-400">@_result.Summary.MissingIndexes</div>
                <div class="text-xs text-gray-400">Missing Indexes</div>
            </div>
            <div class="bg-[#1e1e2e] border border-[#333] rounded-lg p-3 text-center">
                <div class="text-2xl font-bold text-blue-400">@_result.Summary.MaxEstimatedCost.ToString("F2")</div>
                <div class="text-xs text-gray-400">Max Cost</div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_result.SqlServerVersion))
        {
            <div class="text-xs text-gray-500 mb-3">
                SQL Server Version: @_result.SqlServerVersion @(!string.IsNullOrEmpty(_result.SqlServerBuild) ? $"(Build {_result.SqlServerBuild})" : "")
            </div>
        }

        @* Warnings Section *@
        @foreach (var stmt in _result.Statements)
        {
            <div class="bg-[#1e1e2e] border border-[#333] rounded-lg p-4 mb-4">
                <div class="flex items-start gap-2 mb-3">
                    <i class="fa-solid fa-code text-blue-400 mt-1"></i>
                    <div class="flex-1 min-w-0">
                        <div class="text-sm font-medium text-gray-200">@stmt.StatementType</div>
                        <pre class="text-xs text-gray-400 mt-1 overflow-x-auto whitespace-pre-wrap break-all max-h-24 overflow-y-auto">@TruncateStatement(stmt.StatementText)</pre>
                    </div>
                    <div class="text-right text-xs text-gray-500 shrink-0">
                        <div>Cost: @stmt.EstimatedCost.ToString("F4")</div>
                        <div>Rows: @stmt.EstimatedRows.ToString("N0")</div>
                        @if (stmt.DegreeOfParallelism > 0)
                        {
                            <div>DOP: @stmt.DegreeOfParallelism</div>
                        }
                    </div>
                </div>

                @if (stmt.MemoryGrant != null)
                {
                    <div class="bg-[#252540] rounded p-2 mb-3 text-xs">
                        <span class="text-purple-400 font-medium"><i class="fa-solid fa-memory mr-1"></i>Memory Grant:</span>
                        <span class="text-gray-300 ml-2">Requested: @FormatKB(stmt.MemoryGrant.RequestedKB)</span>
                        <span class="text-gray-300 ml-2">Granted: @FormatKB(stmt.MemoryGrant.GrantedKB)</span>
                        <span class="text-gray-300 ml-2">Used: @FormatKB(stmt.MemoryGrant.MaxUsedKB)</span>
                        @if (stmt.MemoryGrant.GrantWaitMs > 0)
                        {
                            <span class="text-yellow-400 ml-2">Wait: @stmt.MemoryGrant.GrantWaitMs ms</span>
                        }
                    </div>
                }

                @if (stmt.QueryTime != null)
                {
                    <div class="bg-[#252540] rounded p-2 mb-3 text-xs">
                        <span class="text-cyan-400 font-medium"><i class="fa-solid fa-clock mr-1"></i>Runtime:</span>
                        <span class="text-gray-300 ml-2">CPU: @stmt.QueryTime.CpuTimeMs ms</span>
                        <span class="text-gray-300 ml-2">Elapsed: @stmt.QueryTime.ElapsedTimeMs ms</span>
                    </div>
                }

                @if (stmt.Parameters.Count > 0)
                {
                    <div class="bg-[#252540] rounded p-2 mb-3 text-xs">
                        <span class="text-green-400 font-medium"><i class="fa-solid fa-at mr-1"></i>Parameters:</span>
                        @foreach (var p in stmt.Parameters)
                        {
                            <span class="ml-2 @(p.SniffingIssue ? "text-yellow-400" : "text-gray-300")">
                                @p.Name (@p.DataType) = @(p.CompiledValue ?? "NULL")
                                @if (p.SniffingIssue)
                                {
                                    <i class="fa-solid fa-triangle-exclamation text-yellow-400 ml-1" title="Parameter sniffing issue detected"></i>
                                }
                            </span>
                        }
                    </div>
                }

                @* Warnings *@
                @if (stmt.Warnings.Count > 0)
                {
                    <div class="space-y-1 mb-3">
                        @foreach (var w in stmt.Warnings)
                        {
                            <div class="flex items-start gap-2 p-2 rounded text-xs @GetWarningSeverityClass(w.Severity)">
                                <i class="@GetWarningSeverityIcon(w.Severity) mt-0.5 shrink-0"></i>
                                <div class="flex-1">
                                    <span class="font-medium">@w.Type</span>
                                    @if (w.NodeId.HasValue)
                                    {
                                        <span class="text-gray-500 ml-1">[Node @w.NodeId]</span>
                                    }
                                    <div class="text-gray-300 mt-0.5">@w.Message</div>
                                </div>
                            </div>
                        }
                    </div>
                }

                @* Missing Indexes *@
                @if (stmt.MissingIndexes.Count > 0)
                {
                    <div class="space-y-2">
                        @foreach (var idx in stmt.MissingIndexes)
                        {
                            <div class="bg-orange-900/20 border border-orange-800/50 rounded p-3">
                                <div class="flex items-center gap-2 text-sm text-orange-300 mb-1">
                                    <i class="fa-solid fa-database"></i>
                                    <span class="font-medium">Missing Index — @idx.Table</span>
                                    <span class="text-xs text-orange-400/70 ml-auto">Impact: @idx.Impact.ToString("F1")%</span>
                                </div>
                                @if (idx.EqualityColumns.Count > 0)
                                {
                                    <div class="text-xs text-gray-400">Equality: @string.Join(", ", idx.EqualityColumns)</div>
                                }
                                @if (idx.InequalityColumns.Count > 0)
                                {
                                    <div class="text-xs text-gray-400">Inequality: @string.Join(", ", idx.InequalityColumns)</div>
                                }
                                @if (idx.IncludeColumns.Count > 0)
                                {
                                    <div class="text-xs text-gray-400">Include: @string.Join(", ", idx.IncludeColumns)</div>
                                }
                                <pre class="text-xs text-green-300 mt-2 bg-[#0d1117] p-2 rounded overflow-x-auto">@idx.CreateStatement</pre>
                            </div>
                        }
                    </div>
                }

                @* Operator Tree (collapsible) *@
                @if (stmt.OperatorTree != null)
                {
                    <details class="mt-3">
                        <summary class="text-xs text-gray-400 cursor-pointer hover:text-gray-200">
                            <i class="fa-solid fa-sitemap mr-1"></i> Operator Tree
                        </summary>
                        <div class="mt-2 bg-[#0d1117] rounded p-3 overflow-x-auto text-xs font-mono max-h-96 overflow-y-auto">
                            @RenderOperatorTree(stmt.OperatorTree, 0)
                        </div>
                    </details>
                }
            </div>
        }
    }
</div>

@code {
    private string? _planXml;
    private AnalysisResult? _result;
    private string? _error;
    private bool _analyzing;
    private long _analysisDurationMs;

    private void AnalyzePlan()
    {
        if (string.IsNullOrWhiteSpace(_planXml)) return;

        _analyzing = true;
        _error = null;
        _result = null;
        StateHasChanged();

        try
        {
            var sw = System.Diagnostics.Stopwatch.StartNew();

            // Parse the XML plan
            var parsed = ShowPlanParser.Parse(_planXml);
            if (!string.IsNullOrEmpty(parsed.ParseError))
            {
                _error = $"Parse error: {parsed.ParseError}";
                return;
            }

            // Run the 30+ analysis rules
            PlanAnalyzer.Analyze(parsed);

            // Map to structured output
            _result = ResultMapper.Map(parsed, "user-upload");

            sw.Stop();
            _analysisDurationMs = sw.ElapsedMilliseconds;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _analyzing = false;
            StateHasChanged();
        }
    }

    private void Clear()
    {
        _planXml = null;
        _result = null;
        _error = null;
    }

    private void LoadSample()
    {
        _planXml = @"<?xml version=""1.0"" encoding=""utf-16""?>
<ShowPlanXML xmlns=""http://schemas.microsoft.com/sqlserver/2004/07/showplan"" Version=""1.6"" Build=""16.0.4175.1"">
  <BatchSequence>
    <Batch>
      <Statements>
        <StmtSimple StatementText=""SELECT * FROM sys.objects WHERE name = @p1""
                    StatementId=""1"" StatementCompId=""1""
                    StatementType=""SELECT""
                    StatementSubTreeCost=""0.003""
                    StatementEstRows=""1"">
          <QueryPlan DegreeOfParallelism=""1"" CachedPlanSize=""16"">
            <RelOp NodeId=""0"" PhysicalOp=""Clustered Index Scan"" LogicalOp=""Clustered Index Scan""
                   EstimateRows=""1"" EstimatedTotalSubtreeCost=""0.003""
                   EstimateIO=""0.002"" EstimateCPU=""0.001"">
              <OutputList>
                <ColumnReference Column=""name"" />
              </OutputList>
              <IndexScan Ordered=""false"">
                <DefinedValues/>
                <Object Database=""[tempdb]"" Schema=""[sys]"" Table=""[objects]"" Index=""[clst]"" />
                <Predicate>
                  <ScalarOperator ScalarString=""[name]=@p1"">
                    <Compare CompareOp=""EQ"">
                      <ScalarOperator><Identifier><ColumnReference Column=""name""/></Identifier></ScalarOperator>
                      <ScalarOperator><Identifier><ColumnReference Column=""@p1""/></Identifier></ScalarOperator>
                    </Compare>
                  </ScalarOperator>
                </Predicate>
              </IndexScan>
            </RelOp>
          </QueryPlan>
        </StmtSimple>
      </Statements>
    </Batch>
  </BatchSequence>
</ShowPlanXML>";
    }

    private static string TruncateStatement(string text)
    {
        if (string.IsNullOrEmpty(text)) return "";
        return text.Length > 500 ? text[..500] + "..." : text;
    }

    private static string FormatKB(long kb)
    {
        if (kb > 1024 * 1024) return $"{kb / 1024.0 / 1024.0:F1} GB";
        if (kb > 1024) return $"{kb / 1024.0:F1} MB";
        return $"{kb:N0} KB";
    }

    private static string GetWarningSeverityClass(string severity) => severity switch
    {
        "Critical" => "bg-red-900/30 border border-red-800/50 text-red-300",
        "Warning" => "bg-yellow-900/20 border border-yellow-800/50 text-yellow-300",
        _ => "bg-blue-900/20 border border-blue-800/50 text-blue-300"
    };

    private static string GetWarningSeverityIcon(string severity) => severity switch
    {
        "Critical" => "fa-solid fa-circle-xmark text-red-400",
        "Warning" => "fa-solid fa-triangle-exclamation text-yellow-400",
        _ => "fa-solid fa-circle-info text-blue-400"
    };

    private RenderFragment RenderOperatorTree(OperatorResult node, int depth) => builder =>
    {
        var indent = new string(' ', depth * 3);
        var costClass = node.CostPercent >= 25 ? "text-red-400" : node.CostPercent >= 10 ? "text-yellow-400" : "text-gray-300";
        var line = $"{indent}{(depth > 0 ? "├── " : "")}{node.PhysicalOp}";

        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", $"{costClass} leading-relaxed");

        var detail = $"{line}  ({node.CostPercent}% | rows: {node.EstimatedRows:N0})";
        if (!string.IsNullOrEmpty(node.ObjectName))
            detail += $"  [{node.ObjectName}]";
        if (!string.IsNullOrEmpty(node.IndexName))
            detail += $"  idx: {node.IndexName}";

        builder.AddContent(2, detail);
        builder.CloseElement();

        if (node.Warnings.Count > 0)
        {
            foreach (var w in node.Warnings)
            {
                builder.OpenElement(3, "div");
                builder.AddAttribute(4, "class", "text-yellow-500 ml-6");
                builder.AddContent(5, $"{indent}   ⚠ {w.Type}: {w.Message}");
                builder.CloseElement();
            }
        }

        foreach (var child in node.Children)
        {
            RenderOperatorTree(child, depth + 1)(builder);
        }
    };
}
