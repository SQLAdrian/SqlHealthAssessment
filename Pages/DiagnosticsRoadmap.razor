    // ── Lifecycle ──
    protected override async Task OnInitializedAsync()
    {
        await ScanOutputFolder();
        // Auto-select the preferred file per server (triage beats blitz, then newest).
        // This selects all servers across all domains on first load.
        if (_availableServers.Count > 0)
        {
            var preferred = _availableServers
                .GroupBy(s => s.SqlInstance, StringComparer.OrdinalIgnoreCase)
                .Select(g => g.OrderBy(s => s.FileType == AuditFileType.SpTriage ? 0 : 1)
                              .ThenByDescending(s => s.AuditDate)
                              .First())
                .ToHashSet();
            foreach (var srv in _availableServers)
                srv.IsSelected = preferred.Contains(srv);
            await RecalculateFromSelected();
        }

        // Load schedule settings and start background timer
        LoadScheduleSettings();
        StartScheduleTimer();
    }

    public void Dispose()
    {
        _scheduleTimer?.Stop();
        _scheduleTimer?.Dispose();
    }

    private void LoadScheduleSettings()
    {
        var s = UserSettings.GetRoadmapSchedule();
        _scheduleEnabled       = s.Enabled;
        _scheduleType          = s.Type;
        _scheduleTime          = s.Time;
        _scheduleDayOfWeek     = s.DayOfWeek;
        _scheduleDayOfMonth    = s.DayOfMonth;
        _scheduleSplitByDomain = s.SplitByDomain;
        _scheduleLastRun       = s.LastRun;
    }

    private void SaveSchedule()
    {
        UserSettings.SaveRoadmapSchedule(_scheduleEnabled, _scheduleType, _scheduleTime,
            _scheduleDayOfWeek, _scheduleDayOfMonth, _scheduleSplitByDomain);
        _showScheduleModal = false;
        // Restart timer so new schedule takes effect immediately
        StartScheduleTimer();
    }

    private void StartScheduleTimer()
    {
        _scheduleTimer?.Stop();
        _scheduleTimer?.Dispose();
        // Check every 60 seconds whether the export is due
        _scheduleTimer = new System.Timers.Timer(60_000);
        _scheduleTimer.Elapsed += async (_, _) => await CheckScheduleDueAsync();
        _scheduleTimer.AutoReset = true;
        _scheduleTimer.Start();
    }

    private async Task CheckScheduleDueAsync()
    {
        if (!_scheduleEnabled || _exporting) return;

        var s   = UserSettings.GetRoadmapSchedule();
        var now = DateTime.Now;

        bool due = s.Type switch
        {
            "Daily"   => IsTimeReached(s.Time, now) && s.LastRun.ToLocalTime().Date < now.Date,
            "Weekly"  => now.DayOfWeek == (DayOfWeek)s.DayOfWeek
                         && IsTimeReached(s.Time, now)
                         && s.LastRun.ToLocalTime().Date < now.Date,
            "Monthly" => now.Day == Math.Min(s.DayOfMonth, DateTime.DaysInMonth(now.Year, now.Month))
                         && IsTimeReached(s.Time, now)
                         && s.LastRun.ToLocalTime().Date < now.Date,
            _ => false
        };

        if (!due) return;

        Logger.LogInformation("Scheduled roadmap PDF export triggered ({Type} at {Time})", s.Type, s.Time);
        UserSettings.UpdateRoadmapScheduleLastRun(DateTime.UtcNow);
        _scheduleLastRun = DateTime.UtcNow;

        // Temporarily apply split-by-domain setting from schedule config
        var prevSplit = _splitByDomain;
        _splitByDomain = s.SplitByDomain;

        await InvokeAsync(async () => await ExportPdf());

        _splitByDomain = prevSplit;
    }

    private static bool IsTimeReached(string hhMm, DateTime now)
    {
        if (!TimeSpan.TryParse(hhMm, out var t)) return false;
        return now.TimeOfDay >= t && now.TimeOfDay < t.Add(TimeSpan.FromMinutes(2));
    }

    // ── Output folder scan ──
    private async Task ScanOutputFolder()
    {
        _loading        = true;
        _loadingMessage = "Scanning output folder for audit files…";
        _loadProgress   = 10;
        StateHasChanged();

        await Task.Run(() =>
        {
            var outputDir = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "output");
            if (!Directory.Exists(outputDir)) return;

            static string StripQuotes(string s) => s.Trim('\'', '"', ' ');

            // Find all sp_triage/sqlmagic and sp_Blitz CSVs
            var allFiles = Directory.GetFiles(outputDir, "*.csv", SearchOption.TopDirectoryOnly);
            var triageFiles = allFiles.Where(f => {
                                    var n = Path.GetFileName(f);
                                    return n.IndexOf("sp_triage", StringComparison.OrdinalIgnoreCase) >= 0
                                        || n.IndexOf("sqlmagic",  StringComparison.OrdinalIgnoreCase) >= 0;
                                })
                                .OrderByDescending(f => File.GetLastWriteTime(f)).ToList();
            var blitzFiles  = allFiles.Where(f => {
                                    var n = Path.GetFileName(f);
                                    return n.IndexOf("blitz",  StringComparison.OrdinalIgnoreCase) >= 0
                                        && n.IndexOf("triage",  StringComparison.OrdinalIgnoreCase) < 0
                                        && n.IndexOf("sqlmagic", StringComparison.OrdinalIgnoreCase) < 0;
                                })
                                .OrderByDescending(f => File.GetLastWriteTime(f)).ToList();

            // Build list: newest file per (SqlInstance, FileType) pair
            var seen    = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            var servers = new List<AuditedServer>();

            void ScanFiles(IEnumerable<string> files, AuditFileType fileType)
            {
                foreach (var file in files)
                {
                    try
                    {
                        using var reader = new StreamReader(file);
                        var headerLine = reader.ReadLine();
                        if (string.IsNullOrEmpty(headerLine)) continue;

                        var delim       = DetectDelimiter(headerLine);
                        var headers     = ParseCsvLine(headerLine, delim).Select(h => StripQuotes(h)).ToList();
                        // sp_triage/sqlmagic use SQLInstance or Server; sp_Blitz uses ServerName
                        int instanceIdx = fileType == AuditFileType.SpTriage
                                            ? headers.FindIndex(h => h.Equals("SQLInstance", StringComparison.OrdinalIgnoreCase)
                                                                   || h.Equals("Server",      StringComparison.OrdinalIgnoreCase))
                                            : headers.FindIndex(h => h.Equals("ServerName",  StringComparison.OrdinalIgnoreCase));
                        // sp_triage uses evaldate; sp_Blitz column 4 is the date (header is empty)
                        int dateIdx     = fileType == AuditFileType.SpTriage
                                            ? headers.FindIndex(h => h.Equals("evaldate", StringComparison.OrdinalIgnoreCase))
                                            : 4;
                        int domainIdx   = headers.FindIndex(h => h.Equals("Domain", StringComparison.OrdinalIgnoreCase));
                        if (instanceIdx < 0) continue;

                        string? sqlInstance = null;
                        string  domain      = "";
                        DateTime auditDate  = File.GetLastWriteTime(file);

                        while (!reader.EndOfStream && sqlInstance == null)
                        {
                            var line = reader.ReadLine();
                            if (string.IsNullOrEmpty(line)) continue;
                            var cols = ParseCsvLine(line, delim);
                            if (cols.Count > instanceIdx)
                            {
                                sqlInstance = StripQuotes(cols[instanceIdx]);
                                if (dateIdx >= 0 && cols.Count > dateIdx &&
                                    DateTime.TryParse(StripQuotes(cols[dateIdx]), out var dt))
                                    auditDate = dt;
                                if (domainIdx >= 0 && cols.Count > domainIdx)
                                    domain = StripQuotes(cols[domainIdx]);
                            }
                        }

                        if (string.IsNullOrEmpty(sqlInstance)) continue;
                        // Key = instance + filetype — allow same instance to appear in both types
                        var key = $"{sqlInstance}|{fileType}";
                        if (!seen.Add(key)) continue;

                        servers.Add(new AuditedServer
                        {
                            SqlInstance = sqlInstance,
                            Domain      = domain,
                            AuditDate   = auditDate,
                            FilePath    = file,
                            FileType    = fileType
                        });
                    }
                    catch { /* skip unreadable files */ }
                }
            }

            ScanFiles(triageFiles, AuditFileType.SpTriage);
            ScanFiles(blitzFiles,  AuditFileType.SpBlitz);

            _availableServers = servers.OrderBy(s => s.SqlInstance).ThenBy(s => s.FileType).ToList();
        });

        _loading      = false;
        _loadProgress = 100;
        StateHasChanged();
    }

    private async Task RefreshOutputFolder()
    {
        _availableServers.Clear();
        _maturityLevels.Clear();
        await ScanOutputFolder();
    }

    // ── Server toggle (multi-select) ──
    private async Task OnServerToggled(AuditedServer server, bool isChecked)
    {
        server.IsSelected = isChecked;
        if (!isChecked)
        {
            server.CheckCounts.Clear();
        }
        await RecalculateFromSelected();
    }

    // ── Load & parse a single audit file into server.CheckCounts ──
    private async Task LoadServerData(AuditedServer server)
    {
        _loading        = true;
        _loadingMessage = $"Reading {(server.FileType == AuditFileType.SpBlitz ? "sp_Blitz" : "sp_triage")} for {server.SqlInstance}…";
        _loadProgress   = 20;
        StateHasChanged();

        await Task.Run(() =>
        {
            var counts = new Dictionary<int, int>();

            try
            {
                using var reader = new StreamReader(server.FilePath);
                var headerLine = reader.ReadLine();
                if (string.IsNullOrEmpty(headerLine)) return;

                static string StripQuotes(string s) => s.Trim('\'', '"', ' ');
                var delim       = DetectDelimiter(headerLine);
                var headers     = ParseCsvLine(headerLine, delim).Select(h => StripQuotes(h)).ToList();
                // sp_triage/sqlmagic use SQLInstance or Server; sp_Blitz uses ServerName
                int instanceIdx = server.FileType == AuditFileType.SpTriage
                    ? headers.FindIndex(h => h.Equals("SQLInstance", StringComparison.OrdinalIgnoreCase)
                                          || h.Equals("Server",      StringComparison.OrdinalIgnoreCase))
                    : headers.FindIndex(h => h.Equals("ServerName",  StringComparison.OrdinalIgnoreCase));

                // sp_Blitz: "CheckID" column is the BlitzCheckID directly.
                // sp_triage: "SectionID" column is the BlitzCheckID, but only for rows
                //            where "Section" starts with "sp_Blitz:" (filters out non-blitz rows).
                //            New sqlmagic format: use SectionID > 0 directly (no Section prefix filter needed).
                int checkIdx      = server.FileType == AuditFileType.SpBlitz
                    ? headers.FindIndex(h => h.Equals("CheckID",   StringComparison.OrdinalIgnoreCase))
                    : headers.FindIndex(h => h.Equals("SectionID", StringComparison.OrdinalIgnoreCase));
                int sectionLblIdx = server.FileType == AuditFileType.SpTriage
                    ? headers.FindIndex(h => h.Equals("Section", StringComparison.OrdinalIgnoreCase))
                    : -1;
                // Detect new sqlmagic format (has "Server" col rather than "SQLInstance")
                bool isNewSqlMagic = server.FileType == AuditFileType.SpTriage
                    && headers.Any(h => h.Equals("Server", StringComparison.OrdinalIgnoreCase))
                    && !headers.Any(h => h.Equals("SQLInstance", StringComparison.OrdinalIgnoreCase));

                if (checkIdx < 0) return;

                int rowCount = 0;
                while (!reader.EndOfStream)
                {
                    var line = reader.ReadLine();
                    if (string.IsNullOrEmpty(line)) continue;
                    var cols = ParseCsvLine(line, delim);

                    // Filter to this SQLInstance if file contains multiple
                    if (instanceIdx >= 0 && cols.Count > instanceIdx)
                    {
                        var inst = StripQuotes(cols[instanceIdx]);
                        if (!string.IsNullOrEmpty(inst) &&
                            !string.Equals(inst, server.SqlInstance, StringComparison.OrdinalIgnoreCase))
                            continue;
                    }

                    if (cols.Count <= checkIdx) continue;

                    // sp_triage: skip rows where Section doesn't start with "sp_Blitz:"
                    // (New sqlmagic format uses SectionID > 0 to filter; no "sp_Blitz:" prefix needed)
                    if (server.FileType == AuditFileType.SpTriage && !isNewSqlMagic && sectionLblIdx >= 0)
                    {
                        if (cols.Count <= sectionLblIdx) continue;
                        var lbl = StripQuotes(cols[sectionLblIdx]);
                        if (!lbl.StartsWith("sp_Blitz:", StringComparison.OrdinalIgnoreCase)) continue;
                    }

                    int.TryParse(StripQuotes(cols[checkIdx]), out int checkId);

                    if (checkId > 0)
                        counts[checkId] = counts.TryGetValue(checkId, out var c) ? c + 1 : 1;

                    rowCount++;
                    if (rowCount % 200 == 0)
                        _loadProgress = Math.Min(80, 20 + rowCount / 50.0);
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Error reading audit file {File}", server.FilePath);
            }

            server.CheckCounts = counts;
        });

        _loadProgress = 100;
    }

    // ── Aggregate all selected servers and recalculate maturity ──
    private async Task RecalculateFromSelected()
    {
        var selected = _availableServers.Where(s => s.IsSelected).ToList();
        if (selected.Count == 0)
        {
            _maturityLevels.Clear();
            _expandedLevels.Clear();
            _totalFindings = _passedFindings = _totalItemsImpacted = 0;
            StateHasChanged();
            return;
        }

        _loading        = true;
        _loadingMessage = $"Loading {selected.Count} file(s)…";
        _loadProgress   = 5;
        StateHasChanged();

        // Load any files not yet loaded
        int loaded = 0;
        foreach (var srv in selected)
        {
            if (srv.CheckCounts.Count == 0)
            {
                await LoadServerData(srv);
            }
            loaded++;
            _loadProgress = 10 + loaded * 60.0 / selected.Count;
            StateHasChanged();
        }

        _loadProgress   = 80;
        _loadingMessage = "Calculating combined maturity scores…";
        StateHasChanged();

        await Task.Run(() =>
        {
            var checkMap = LoadRoadmapMapping();

            // Merged view (all selected servers combined)
            var mergedFiredIds = new HashSet<int>();
            foreach (var srv in selected)
                foreach (var id in srv.CheckCounts.Keys)
                    mergedFiredIds.Add(id);

            var mergedCounts = new Dictionary<int, int>();
            foreach (var srv in selected)
                foreach (var (id, count) in srv.CheckCounts)
                    mergedCounts[id] = mergedCounts.TryGetValue(id, out var c) ? c + count : count;

            CalculateMaturity(mergedFiredIds, mergedCounts);

            // Per-server levels (only meaningful when >1 selected)
            _serverLevels = new Dictionary<string, (int, double)>();
            if (selected.Count > 1)
            {
                foreach (var srv in selected)
                {
                    var firedIds = new HashSet<int>(srv.CheckCounts.Keys);
                    _serverLevels[srv.SqlInstance] = ComputeLevel(firedIds, checkMap);
                }
            }
        });

        _expandedLevels.Add(_overallLevel);
        _loading = false;
        StateHasChanged();
    }

    // ── Maturity calculation from sp_Blitz findings ──
    private void CalculateMaturity(HashSet<int> firedIds, Dictionary<int, int>? checkCounts = null)
    {
        // Load check definitions from roadmap-mapping.json
        // checkId → (FindingName, Level, Roadmap/category)
        var checkMap = LoadRoadmapMapping();

        // Items impacted = sum of counts for mapped+fired IDs only (excludes informational/unmapped)
        _totalItemsImpacted = 0;
        if (checkCounts != null)
            foreach (var (id, count) in checkCounts)
                if (checkMap.ContainsKey(id))
                    _totalItemsImpacted += count;

        // Per-level, per-roadmap pass/fail accumulators
        // level → roadmap → (passed, total, failed(checkId,name,tag), passed(name,tag))
        var levelCatResults = new Dictionary<int, Dictionary<string, (int passed, int total, List<(int,string,string)> failed, List<(string,string)> passedList)>>();
        for (int i = 1; i <= 5; i++)
            levelCatResults[i] = new Dictionary<string, (int, int, List<(int,string,string)>, List<(string,string)>)>(StringComparer.OrdinalIgnoreCase);

        _totalFindings  = 0;
        _passedFindings = 0;

        foreach (var (checkId, info) in checkMap)
        {
            var (findingName, level, roadmap, tag) = info;
            if (level < 1 || level > 5) continue;

            var catDict = levelCatResults[level];
            if (!catDict.ContainsKey(roadmap))
                catDict[roadmap] = (0, 0, new List<(int,string,string)>(), new List<(string,string)>());

            var (p, t, f, pl) = catDict[roadmap];
            bool fired = firedIds.Contains(checkId);

            // fired = check triggered (problem exists) = fail; not fired = pass
            _totalFindings++; t++;
            if (fired) { f.Add((checkId, findingName, tag)); }
            else       { p++; _passedFindings++; pl.Add((findingName, tag)); }

            catDict[roadmap] = (p, t, f, pl);
        }

        // Build maturity levels
        _maturityLevels = new List<MaturityLevel>();

        for (int lvl = 1; lvl <= 5; lvl++)
        {
            var def      = LevelDefinitions[lvl];
            var catDict  = levelCatResults[lvl];
            int levelPassed = 0, levelTotal = 0;
            var categories  = new List<CategoryProgress>();

            foreach (var (catName, r) in catDict)
            {
                var (p, t, failedList, passedList) = r;
                levelPassed += p;
                levelTotal  += t;
                categories.Add(new CategoryProgress
                {
                    Category     = catName,
                    Total        = t,
                    Passed       = p,
                    PassRate     = t > 0 ? p * 100.0 / t : 100.0,
                    FailedChecks = failedList,
                    PassedChecks = passedList
                });
            }

            _maturityLevels.Add(new MaturityLevel
            {
                Level           = lvl,
                Name            = def.Name,
                Description     = def.Description,
                Recommendations = def.Recommendations,
                Categories      = categories.OrderByDescending(c => c.Total).ThenBy(c => c.PassRate).ToList(),
                TotalChecks     = levelTotal,
                PassedChecks    = levelPassed,
                PassRate        = levelTotal > 0 ? levelPassed * 100.0 / levelTotal : 100.0
            });
        }

        // Overall level: highest where this and all prior levels >= 80%
        _overallLevel = 1;
        for (int i = 0; i < _maturityLevels.Count; i++)
        {
            if (_maturityLevels[i].PassRate >= 80)
                _overallLevel = _maturityLevels[i].Level + 1;
            else
                break;
        }
        _overallLevel = Math.Clamp(_overallLevel, 1, 5);

        var totalAll  = _maturityLevels.Sum(l => l.TotalChecks);
        var passedAll = _maturityLevels.Sum(l => l.PassedChecks);
        _overallScore = totalAll > 0 ? passedAll * 100.0 / totalAll : 0;
    }



    // ── Lightweight per-server level computation (no full maturity build) ──
    private static (int Level, double Score) ComputeLevel(HashSet<int> firedIds,
        Dictionary<int, (string FindingName, int Level, string Roadmap, string Tag)> checkMap)
    {
        // level → (passed, total)
        var lvlStats = new Dictionary<int, (int passed, int total)>();
        for (int i = 1; i <= 5; i++) lvlStats[i] = (0, 0);

        foreach (var (checkId, info) in checkMap)
        {
            if (info.Level < 1 || info.Level > 5) continue;
            var (p, t) = lvlStats[info.Level];
            t++;
            if (!firedIds.Contains(checkId)) p++;
            lvlStats[info.Level] = (p, t);
        }

        int level = 1;
        for (int i = 1; i <= 5; i++)
        {
            var (p, t) = lvlStats[i];
            double rate = t > 0 ? p * 100.0 / t : 100.0;
            if (rate >= 80) level = i + 1;
            else break;
        }
        level = Math.Clamp(level, 1, 5);

        int totalAll  = lvlStats.Values.Sum(x => x.total);
        int passedAll = lvlStats.Values.Sum(x => x.passed);
        double score  = totalAll > 0 ? passedAll * 100.0 / totalAll : 0;
        return (level, score);
    }

    // ── Load check map from roadmap-mapping.json (checkId → findingName, level, roadmap, category tag) ──
    private static Dictionary<int, (string FindingName, int Level, string Roadmap, string Tag)> LoadRoadmapMapping()
    {
        var map  = new Dictionary<int, (string, int, string, string)>();
        var path = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Config", "roadmap-mapping.json");
        if (!File.Exists(path)) return map;
        try
        {
            var json = File.ReadAllText(path);
            var doc  = System.Text.Json.JsonDocument.Parse(json);
            if (!doc.RootElement.TryGetProperty("blitzCheckMap", out var arr)) return map;
            foreach (var entry in arr.EnumerateArray())
            {
                var checkId  = entry.TryGetProperty("checkId",     out var ci) ? ci.GetInt32()         : -1;
                var name     = entry.TryGetProperty("findingName",  out var fn) ? fn.GetString() ?? "" : "";
                var roadmap  = entry.TryGetProperty("Roadmap",     out var rm) ? rm.GetString() ?? ""  : "";
                var category = entry.TryGetProperty("category",    out var cv) ? cv.GetString() ?? ""  : "";
                var level    = entry.TryGetProperty("level",       out var lv) ? lv.GetInt32()         : 0;

                // Skip informational/hardware items — they don't contribute to maturity score
                if (category.Equals("Server Info",   StringComparison.OrdinalIgnoreCase) ||
                    category.Equals("Information",   StringComparison.OrdinalIgnoreCase) ||
                    category.Equals("Informational", StringComparison.OrdinalIgnoreCase))
                    continue;

                if (checkId >= 0 && level >= 1 && level <= 5)
                    map[checkId] = (name, level, roadmap, category);
            }
        }
        catch { /* return empty map on parse error */ }
        return map;
    }

    // ── CSV Action Plan Export — failed checks with priority, grouped by level ──
    private void ExportCsv()
    {
        if (!_maturityLevels.Any()) return;

        var selectedServers = _availableServers.Where(s => s.IsSelected).ToList();
        var domains         = selectedServers.Select(s => s.Domain).Where(d => !string.IsNullOrEmpty(d)).Distinct(StringComparer.OrdinalIgnoreCase).ToList();
        var fileLabel       = selectedServers.Count == 1
            ? selectedServers[0].SqlInstance.Replace("\\", "_").Replace("/", "_")
            : domains.Count >= 1 ? $"{string.Join("-", domains)}_{selectedServers.Count}servers" : $"{selectedServers.Count}servers";
        if (fileLabel.Length > 60) fileLabel = fileLabel[..60];
        var fileName = $"RoadmapActionPlan_{fileLabel}_{DateTime.Now:yyyyMMdd_HHmmss}.csv";

        var outputDir = System.IO.Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "output");
        Directory.CreateDirectory(outputDir);
        var filePath  = System.IO.Path.Combine(outputDir, fileName);

        var sb = new System.Text.StringBuilder();

        // ── Report header ──
        sb.AppendLine(CsvQuote($"SQL Health Assessment — Diagnostics Maturity Roadmap — Action Plan"));
        sb.AppendLine(CsvQuote($"Generated: {DateTime.Now:dd MMM yyyy HH:mm}"));
        sb.AppendLine(CsvQuote($"Servers: {string.Join("; ", selectedServers.Select(s => s.SqlInstance))}"));
        sb.AppendLine(CsvQuote($"Overall Level: L{_overallLevel} — {GetMaturityName(_overallLevel)}  |  Score: {_overallScore:N0}%  |  {_passedFindings}/{_totalFindings} checks passed  |  {_totalItemsImpacted} items impacted"));
        sb.AppendLine();

        // ── Summary by level ──
        sb.AppendLine("SUMMARY BY MATURITY LEVEL");
        sb.AppendLine("Level,Stage,Pass Rate,Passed,Total,Status");
        foreach (var level in _maturityLevels)
        {
            var status = level.Level < _overallLevel ? "COMPLETE" : level.Level == _overallLevel ? "IN PROGRESS" : "NOT STARTED";
            sb.AppendLine(string.Join(",", $"L{level.Level}", CsvQuote(level.Name),
                level.PassRate.ToString("N0") + "%", level.PassedChecks.ToString(), level.TotalChecks.ToString(), status));
        }
        sb.AppendLine();

        // ── Action plan — failed checks ordered by priority ──
        sb.AppendLine("ACTION PLAN — FAILED CHECKS");
        sb.AppendLine("Priority,CheckID,Level,Stage,Category,CheckName,Tag,ServersImpacted,ServerCount,CategoryPassRate%,Recommended Action");

        int priority = 1;
        // Order: lowest level first (foundation before governed), then lowest pass rate category first
        foreach (var level in _maturityLevels.OrderBy(l => l.Level))
        {
            foreach (var cat in level.Categories.OrderBy(c => c.PassRate))
            {
                foreach (var (checkId, name, tag) in cat.FailedChecks)
                {
                    var serversWithCheck = selectedServers
                        .Where(s => s.CheckCounts.ContainsKey(checkId))
                        .Select(s => s.SqlInstance)
                        .ToList();
                    var action = GetRecommendedAction(tag, level.Level);
                    sb.AppendLine(string.Join(",",
                        priority++,
                        checkId,
                        $"L{level.Level}",
                        CsvQuote(level.Name),
                        CsvQuote(cat.Category),
                        CsvQuote(name),
                        CsvQuote(tag),
                        CsvQuote(string.Join("; ", serversWithCheck)),
                        serversWithCheck.Count,
                        cat.PassRate.ToString("N0") + "%",
                        CsvQuote(action)));
                }
            }
        }

        System.IO.File.WriteAllText(filePath, sb.ToString(), System.Text.Encoding.UTF8);
        Logger.LogInformation("Action plan CSV exported: {File}", filePath);
        _ = Task.Run(() => System.Diagnostics.Process.Start("explorer.exe", $"/select,\"{filePath}\""));
    }

    private static string GetRecommendedAction(string tag, int level) => tag switch
    {
        "Reliability"          => "Review backup, CHECKDB, and HA configuration",
        "Performance"          => "Investigate query plans, indexing, and resource waits",
        "Security"             => "Audit logins, permissions, and surface area configuration",
        "Configuration"        => "Review sp_configure and instance-level settings",
        "Monitoring/Alerting"  => "Configure SQL Agent alerts or a monitoring solution",
        "Availability"         => "Review AG/FCI health, listener, and synchronisation",
        _                      => level <= 2 ? "Address as high priority — blocking next maturity level" : "Schedule for next maintenance window"
    };

    private static string CsvQuote(string s)
    {
        if (!s.Contains(',') && !s.Contains('"') && !s.Contains('\n')) return s;
        return "\"" + s.Replace("\"", "\"\"") + "\"";
    }

    // ── PDF Export ──
    private async Task ExportPdf()
    {
        if (_exporting || !_anySelected) return;
        _exporting = true;

        var prevExpanded = new HashSet<int>(_expandedLevels);
        // Remember which servers were selected before we start looping
        var originalSelected = _availableServers.Where(s => s.IsSelected).Select(s => s.FilePath).ToHashSet();

        if (_splitByDomain)
        {
            // Collect distinct domains from currently selected servers
            var domainList = _availableServers
                .Where(s => s.IsSelected && !string.IsNullOrEmpty(s.Domain))
                .Select(s => s.Domain)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(d => d, StringComparer.OrdinalIgnoreCase)
                .ToList();

            foreach (var domain in domainList)
            {
                // Select only servers in this domain that were originally selected
                foreach (var srv in _availableServers)
                    srv.IsSelected = originalSelected.Contains(srv.FilePath) && srv.Domain.Equals(domain, StringComparison.OrdinalIgnoreCase);

                await RecalculateFromSelected();
                _expandedLevels = new HashSet<int> { 1, 2, 3, 4, 5 };
                StateHasChanged();
                await Task.Delay(600);

                await PrintPrepareDomAsync();
                var domServers = _availableServers.Where(s => s.IsSelected).ToList();
                await PrintSinglePdfAsync(domServers, new List<string> { domain });
                await PrintRestoreDomAsync();
            }

            // Restore original selection + recalculate
            foreach (var srv in _availableServers)
                srv.IsSelected = originalSelected.Contains(srv.FilePath);
            await RecalculateFromSelected();
        }
        else
        {
            _expandedLevels = new HashSet<int> { 1, 2, 3, 4, 5 };
            StateHasChanged();
            await Task.Delay(600);

            await PrintPrepareDomAsync();
            var selectedServers = _availableServers.Where(s => s.IsSelected).ToList();
            var domains         = selectedServers.Select(s => s.Domain).Where(d => !string.IsNullOrEmpty(d)).Distinct(StringComparer.OrdinalIgnoreCase).ToList();
            await PrintSinglePdfAsync(selectedServers, domains);
            await PrintRestoreDomAsync();
        }

        _expandedLevels = prevExpanded;
        _exporting = false;
        StateHasChanged();
    }

    private async Task PrintPrepareDomAsync()
    {
        await JS.InvokeVoidAsync("eval",
            "var cover=document.querySelector('.pdf-cover-page'); if(cover){ cover.style.display='flex'; cover.dataset.printShown='1'; }" +
            "document.querySelectorAll('.print-executive-summary').forEach(e => e.style.display='block');" +
            "document.querySelectorAll('.nav-menu,.dashboard-toolbar,.roadmap-toolbar,.settings-page > div:first-child,[class*=\"server-mode\"],[id*=\"server-mode\"]').forEach(e => { e.dataset.printHidden='1'; e.style.display='none'; });" +
            "document.getElementById('roadmap-print-region')?.querySelectorAll('.level-section').forEach((el,i) => {" +
            "  if(i>0) el.style.pageBreakBefore='always';" +
            "  el.style.pageBreakInside='avoid';" +
            "});" +
            "document.getElementById('roadmap-print-region')?.querySelectorAll('.level-detail,.risk-panel-detail,.compliance-panel-detail').forEach(el => { el.style.display='block'; el.dataset.printForceShown='1'; });" +
            "document.querySelector('.risk-panel-wrapper')?.style.setProperty('page-break-before','always');" +
            "document.querySelector('.compliance-panel-wrapper')?.style.setProperty('page-break-before','always');" +
            "document.querySelector('.server-comparison-section')?.style.setProperty('page-break-before','always');" +
            "var sc=document.querySelector('.server-comparison-scroll'); if(sc){ sc.style.maxHeight='none'; sc.style.overflow='visible'; sc.dataset.printExpanded='1'; }" +
            "document.body.classList.add('printing-active');");
        await Task.Delay(200);
    }

    private async Task PrintSinglePdfAsync(List<AuditedServer> selectedServers, List<string> domains)
    {
        var fileLabel = selectedServers.Count == 1
            ? selectedServers[0].SqlInstance.Replace("\\", "_").Replace("/", "_")
            : domains.Count >= 1
                ? $"{string.Join("-", domains)}_{selectedServers.Count}servers"
                : $"{selectedServers.Count}servers";
        if (fileLabel.Length > 60) fileLabel = fileLabel[..60];
        var fileName = $"RoadmapReport_{fileLabel}_{DateTime.Now:yyyyMMdd_HHmmss}.pdf";

        var serverNames = selectedServers.Count == 1
            ? selectedServers[0].SqlInstance
            : domains.Count >= 1
                ? $"{string.Join(", ", domains)} ({selectedServers.Count} servers)"
                : $"{selectedServers.Count} servers";
        var footerCentre = System.Web.HttpUtility.HtmlEncode($"SQL Health Assessment — Diagnostics Maturity Roadmap — {serverNames} — {DateTime.Now:dd MMM yyyy HH:mm}");
        var footerRight  = System.Web.HttpUtility.HtmlEncode(_pdfFooterLeft);
        await JS.InvokeVoidAsync("eval",
            $"var f=document.createElement('div');" +
            $"f.id='pdf-footer-bar';" +
            $"f.style='position:fixed;bottom:0;left:0;right:0;height:22px;display:flex;justify-content:space-between;align-items:center;padding:0 14px;font-size:8px;font-family:Arial,sans-serif;color:#555;border-top:2px solid #e2583e;background:linear-gradient(to right,#fff8f6,#ffffff);z-index:9999;';" +
            $"f.innerHTML='<span style=\"display:flex;align-items:center;gap:5px;font-weight:700;color:#e2583e;\"><i class=\"fa-solid fa-heart-pulse\" style=\"font-size:10px;\"></i> SQL Health Assessment</span><span style=\"color:#444;\">{footerCentre}</span><span style=\"color:#888;font-style:italic;\">{footerRight}</span>';" +
            $"document.body.appendChild(f);");

        var (success, path, error) = await PrintSvc.PrintToPdfAsync(fileName,
            printBackgrounds: false,
            orientation: Microsoft.Web.WebView2.Core.CoreWebView2PrintOrientation.Landscape,
            headerTitle: null,
            footerUri: null);

        await JS.InvokeVoidAsync("eval", "document.getElementById('pdf-footer-bar')?.remove();");

        if (success)
            Logger.LogInformation("Roadmap PDF exported: {File}", path);
        else
            Logger.LogWarning("PDF export failed: {Error}", error);
    }

    private async Task PrintRestoreDomAsync()
    {
        await JS.InvokeVoidAsync("eval",
            "var cover=document.querySelector('.pdf-cover-page[data-print-shown]'); if(cover){ cover.style.display='none'; delete cover.dataset.printShown; }" +
            "document.querySelectorAll('.print-executive-summary').forEach(e => e.style.display='none');" +
            "document.querySelectorAll('[data-print-hidden]').forEach(e => { e.style.removeProperty('display'); delete e.dataset.printHidden; });" +
            "document.getElementById('roadmap-print-region')?.querySelectorAll('.level-section').forEach(el => { el.style.removeProperty('page-break-before'); el.style.removeProperty('page-break-inside'); });" +
            "document.getElementById('roadmap-print-region')?.querySelectorAll('[data-print-force-shown]').forEach(el => { el.style.removeProperty('display'); delete el.dataset.printForceShown; });" +
            "document.querySelector('.risk-panel-wrapper')?.style.removeProperty('page-break-before');" +
            "document.querySelector('.compliance-panel-wrapper')?.style.removeProperty('page-break-before');" +
            "document.querySelector('.server-comparison-section')?.style.removeProperty('page-break-before');" +
            "var sc=document.querySelector('.server-comparison-scroll[data-print-expanded]'); if(sc){ sc.style.maxHeight='320px'; sc.style.overflow='auto'; delete sc.dataset.printExpanded; }" +
            "document.body.classList.remove('printing-active');");
    }

