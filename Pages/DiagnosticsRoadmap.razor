    // Coverage: look up checks in maturityLevels matching the roadmap tags, count pass/fail
    private CoverageResult GetComplianceCoverage(string[] roadmapTags)
    {
        int total = 0, passed = 0;
        foreach (var lvl in _maturityLevels)
            foreach (var cat in lvl.Categories.Where(c => roadmapTags.Any(t => c.Category.Contains(t, StringComparison.OrdinalIgnoreCase))))
            {
                total  += cat.Total;
                passed += cat.Passed;
            }
        if (total == 0) return new("No Data", 0, 0);
        double rate = passed * 100.0 / total;
        return new(rate >= 80 ? "Covered" : rate >= 40 ? "Partial" : "Gap", passed, total);
    }

    private CoverageResult GetRiskCoverage(RiskEntry risk)
        => GetComplianceCoverage(risk.RoadmapTags);

