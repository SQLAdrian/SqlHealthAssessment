<!--/* In the name of God, the Merciful, the Compassionate */-->
@page "/diagnostics-roadmap"
@implements IDisposable

@using SqlHealthAssessment.Data
@using SqlHealthAssessment.Data.Models
@using SqlHealthAssessment.Data.Services
@using Microsoft.Extensions.Logging
@using System.IO
@using System.Globalization
@inject ILogger<DiagnosticsRoadmap> Logger
@inject PrintService PrintSvc
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject UserSettingsService UserSettings

@* ══════════════════════════════════════════════════════
   Print / PDF styles — enterprise report look
   Toasts are suppressed during print via .printing-active
   ══════════════════════════════════════════════════════ *@
<style>
    /* Slightly smaller font during print to fit more content per page */
    body.printing-active #roadmap-print-region {
        font-size: 11px;
    }
    body.printing-active #roadmap-print-region .print-cat-card {
        font-size: 10px;
        padding: 6px 8px !important;
    }
    body.printing-active #roadmap-print-region .print-level-header {
        font-size: 12px;
        padding: 6px 10px !important;
    }
    /* Tighten level card margins, grid gaps, and detail padding */
    body.printing-active #roadmap-print-region .print-level-card {
        margin-bottom: 6px !important;
    }
    body.printing-active #roadmap-print-region .level-detail {
        padding: 6px 10px !important;
    }
    body.printing-active #roadmap-print-region .print-cat-grid {
        gap: 6px !important;
    }
    /* Tighten the failed/passed divider and progress bar spacing */
    body.printing-active #roadmap-print-region .print-passed-section {
        margin-top: 2px !important;
        padding-top: 2px !important;
        max-height: none !important;
        overflow-y: visible !important;
    }
    /* Remove overflow clipping on failed checks list during print */
    body.printing-active #roadmap-print-region .print-cat-card > div[style*="max-height:80px"] {
        max-height: none !important;
        overflow-y: visible !important;
    }

    /* Suppress the global MainLayout print-header/footer — roadmap has its own DOM footer */
    body.printing-active .print-header,
    body.printing-active .print-footer,
    body.printing-active .roadmap-toolbar {
        display: none !important;
    }
    /* Remove the body/layout padding that media-print reserves for the global header/footer */
    body.printing-active,
    body.printing-active .app-layout,
    body.printing-active .app-container,
    body.printing-active .app-content,
    body.printing-active .settings-page {
        padding-top: 0 !important;
        padding-bottom: 0 !important;
        margin-top: 0 !important;
        margin-bottom: 0 !important;
    }

    /* Hide toast container while printing */
    body.printing-active .rz-notification,
    body.printing-active [class*="toast"],
    body.printing-active [class*="Toast"],
    body.printing-active .mud-snackbar-container,
    body.printing-active .notification-container {
        display: none !important;
    }

    @@media screen {
        #roadmap-print-region .print-executive-summary { display: none; }
    }
</style>

<div class="settings-page" style="max-width: 1400px;">

    @* ── Toolbar ── *@
    <div class="roadmap-toolbar" style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; flex-wrap:wrap; gap:8px;">
        <h2 style="margin:0;">Diagnostics Maturity Roadmap</h2>
        <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
            @if (_availableServers.Count > 0)
            {
                <div style="background:var(--bg-primary); border:1px solid var(--border); border-radius:4px; padding:4px 8px; min-width:280px; max-height:200px; overflow-y:auto; font-size:12px;">
                    @foreach (var domainGroup in _domainGroups)
                    {
                        var dg = domainGroup;
                        var preferredInDomain = PreferredInDomain(dg).ToList();
                        bool hasDomain = !string.IsNullOrEmpty(dg.Key);

                        @if (hasDomain)
                        {
                            <div style="display:flex; align-items:center; gap:6px; padding:4px 2px 2px; border-top:1px solid var(--border); margin-top:2px;">
                                <input type="checkbox" checked="@IsDomainAllSelected(dg)"
                                       @onchange="async e => await ToggleDomain(dg, (bool)(e.Value ?? false))" />
                                <span style="font-weight:600; color:var(--text-secondary); font-size:11px; text-transform:uppercase; letter-spacing:.04em;">
                                    <i class="fa-solid fa-building" style="color:var(--text-muted); margin-right:3px; font-size:10px;"></i>@dg.Key
                                </span>
                                <span style="color:var(--text-muted); font-size:10px;">@preferredInDomain.Count server@(preferredInDomain.Count == 1 ? "" : "s")</span>
                            </div>
                        }

                        @foreach (var srv in _availableServers.Where(s =>
                            string.Equals(s.Domain, dg.Key, StringComparison.OrdinalIgnoreCase)))
                        {
                            var s = srv;
                            bool isPreferred = preferredInDomain.Any(p => p.FilePath == s.FilePath);
                            <label style="display:flex; align-items:center; gap:6px; padding:2px 2px 2px @(hasDomain ? "16px" : "2px"); cursor:pointer; white-space:nowrap; color:var(--text-primary); @(!isPreferred ? "opacity:0.6;" : "")">
                                <input type="checkbox" checked="@s.IsSelected"
                                       @onchange="async e => await OnServerToggled(s, (bool)(e.Value ?? false))" />
                                <span>@s.SqlInstance</span>
                                <span style="color:var(--text-muted); font-size:10px;">@(s.FileType == AuditFileType.SpBlitz ? "sp_Blitz" : "sp_triage") @s.AuditDate.ToString("yyyy-MM-dd")</span>
                                @if (!isPreferred)
                                {
                                    <span style="color:var(--text-muted); font-size:9px;" title="A triage file is available for this server — prefer that one">alt</span>
                                }
                            </label>
                        }
                    }
                </div>
            }
            <button class="settings-btn" title="Deselect all servers"
                    disabled="@(!_availableServers.Any(s => s.IsSelected))"
                    style="@(!_availableServers.Any(s => s.IsSelected) ? "opacity:0.4;cursor:not-allowed;" : "")"
                    @onclick="async () => { foreach (var s in _availableServers) { s.IsSelected = false; s.CheckCounts.Clear(); } await RecalculateFromSelected(); }">
                <i class="fa-solid fa-square-minus"></i> Clear
            </button>
            <button class="settings-btn" @onclick="RefreshOutputFolder" title="Rescan output folder">
                <i class="fa-solid fa-rotate"></i>
            </button>
            <button class="settings-btn" @onclick='() => Navigation.NavigateTo("/fullaudit")'>
                <i class="fa-solid fa-stethoscope"></i> Run Full Audit
            </button>
            <button class="settings-btn" @onclick="ExportCsv" title="Export failed checks to CSV"
                    disabled="@(!_anySelected || !_maturityLevels.Any())"
                    style="@(!_anySelected || !_maturityLevels.Any() ? "opacity:0.4;cursor:not-allowed;" : "")">
                <i class="fa-solid fa-file-csv"></i> Export CSV
            </button>
            @if (_domainGroups.Count() > 1)
            {
                <label style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text-secondary);cursor:pointer;user-select:none;">
                    <input type="checkbox" @bind="_splitByDomain" style="cursor:pointer;" />
                    PDF per domain
                </label>
            }
            <button class="settings-btn settings-btn-primary" @onclick="ExportPdf"
                    disabled="@(!_anySelected || _exporting)"
                    style="@(!_anySelected ? "opacity:0.4;cursor:not-allowed;" : "")">
                @if (_exporting)
                {
                    <i class="fa-solid fa-spinner fa-spin"></i>
                    <span>Exporting…</span>
                }
                else
                {
                    <i class="fa-solid fa-file-pdf"></i>
                    <span>@(_splitByDomain ? "Export PDF per Domain" : "Export PDF")</span>
                }
            </button>
            <button class="settings-btn @(_scheduleEnabled ? "settings-btn-primary" : "")"
                    title="@(_scheduleEnabled ? $"Scheduled PDF: {_scheduleType} at {_scheduleTime}" : "Configure scheduled PDF export")"
                    @onclick="() => _showScheduleModal = true">
                <i class="fa-solid @(_scheduleEnabled ? "fa-clock" : "fa-clock")"></i>
                @if (_scheduleEnabled) { <span style="font-size:10px;">Scheduled</span> }
            </button>
        </div>
    </div>

    @* ── Schedule Modal ── *@
    @if (_showScheduleModal)
    {
        <div style="position:fixed;inset:0;background:rgba(0,0,0,0.55);z-index:1000;display:flex;align-items:center;justify-content:center;" @onclick="() => _showScheduleModal = false">
            <div style="background:var(--bg-primary);border:1px solid var(--border);border-radius:10px;padding:28px 32px;min-width:380px;max-width:460px;box-shadow:0 8px 40px rgba(0,0,0,0.4);" @onclick:stopPropagation>
                <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;border-bottom:1px solid var(--border);padding-bottom:14px;">
                    <i class="fa-solid fa-clock" style="color:var(--primary);font-size:18px;"></i>
                    <span style="font-size:15px;font-weight:700;color:var(--text-primary);">Scheduled PDF Export</span>
                </div>

                <label style="display:flex;align-items:center;gap:10px;margin-bottom:18px;cursor:pointer;">
                    <input type="checkbox" @bind="_scheduleEnabled" style="width:16px;height:16px;cursor:pointer;" />
                    <span style="font-size:13px;font-weight:600;color:var(--text-primary);">Enable scheduled export</span>
                </label>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;">
                    <div>
                        <div style="font-size:11px;color:var(--text-muted);margin-bottom:4px;text-transform:uppercase;letter-spacing:0.05em;">Frequency</div>
                        <select @bind="_scheduleType" style="width:100%;padding:6px 8px;border:1px solid var(--border);border-radius:5px;background:var(--bg-secondary);color:var(--text-primary);font-size:12px;">
                            <option value="Daily">Daily</option>
                            <option value="Weekly">Weekly</option>
                            <option value="Monthly">Monthly</option>
                        </select>
                    </div>
                    <div>
                        <div style="font-size:11px;color:var(--text-muted);margin-bottom:4px;text-transform:uppercase;letter-spacing:0.05em;">Time</div>
                        <input type="time" value="@_scheduleTime" @onchange="e => _scheduleTime = e.Value?.ToString() ?? _scheduleTime"
                               style="width:100%;padding:6px 8px;border:1px solid var(--border);border-radius:5px;background:var(--bg-secondary);color:var(--text-primary);font-size:12px;" />
                    </div>
                </div>

                @if (_scheduleType == "Weekly")
                {
                    <div style="margin-bottom:14px;">
                        <div style="font-size:11px;color:var(--text-muted);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.05em;">Day of Week</div>
                        <div style="display:flex;gap:6px;flex-wrap:wrap;">
                            @foreach (var (label, val) in new[]{("Sun",0),("Mon",1),("Tue",2),("Wed",3),("Thu",4),("Fri",5),("Sat",6)})
                            {
                                var v = val;
                                <button style="padding:4px 10px;border-radius:5px;font-size:11px;font-weight:600;cursor:pointer;border:1px solid var(--border);background:@(_scheduleDayOfWeek==v?"var(--primary)":"var(--bg-secondary)");color:@(_scheduleDayOfWeek==v?"#fff":"var(--text-primary)");"
                                        @onclick="() => _scheduleDayOfWeek = v">@label</button>
                            }
                        </div>
                    </div>
                }
                @if (_scheduleType == "Monthly")
                {
                    <div style="margin-bottom:14px;">
                        <div style="font-size:11px;color:var(--text-muted);margin-bottom:4px;text-transform:uppercase;letter-spacing:0.05em;">Day of Month</div>
                        <input type="number" min="1" max="28" @bind="_scheduleDayOfMonth"
                               style="width:80px;padding:6px 8px;border:1px solid var(--border);border-radius:5px;background:var(--bg-secondary);color:var(--text-primary);font-size:12px;" />
                    </div>
                }

                <label style="display:flex;align-items:center;gap:8px;margin-bottom:20px;cursor:pointer;">
                    <input type="checkbox" @bind="_scheduleSplitByDomain" style="cursor:pointer;" />
                    <span style="font-size:12px;color:var(--text-secondary);">Export one PDF per domain</span>
                </label>

                @if (_scheduleLastRun > DateTime.MinValue)
                {
                    <div style="font-size:11px;color:var(--text-muted);margin-bottom:16px;">
                        <i class="fa-solid fa-check-circle" style="color:var(--green);"></i>
                        Last run: @_scheduleLastRun.ToLocalTime().ToString("dd MMM yyyy HH:mm")
                    </div>
                }

                <div style="display:flex;gap:10px;justify-content:flex-end;">
                    <button class="settings-btn" @onclick="() => _showScheduleModal = false">Cancel</button>
                    <button class="settings-btn settings-btn-primary" @onclick="SaveSchedule">
                        <i class="fa-solid fa-floppy-disk"></i> Save Schedule
                    </button>
                </div>
            </div>
        </div>
    }

    @* ── Loading / empty states ── *@
    @if (_loading)
    {
        <div style="padding:20px; background:var(--bg-secondary); border:1px solid var(--border); border-radius:8px; margin-bottom:16px;">
            <div style="display:flex; align-items:center; gap:12px; margin-bottom:10px;">
                <i class="fa-solid fa-spinner fa-spin" style="color:var(--primary);"></i>
                <span style="font-size:13px; color:var(--text-secondary);">@_loadingMessage</span>
            </div>
            <div style="height:6px; background:var(--bg-tertiary); border-radius:3px; overflow:hidden;">
                <div style="height:100%; width:@(_loadProgress)%; background:var(--primary); border-radius:3px; transition:width 0.3s ease;"></div>
            </div>
        </div>
    }
    else if (_availableServers.Count == 0)
    {
        <div style="padding:32px; text-align:center; background:var(--bg-secondary); border:1px solid var(--border); border-radius:8px;">
            <i class="fa-solid fa-folder-open" style="font-size:32px; color:var(--text-muted); margin-bottom:12px; display:block;"></i>
            <div style="font-size:14px; color:var(--text-secondary); margin-bottom:8px;">No audit files found in the output folder.</div>
            <div style="font-size:12px; color:var(--text-muted);">Run a Full Audit to generate sp_triage output, then return here.</div>
            <button class="settings-btn settings-btn-primary" style="margin-top:16px;" @onclick='() => Navigation.NavigateTo("/fullaudit")'>
                <i class="fa-solid fa-stethoscope"></i> Run Full Audit
            </button>
        </div>
    }
    else if (!_anySelected)
    {
        <div style="padding:24px; text-align:center; background:var(--bg-secondary); border:1px solid var(--border); border-radius:8px;">
            <i class="fa-solid fa-server" style="font-size:28px; color:var(--text-muted); margin-bottom:10px; display:block;"></i>
            <div style="font-size:13px; color:var(--text-secondary);">Select one or more audit files above to view the combined maturity roadmap.</div>
            <div style="font-size:11px; color:var(--text-muted); margin-top:6px;">@_availableServers.Count audit file(s) available</div>
        </div>
    }

    @* ── Main roadmap (screen + print) ── *@
    @if (_anySelected && !_loading)
    {
        <div id="roadmap-print-region">

            @* ── PDF Cover Page (print-only) ── *@
            <div class="pdf-cover-page" style="display:none; page-break-after:always; min-height:90vh; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:60px 40px;">
                <div style="margin-bottom:32px;">
                    <i class="fa-solid fa-heart-pulse" style="font-size:64px; color:#e2583e;"></i>
                </div>
                <div style="font-size:11px; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:#888; margin-bottom:8px;">SQL Health Assessment</div>
                <div style="font-size:32px; font-weight:800; color:#222; margin-bottom:8px; line-height:1.2;">Diagnostics Maturity Roadmap</div>
                @{ var coverDomains = _availableServers.Where(s => s.IsSelected).Select(s => s.Domain).Where(d => !string.IsNullOrEmpty(d)).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(d => d); }
                <div style="font-size:15px; color:#555; margin-bottom:40px;">@string.Join(" · ", coverDomains)</div>

                @* Big maturity badge *@
                <div style="width:140px; height:140px; border-radius:50%; display:flex; flex-direction:column; align-items:center; justify-content:center; border:5px solid @GetMaturityColor(_overallLevel); margin:0 auto 32px; background:@(GetMaturityColor(_overallLevel))15;">
                    <div style="font-size:48px; font-weight:800; color:@GetMaturityColor(_overallLevel); line-height:1;">L@(_overallLevel)</div>
                    <div style="font-size:12px; font-weight:600; color:@GetMaturityColor(_overallLevel);">@GetMaturityName(_overallLevel)</div>
                </div>

                @* Level progress dots *@
                <div style="display:flex; gap:24px; align-items:center; justify-content:center; margin-bottom:40px;">
                    @for (int ci = 1; ci <= 5; ci++)
                    {
                        var lv = ci;
                        <div style="display:flex; flex-direction:column; align-items:center; gap:4px;">
                            <i class="fa-solid @(lv <= _overallLevel ? "fa-circle-check" : "fa-circle")"
                               style="font-size:22px; color:@(lv <= _overallLevel ? GetMaturityColor(lv) : "#ddd");"></i>
                            <span style="font-size:9px; color:@(lv <= _overallLevel ? "#444" : "#bbb"); font-weight:600; text-transform:uppercase; letter-spacing:0.04em;">@GetMaturityName(lv)</span>
                        </div>
                    }
                </div>

                @* Stats row *@
                <div style="display:flex; gap:48px; justify-content:center; margin-bottom:48px;">
                    <div><div style="font-size:28px; font-weight:700; color:#222;">@(_overallScore.ToString("N0"))%</div><div style="font-size:11px; color:#888; text-transform:uppercase; letter-spacing:0.06em;">Overall Score</div></div>
                    <div><div style="font-size:28px; font-weight:700; color:#222;">@_availableServers.Count(s => s.IsSelected)</div><div style="font-size:11px; color:#888; text-transform:uppercase; letter-spacing:0.06em;">Servers</div></div>
                    <div><div style="font-size:28px; font-weight:700; color:#222;">@_passedFindings / @_totalFindings</div><div style="font-size:11px; color:#888; text-transform:uppercase; letter-spacing:0.06em;">Checks Passed</div></div>
                    <div><div style="font-size:28px; font-weight:700; color:@(_totalItemsImpacted > 0 ? "#e2583e" : "#22c55e");">@_totalItemsImpacted</div><div style="font-size:11px; color:#888; text-transform:uppercase; letter-spacing:0.06em;">Items Impacted</div></div>
                </div>

                <div style="margin-top:48px; font-size:10px; color:#aaa;">Generated @DateTime.Now.ToString("dd MMM yyyy HH:mm") · Compliments of sqldba.org</div>
            </div>

            @* ── Overall Maturity Score ── *@
            <div style="background:var(--bg-secondary); border:1px solid var(--border); border-radius:8px; padding:20px; margin-bottom:20px;">
                <div style="display:flex; align-items:center; gap:24px; flex-wrap:wrap;">
                    <div style="text-align:center; min-width:120px;">
                        <div style="font-size:48px; font-weight:700; color:@GetMaturityColor(_overallLevel);">
                            L@(_overallLevel)
                        </div>
                        <div style="font-size:13px; color:var(--text-secondary); font-weight:600;">@GetMaturityName(_overallLevel)</div>
                    </div>
                    <div style="flex:1; min-width:200px;">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
                            <span style="font-size:12px; color:var(--text-secondary);">Overall Maturity Progress — @string.Join(", ", _availableServers.Where(s => s.IsSelected).Select(s => s.SqlInstance))</span>
                            <span style="font-size:12px; font-weight:600; color:var(--text-primary);">@(_overallScore.ToString("N0"))%</span>
                        </div>
                        <div style="height:10px; background:var(--bg-tertiary); border-radius:5px; overflow:hidden;">
                            <div style="height:100%; width:@(_overallScore)%; background:@GetMaturityColor(_overallLevel); border-radius:5px; transition:width 0.5s ease;"></div>
                        </div>
                        <div style="display:flex; justify-content:space-between; margin-top:8px;">
                            @for (int i = 1; i <= 5; i++)
                            {
                                var level = i;
                                <div style="text-align:center; font-size:10px; color:@(level <= _overallLevel ? GetMaturityColor(level) : "var(--text-muted)");">
                                    <i class="fa-solid @(level <= _overallLevel ? "fa-circle-check" : "fa-circle")" style="font-size:14px;"></i>
                                    <div>@GetMaturityName(level)</div>
                                </div>
                            }
                        </div>
                    </div>
                    @* Executive summary for print *@
                    <div style="font-size:11px; color:var(--text-muted); max-width:280px;">
                        Servers selected: @_availableServers.Count(s => s.IsSelected)<br/>
                        Findings evaluated: @_totalFindings &nbsp;|&nbsp; Passed: @_passedFindings<br/>
                        Items impacted: <span style="color:@(_totalItemsImpacted > 0 ? "var(--red)" : "var(--green)"); font-weight:600;">@_totalItemsImpacted</span>
                    </div>
                </div>
            </div>

            @* ── Executive Summary Table (print) ── *@
            <div style="margin-bottom:20px; display:none;" class="print-executive-summary">
                <div class="print-section-header">
                    <strong>Executive Summary</strong>
                </div>
                <table class="print-summary-table">
                    <thead>
                        <tr>
                            <th>Level</th>
                            <th>Maturity Stage</th>
                            <th>Pass Rate</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ml in _maturityLevels)
                        {
                            <tr>
                                <td><strong>L@(ml.Level)</strong></td>
                                <td>@ml.Name — @ml.Description</td>
                                <td>@ml.PassRate.ToString("N0")% (@ml.PassedChecks / @ml.TotalChecks)</td>
                                <td>
                                    @if (ml.PassRate >= 80)
                                    {
                                        <span class="badge-pass" style="padding:1px 6px; border-radius:3px; font-size:8pt;">COMPLETE</span>
                                    }
                                    else if (ml.Level == _overallLevel)
                                    {
                                        <span class="badge-warn" style="padding:1px 6px; border-radius:3px; font-size:8pt;">IN PROGRESS</span>
                                    }
                                    else
                                    {
                                        <span class="badge-fail" style="padding:1px 6px; border-radius:3px; font-size:8pt;">NOT STARTED</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* ── Maturity Levels ── *@
            @foreach (var level in _maturityLevels)
            {
                var isCurrentLevel = level.Level == _overallLevel;
                var isCompleted    = level.Level < _overallLevel;

                <div class="print-level-card level-section" style="border:1px solid @(isCurrentLevel ? GetMaturityColor(level.Level) : "var(--border)"); border-radius:8px; margin-bottom:12px; overflow:hidden;
                            @(isCurrentLevel ? $"box-shadow: 0 0 0 1px {GetMaturityColor(level.Level)}20;" : "")">

                    @* Level Header *@
                    <div class="print-level-header" style="display:flex; align-items:center; gap:12px; padding:12px 16px; background:@(isCurrentLevel ? $"{GetMaturityColor(level.Level)}10" : "var(--bg-secondary)"); cursor:pointer;"
                         @onclick="() => ToggleLevel(level.Level)">
                        <div style="width:36px; height:36px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:14px;
                                    background:@(isCompleted ? GetMaturityColor(level.Level) : "var(--bg-tertiary)"); color:@(isCompleted ? "white" : GetMaturityColor(level.Level));">
                            @if (isCompleted)
                            {
                                <i class="fa-solid fa-check"></i>
                            }
                            else
                            {
                                <span>L@(level.Level)</span>
                            }
                        </div>
                        <div style="flex:1;">
                            <div style="font-weight:600; font-size:14px; color:var(--text-primary);">
                                @level.Name
                                @if (isCurrentLevel)
                                {
                                    <span style="font-size:10px; font-weight:500; padding:2px 8px; border-radius:10px; margin-left:8px;
                                                background:@(GetMaturityColor(level.Level))20; color:@GetMaturityColor(level.Level);">CURRENT</span>
                                }
                            </div>
                            <div style="font-size:11px; color:var(--text-muted);">@level.Description</div>
                        </div>
                        <div style="text-align:right; min-width:80px;">
                            <div style="font-size:14px; font-weight:600; color:@GetMaturityColor(level.Level);">@level.PassRate.ToString("N0")%</div>
                            <div style="font-size:10px; color:var(--text-muted);">@level.PassedChecks / @level.TotalChecks passed</div>
                        </div>
                        <i class="fa-solid @(_expandedLevels.Contains(level.Level) ? "fa-chevron-up" : "fa-chevron-down")"
                           style="color:var(--text-muted);"></i>
                    </div>

                    @* Level Details — always in DOM, hidden via CSS so JS can show instantly for print *@
                    <div class="level-detail" style="@(_expandedLevels.Contains(level.Level) ? "" : "display:none;")padding:12px 16px; border-top:1px solid var(--border);">
                            <div class="print-cat-grid" style="display:grid; grid-template-columns:repeat(auto-fill, minmax(260px,1fr)); gap:10px;">
                                @foreach (var cat in level.Categories)
                                {
                                    <div class="print-cat-card" style="border:1px solid var(--border); border-radius:6px; padding:10px; background:var(--bg-primary);">
                                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
                                            <span style="font-weight:600; font-size:12px; color:var(--text-primary);">
                                                <i class="fa-solid @GetCategoryIcon(cat.Category)" style="color:@GetMaturityColor(level.Level); margin-right:4px;"></i>
                                                @cat.Category
                                            </span>
                                            <span class="severity-badge @(cat.PassRate >= 100 ? "severity-info" : cat.PassRate >= 70 ? "severity-warning" : "severity-high")"
                                                  style="font-size:10px;">
                                                @cat.Passed / @cat.Total
                                            </span>
                                        </div>
                                        <div style="height:4px; background:var(--bg-tertiary); border-radius:2px; overflow:hidden; margin-bottom:6px;">
                                            <div style="height:100%; width:@(cat.PassRate)%; background:@(cat.PassRate >= 100 ? "var(--green)" : cat.PassRate >= 70 ? "var(--orange)" : "var(--red)"); border-radius:2px;"></div>
                                        </div>
                                        @if (cat.FailedChecks.Count > 0)
                                        {
                                            <div style="font-size:10px; color:var(--text-muted); max-height:80px; overflow-y:auto;">
                                                @foreach (var (_, name, tag) in cat.FailedChecks.Take(5))
                                                {
                                                    <div style="padding:1px 0; display:flex; gap:4px; align-items:center;">
                                                        <i class="fa-solid fa-xmark" style="color:var(--red); font-size:9px; flex-shrink:0;"></i>
                                                        <span style="flex:1;">@name</span>
                                                        @if (!string.IsNullOrEmpty(tag))
                                                        {
                                                            <span style="font-size:9px; padding:1px 5px; border-radius:8px; background:var(--bg-tertiary); color:var(--text-muted); flex-shrink:0;">@tag</span>
                                                        }
                                                    </div>
                                                }
                                                @if (cat.FailedChecks.Count > 5)
                                                {
                                                    <div style="color:var(--text-muted); font-style:italic;">+@(cat.FailedChecks.Count - 5) more</div>
                                                }
                                            </div>
                                        }
                                        else if (cat.Total > 0)
                                        {
                                            <div style="font-size:10px; color:var(--green);">
                                                <i class="fa-solid fa-check"></i> All checks passing
                                            </div>
                                        }
                                        else
                                        {
                                            <div style="font-size:10px; color:var(--text-muted); font-style:italic;">No data in audit</div>
                                        }
                                        @* DEBUG: passed checks from audit file *@
                                        @if (cat.PassedChecks.Count > 0)
                                        {
                                            <div class="print-passed-section" style="font-size:10px; margin-top:4px; border-top:1px dashed var(--border); padding-top:4px; max-height:100px; overflow-y:auto;">
                                                @foreach (var (name, tag) in cat.PassedChecks)
                                                {
                                                    <div style="padding:1px 0; display:flex; gap:4px; align-items:center;">
                                                        <i class="fa-solid fa-check" style="color:var(--green); font-size:9px; flex-shrink:0;"></i>
                                                        <span style="flex:1; color:var(--text-muted);">@name</span>
                                                        @if (!string.IsNullOrEmpty(tag))
                                                        {
                                                            <span style="font-size:9px; padding:1px 5px; border-radius:8px; background:var(--bg-tertiary); color:var(--text-muted); flex-shrink:0;">@tag</span>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>

                            @if (!isCompleted && level.Recommendations.Count > 0)
                            {
                                <div style="margin-top:12px; padding:10px; background:var(--bg-tertiary); border-radius:6px;">
                                    <div style="font-size:11px; font-weight:600; color:var(--text-secondary); margin-bottom:6px;">
                                        <i class="fa-solid fa-lightbulb" style="color:var(--orange);"></i> Recommendations to reach this level
                                    </div>
                                    @foreach (var rec in level.Recommendations)
                                    {
                                        <div style="font-size:11px; color:var(--text-secondary); padding:2px 0; display:flex; gap:6px; align-items:start;">
                                            <i class="fa-solid fa-arrow-right" style="color:var(--text-muted); margin-top:3px; font-size:9px;"></i>
                                            <span>@rec</span>
                                        </div>
                                    }
                                </div>
                            }
                    </div>
                </div>
            }

            @* ── Legend ── *@
            <div style="padding:12px 16px; background:var(--bg-secondary); border:1px solid var(--border); border-radius:6px; margin-top:8px;">
                <div style="font-size:11px; color:var(--text-muted);">
                    <strong>How maturity is calculated:</strong> Each level groups related check categories from the sp_triage audit output.
                    A level is considered complete when 80%+ of its checks pass. Your overall level is the highest where all prior levels are complete.
                    Sources: @string.Join(", ", _availableServers.Where(s => s.IsSelected).Select(s => $"{s.SqlInstance} ({(s.FileType == AuditFileType.SpBlitz ? "sp_Blitz" : "sp_triage")} {s.AuditDate:yyyy-MM-dd})"))
                </div>
            </div>

        @* ── Per-server level summary (only when >1 server selected) ── *@
        @if (_serverLevels.Count > 1)
        {
            var useTable = _serverLevels.Count > 12;
            <div class="server-comparison-section" style="margin-top:16px; background:var(--bg-secondary); border:1px solid var(--border); border-radius:8px; overflow:hidden;">
                <div style="padding:10px 16px; border-bottom:1px solid var(--border); font-size:12px; font-weight:600; color:var(--text-secondary);">
                    <i class="fa-solid fa-server" style="margin-right:6px; color:var(--text-muted);"></i>Server Maturity Comparison
                    <span style="font-weight:400; color:var(--text-muted); margin-left:6px;">@_serverLevels.Count servers</span>
                </div>
                @if (useTable)
                {
                    <div class="server-comparison-scroll" style="max-height:320px; overflow-y:auto; border-top:1px solid var(--border);">
                        <table style="width:100%; border-collapse:collapse; font-size:12px;">
                            <thead style="background:var(--bg-tertiary); position:sticky; top:0; z-index:1;">
                                <tr>
                                    <th style="padding:6px 14px; text-align:left; font-weight:600; color:var(--text-secondary); border-bottom:1px solid var(--border);">Server</th>
                                    <th style="padding:6px 10px; text-align:center; font-weight:600; color:var(--text-secondary); border-bottom:1px solid var(--border); width:60px;">Level</th>
                                    <th style="padding:6px 14px; text-align:left; font-weight:600; color:var(--text-secondary); border-bottom:1px solid var(--border);">Stage</th>
                                    <th style="padding:6px 14px; text-align:right; font-weight:600; color:var(--text-secondary); border-bottom:1px solid var(--border); width:60px;">Score</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var kvp in _serverLevels.OrderBy(x => x.Key))
                                {
                                    var srvInstance = kvp.Key;
                                    var srvLvl      = kvp.Value.Level;
                                    var srvScore    = kvp.Value.Score;
                                    <tr style="border-bottom:1px solid var(--border);">
                                        <td style="padding:5px 14px; color:var(--text-primary);">@srvInstance</td>
                                        <td style="padding:5px 10px; text-align:center;">
                                            <span style="font-weight:700; color:@(GetMaturityColor(srvLvl));">L@(srvLvl)</span>
                                        </td>
                                        <td style="padding:5px 14px; color:var(--text-secondary);">@(GetMaturityName(srvLvl))</td>
                                        <td style="padding:5px 14px; text-align:right; color:var(--text-muted);">@(srvScore.ToString("N0"))%</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(200px,1fr)); gap:1px; background:var(--border);">
                        @foreach (var kvp in _serverLevels.OrderBy(x => x.Key))
                        {
                            var srvInstance = kvp.Key;
                            var srvLvl      = kvp.Value.Level;
                            var srvScore    = kvp.Value.Score;
                            <div style="background:var(--bg-primary); padding:10px 14px; display:flex; align-items:center; gap:10px;">
                                <div style="width:32px; height:32px; border-radius:50%; display:flex; align-items:center; justify-content:center;
                                            background:@(GetMaturityColor(srvLvl))20; color:@GetMaturityColor(srvLvl); font-weight:700; font-size:13px; flex-shrink:0;">
                                    L@(srvLvl)
                                </div>
                                <div style="min-width:0;">
                                    <div style="font-size:12px; font-weight:600; color:var(--text-primary); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;" title="@srvInstance">@srvInstance</div>
                                    <div style="font-size:11px; color:var(--text-muted);">@GetMaturityName(srvLvl) &nbsp;·&nbsp; @srvScore.ToString("N0")%</div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }

        @* ── Risk Register ── *@
        <div class="risk-panel-wrapper" style="margin-top:24px;">
            <div style="display:flex; align-items:center; gap:10px; padding:10px 14px; background:var(--bg-secondary); border:1px solid var(--border); border-radius:6px; cursor:pointer; user-select:none;"
                 @onclick="() => _riskPanelOpen = !_riskPanelOpen">
                <i class="fa-solid fa-triangle-exclamation" style="color:#f59e0b;"></i>
                <span style="font-weight:600; font-size:13px;">Risk Register</span>
                <span style="font-size:11px; color:var(--text-muted); margin-left:4px;">Likelihood × Impact — dynamically rated from audit findings</span>
                <i class="fa-solid @(_riskPanelOpen ? "fa-chevron-up" : "fa-chevron-down")" style="margin-left:auto; color:var(--text-muted);"></i>
            </div>
            <div class="risk-panel-detail" style="@(_riskPanelOpen ? "" : "display:none;")border:1px solid var(--border); border-top:none; border-radius:0 0 6px 6px; overflow:hidden;">
                    <table style="width:100%; border-collapse:collapse; font-size:12px;">
                        <thead>
                            <tr style="background:var(--bg-tertiary); color:var(--text-secondary); font-size:11px; text-transform:uppercase; letter-spacing:0.04em;">
                                <th style="padding:8px 10px; text-align:left; font-weight:600;">ID</th>
                                <th style="padding:8px 10px; text-align:left; font-weight:600;">Risk Theme</th>
                                <th style="padding:8px 10px; text-align:left; font-weight:600; max-width:300px;">Description</th>
                                <th style="padding:8px 10px; text-align:center; font-weight:600;">Likelihood</th>
                                <th style="padding:8px 10px; text-align:center; font-weight:600;">Impact</th>
                                <th style="padding:8px 10px; text-align:center; font-weight:600;">Rating</th>
                                <th style="padding:8px 10px; text-align:center; font-weight:600;">Coverage</th>
                                <th style="padding:8px 10px; text-align:left; font-weight:600;">Checks Covering This</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var risk in GetRiskRegister())
                            {
                                var coverage = GetRiskCoverage(risk);
                                <tr style="border-top:1px solid var(--border);">
                                    <td style="padding:8px 10px; font-weight:600; color:var(--text-muted); white-space:nowrap;">@risk.Id</td>
                                    <td style="padding:8px 10px; font-weight:600; white-space:nowrap;">@risk.Theme</td>
                                    <td style="padding:8px 10px; color:var(--text-secondary); font-size:11px; max-width:300px;">@risk.Description</td>
                                    <td style="padding:8px 10px; text-align:center;">
                                        <span style="font-size:11px; padding:2px 8px; border-radius:10px; background:var(--bg-tertiary); color:var(--text-secondary);">@risk.Likelihood</span>
                                    </td>
                                    <td style="padding:8px 10px; text-align:center;">
                                        <span style="font-size:11px; padding:2px 8px; border-radius:10px; background:var(--bg-tertiary); color:var(--text-secondary);">@risk.Impact</span>
                                    </td>
                                    <td style="padding:8px 10px; text-align:center;">
                                        <span style="font-size:11px; padding:2px 8px; border-radius:10px; font-weight:600;
                                            background:@RiskRatingBg(risk.Rating); color:@RiskRatingFg(risk.Rating);">@risk.Rating</span>
                                    </td>
                                    <td style="padding:8px 10px; text-align:center;">
                                        @if (_anySelected)
                                        {
                                            <span style="font-size:11px; padding:2px 8px; border-radius:10px; font-weight:600;
                                                background:@CoverageBg(coverage.Status); color:@CoverageFg(coverage.Status);">
                                                @coverage.Status
                                            </span>
                                            <div style="font-size:10px; color:var(--text-muted); margin-top:2px;">@coverage.PassedCount / @coverage.TotalCount checks pass</div>
                                        }
                                        else
                                        {
                                            <span style="font-size:11px; color:var(--text-muted);">—</span>
                                        }
                                    </td>
                                    <td style="padding:8px 10px; font-size:11px; color:var(--text-muted);">@risk.CheckScope</td>
                                </tr>
                            }
                        </tbody>
                    </table>
            </div>
        </div>

        @* ── Compliance Mapping ── *@
        <div class="compliance-panel-wrapper" style="margin-top:16px; margin-bottom:24px;">
            <div style="display:flex; align-items:center; gap:10px; padding:10px 14px; background:var(--bg-secondary); border:1px solid var(--border); border-radius:6px; cursor:pointer; user-select:none;"
                 @onclick="() => _compliancePanelOpen = !_compliancePanelOpen">
                <i class="fa-solid fa-shield-halved" style="color:#6366f1;"></i>
                <span style="font-weight:600; font-size:13px;">Compliance Mapping</span>
                <span style="font-size:11px; color:var(--text-muted); margin-left:4px;">ISO 27001 · SOC 2 · NIST CSF 2.0</span>
                <i class="fa-solid @(_compliancePanelOpen ? "fa-chevron-up" : "fa-chevron-down")" style="margin-left:auto; color:var(--text-muted);"></i>
            </div>
            <div class="compliance-panel-detail" style="@(_compliancePanelOpen ? "" : "display:none;")border:1px solid var(--border); border-top:none; border-radius:0 0 6px 6px; padding:16px; display:grid; grid-template-columns:1fr 1fr 1fr; gap:16px;">
                    @* ISO 27001 *@
                    <div>
                        <div style="font-weight:600; font-size:12px; color:var(--text-secondary); margin-bottom:8px; text-transform:uppercase; letter-spacing:0.05em;">ISO/IEC 27001 (2022)</div>
                        @foreach (var ctrl in GetIsoControls())
                        {
                            var cov = GetComplianceCoverage(ctrl.CheckCategories);
                            <div style="padding:8px; background:var(--bg-secondary); border:1px solid var(--border); border-radius:4px; margin-bottom:6px;">
                                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:3px;">
                                    <span style="font-size:11px; font-weight:600; color:var(--text-primary);">@ctrl.Id</span>
                                    @if (_anySelected)
                                    {
                                        <span style="font-size:10px; padding:1px 7px; border-radius:8px; font-weight:600;
                                            background:@CoverageBg(cov.Status); color:@CoverageFg(cov.Status);">@cov.Status</span>
                                    }
                                </div>
                                <div style="font-size:11px; color:var(--text-secondary); margin-bottom:3px;">@ctrl.Name</div>
                                <div style="font-size:10px; color:var(--text-muted);">@ctrl.CheckScope</div>
                            </div>
                        }
                    </div>
                    @* SOC 2 *@
                    <div>
                        <div style="font-weight:600; font-size:12px; color:var(--text-secondary); margin-bottom:8px; text-transform:uppercase; letter-spacing:0.05em;">SOC 2 Trust Services</div>
                        @foreach (var ctrl in GetSoc2Controls())
                        {
                            var cov = GetComplianceCoverage(ctrl.CheckCategories);
                            <div style="padding:8px; background:var(--bg-secondary); border:1px solid var(--border); border-radius:4px; margin-bottom:6px;">
                                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:3px;">
                                    <span style="font-size:11px; font-weight:600; color:var(--text-primary);">@ctrl.Id</span>
                                    @if (_anySelected)
                                    {
                                        <span style="font-size:10px; padding:1px 7px; border-radius:8px; font-weight:600;
                                            background:@CoverageBg(cov.Status); color:@CoverageFg(cov.Status);">@cov.Status</span>
                                    }
                                </div>
                                <div style="font-size:11px; color:var(--text-secondary); margin-bottom:3px;">@ctrl.Name</div>
                                <div style="font-size:10px; color:var(--text-muted);">@ctrl.CheckScope</div>
                            </div>
                        }
                    </div>
                    @* NIST CSF *@
                    <div>
                        <div style="font-weight:600; font-size:12px; color:var(--text-secondary); margin-bottom:8px; text-transform:uppercase; letter-spacing:0.05em;">NIST CSF 2.0</div>
                        @foreach (var ctrl in GetNistControls())
                        {
                            var cov = GetComplianceCoverage(ctrl.CheckCategories);
                            <div style="padding:8px; background:var(--bg-secondary); border:1px solid var(--border); border-radius:4px; margin-bottom:6px;">
                                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:3px;">
                                    <span style="font-size:11px; font-weight:600; color:var(--text-primary);">@ctrl.Id</span>
                                    @if (_anySelected)
                                    {
                                        <span style="font-size:10px; padding:1px 7px; border-radius:8px; font-weight:600;
                                            background:@CoverageBg(cov.Status); color:@CoverageFg(cov.Status);">@cov.Status</span>
                                    }
                                </div>
                                <div style="font-size:11px; color:var(--text-secondary); margin-bottom:3px;">@ctrl.Name</div>
                                <div style="font-size:10px; color:var(--text-muted);">@ctrl.CheckScope</div>
                            </div>
                        }
                    </div>
            </div>
        </div>

        </div> @* #roadmap-print-region *@

    }
</div>

@code {
    // ── Type declarations (must precede field/method references for Razor wpftmp compiler) ──
    private enum AuditFileType { SpTriage, SpBlitz }

    private record AuditedServer
    {
        public string        SqlInstance { get; init; } = "";
        public string        Domain      { get; init; } = "";
        public DateTime      AuditDate   { get; init; }
        public string        FilePath    { get; init; } = "";
        public AuditFileType FileType    { get; init; } = AuditFileType.SpTriage;
        public bool          IsSelected  { get; set;  } = false;
        public Dictionary<int, int> CheckCounts { get; set; } = new();
    }

    private record MaturityLevel
    {
        public int    Level        { get; init; }
        public string Name         { get; init; } = "";
        public string Description  { get; init; } = "";
        public List<string>           Recommendations { get; init; } = new();
        public List<CategoryProgress> Categories      { get; init; } = new();
        public int    TotalChecks  { get; init; }
        public int    PassedChecks { get; init; }
        public double PassRate     { get; init; }
    }

    private record CategoryProgress
    {
        public string                          Category     { get; init; } = "";
        public int                             Total        { get; init; }
        public int                             Passed       { get; init; }
        public double                          PassRate     { get; init; }
        public List<(int CheckId, string Name, string Tag)> FailedChecks { get; init; } = new();
        public List<(string Name, string Tag)>               PassedChecks { get; init; } = new();
    }

    // ── State ──
    private bool   _loading        = false;
    private string _loadingMessage = "";
    private double _loadProgress   = 0;
    private bool   _exporting        = false;
    private bool   _splitByDomain    = false;

    // ── Schedule modal state ──
    private bool     _showScheduleModal   = false;
    private bool     _scheduleEnabled     = false;
    private string   _scheduleType        = "Weekly";
    private string   _scheduleTime        = "07:00";
    private int      _scheduleDayOfWeek   = 1; // Monday
    private int      _scheduleDayOfMonth  = 1;
    private bool     _scheduleSplitByDomain = false;
    private DateTime _scheduleLastRun     = DateTime.MinValue;
    private System.Timers.Timer? _scheduleTimer;

    private List<AuditedServer> _availableServers = new();

    // Derived helpers — computed from _availableServers where IsSelected
    private string? _selectedInstance
        => _availableServers.Where(s => s.IsSelected).Select(s => s.SqlInstance)
                            .FirstOrDefault();
    private AuditedServer? _selectedServer
        => _availableServers.FirstOrDefault(s => s.IsSelected);
    private bool _anySelected => _availableServers.Any(s => s.IsSelected);

    // Grouped by domain for UI — within each domain, deduplicate by SqlInstance keeping
    // the preferred file (triage > blitz, then newest).  Ungrouped servers go under "".
    private IEnumerable<IGrouping<string, AuditedServer>> _domainGroups
        => _availableServers
            .GroupBy(s => s.Domain, StringComparer.OrdinalIgnoreCase)
            .OrderBy(g => string.IsNullOrEmpty(g.Key) ? 1 : 0)
            .ThenBy(g => g.Key, StringComparer.OrdinalIgnoreCase);

    // Within a domain, the "preferred" entry per SqlInstance (triage beats blitz, then newest).
    private IEnumerable<AuditedServer> PreferredInDomain(IGrouping<string, AuditedServer> group)
        => group
            .GroupBy(s => s.SqlInstance, StringComparer.OrdinalIgnoreCase)
            .Select(g => g.OrderBy(s => s.FileType == AuditFileType.SpTriage ? 0 : 1)
                          .ThenByDescending(s => s.AuditDate)
                          .First());

    private bool IsDomainAllSelected(IGrouping<string, AuditedServer> group)
        => PreferredInDomain(group).All(s => s.IsSelected);

    private async Task ToggleDomain(IGrouping<string, AuditedServer> group, bool select)
    {
        var preferred = PreferredInDomain(group).ToHashSet();
        foreach (var srv in _availableServers)
        {
            bool isPreferred = preferred.Any(p =>
                string.Equals(p.SqlInstance, srv.SqlInstance, StringComparison.OrdinalIgnoreCase) &&
                p.FilePath == srv.FilePath);
            if (isPreferred)
                srv.IsSelected = select;
            else if (select) // deselect non-preferred duplicates when selecting a domain
                srv.IsSelected = false;
        }
        await RecalculateFromSelected();
    }

