    private static string GetCategoryIcon(string category)
    {
        var s = category.ToLowerInvariant();
        if (s == "backup" || s == "data protection & backup") return "fa-database";
        if (s == "reliability" || s == "operational reliability") return "fa-shield";
        if (s == "integrity") return "fa-check-double";
        if (s.Contains("security")) return "fa-lock";
        if (s.Contains("configuration")) return "fa-sliders";
        if (s.Contains("performance") || s.Contains("capacity")) return "fa-gauge-high";
        if (s == "indexes") return "fa-list-ol";
        if (s == "i/o") return "fa-hard-drive";
        if (s == "tempdb") return "fa-temperature-half";
        if (s.Contains("monitor") || s.Contains("observ")) return "fa-eye";
        if (s == "database housekeeping") return "fa-broom";
        if (s == "informational") return "fa-info-circle";
        if (s == "custom") return "fa-wrench";
        if (s == "naming checks") return "fa-tag";
        if (s == "availability") return "fa-tower-broadcast";
        if (s == "database") return "fa-database";
        return "fa-circle";
    }

