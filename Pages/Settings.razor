@inject IJSRuntime JS
@inject UserSettingsService UserSettings
@inject DashboardConfigService DashboardConfig
@inject MemoryMonitorService MemoryMonitor
@inject ConfigurationValidator ConfigValidator
@inject AutoUpdateService UpdateService
@inject AzureBlobExportService BlobExport
@inject SQLTriage.Data.ToastService Toast
@inject SQLTriage.Data.Services.AppUserState UserState
@inject SQLTriage.Data.Services.RbacService RbacService
@inject SQLTriage.Data.ServerConnectionManager ConnectionManager
@inject SQLTriage.Data.Services.CacheMetricsService CacheMetrics
@inject SQLTriage.Data.Services.CacheMetricsService CacheMetrics
@inject SQLTriage.Data.QueryThrottleService QueryThrottle

@if (!RbacService.HasPermission(UserState.Role, "settings"))
{
    <div style="padding: 32px;">
        <AccessDenied RequiredRole="Admin" Message="Settings are restricted to Admin users." />
    </div>
    return;
}

<div class="settings-page" style="max-width: 1000px;">
    <h2 style="margin-bottom: 20px;">Settings</h2>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; align-items: start;">


