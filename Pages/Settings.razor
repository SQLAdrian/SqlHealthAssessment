<!--/* In the name of God, the Merciful, the Compassionate */-->
@page "/settings"
<PageTitle>SQLTriage - Settings</PageTitle>
@using Microsoft.Extensions.Configuration
@using Microsoft.Extensions.DependencyInjection
@using System.IO
@using System.Text.Json
@using Microsoft.Data.SqlClient
@using Microsoft.JSInterop
@using SQLTriage.Data
@using SQLTriage.Data.Models
@using SQLTriage.Data.Services
@inject IDbConnectionFactory ConnectionFactory
@inject SqlServerConnectionFactory SqlServerConnectionFactory
@inject IConfiguration Configuration
@inject IJSRuntime JS
@inject UserSettingsService UserSettings
@inject DashboardConfigService DashboardConfig
@inject MemoryMonitorService MemoryMonitor
@inject ConfigurationValidator ConfigValidator
@inject AutoUpdateService UpdateService
@inject AzureBlobExportService BlobExport
@inject SQLTriage.Data.ToastService Toast
@inject SQLTriage.Data.Services.AppUserState UserState
@inject SQLTriage.Data.Services.RbacService RbacService
@inject SQLTriage.Data.ServerConnectionManager ConnectionManager
@inject SQLTriage.Data.Services.CacheMetricsService CacheMetrics
@inject SQLTriage.Data.Scheduling.IQueryOrchestrator QueryOrchestrator
@inject AuditLogService AuditLog
@inject SQLTriage.Data.Services.UptimeTrackerService UptimeTracker
@inject SQLTriage.Data.Services.ConfigBaselineService ConfigBaselineSvc

@if (!RbacService.IsAuthorized(UserState.Role, "settings"))
{
    <div style="padding: 32px;">
        <AccessDenied RequiredRole="Admin" Message="Settings are restricted to Admin users." />
    </div>
    return;
}

