    <h2>Settings</h2>

    <div class="settings-layout">
        <nav class="settings-rail" aria-label="Settings sections">
            <div class="settings-rail-group">
                <div class="settings-rail-heading">General</div>
                <a href="#set-reporting">Reporting</a>
                <a href="#set-refresh">Refresh</a>
                <a href="#set-configuration">Configuration</a>
                <a href="#set-updates">Updates</a>
                <a href="#set-modes">Modes</a>
                <a href="#set-appearance">Appearance</a>
            </div>
            <div class="settings-rail-group">
                <div class="settings-rail-heading">Performance</div>
                <a href="#set-performance">Performance</a>
                <a href="#set-cache">Cache Management</a>
                <a href="#set-perf-diag">Performance Diagnostics</a>
                <a href="#set-orchestrator">Orchestrator Tuning</a>
                <a href="#set-alerts">Alert Baseline</a>
                <a href="#set-thresholds">Threshold Highlighting</a>
            </div>
            <div class="settings-rail-group">
                <div class="settings-rail-heading">Diagnostics</div>
                <a href="#set-quick-check">Quick Check</a>
                <a href="#set-diagnostics">Diagnostics</a>
                <a href="#set-query-plan">Query Plan Viewer</a>
                <a href="#set-default-dashboard">Default Dashboard</a>
            </div>
            <div class="settings-rail-group">
                <div class="settings-rail-heading">Security &amp; Access</div>
                <a href="#set-credentials">Server Credentials</a>
                <a href="#set-access-control">Access Control</a>
                <a href="#set-notifications">Notifications</a>
            </div>
            <div class="settings-rail-group">
                <div class="settings-rail-heading">Integrations</div>
                <a href="#set-azure-blob">Azure Blob Export</a>
                <a href="#set-auto-export">Auto-Export Reports</a>
                <a href="#set-preview">Preview Features</a>
            </div>
            <div class="settings-rail-group">
                <div class="settings-rail-heading">Compliance</div>
                <a href="#set-uptime">Uptime / Availability</a>
                <a href="#set-continuity">Continuity Posture</a>
                <a href="#set-config-baseline">Config Baseline</a>
                <a href="#set-hmac-rotation">Audit Key Rotation</a>
            </div>
        </nav>

        <div class="settings-content" style="display: flex; flex-direction: column; gap: 16px;">


