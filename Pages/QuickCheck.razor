<!--/* In the name of God, the Merciful, the Compassionate */-->
@page "/quickcheck"

@using SqlHealthAssessment.Data
@using SqlHealthAssessment.Data.Models
@using System.IO
@inject CheckRepositoryService CheckRepo
@inject CheckExecutionService CheckExecutor
@inject ServerConnectionManager ConnectionManager
@inject UserSettingsService UserSettings
@inject QuickCheckStateService State
@inject SqlHealthAssessment.Data.Services.PrintService PrintSvc
@inject SqlHealthAssessment.Data.Services.ReportPageConfigService ReportPageCfg
@inject SqlHealthAssessment.Data.ToastService Toast
@inject IJSRuntime JSRuntime
@implements IDisposable

<PdfExportModal @ref="_pdfModal"
    Title="Export Results to PDF"
    DefaultLandscape="false"
    DefaultBackgrounds="false"
    OnConfirm="OnPdfConfirmed" />

<SectionEditorModal IsVisible="_editingSection != null"
    Section="_editingSection"
    NativeKeys="_availableNativeKeys"
    AvailableFields="_qcFields"
    OnSave="HandleSectionSaved"
    OnCancel="() => _editingSection = null" />

<AddSectionModal IsVisible="_showAddSection"
    NativeKeys="_availableNativeKeys"
    OnAdd="HandleSectionAdded"
    OnCancel="() => _showAddSection = false" />

<div class="quickcheck-page">
    <EditPageToolbar EditMode="_editMode"
        PageTitle="Quick Check"
        HasUnsavedChanges="false"
        OnAddSection="() => _showAddSection = true"
        OnDone="() => _editMode = false"
        OnReset="ResetSections" />

    <div class="page-header">
        <div>
            <h2>Quick Check</h2>
            <p class="page-description">
                Run SQL health checks from sql-checks.json against configured servers.
            </p>
        </div>
        <div class="header-actions">
            <div class="header-stats">
                <span class="stat-pill">@EnabledChecksCount enabled checks</span>
                <span class="stat-pill">@EnabledServersCount enabled servers</span>
            </div>
            <button class="btn btn-sm btn-toggle-diag @(ShowDiagnosticPane ? "active" : "")"
                    @onclick="ToggleDiagnosticPane" title="Toggle diagnostic output">
                Diagnostics @(ShowDiagnosticPane ? "ON" : "OFF")
            </button>
            <button class="btn-edit-page @(_editMode ? "btn-edit-page--active" : "")"
                    @onclick="() => _editMode = !_editMode" title="Edit page layout">
                <i class="fa-solid fa-pen-to-square"></i> Edit Page
            </button>
        </div>
    </div>

    <div class="qc-layout @(ShowDiagnosticPane ? "with-diag" : "")">
        <!-- Main Content -->
        <div class="qc-main">
            <!-- Server Selection -->
            <ReportSectionWrapper Section="@GetSection("server-selection")" EditMode="_editMode"
                IsFirst="@IsFirstSection("server-selection")" IsLast="@IsLastSection("server-selection")"
                OnMoveUp="s => MoveSection(s, -1)" OnMoveDown="s => MoveSection(s, 1)"
                OnEdit="s => _editingSection = s" OnDelete="s => DeleteSection(s)"
                OnToggle="s => ToggleSection(s)">
            <div class="server-selection">
                <div class="server-selection-header">
                    <label>Target Servers:</label>
                    <div class="server-scope-toggle">
                        <button class="scope-btn @(State.RunAllServers ? "active" : "")" @onclick="() => State.RunAllServers = true">
                            All Enabled Servers
                        </button>
                        <button class="scope-btn @(!State.RunAllServers ? "active" : "")" @onclick="() => State.RunAllServers = false">
                            Select Server
                        </button>
                    </div>
                </div>

                @if (!State.RunAllServers)
                {
                    <select @bind="State.SelectedConnectionId" @bind:after="OnServerSelected" class="server-select">
                        <option value="">-- Select a server connection --</option>
                        @foreach (var conn in Connections)
                        {
                            <option value="@conn.Id">
                                @conn.ServerNames (@conn.AuthenticationDisplay)
                                @(conn.Environment != null ? $"[{conn.Environment}]" : "")
                                @(!conn.IsEnabled ? " [DISABLED]" : "")
                            </option>
                        }
                    </select>
                }
                else
                {
                    <div class="all-servers-preview">
                        @if (EnabledConnections.Count == 0)
                        {
                            <span class="no-servers">No enabled server connections configured. Go to Servers page to add connections.</span>
                        }
                        else
                        {
                            @foreach (var conn in EnabledConnections)
                            {
                                @foreach (var server in conn.GetServerList())
                                {
                                    <span class="server-chip">@server</span>
                                }
                            }
                        }
                    </div>
                }

                <div class="action-row">
                    <button class="btn btn-primary btn-run" @onclick="RunChecks"
                            disabled="@(State.IsRunning || (!State.RunAllServers && string.IsNullOrEmpty(State.SelectedConnectionId)) || (State.RunAllServers && EnabledConnections.Count == 0))">
                        @if (State.IsRunning)
                        {
                            <span>Running...</span>
                        }
                        else
                        {
                            <span><i class="fa-solid fa-magnifying-glass"></i> Run Full Check</span>
                        }
                    </button>

                    @if (State.Results.Count > 0)
                    {
                        <button class="btn btn-secondary" @onclick="ClearResults">Clear Results</button>
                        <button class="btn btn-secondary" @onclick="PrintResults"><i class="fa-solid fa-file-pdf"></i> Export PDF</button>
                    }

                    <button class="btn btn-secondary" @onclick="ImportChecks" disabled="@State.IsImporting">
                        @if (State.IsImporting)
                        {
                            <span>Importing...</span>
                        }
                        else
                        {
                            <span><i class="fa-solid fa-download"></i> Import Checks</span>
                        }
                    </button>
                </div>
            </div>
            </ReportSectionWrapper>

            @if (State.IsRunning)
            {
                <div class="progress-section">
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: @State.Progress%"></div>
                    </div>
                    <span class="progress-text">
                        @State.ProgressMessage (@State.Progress%)
                    </span>
                </div>
            }

            @if (State.Results.Count > 0)
            {
                <ReportSectionWrapper Section="@GetSection("summary-cards")" EditMode="_editMode"
                    IsFirst="@IsFirstSection("summary-cards")" IsLast="@IsLastSection("summary-cards")"
                    OnMoveUp="s => MoveSection(s, -1)" OnMoveDown="s => MoveSection(s, 1)"
                    OnEdit="s => _editingSection = s" OnDelete="s => DeleteSection(s)"
                    OnToggle="s => ToggleSection(s)">
                <!-- Execution Info -->
                <div class="execution-info">
                    <span>Executed at @State.ExecutionTime.ToString("HH:mm:ss") | Duration: @State.ExecutionDuration</span>
                    <span>@State.ServersTested server(s) tested</span>
                </div>

                <!-- Per-Server Summary -->
                @if (State.ServerSummaries.Count > 0)
                {
                    <div class="server-summaries">
                        @foreach (var summary in State.ServerSummaries)
                        {
                            <div class="server-summary-card @(summary.Failed > 0 ? "has-failures" : summary.Errors > 0 ? "has-errors" : "all-passed")">
                                <div class="server-summary-name">@summary.InstanceName</div>
                                <div class="server-summary-stats">
                                    <span class="ss-passed" title="Passed">✅ @summary.Passed</span>
                                    <span class="ss-failed" title="Failed">❌ @summary.Failed</span>
                                    <span class="ss-errors" title="Errors">⚠️ @summary.Errors</span>
                                    <span class="ss-duration" title="Duration">@summary.Duration.TotalSeconds.ToString("F1")s</span>
                                </div>
                            </div>
                        }
                    </div>
                }

                <!-- Clickable Overall Summary Cards -->
                <div class="results-summary">
                    <div class="summary-card passed @(State.SelectedFilter == "passed" ? "active-filter" : "")"
                         @onclick='() => SetFilterFromCard("passed")'>
                        <span class="summary-icon">✅</span>
                        <span class="summary-count">@PassedCount</span>
                        <span class="summary-label">Passed</span>
                    </div>
                    <div class="summary-card failed @(State.SelectedFilter == "failed" ? "active-filter" : "")"
                         @onclick='() => SetFilterFromCard("failed")'>
                        <span class="summary-icon">❌</span>
                        <span class="summary-count">@FailedCount</span>
                        <span class="summary-label">Failed</span>
                    </div>
                    <div class="summary-card errors @(State.SelectedFilter == "errors" ? "active-filter" : "")"
                         @onclick='() => SetFilterFromCard("errors")'>
                        <span class="summary-icon">⚠️</span>
                        <span class="summary-count">@ErrorCount</span>
                        <span class="summary-label">Errors</span>
                    </div>
                    <div class="summary-card total @(State.SelectedFilter == "all" ? "active-filter" : "")"
                         @onclick='() => SetFilterFromCard("all")'>
                        <span class="summary-icon"><i class="fa-solid fa-clipboard-list"></i></span>
                        <span class="summary-count">@State.Results.Count</span>
                        <span class="summary-label">Total</span>
                    </div>
                </div>
                </ReportSectionWrapper>

                <ReportSectionWrapper Section="@GetSection("results-grid")" EditMode="_editMode"
                    IsFirst="@IsFirstSection("results-grid")" IsLast="@IsLastSection("results-grid")"
                    OnMoveUp="s => MoveSection(s, -1)" OnMoveDown="s => MoveSection(s, 1)"
                    OnEdit="s => _editingSection = s" OnDelete="s => DeleteSection(s)"
                    OnToggle="s => ToggleSection(s)">
                <!-- Results Filter -->
                <div class="results-filter">
                    <label>Status:</label>
                    <select @bind="State.SelectedFilter" class="filter-select">
                        <option value="all">All (@State.Results.Count)</option>
                        <option value="passed">Passed (@PassedCount)</option>
                        <option value="failed">Failed (@FailedCount)</option>
                        <option value="errors">Errors (@ErrorCount)</option>
                    </select>
                    <label>Severity:</label>
                    <select @bind="State.SelectedSeverity" class="filter-select">
                        <option value="">All Severities</option>
                        <option value="Critical">Critical</option>
                        <option value="Warning">Warning</option>
                        <option value="Info">Info</option>
                    </select>
                    <label>Category:</label>
                    <select @bind="State.SelectedCategory" class="filter-select">
                        <option value="">All Categories</option>
                        @foreach (var cat in State.Categories)
                        {
                            <option value="@cat">@cat</option>
                        }
                    </select>
                    <label>Server:</label>
                    <select @bind="State.SelectedServer" class="filter-select">
                        <option value="">All Servers</option>
                        @foreach (var srv in ServersInResults)
                        {
                            <option value="@srv">@srv</option>
                        }
                    </select>
                    <span class="filter-count">@FilteredResults.Count() results</span>
                </div>

                <!-- Results Grid -->
                <div class="results-grid">
                    <table class="results-table">
                        <thead>
                            <tr>
                                <th>Status</th>
                                <th>Server</th>
                                <th>Check</th>
                                <th>Category</th>
                                <th>Severity</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var result in FilteredResults)
                            {
                                <tr class="@GetRowClass(result)" @onclick="() => ToggleExpandResult(result.CheckId + result.InstanceName)">
                                    <td class="status-cell">
                                        @if (!string.IsNullOrEmpty(result.ErrorMessage))
                                        {
                                            <span class="status-badge error">⚠️ Error</span>
                                        }
                                        else if (result.Passed)
                                        {
                                            <span class="status-badge passed">✅ Pass</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge failed">❌ Fail</span>
                                        }
                                    </td>
                                    <td class="server-cell">@result.InstanceName</td>
                                    <td class="check-name">
                                        <strong>@result.CheckName</strong>
                                        <br />
                                        <small class="check-id">@result.CheckId</small>
                                    </td>
                                    <td><span class="category-badge">@result.Category</span></td>
                                    <td>
                                        <span class="severity-badge @GetSeverityClass(result.Severity)">
                                            @result.Severity
                                        </span>
                                    </td>
                                    <td class="description-cell">@result.Description</td>
                                </tr>
                                @if (_expandedResults.Contains(result.CheckId + result.InstanceName) && !string.IsNullOrEmpty(result.RecommendedAction))
                                {
                                    <tr class="expanded-row">
                                        <td colspan="8">
                                            <div class="expanded-detail">
                                                @if (!string.IsNullOrEmpty(result.Description))
                                                {
                                                    <div class="detail-section">
                                                        <strong>Description:</strong> @result.Description
                                                    </div>
                                                }
                                                <div class="detail-section">
                                                    <strong>Recommended Action:</strong> @result.RecommendedAction
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                </ReportSectionWrapper>
            }
            else if (!State.IsRunning && State.HasRun)
            {
                <div class="no-checks">
                    <p>No checks were executed. Make sure sql-checks.json is loaded with enabled checks.</p>
                </div>
            }

            @if (!string.IsNullOrEmpty(State.StatusMessage))
            {
                <div class="status-message @State.StatusClass">
                    @State.StatusMessage
                </div>
            }
        </div>

        <!-- Diagnostic Output Pane -->
        @if (ShowDiagnosticPane)
        {
            <div class="qc-diag-pane">
                <div class="diag-header">
                    <span>Diagnostic Output</span>
                    <div class="diag-header-actions">
                        <button class="btn btn-sm" @onclick="() => State.ClearDiagLog()" title="Clear log">Clear</button>
                        <button class="btn btn-sm" @onclick="ToggleDiagnosticPane" title="Close pane">X</button>
                    </div>
                </div>
                <div class="diag-scroll" @ref="_diagScrollRef">
                    @foreach (var entry in State.DiagLog)
                    {
                        <div class="diag-entry @entry.Level">
                            <span class="diag-time">@entry.Timestamp.ToString("HH:mm:ss.fff")</span>
                            <span class="diag-msg">@entry.Message</span>
                        </div>
                    }
                    @if (State.DiagLog.Count == 0)
                    {
                        <div class="diag-empty">Run a check to see diagnostic output here.</div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    // Page-local UI only — not worth persisting across navigation
    private PdfExportModal   _pdfModal       = default!;
    private ElementReference _diagScrollRef;
    private HashSet<string>  _expandedResults = new();
    private bool             ShowDiagnosticPane;
    private bool             _disposed;

    // ── Report Page Editor ────────────────────────────────────────────────
    private bool              _editMode;
    private List<ReportSection> _sections          = new();
    private ReportSection?    _editingSection;
    private bool              _showAddSection;
    private ReportPageDefinition? _pageDef;

    private static readonly List<string> AllNativeKeys =
        new() { "server-selection", "summary-cards", "results-grid", "diagnostics" };

    private static readonly List<ReportFieldInfo> _qcFields = new()
    {
        new() { Name = "CheckId",          Type = "string",   Description = "Unique identifier for the check",                     IsKey = true  },
        new() { Name = "DisplayName",      Type = "string",   Description = "Human-readable check name",                          IsKey = false },
        new() { Name = "Category",         Type = "string",   Description = "Check category (e.g. Security, Performance)",         IsKey = false },
        new() { Name = "Severity",         Type = "string",   Description = "Finding severity: Critical, Warning, Info, Pass",     IsKey = false },
        new() { Name = "Result",           Type = "string",   Description = "Raw result value or finding text",                    IsKey = false },
        new() { Name = "Details",          Type = "string",   Description = "Extended description or recommendation",              IsKey = false },
        new() { Name = "ServerName",       Type = "string",   Description = "SQL Server instance that produced this result",       IsKey = true  },
        new() { Name = "RunDateUtc",       Type = "datetime", Description = "UTC timestamp when the check was executed",           IsKey = false },
        new() { Name = "IsPass",           Type = "bit",      Description = "1 if the check passed, 0 if it raised a finding",     IsKey = false },
        new() { Name = "ImplementationType", Type = "string", Description = "How the fix should be applied (e.g. Script, Config)", IsKey = false },
        new() { Name = "SqlQuery",         Type = "string",   Description = "Suggested remediation SQL, if available",             IsKey = false },
    };

    private List<string> _availableNativeKeys =>
        AllNativeKeys.Where(k => !_sections.Any(s => s.NativeKey == k && s.SectionType == "native")).ToList();

    private ReportSection GetSection(string nativeKey)
    {
        var s = _sections.FirstOrDefault(x => x.NativeKey == nativeKey && x.SectionType == "native");
        return s ?? new ReportSection { NativeKey = nativeKey, Title = nativeKey, SectionType = "native", Enabled = true };
    }

    private bool IsFirstSection(string nativeKey)
    {
        var ordered = _sections.OrderBy(s => s.Order).ToList();
        var idx = ordered.FindIndex(s => s.NativeKey == nativeKey && s.SectionType == "native");
        return idx <= 0;
    }

    private bool IsLastSection(string nativeKey)
    {
        var ordered = _sections.OrderBy(s => s.Order).ToList();
        var idx = ordered.FindIndex(s => s.NativeKey == nativeKey && s.SectionType == "native");
        return idx < 0 || idx == ordered.Count - 1;
    }

    private void LoadSections()
    {
        _pageDef = ReportPageCfg.GetPage("/quickcheck");
        _sections = _pageDef != null
            ? _pageDef.Sections.OrderBy(s => s.Order).ToList()
            : AllNativeKeys.Select((k, i) => new ReportSection { NativeKey = k, Title = k, SectionType = "native", Order = i, Enabled = true }).ToList();
    }

    private void MoveSection(ReportSection section, int direction)
    {
        if (_pageDef == null) return;
        ReportPageCfg.MoveSection(_pageDef.Id, section.Id, direction);
        LoadSections();
        StateHasChanged();
    }

    private void DeleteSection(ReportSection section)
    {
        if (_pageDef == null) return;
        ReportPageCfg.DeleteSection(_pageDef.Id, section.Id);
        LoadSections();
        StateHasChanged();
    }

    private void ToggleSection(ReportSection section)
    {
        if (_pageDef == null) return;
        section.Enabled = !section.Enabled;
        ReportPageCfg.UpsertSection(_pageDef.Id, section);
        LoadSections();
        StateHasChanged();
    }

    private void HandleSectionSaved(ReportSection section)
    {
        if (_pageDef == null) return;
        ReportPageCfg.UpsertSection(_pageDef.Id, section);
        LoadSections();
        _editingSection = null;
        StateHasChanged();
    }

    private void HandleSectionAdded(ReportSection section)
    {
        if (_pageDef == null) return;
        section.Order = _sections.Count;
        ReportPageCfg.UpsertSection(_pageDef.Id, section);
        LoadSections();
        _showAddSection = false;
        StateHasChanged();
    }

    private void ResetSections()
    {
        // Remove all sections and let the service regenerate defaults
        if (_pageDef == null) return;
        foreach (var s in _sections.ToList())
            ReportPageCfg.DeleteSection(_pageDef.Id, s.Id);
        // Re-seed native keys
        int i = 0;
        foreach (var key in AllNativeKeys)
            ReportPageCfg.UpsertSection(_pageDef.Id, new ReportSection
            {
                Id = Guid.NewGuid().ToString("N")[..8],
                Title = key, NativeKey = key, SectionType = "native", Enabled = true, Order = i++
            });
        LoadSections();
        StateHasChanged();
    }

    private List<ServerConnection> Connections => ConnectionManager.GetConnections();
    private List<ServerConnection> EnabledConnections => ConnectionManager.GetEnabledConnections();
    private int EnabledChecksCount => CheckRepo.GetEnabledChecks().Count;
    private int EnabledServersCount => EnabledConnections.SelectMany(c => c.GetServerList()).Count();

    private int PassedCount => State.Results.Count(r => r.Passed && string.IsNullOrEmpty(r.ErrorMessage));
    private int FailedCount => State.Results.Count(r => !r.Passed && string.IsNullOrEmpty(r.ErrorMessage));
    private int ErrorCount  => State.Results.Count(r => !string.IsNullOrEmpty(r.ErrorMessage));

    private List<string> ServersInResults =>
        State.Results.Select(r => r.InstanceName).Distinct().OrderBy(s => s).ToList();

    private IEnumerable<CheckResult> FilteredResults
    {
        get
        {
            var filtered = State.Results.AsEnumerable();

            filtered = State.SelectedFilter switch
            {
                "passed" => filtered.Where(r => r.Passed && string.IsNullOrEmpty(r.ErrorMessage)),
                "failed" => filtered.Where(r => !r.Passed && string.IsNullOrEmpty(r.ErrorMessage)),
                "errors" => filtered.Where(r => !string.IsNullOrEmpty(r.ErrorMessage)),
                _        => filtered
            };

            if (!string.IsNullOrEmpty(State.SelectedCategory))
                filtered = filtered.Where(r => r.Category.Equals(State.SelectedCategory, StringComparison.OrdinalIgnoreCase));

            if (!string.IsNullOrEmpty(State.SelectedServer))
                filtered = filtered.Where(r => r.InstanceName.Equals(State.SelectedServer, StringComparison.OrdinalIgnoreCase));

            if (!string.IsNullOrEmpty(State.SelectedSeverity))
                filtered = filtered.Where(r => r.Severity.Equals(State.SelectedSeverity, StringComparison.OrdinalIgnoreCase));

            return filtered;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        LoadSections();
        ShowDiagnosticPane = UserSettings.GetShowDiagnosticPane();
        await CheckRepo.LoadChecksAsync();

        // Re-attach to state change notifications each time the page mounts
        State.StateChanged += OnStateChanged;

        // Ensure categories are populated (may have been loaded on a prior visit)
        if (State.Categories.Count == 0)
            State.Categories = CheckRepo.GetEnabledChecks()
                .Select(c => c.Category).Distinct().OrderBy(c => c).ToList();
    }

    public void Dispose()
    {
        _disposed = true;
        State.StateChanged -= OnStateChanged;
    }

    private void OnStateChanged()
    {
        if (!_disposed)
            InvokeAsync(StateHasChanged);
    }

    private void OnServerSelected() => StateHasChanged();

    private void SetFilterFromCard(string filter)
    {
        State.SelectedFilter = State.SelectedFilter == filter ? "all" : filter;
        StateHasChanged();
    }

    private void ToggleDiagnosticPane()
    {
        ShowDiagnosticPane = !ShowDiagnosticPane;
        UserSettings.SetShowDiagnosticPane(ShowDiagnosticPane);
    }

    private async Task AutoExportQuickCheckResults()
    {
        var settings = UserSettings.GetSettings();
        if (!settings.AutoExportQuickCheckCsv && !settings.AutoExportQuickCheckPdf) return;
        if (State.Results.Count == 0) return;

        var outputDir = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "output");
        Directory.CreateDirectory(outputDir);
        var timestamp = DateTime.Now.ToString("yyyyMMdd_HHmmss");

        if (settings.AutoExportQuickCheckCsv)
        {
            try
            {
                var csv = new System.Text.StringBuilder();
                csv.AppendLine("Instance,CheckId,CheckName,Category,Severity,Passed,ActualValue,ExpectedValue,Message,DurationMs,ExecutedAt");
                foreach (var r in State.Results)
                {
                    var msg = (r.Message ?? "").Replace("\"", "\"\"");
                    csv.AppendLine($"\"{r.InstanceName}\",\"{r.CheckId}\",\"{r.CheckName}\",\"{r.Category}\",\"{r.Severity}\",{r.Passed},{r.ActualValue},{r.ExpectedValue},\"{msg}\",{r.DurationMs},\"{r.ExecutedAt:o}\"");
                }
                var fileName = $"QuickCheck_{timestamp}.csv";
                await File.WriteAllTextAsync(Path.Combine(outputDir, fileName), csv.ToString());
                Toast.ShowInfo($"Quick Check CSV exported: {fileName}");
            }
            catch (Exception ex)
            {
                Toast.ShowError($"CSV export failed: {ex.Message}");
            }
        }

        if (settings.AutoExportQuickCheckPdf)
        {
            try
            {
                await Task.Delay(500); // let UI render final state
                if (!PrintSvc.IsAvailable)
                {
                    await PrintSvc.PrintViaBrowserAsync(JSRuntime);
                    Toast.ShowInfo("Browser print dialog opened for PDF export.");
                }
                else
                {
                    var fileName = $"QuickCheck_{timestamp}.pdf";
                    var (success, path, error) = await PrintSvc.PrintToPdfAsync(
                        fileName,
                        printBackgrounds: false,
                        orientation: Microsoft.Web.WebView2.Core.CoreWebView2PrintOrientation.Portrait);
                    if (success)
                        Toast.ShowInfo($"Quick Check PDF exported: {fileName}");
                }
            }
            catch (Exception ex)
            {
                Toast.ShowError($"PDF export failed: {ex.Message}");
            }
        }
    }

    private void PrintResults()
    {
        var stem = $"QuickCheck_{DateTime.Now:yyyyMMdd_HHmmss}";
        _pdfModal.Show(stem);
    }

    private async Task OnPdfConfirmed(PdfExportSettings settings)
    {
        await Task.Delay(350);
        try
        {
            if (!PrintSvc.IsAvailable)
            {
                // Server mode — use browser's native print dialog
                await PrintSvc.PrintViaBrowserAsync(JSRuntime);
                Toast.ShowInfo("Browser print dialog opened — use 'Save as PDF' to export.");
                return;
            }

            var orientation = settings.LandscapeOrientation
                ? Microsoft.Web.WebView2.Core.CoreWebView2PrintOrientation.Landscape
                : Microsoft.Web.WebView2.Core.CoreWebView2PrintOrientation.Portrait;
            var (success, path, error) = await PrintSvc.PrintToPdfAsync(
                settings.FileName,
                printBackgrounds: settings.PrintBackgrounds,
                orientation: orientation);
            if (success && path != null)
                Toast.ShowSuccess($"PDF saved: {System.IO.Path.GetFileName(path)}");
            else
                Toast.ShowError($"PDF export failed: {error ?? "WebView not ready."}");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"PDF export error: {ex.Message}");
        }
    }

    private void ClearResults()
    {
        State.ClearResults();
        _expandedResults.Clear();
        StateHasChanged();
    }

    private void ToggleExpandResult(string key)
    {
        if (!_expandedResults.Remove(key))
            _expandedResults.Add(key);
    }

    private async Task RunChecks()
    {
        CheckExecutor.ClearAllResults();
        State.IsRunning       = true;
        State.Progress        = 0;
        State.ProgressMessage = "Starting...";
        State.Results.Clear();
        State.ServerSummaries.Clear();
        State.ExecutionTime   = DateTime.Now;
        State.ServersTested   = 0;
        State.NotifyStateChanged();

        var overallStart = DateTime.UtcNow;
        State.AddDiagEntry("=== Quick Check started ===", "info");

        try
        {
            var targets = new List<(ServerConnection Connection, string Server)>();

            if (State.RunAllServers)
            {
                foreach (var conn in EnabledConnections)
                    foreach (var server in conn.GetServerList())
                        targets.Add((conn, server));
            }
            else
            {
                var connection = ConnectionManager.GetConnection(State.SelectedConnectionId);
                if (connection == null)
                {
                    State.StatusMessage = "Connection not found.";
                    State.StatusClass   = "error";
                    State.AddDiagEntry("ERROR: Connection not found", "error");
                    return;
                }
                foreach (var server in connection.GetServerList())
                    targets.Add((connection, server));
            }

            if (targets.Count == 0)
            {
                State.StatusMessage = "No servers to check.";
                State.StatusClass   = "error";
                State.AddDiagEntry("ERROR: No servers to check", "error");
                return;
            }

            State.AddDiagEntry($"Targets: {targets.Count} server(s)", "info");

            Func<SqlCheck, bool> filter = c =>
                c.Severity.Equals("Critical", StringComparison.OrdinalIgnoreCase) ||
                c.Severity.Equals("Warning",  StringComparison.OrdinalIgnoreCase) ||
                c.Severity.Equals("Info",     StringComparison.OrdinalIgnoreCase);

            var checksToRun = CheckRepo.GetEnabledChecks().Where(filter).ToList();
            State.AddDiagEntry($"Checks to execute per server: {checksToRun.Count}", "info");

            foreach (var g in checksToRun.GroupBy(c => c.Category).OrderBy(g => g.Key))
                State.AddDiagEntry($"  Category '{g.Key}': {g.Count()} checks", "info");
            foreach (var g in checksToRun.GroupBy(c => c.Severity).OrderBy(g => g.Key))
                State.AddDiagEntry($"  Severity '{g.Key}': {g.Count()} checks", "info");
            foreach (var g in checksToRun.GroupBy(c => c.ExecutionType ?? "scalar").OrderBy(g => g.Key))
                State.AddDiagEntry($"  ExecutionType '{g.Key}': {g.Count()} checks", "info");

            var allResults    = new List<CheckResult>();
            int totalTargets  = targets.Count;
            int completedTargets = 0;

            foreach (var (conn, server) in targets)
            {
                State.ProgressMessage = $"Checking {server}...";
                State.AddDiagEntry($"--- Connecting to {server} ---", "info");
                State.NotifyStateChanged();

                try
                {
                    var summary = await CheckExecutor.ExecuteChecksAsync(conn, server, filter);
                    State.ServerSummaries.Add(summary);
                    State.AddDiagEntry($"--- {server} complete: {summary.Passed} pass, {summary.Failed} fail, {summary.Errors} err ({summary.Duration.TotalSeconds:F1}s) ---", "info");
                    Toast.ShowInfo($"Quick Check: {server} — {summary.Passed} pass, {summary.Failed} fail ({summary.Duration.TotalSeconds:F1}s)");
                    allResults.AddRange(CheckExecutor.GetResults(server, 1000));
                }
                catch (Exception ex)
                {
                    State.AddDiagEntry($"ERROR on {server}: {ex.Message}", "error");
                    State.ServerSummaries.Add(new CheckExecutionSummary
                    {
                        InstanceName  = server,
                        StartedAt     = DateTime.UtcNow,
                        CompletedAt   = DateTime.UtcNow,
                        Errors        = CheckRepo.GetEnabledChecks().Count
                    });
                }

                completedTargets++;
                State.Progress      = (int)((double)completedTargets / totalTargets * 100);
                State.ServersTested = completedTargets;
                State.NotifyStateChanged();
            }

            State.Results = allResults;
            State.HasRun  = true;

            var totalDuration     = DateTime.UtcNow - overallStart;
            State.ExecutionDuration = $"{totalDuration.TotalSeconds:F1}s";
            State.Categories = State.Results.Select(r => r.Category).Distinct().OrderBy(c => c).ToList();

            if (State.Results.Count > 0)
            {
                State.StatusMessage = $"Quick check completed: {PassedCount} passed, {FailedCount} failed, {ErrorCount} errors across {State.ServersTested} server(s)";
                State.StatusClass   = FailedCount > 0 || ErrorCount > 0 ? "warning" : "success";
            }
            else
            {
                State.StatusMessage = "No checks were executed. Make sure checks are enabled in sql-checks.json";
                State.StatusClass   = "warning";
            }

            State.AddDiagEntry($"=== Complete: {State.Results.Count} total results in {State.ExecutionDuration} ===", "info");

            await AutoExportQuickCheckResults();
        }
        catch (Exception ex)
        {
            State.StatusMessage = $"Error running checks: {ex.Message}";
            State.StatusClass   = "error";
            State.AddDiagEntry($"FATAL ERROR: {ex.Message}", "error");
            System.Diagnostics.Debug.WriteLine($"[QuickCheck] Error: {ex}");
        }
        finally
        {
            State.IsRunning       = false;
            State.Progress        = 100;
            State.ProgressMessage = "Complete";
            State.NotifyStateChanged();
        }
    }

    private async Task ImportChecks()
    {
        State.IsImporting   = true;
        State.StatusMessage = string.Empty;
        State.NotifyStateChanged();

        try
        {
            var searchPaths = new[]
            {
                Path.Combine(AppContext.BaseDirectory, "..", "SQLMonitoring"),
                Path.Combine(AppContext.BaseDirectory, "SQLMonitoring"),
                AppContext.BaseDirectory
            };

            string? importFile = null;
            foreach (var searchPath in searchPaths)
            {
                if (Directory.Exists(searchPath))
                {
                    var jsonFiles = Directory.GetFiles(searchPath, "sql-checks*.json")
                        .OrderByDescending(f => f).FirstOrDefault();
                    if (jsonFiles != null) { importFile = jsonFiles; break; }
                }
            }

            if (importFile == null)
            {
                State.StatusMessage = "No import file found. Place a sql-checks-export*.json file in the SQLMonitoring folder.";
                State.StatusClass   = "warning";
                State.AddDiagEntry("Import: no import file found", "error");
                return;
            }

            State.AddDiagEntry($"Importing from {Path.GetFileName(importFile)}...", "info");
            var (added, updated, skipped) = await CheckRepo.ImportChecksFromFileAsync(importFile);

            State.StatusMessage = $"Import complete from {Path.GetFileName(importFile)}: {added} added, {updated} updated, {skipped} skipped";
            State.StatusClass   = "success";
            State.AddDiagEntry($"Import done: {added} added, {updated} updated, {skipped} skipped", "pass");

            State.Categories = CheckRepo.GetEnabledChecks()
                .Select(c => c.Category).Distinct().OrderBy(c => c).ToList();
        }
        catch (Exception ex)
        {
            State.StatusMessage = $"Import error: {ex.Message}";
            State.StatusClass   = "error";
            State.AddDiagEntry($"Import ERROR: {ex.Message}", "error");
        }
        finally
        {
            State.IsImporting = false;
            State.NotifyStateChanged();
        }
    }

    private string GetRowClass(CheckResult result)
    {
        if (!string.IsNullOrEmpty(result.ErrorMessage)) return "row-error";
        return result.Passed ? "row-passed" : "row-failed";
    }

    private string GetSeverityClass(string severity) =>
        severity?.ToLower() switch
        {
            "critical" => "severity-critical",
            "warning"  => "severity-warning",
            "info"     => "severity-info",
            _          => "severity-default"
        };
}
