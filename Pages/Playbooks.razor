<!--/* In the name of God, the Merciful, the Compassionate */-->
@page "/playbooks"

@using System.IO
@using System.Text.Json
@using SQLTriage.Data.Models
@inject ServerConnectionManager ConnectionManager
@inject ToastService Toast
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="playbooks-page page-fade-in">
    <div class="playbooks-header">
        <h2><i class="fa-solid fa-book-medical"></i> Remediation Playbooks</h2>
        <p class="playbooks-subtitle">Actionable guidance for every finding</p>
    </div>

    @if (_loading)
    {
        <PageLoadingSpinner Message="Loading playbooks..." />
    }
    else if (_allChecks.Count == 0)
    {
        <div class="playbooks-empty">
            <i class="fa-solid fa-book-medical"></i>
            <p>No playbooks available</p>
            <span class="playbooks-empty-hint">The sql-checks.json file could not be loaded or contains no entries.</span>
        </div>
    }
    else
    {
        <div class="playbooks-filter-bar">
            <label for="pb-category">Category</label>
            <select id="pb-category" @bind="_selectedCategory" @bind:after="ApplyFilters">
                <option value="">All</option>
                @foreach (var cat in _categories)
                {
                    <option value="@cat">@cat</option>
                }
            </select>

            <label for="pb-severity">Severity</label>
            <select id="pb-severity" @bind="_selectedSeverity" @bind:after="ApplyFilters">
                <option value="">All</option>
                @foreach (var sev in _severities)
                {
                    <option value="@sev">@sev</option>
                }
            </select>

            <input type="text" placeholder="Search by name or description..."
                   @bind="_searchText" @bind:after="ApplyFilters" />

            <label class="pb-top-actions-toggle" title="Show only the consolidated top-action findings.">
                <input type="checkbox" @bind="_topActionsOnly" @bind:after="ApplyFilters" />
                <i class="fa-solid fa-star"></i> Top Actions only
            </label>

            <span class="playbooks-count">@_filteredChecks.Count of @_allChecks.Count playbooks</span>
        </div>

        <div class="playbooks-scroll">
            @if (_filteredChecks.Count == 0)
            {
                <div class="playbooks-empty">
                    <i class="fa-solid fa-filter-circle-xmark"></i>
                    <p>No playbooks match your filters</p>
                    <span class="playbooks-empty-hint">Try broadening your search or resetting the filters.</span>
                </div>
            }
            else
            {
                <div class="playbooks-grid">
                    @foreach (var check in _filteredChecks)
                    {
                        var isExpanded = _expandedId == check.Id;
                        <div class="playbook-card @(isExpanded ? "expanded" : "")"
                             @onclick="() => ToggleExpand(check.Id)">
                            <div class="playbook-card-header">
                                <div class="playbook-card-title">
                                    <h3>@check.Name</h3>
                                    <div class="playbook-badges">
                                        <span class="badge badge-severity-@check.Severity.ToLowerInvariant()">@check.Severity</span>
                                        <span class="badge badge-category">@check.Category</span>
                                        @if (check.IncludeInMainActions == true)
                                        {
                                            <span class="badge badge-top-action" title="Top action in the consolidated narrative — surfaces in monthly reports.">
                                                <i class="fa-solid fa-star"></i> Top Action
                                            </span>
                                        }
                                    </div>
                                </div>
                                <span class="playbook-card-expand">
                                    <i class="fa-solid fa-chevron-down"></i>
                                </span>
                            </div>

                            <div class="playbook-description @(isExpanded ? "" : "truncated")">
                                @check.Description
                            </div>

                            @if (!isExpanded && check.FrameworkMappings?.Count > 0)
                            {
                                <div class="playbook-mappings">
                                    @foreach (var m in check.FrameworkMappings.Take(4))
                                    {
                                        <span class="mapping-pill">
                                            <span class="mapping-framework">@ShortFramework(m.Framework)</span>
                                            <span class="mapping-id">@m.ControlId</span>
                                        </span>
                                    }
                                    @if (check.FrameworkMappings.Count > 4)
                                    {
                                        <span class="mapping-pill">+@(check.FrameworkMappings.Count - 4) more</span>
                                    }
                                </div>
                            }

                            @if (isExpanded)
                            {
                                <div class="playbook-detail" @onclick:stopPropagation>
                                    @if (!string.IsNullOrWhiteSpace(check.FullStoryAction) || !string.IsNullOrWhiteSpace(check.NextAction))
                                    {
                                        <div class="playbook-detail-section playbook-detail-story">
                                            <h4><i class="fa-solid fa-book-open"></i> Story</h4>
                                            @if (!string.IsNullOrWhiteSpace(check.FullStoryAction))
                                            {
                                                <p class="playbook-story-body">@check.FullStoryAction</p>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(check.NextAction))
                                            {
                                                <p class="playbook-next-action">
                                                    <strong>Next action:</strong> @check.NextAction
                                                </p>
                                            }
                                        </div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(check.RecommendedAction))
                                    {
                                        <div class="playbook-detail-section">
                                            <h4><i class="fa-solid fa-wrench"></i> Remediation Steps</h4>
                                            <pre>@check.RecommendedAction</pre>
                                        </div>
                                    }

                                    @if (check.FrameworkMappings?.Count > 0)
                                    {
                                        <div class="playbook-detail-section">
                                            <h4><i class="fa-solid fa-shield-halved"></i> Framework Mappings</h4>
                                            <table class="playbook-mapping-table">
                                                <thead>
                                                    <tr>
                                                        <th>Framework</th>
                                                        <th>Control ID</th>
                                                        <th>Control Name</th>
                                                        <th>Type</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var m in check.FrameworkMappings)
                                                    {
                                                        <tr>
                                                            <td>@m.Framework</td>
                                                            <td>@m.ControlId</td>
                                                            <td>@m.ControlName</td>
                                                            <td>
                                                                <span class="mapping-type-badge @(m.MappingType ?? "")">
                                                                    @(m.MappingType ?? "n/a")
                                                                </span>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(check.ExpectedResult))
                                    {
                                        <div class="playbook-detail-section">
                                            <h4><i class="fa-solid fa-circle-check"></i> What to Expect</h4>
                                            <p>@check.ExpectedResult</p>
                                        </div>
                                    }

                                    <div class="playbook-actions">
                                        <button class="btn-run-check" @onclick="() => NavigateToQuickCheck(check.Id)" @onclick:stopPropagation>
                                            <i class="fa-solid fa-bolt-lightning"></i> Run Check
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private List<PlaybookCheck> _allChecks = new();
    private List<PlaybookCheck> _filteredChecks = new();
    private List<string> _categories = new();
    private List<string> _severities = new();

    private string _selectedCategory = "";
    private string _selectedSeverity = "";
    private string _searchText = "";
    private bool _topActionsOnly = false;
    private string? _expandedId;

    private static readonly JsonSerializerOptions JsonOpts = new()
    {
        PropertyNameCaseInsensitive = true
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var filePath = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Config", "sql-checks.json");
            if (!File.Exists(filePath))
            {
                Toast.ShowWarning("Playbooks", "sql-checks.json not found.");
                _loading = false;
                return;
            }

            var json = await File.ReadAllTextAsync(filePath);
            var all = JsonSerializer.Deserialize<List<PlaybookCheck>>(json, JsonOpts) ?? new();
            _allChecks = all.Where(c => c.Enabled).ToList();

            _categories = _allChecks
                .Select(c => c.Category)
                .Where(c => !string.IsNullOrWhiteSpace(c))
                .Distinct()
                .OrderBy(c => c)
                .ToList();

            _severities = _allChecks
                .Select(c => c.Severity)
                .Where(s => !string.IsNullOrWhiteSpace(s))
                .Distinct()
                .OrderBy(s => SeverityOrder(s))
                .ToList();

            ApplyFilters();
        }
        catch (Exception ex)
        {
            Toast.ShowError("Playbooks", $"Failed to load playbooks: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private void ApplyFilters()
    {
        _filteredChecks = _allChecks.Where(c =>
        {
            if (!string.IsNullOrEmpty(_selectedCategory) &&
                !string.Equals(c.Category, _selectedCategory, StringComparison.OrdinalIgnoreCase))
                return false;

            if (!string.IsNullOrEmpty(_selectedSeverity) &&
                !string.Equals(c.Severity, _selectedSeverity, StringComparison.OrdinalIgnoreCase))
                return false;

            if (!string.IsNullOrWhiteSpace(_searchText))
            {
                var search = _searchText.Trim();
                var nameMatch = c.Name?.Contains(search, StringComparison.OrdinalIgnoreCase) == true;
                var descMatch = c.Description?.Contains(search, StringComparison.OrdinalIgnoreCase) == true;
                if (!nameMatch && !descMatch)
                    return false;
            }

            if (_topActionsOnly && c.IncludeInMainActions != true)
                return false;

            return true;
        }).ToList();

        _expandedId = null;
    }

    private void ToggleExpand(string id)
    {
        _expandedId = _expandedId == id ? null : id;
    }

    private void NavigateToQuickCheck(string checkId)
    {
        Navigation.NavigateTo($"/quickcheck?checkId={checkId}");
    }

    private static string ShortFramework(string framework)
    {
        if (string.IsNullOrWhiteSpace(framework)) return "";
        if (framework.StartsWith("NIST", StringComparison.OrdinalIgnoreCase)) return "NIST";
        if (framework.StartsWith("CIS", StringComparison.OrdinalIgnoreCase)) return "CIS";
        if (framework.StartsWith("SOC", StringComparison.OrdinalIgnoreCase)) return "SOC2";
        if (framework.StartsWith("ISO", StringComparison.OrdinalIgnoreCase)) return "ISO";
        if (framework.StartsWith("PCI", StringComparison.OrdinalIgnoreCase)) return "PCI";
        if (framework.StartsWith("HIPAA", StringComparison.OrdinalIgnoreCase)) return "HIPAA";
        var parts = framework.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length > 0 ? parts[0] : framework;
    }

    private static int SeverityOrder(string severity) => severity.ToLowerInvariant() switch
    {
        "critical" => 0,
        "high" => 1,
        "medium" => 2,
        "warning" => 3,
        "low" => 4,
        _ => 5
    };
}
