{
  "_comment": "SQLTriage governance scoring weights. Reloadable at runtime via IOptionsMonitor. Edit via Settings page or this file directly.",
  "_rationale": "Compliance raised to 20% (not 5%) because tagline is audit-prep. Security is primary; Performance/Reliability equal secondary; Cost is tertiary.",

  "categories": {
    "Security":    0.25,
    "Performance": 0.20,
    "Reliability": 0.20,
    "Cost":        0.15,
    "Compliance":  0.20
  },

  "caps": {
    "_comment": "Three-level clamp. perFinding prevents one critical from dominating; perCategory enforces category weight ceiling; overall = 100.",
    "perFinding":  40,
    "perCategory": 100,
    "overall":     100
  },

  "bands": {
    "Emerging": [ 0, 20],
    "Bronze":   [21, 40],
    "Silver":   [41, 60],
    "Gold":     [61, 80],
    "Platinum": [81,100]
  },

  "categoryMapping": {
    "_comment": "Maps check categories → 5 governance dimensions. Unmapped defaults to Reliability.",
    "Security":           "Security",
    "Authentication":     "Security",
    "Authorization":      "Security",
    "Encryption":         "Security",
    "Surface_Area":       "Security",
    "Auditing":           "Compliance",
    "Compliance":         "Compliance",
    "Data_Protection":    "Compliance",
    "Patching":           "Compliance",
    "Maintenance":        "Compliance",
    "Maintenance Monitoring checks": "Compliance",
    "Monitoring":         "Compliance",
    "Configuration":      "Reliability",
    "DefaultRuleset":     "Reliability",
    "Backup":             "Reliability",
    "Indexes":            "Performance",
    "Performance":        "Performance",
    "Memory":             "Performance",
    "Network":            "Performance",
    "Availability":       "Reliability",
    "Reliability":        "Reliability",
    "Cost":               "Cost",
    "Custom":             "Reliability"
  },

  "schemaVersion": 1
}
