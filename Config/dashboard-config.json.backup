          "query": {
            "source": "sqlwatch",
            "sqlServer": "SELECT SUM(CONVERT(BIGINT,CASE WHEN wait_type IN('LCK_M_RS_S', 'LCK_M_RS_U', 'LCK_M_RIn_NL','LCK_M_RIn_S', 'LCK_M_RIn_U','LCK_M_RIn_X', 'LCK_M_RX_S', 'LCK_M_RX_U','LCK_M_RX_X') THEN wait_time_ms-signal_wait_time_ms ELSE 0 END)) AS [Value] FROM sys.dm_os_wait_stats WITH(NOLOCK)",
