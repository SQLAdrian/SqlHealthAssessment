          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SELECT SUM(CONVERT(BIGINT,CASE WHEN wait_type IN('IO_QUEUE_LIMIT', 'IO_RETRY', 'LOG_RATE_GOVERNOR', 'POOL_LOG_RATE_GOVERNOR', 'RESMGR_THROTTLED', 'RESOURCE_SEMAPHORE', 'THREADPOOL') THEN wait_time_ms-signal_wait_time_ms ELSE 0 END)) AS [Value] FROM sys.dm_os_wait_stats WITH(NOLOCK)",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
