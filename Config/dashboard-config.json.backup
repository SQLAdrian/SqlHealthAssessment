          "description": null,
          "enabled": true,
          "source": "",
          "panelType": "DeltaStatCard",
          "chartType": "Line",
          "height": 120,
          "refreshIntervalSeconds": 5,
          "layout": {
            "column": 0,
            "order": 8,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SELECT SUM(CONVERT(BIGINT,CASE WHEN wait_type = 'CMEMTHREAD' THEN wait_time_ms-signal_wait_time_ms ELSE 0 END)) AS [Value] FROM sys.dm_os_wait_stats WITH(NOLOCK)",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
