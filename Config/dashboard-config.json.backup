          "query": {
            "source": "sqlwatch",
            "sqlServer": "SELECT\n    h.report_time AS [Time],\n    m.counter_name AS [Series],\n    CONVERT(MONEY,SUM(d.cntr_value_calculated)) AS [Value]\n    --, m.*\nFROM dbo.sqlwatch_logger_perf_os_performance_counters d WITH (NOLOCK)\nINNER JOIN dbo.sqlwatch_logger_snapshot_header h WITH (NOLOCK)\n    ON h.snapshot_time = d.snapshot_time\n    AND h.snapshot_type_id = d.snapshot_type_id\n    AND h.sql_instance = d.sql_instance\nINNER JOIN dbo.sqlwatch_meta_performance_counter m WITH (NOLOCK)\n    ON m.sql_instance = d.sql_instance\n    AND m.performance_counter_id = d.performance_counter_id\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\n    AND d.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\n    AND m.counter_name IN ('Batch Requests/Sec','Readahead pages/sec','Transactions/sec','Processes blocked')\n    AND m.cntr_type <> 1073939712\nGROUP BY h.report_time ,\n    m.counter_name ",
            "liveQueries": "\r\nSELECT\r\n    h.report_time AS [Time],\r\n    m.counter_name AS [Series],\r\n    d.cntr_value_calculated AS [Value]\r\nFROM sqlwatch_logger_perf_os_performance_counters d\r\nINNER JOIN sqlwatch_logger_snapshot_header h\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nINNER JOIN sqlwatch_meta_performance_counter m\r\n    ON m.sql_instance = d.sql_instance\r\n    AND m.performance_counter_id = d.performance_counter_id\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance = @SqlInstance\r\n    AND m.counter_name IN ('Batch Requests/Sec','Readahead pages/sec','Transactions/sec','Processes blocked')\r\n    AND m.cntr_type <> 1073939712\r\nORDER BY h.report_time"
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        }
      ]
    },
    {
      "id": "longqueries",
      "title": "Long Running Queries",
      "navTitle": "",
      "navIcon": "📊",
      "navCategory": "Dashboards",
      "navOrder": 0,
      "route": "/longqueries",
      "enabled": true,
      "source": "sqlwatch",
      "defaultDatabase": "master",
      "showAllOption": true,
      "panels": [
        {
          "id": "repo.long_queries",
          "title": "Long Running Queries",
          "description": null,
          "enabled": true,
          "source": "",
          "panelType": "TimeSeries",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 1,
            "order": 5,
            "spanColumns": true
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SELECT [Time]=event_time, [Series] = 'Long queries', [Value] = count(*)\nFROM [dbo].[vw_sqlwatch_report_fact_xes_long_queries]\nWHERE report_time BETWEEN @TimeFrom AND @TimeTo\n    AND sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\nGROUP BY event_time\nORDER BY  [Time] desc",
            "liveQueries": "\r\nSELECT\r\n    h.report_time AS [Time],\r\n    'Long Queries' AS [Series],\r\n    COUNT(*) AS [Value]\r\nFROM sqlwatch_logger_xes_long_queries d\r\nINNER JOIN sqlwatch_logger_snapshot_header h\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance = @SqlInstance\r\nGROUP BY h.report_time\r\nORDER BY h.report_time"
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
