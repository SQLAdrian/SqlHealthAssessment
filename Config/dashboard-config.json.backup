    {
      "id": "pquery",
      "title": "Query Performance",
      "navTitle": "",
      "navIcon": "📊",
      "navCategory": "Dashboards",
      "navOrder": 0,
      "route": "/pquery",
      "enabled": true,
      "source": "sqlwatch",
      "defaultDatabase": "PerformanceMonitor",
      "showAllOption": false,
      "panels": [
        {
          "id": "pquery.expensive_queries",
          "title": "Expensive Queries",
          "description": "Top queries by average worker time",
          "enabled": true,
          "source": "",
          "panelType": "DataGrid",
          "chartType": "Line",
          "height": 400,
          "refreshIntervalSeconds": 120,
          "layout": {
            "column": 1,
            "order": 0,
            "spanColumns": true
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED; SELECT TOP 20 source, database_name, object_name, execution_count, avg_worker_time_ms, avg_elapsed_time_ms, avg_logical_reads, query_text_sample FROM report.expensive_queries_today WHERE last_execution_time >= DATEADD(HOUR, -24, SYSDATETIME()) ORDER BY avg_worker_time_ms DESC",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": true,
          "dataGridMaxRows": 20,
          "dataGridTopRows": 0
        },
        {
          "id": "pquery.query_stats",
          "title": "Query Statistics",
          "description": "Aggregated query performance statistics",
          "enabled": true,
          "source": "",
          "panelType": "DataGrid",
          "chartType": "Line",
          "height": 400,
          "refreshIntervalSeconds": 180,
          "layout": {
            "column": 1,
            "order": 1,
            "spanColumns": true
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED; SELECT TOP 50 database_name, object_name, execution_count, avg_worker_time_ms, avg_elapsed_time_ms, avg_logical_reads, avg_physical_reads, first_execution_time, last_execution_time FROM (SELECT database_name, CASE object_type WHEN 'STATEMENT' THEN 'Adhoc' ELSE QUOTENAME(schema_name) + '.' + QUOTENAME(object_name) END AS object_name, SUM(execution_count) AS execution_count, SUM(total_worker_time) / 1000.0 / NULLIF(SUM(execution_count), 0) AS avg_worker_time_ms, SUM(total_elapsed_time) / 1000.0 / NULLIF(SUM(execution_count), 0) AS avg_elapsed_time_ms, SUM(total_logical_reads) / NULLIF(SUM(execution_count), 0) AS avg_logical_reads, SUM(total_physical_reads) / NULLIF(SUM(execution_count), 0) AS avg_physical_reads, MIN(creation_time) AS first_execution_time, MAX(last_execution_time) AS last_execution_time FROM collect.query_stats WHERE last_execution_time >= DATEADD(HOUR, -24, SYSDATETIME()) GROUP BY database_name, query_hash, object_type, schema_name, object_name) q ORDER BY avg_worker_time_ms DESC",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 50,
          "dataGridTopRows": 0
        },
        {
          "id": "pquery.blocking_events",
          "title": "Blocking Events",
          "description": "Recent blocking and deadlock events",
          "enabled": true,
          "source": "",
          "panelType": "DataGrid",
          "chartType": "Line",
          "height": 300,
          "refreshIntervalSeconds": 60,
          "layout": {
            "column": 1,
            "order": 2,
            "spanColumns": true
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED; SELECT TOP 50 collection_time, event_time, database_name, activity, spid, wait_time_ms, status, isolation_level, lock_mode, login_name, host_name, client_app FROM collect.blocking_BlockedProcessReport WHERE collection_time >= DATEADD(HOUR, -24, SYSDATETIME()) ORDER BY event_time DESC",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 50,
          "dataGridTopRows": 0
        },
        {
          "id": "pquery.execution_trends",
          "title": "Query Execution Trends",
          "description": "Query execution rate over time",
          "enabled": true,
          "source": "",
          "panelType": "TimeSeries",
          "chartType": "Line",
          "height": 300,
          "refreshIntervalSeconds": 300,
          "layout": {
            "column": 1,
            "order": 3,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED; WITH exec_deltas AS (SELECT qs.collection_time, total_execution_count = SUM(qs.execution_count_delta), interval_seconds = DATEDIFF(SECOND, LAG(qs.collection_time, 1, qs.collection_time) OVER (ORDER BY qs.collection_time), qs.collection_time) FROM collect.query_stats AS qs WHERE qs.collection_time >= DATEADD(HOUR, -24, SYSDATETIME()) GROUP BY qs.collection_time) SELECT ed.collection_time AS [Time], 'Executions/sec' AS [Series], CAST(ed.total_execution_count AS decimal(19, 4)) / ed.interval_seconds AS [Value] FROM exec_deltas AS ed WHERE ed.interval_seconds > 0 ORDER BY ed.collection_time",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        }
      ]
    },
    {
      "id": "pmemory_analysis",
      "title": "Memory Analysis",
      "navTitle": "",
      "navIcon": "📊",
      "navCategory": "Dashboards",
      "navOrder": 0,
      "route": "/pmemory-analysis",
      "enabled": true,
      "source": "sqlwatch",
      "defaultDatabase": "PerformanceMonitor",
      "showAllOption": false,
      "panels": [
        {
          "id": "pmemory.memory_stats",
          "title": "Memory Statistics",
          "description": "SQL Server memory usage over time",
          "enabled": true,
          "source": "",
          "panelType": "TimeSeries",
          "chartType": "Line",
          "height": 300,
          "refreshIntervalSeconds": 120,
          "layout": {
            "column": 1,
            "order": 0,
            "spanColumns": true
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED; SELECT ms.collection_time AS [Time], 'Buffer Pool MB' AS [Series], ms.buffer_pool_mb AS [Value] FROM collect.memory_stats AS ms WHERE ms.collection_time >= DATEADD(HOUR, -24, SYSDATETIME()) UNION ALL SELECT ms.collection_time, 'Plan Cache MB', ms.plan_cache_mb FROM collect.memory_stats AS ms WHERE ms.collection_time >= DATEADD(HOUR, -24, SYSDATETIME()) UNION ALL SELECT ms.collection_time, 'Other Memory MB', ms.other_memory_mb FROM collect.memory_stats AS ms WHERE ms.collection_time >= DATEADD(HOUR, -24, SYSDATETIME()) ORDER BY [Time]",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "MB",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "",
          "valueFormat": "N0",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "pmemory.memory_clerks",
          "title": "Memory Clerks",
          "description": "Top memory consumers by clerk type",
          "enabled": true,
          "source": "",
          "panelType": "DataGrid",
          "chartType": "Line",
          "height": 400,
          "refreshIntervalSeconds": 180,
          "layout": {
            "column": 1,
            "order": 1,
            "spanColumns": true
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED; SELECT TOP 20 mcs.collection_time, mcs.clerk_type, mcs.pages_kb / 1024 AS pages_mb, CASE WHEN mcs.clerk_type = 'MEMORYCLERK_SQLBUFFERPOOL' THEN 'Data and index pages cache (Buffer Pool)' WHEN mcs.clerk_type = 'MEMORYCLERK_SQLGENERAL' THEN 'Multiple consumers: replication, diagnostics, parser' WHEN mcs.clerk_type = 'MEMORYCLERK_SQLQUERYEXEC' THEN 'Batch mode, parallel query, sort and hash operations' WHEN mcs.clerk_type = 'CACHESTORE_SQLCP' THEN 'Ad hoc queries and prepared statements in plan cache' WHEN mcs.clerk_type = 'CACHESTORE_OBJCP' THEN 'Stored procedures, functions, triggers in plan cache' ELSE 'See documentation for clerk type details' END AS description FROM collect.memory_clerks_stats AS mcs WHERE mcs.collection_time >= DATEADD(HOUR, -1, SYSDATETIME()) ORDER BY mcs.pages_kb DESC",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 20,
          "dataGridTopRows": 0
        },
        {
          "id": "pmemory.memory_grants",
          "title": "Memory Grant Statistics",
          "description": "Query memory grant information",
          "enabled": true,
          "source": "",
          "panelType": "TimeSeries",
          "chartType": "Line",
          "height": 300,
          "refreshIntervalSeconds": 120,
          "layout": {
            "column": 1,
            "order": 2,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED; SELECT mgs.collection_time AS [Time], 'Granted Memory MB' AS [Series], mgs.granted_memory_mb AS [Value] FROM collect.memory_grant_stats AS mgs WHERE mgs.collection_time >= DATEADD(HOUR, -24, SYSDATETIME()) UNION ALL SELECT mgs.collection_time, 'Available Memory MB', mgs.available_memory_mb FROM collect.memory_grant_stats AS mgs WHERE mgs.collection_time >= DATEADD(HOUR, -24, SYSDATETIME()) ORDER BY [Time]",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "MB",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "",
          "valueFormat": "N0",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "pmemory.plan_cache",
          "title": "Plan Cache Statistics",
          "description": "Plan cache composition and bloat analysis",
          "enabled": true,
          "source": "",
          "panelType": "DataGrid",
          "chartType": "Line",
          "height": 300,
          "refreshIntervalSeconds": 300,
          "layout": {
            "column": 1,
            "order": 3,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED; SELECT TOP 10 pcs.collection_time, pcs.cacheobjtype, pcs.objtype, pcs.total_plans, pcs.total_size_mb, pcs.single_use_plans, pcs.single_use_size_mb, CASE WHEN pcs.total_plans > 0 AND pcs.single_use_plans * 100.0 / pcs.total_plans > 50 THEN 'CRITICAL' WHEN pcs.total_plans > 0 AND pcs.single_use_plans * 100.0 / pcs.total_plans > 30 THEN 'HIGH' WHEN pcs.total_plans > 0 AND pcs.single_use_plans * 100.0 / pcs.total_plans > 20 THEN 'MEDIUM' ELSE 'NORMAL' END AS bloat_level FROM collect.plan_cache_stats AS pcs WHERE pcs.collection_time >= DATEADD(HOUR, -1, SYSDATETIME()) ORDER BY pcs.total_size_mb DESC",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 10,
          "dataGridTopRows": 0
        }
      ]
    }
  ],
