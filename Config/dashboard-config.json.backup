        {
          "id": "repo.file_stats",
          "title": "File IO Throughput",
          "description": "",
          "enabled": true,
          "source": "",
          "panelType": "TimeSeries",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 2,
            "order": 4,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "\r\nSELECT\r\n    h.report_time AS [Time],\r\n    'Bytes Read/s' AS [Series],\r\n    SUM(CASE WHEN ISNULL(d.delta_seconds,0) > 0 THEN d.num_of_bytes_read_delta / d.delta_seconds ELSE 0 END) AS [Value]\r\nFROM dbo.sqlwatch_logger_perf_file_stats d WITH (NOLOCK)\r\nINNER JOIN dbo.sqlwatch_logger_snapshot_header h WITH (NOLOCK)\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\r\nGROUP BY h.report_time\r\n\r\nUNION ALL\r\n\r\nSELECT\r\n    h.report_time AS [Time],\r\n    'Bytes Written/s' AS [Series],\r\n    SUM(CASE WHEN ISNULL(d.delta_seconds,0) > 0 THEN d.num_of_bytes_written_delta / d.delta_seconds ELSE 0 END) AS [Value]\r\nFROM dbo.sqlwatch_logger_perf_file_stats d WITH (NOLOCK)\r\nINNER JOIN dbo.sqlwatch_logger_snapshot_header h WITH (NOLOCK)\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\r\nGROUP BY h.report_time\r\nORDER BY [Time]",
            "liveQueries": "\r\nSELECT\r\n    h.report_time AS [Time],\r\n    'Bytes Read/s' AS [Series],\r\n    SUM(CASE WHEN COALESCE(d.delta_seconds,0) > 0 THEN d.num_of_bytes_read_delta / d.delta_seconds ELSE 0 END) AS [Value]\r\nFROM sqlwatch_logger_perf_file_stats d\r\nINNER JOIN sqlwatch_logger_snapshot_header h\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance = @SqlInstance\r\nGROUP BY h.report_time\r\n\r\nUNION ALL\r\n\r\nSELECT\r\n    h.report_time AS [Time],\r\n    'Bytes Written/s' AS [Series],\r\n    SUM(CASE WHEN COALESCE(d.delta_seconds,0) > 0 THEN d.num_of_bytes_written_delta / d.delta_seconds ELSE 0 END) AS [Value]\r\nFROM sqlwatch_logger_perf_file_stats d\r\nINNER JOIN sqlwatch_logger_snapshot_header h\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance = @SqlInstance\r\nGROUP BY h.report_time\r\nORDER BY [Time]"
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "repo.long_queries",
          "title": "Long Running Queries",
          "description": "",
          "enabled": true,
          "source": "",
          "panelType": "TimeSeries",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 1,
            "order": 5,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "\r\nSELECT\r\n    h.report_time AS [Time],\r\n    'Long Queries' AS [Series],\r\n    COUNT(*) AS [Value]\r\nFROM dbo.sqlwatch_logger_xes_long_queries d WITH (NOLOCK)\r\nINNER JOIN dbo.sqlwatch_logger_snapshot_header h WITH (NOLOCK)\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\r\nGROUP BY h.report_time\r\nORDER BY h.report_time",
            "liveQueries": "\r\nSELECT\r\n    h.report_time AS [Time],\r\n    'Long Queries' AS [Series],\r\n    COUNT(*) AS [Value]\r\nFROM sqlwatch_logger_xes_long_queries d\r\nINNER JOIN sqlwatch_logger_snapshot_header h\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance = @SqlInstance\r\nGROUP BY h.report_time\r\nORDER BY h.report_time"
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        }
      ]
    },
    {
      "id": "sessions",
      "title": "Live Sessions",
      "navTitle": "",
      "navIcon": "📊",
      "navCategory": "Dashboards",
      "navOrder": 0,
      "route": "/sessions",
      "enabled": true,
      "source": "sqlwatch",
      "defaultDatabase": "master",
      "showAllOption": false,
      "panels": [
        {
          "id": "sessions.bubble",
          "title": "Live Sessions Bubble View",
          "description": "Real-time visualization of active SQL Server sessions. Each bubble represents a SPID. Size indicates activity, color indicates state (blue=active, red=blocked, green=idle). Red lines show blocking chains.",
          "enabled": true,
          "source": "",
          "panelType": "SessionBubble",
          "chartType": "Line",
          "height": 500,
          "refreshIntervalSeconds": 5,
          "layout": {
            "column": 1,
            "order": 0,
            "spanColumns": true
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SELECT s.session_id AS SPID, s.login_name AS LoginName, ISNULL(s.host_name, '') AS HostName, ISNULL(DB_NAME(s.database_id), '') AS DatabaseName, s.status AS SessionStatus, s.cpu_time AS CpuTime, s.reads AS LogicalReads, s.writes AS Writes, s.open_transaction_count AS OpenTransactionCount, r.status AS RequestStatus, r.command AS Command, r.wait_type AS WaitType, ISNULL(r.wait_time, 0) AS WaitTime, ISNULL(r.blocking_session_id, 0) AS BlockingSessionId, ISNULL(r.total_elapsed_time, 0) AS TotalElapsedTime, ISNULL(s.program_name, '') AS ProgramName, t.text AS QueryText FROM sys.dm_exec_sessions s WITH (NOLOCK) LEFT JOIN sys.dm_exec_requests r WITH (NOLOCK) ON s.session_id = r.session_id OUTER APPLY sys.dm_exec_sql_text(r.sql_handle) t WHERE s.is_user_process = 1 ORDER BY s.cpu_time + s.reads DESC",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        }
      ]
    },
    {
      "id": "querystore",
      "title": "Query Store",
      "navTitle": "",
      "navIcon": "📊",
      "navCategory": "Dashboards",
      "navOrder": 0,
      "route": "/querystore",
      "enabled": true,
      "source": "sqlwatch",
      "defaultDatabase": "PerformanceMonitor",
      "showAllOption": false,
      "panels": [
        {
          "id": "qs.topcpu",
          "title": "Top CPU Queries (last hour)",
          "description": "Queries with highest average CPU time over the past hour, aggregated across all plans.",
          "enabled": true,
          "source": "",
          "panelType": "DataGrid",
          "chartType": "Line",
          "height": 400,
          "refreshIntervalSeconds": 60,
          "layout": {
            "column": 1,
            "order": 0,
            "spanColumns": true
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED; SELECT TOP 500\n    q.query_id AS [Query ID],\n    LEFT(qt.query_sql_text, 150) AS [Query (truncated)],\n    ROUND(AVG(rs.avg_cpu_time) / 1000.0, 1) AS [Avg CPU (ms)],\n    ROUND(AVG(rs.avg_duration) / 1000.0, 1) AS [Avg Duration (ms)],\n    SUM(rs.count_executions) AS [Executions],\n    ROUND(AVG(rs.avg_logical_io_reads), 0) AS [Avg Logical Reads]\nFROM sys.query_store_query q WITH (NOLOCK)\nJOIN sys.query_store_query_text qt WITH (NOLOCK) ON q.query_text_id = qt.query_text_id\nJOIN sys.query_store_plan p WITH (NOLOCK) ON q.query_id = p.query_id\nJOIN sys.query_store_runtime_stats rs WITH (NOLOCK) ON p.plan_id = rs.plan_id\nJOIN sys.query_store_runtime_stats_interval rsi WITH (NOLOCK) ON rs.runtime_stats_interval_id = rsi.runtime_stats_interval_id\nWHERE rsi.start_time >= DATEADD(HOUR, -1, GETUTCDATE())\n  AND q.is_internal_query = 0\nGROUP BY q.query_id, qt.query_sql_text\nORDER BY AVG(rs.avg_cpu_time) DESC",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "qs.topduration",
          "title": "Top Duration Queries (last hour)",
          "description": "Queries with highest average elapsed duration over the past hour. High duration with low CPU often indicates waits (I/O, locking, network).",
          "enabled": true,
          "source": "",
          "panelType": "DataGrid",
          "chartType": "Line",
          "height": 400,
          "refreshIntervalSeconds": 60,
          "layout": {
            "column": 1,
            "order": 1,
            "spanColumns": true
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED; SELECT TOP 500\n    q.query_id AS [Query ID],\n    LEFT(qt.query_sql_text, 150) AS [Query (truncated)],\n    ROUND(AVG(rs.avg_duration) / 1000.0, 1) AS [Avg Duration (ms)],\n    ROUND(AVG(rs.avg_cpu_time) / 1000.0, 1) AS [Avg CPU (ms)],\n    SUM(rs.count_executions) AS [Executions],\n    ROUND(AVG(rs.avg_logical_io_reads), 0) AS [Avg Logical Reads],\n    ROUND(AVG(rs.avg_physical_io_reads), 0) AS [Avg Physical Reads]\nFROM sys.query_store_query q WITH (NOLOCK)\nJOIN sys.query_store_query_text qt WITH (NOLOCK) ON q.query_text_id = qt.query_text_id\nJOIN sys.query_store_plan p WITH (NOLOCK) ON q.query_id = p.query_id\nJOIN sys.query_store_runtime_stats rs WITH (NOLOCK) ON p.plan_id = rs.plan_id\nJOIN sys.query_store_runtime_stats_interval rsi WITH (NOLOCK) ON rs.runtime_stats_interval_id = rsi.runtime_stats_interval_id\nWHERE rsi.start_time >= DATEADD(HOUR, -1, GETUTCDATE())\n  AND q.is_internal_query = 0\nGROUP BY q.query_id, qt.query_sql_text\nORDER BY AVG(rs.avg_duration) DESC",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "qs.planvariation",
          "title": "High Plan Variation",
          "description": "Queries that have compiled multiple different plans. High plan variation with large duration variance is a sign of parameter sniffing.",
          "enabled": true,
          "source": "",
          "panelType": "DataGrid",
          "chartType": "Line",
          "height": 400,
          "refreshIntervalSeconds": 300,
          "layout": {
            "column": 1,
            "order": 2,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED; SELECT TOP 500\n    q.query_id AS [Query ID],\n    LEFT(qt.query_sql_text, 150) AS [Query (truncated)],\n    COUNT(DISTINCT p.plan_id) AS [Plan Count],\n    ROUND(MAX(rs.avg_duration) / 1000.0, 1) AS [Max Avg Dur (ms)],\n    ROUND(MIN(rs.avg_duration) / 1000.0, 1) AS [Min Avg Dur (ms)],\n    ROUND((MAX(rs.avg_duration) - MIN(rs.avg_duration)) / 1000.0, 1) AS [Variance (ms)]\nFROM sys.query_store_query q WITH (NOLOCK)\nJOIN sys.query_store_query_text qt WITH (NOLOCK) ON q.query_text_id = qt.query_text_id\nJOIN sys.query_store_plan p WITH (NOLOCK) ON q.query_id = p.query_id\nJOIN sys.query_store_runtime_stats rs WITH (NOLOCK) ON p.plan_id = rs.plan_id\nWHERE q.is_internal_query = 0\nGROUP BY q.query_id, qt.query_sql_text\nHAVING COUNT(DISTINCT p.plan_id) >= 2\nORDER BY COUNT(DISTINCT p.plan_id) DESC, (MAX(rs.avg_duration) - MIN(rs.avg_duration)) DESC",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "qs.regressed",
          "title": "Regressed Queries",
          "description": "Queries whose average duration in the last hour is at least 50% worse than their 1-24 hour historical baseline. Indicates a plan change or statistics problem.",
          "enabled": true,
          "source": "",
          "panelType": "DataGrid",
          "chartType": "Line",
          "height": 400,
          "refreshIntervalSeconds": 300,
          "layout": {
            "column": 1,
            "order": 3,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED; SELECT TOP 500\n    q.query_id AS [Query ID],\n    LEFT(qt.query_sql_text, 150) AS [Query (truncated)],\n    ROUND(recent.avg_duration / 1000.0, 1) AS [Recent Avg Dur (ms)],\n    ROUND(hist.avg_duration / 1000.0, 1) AS [Historical Avg Dur (ms)],\n    ROUND((recent.avg_duration - hist.avg_duration) / NULLIF(hist.avg_duration, 0) * 100, 0) AS [Regression %],\n    recent.count_executions AS [Recent Executions]\nFROM sys.query_store_query q WITH (NOLOCK)\nJOIN sys.query_store_query_text qt WITH (NOLOCK) ON q.query_text_id = qt.query_text_id\nCROSS APPLY (\n    SELECT AVG(CAST(rs.avg_duration AS BIGINT)) AS avg_duration, SUM(rs.count_executions) AS count_executions\n    FROM sys.query_store_plan p WITH (NOLOCK)\n    JOIN sys.query_store_runtime_stats rs WITH (NOLOCK) ON p.plan_id = rs.plan_id\n    JOIN sys.query_store_runtime_stats_interval rsi WITH (NOLOCK) ON rs.runtime_stats_interval_id = rsi.runtime_stats_interval_id\n    WHERE p.query_id = q.query_id AND rsi.start_time >= DATEADD(HOUR, -1, GETUTCDATE())\n) recent\nCROSS APPLY (\n    SELECT AVG(CAST(rs.avg_duration AS BIGINT)) AS avg_duration\n    FROM sys.query_store_plan p WITH (NOLOCK)\n    JOIN sys.query_store_runtime_stats rs WITH (NOLOCK) ON p.plan_id = rs.plan_id\n    JOIN sys.query_store_runtime_stats_interval rsi WITH (NOLOCK) ON rs.runtime_stats_interval_id = rsi.runtime_stats_interval_id\n    WHERE p.query_id = q.query_id\n      AND rsi.start_time >= DATEADD(HOUR, -24, GETUTCDATE())\n      AND rsi.start_time < DATEADD(HOUR, -1, GETUTCDATE())\n) hist\nWHERE q.is_internal_query = 0\n  AND recent.avg_duration > hist.avg_duration * 1.5\n  AND hist.avg_duration > 10000\nORDER BY (recent.avg_duration - hist.avg_duration) / NULLIF(hist.avg_duration, 0) DESC",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        }
      ]
    },
    {
      "id": "pm",
      "title": "Performance Monitor",
      "navTitle": "",
      "navIcon": "📊",
      "navCategory": "Dashboards",
      "navOrder": 0,
      "route": "/pm",
      "enabled": true,
      "source": "sqlwatch",
      "defaultDatabase": "PerformanceMonitor",
      "showAllOption": false,
      "panels": [
        {
          "id": "pm.latches",
          "title": "Latch Stats",
          "description": "Latch wait statistics by class",
          "enabled": true,
          "source": "",
          "panelType": "TimeSeries",
          "chartType": "Line",
          "height": 300,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 1,
            "order": 1,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SELECT ls.collection_time AS [Time], ls.latch_class AS [Series], ls.wait_time_ms AS [Value] FROM collect.latch_stats AS ls WHERE ls.collection_time BETWEEN @TimeFrom AND @TimeTo ORDER BY ls.collection_time",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "pm.spinlocks",
          "title": "Spinlock Stats",
          "description": "Spinlock collision statistics",
          "enabled": true,
          "source": "",
          "panelType": "TimeSeries",
          "chartType": "Line",
          "height": 300,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 2,
            "order": 2,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SELECT ss.collection_time AS [Time], ss.spinlock_name AS [Series], ss.backoffs AS [Value] FROM collect.spinlock_stats AS ss WHERE ss.collection_time BETWEEN @TimeFrom AND @TimeTo ORDER BY ss.collection_time",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "pm.memory_grants",
          "title": "Memory Grants",
          "description": "Query memory grant statistics",
          "enabled": true,
          "source": "",
          "panelType": "TimeSeries",
          "chartType": "Line",
          "height": 300,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 1,
            "order": 3,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SELECT mgs.collection_time AS [Time], 'Granted Memory (MB)' AS [Series], mgs.granted_memory_mb AS [Value] FROM collect.memory_grant_stats AS mgs WHERE mgs.collection_time BETWEEN @TimeFrom AND @TimeTo ORDER BY mgs.collection_time",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "pm.plan_cache",
          "title": "Plan Cache",
          "description": "Plan cache size by type",
          "enabled": true,
          "source": "",
          "panelType": "BarGauge",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 2,
            "order": 4,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SELECT pcs.cache_type AS [Series], SUM(pcs.single_pages_kb + pages_kb) / 1024.0 AS [Value] FROM collect.plan_cache_stats AS pcs WHERE pcs.collection_time BETWEEN @TimeFrom AND @TimeTo GROUP BY pcs.cache_type",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "N0",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "pm.tempdb_usage",
          "title": "TempDB Usage",
          "description": "TempDB space allocation and usage",
          "enabled": true,
          "source": "",
          "panelType": "TimeSeries",
          "chartType": "Line",
          "height": 300,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 1,
            "order": 5,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SELECT ts.collection_time AS [Time], 'User Objects (MB)' AS [Series], ts.user_object_reserved_page_count * 8.0 / 1024 AS [Value] FROM collect.tempdb_stats AS ts WHERE ts.collection_time BETWEEN @TimeFrom AND @TimeTo ORDER BY ts.collection_time",
            "liveQueries": ""
