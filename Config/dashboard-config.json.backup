    {
      "id": "pmemory",
      "title": "Memory",
      "navTitle": "",
      "navIcon": "📊",
      "navCategory": "Dashboards",
      "navOrder": 0,
      "route": "/pmemory",
      "enabled": true,
      "source": "sqlwatch",
      "defaultDatabase": "PerformanceMonitor",
      "showAllOption": false,
      "panels": [
        {
          "id": "pmemory.total",
          "title": "Total Memory Usage",
          "description": "SQL Server total memory usage",
          "enabled": true,
          "source": "",
          "panelType": "StatCard",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 0,
            "order": 0,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
