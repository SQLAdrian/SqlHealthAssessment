          "query": {
            "source": "sqlwatch",
            "sqlServer": "SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED; SELECT TOP 100 dte.event_time, dte.event_name, dte.database_name, dte.login_name, dte.host_name, dte.application_name, dte.object_name, dte.text_data FROM collect.default_trace_events AS dte WHERE dte.event_time >= DATEADD(HOUR, -24, SYSDATETIME()) ORDER BY dte.event_time DESC",
