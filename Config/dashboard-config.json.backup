{
  "version": 1,
  "dashboards": [
    {
      "id": "instance",
      "title": "Instance Overview",
      "navTitle": "",
      "navIcon": "📊",
      "navCategory": "Dashboards",
      "navOrder": 0,
      "route": "/instance",
      "enabled": true,
      "source": "sqlwatch",
      "defaultDatabase": "SQLWATCH",
      "showAllOption": false,
      "panels": [
        {
          "id": "repo.database_count",
          "title": "Databases",
          "description": null,
          "enabled": true,
          "source": "",
          "panelType": "StatCard",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 0,
            "order": 0,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "\r\nSELECT COUNT(*) AS [Value]\r\nFROM sys.databases WITH (NOLOCK)\r\nWHERE state_desc = 'ONLINE'",
            "liveQueries": "\r\nSELECT COUNT(*) AS [Value]\r\nFROM liveQueries_master\r\nWHERE type='table' AND name NOT LIKE 'liveQueries_%'"
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "",
          "valueFormat": "N0",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "repo.process_memory",
          "title": "SQL Memory",
          "description": null,
          "enabled": false,
          "source": "",
          "panelType": "StatCard",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 0,
            "order": 1,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "\r\nSELECT TOP 1\r\n    h.report_time AS [Time],\r\n    'Memory %' AS [Series],\r\n    d.memory_utilization_percentage AS [Value]\r\nFROM dbo.sqlwatch_logger_perf_os_process_memory d WITH (NOLOCK)\r\nINNER JOIN dbo.sqlwatch_logger_snapshot_header h WITH (NOLOCK)\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\r\nORDER BY h.report_time DESC",
            "liveQueries": "\r\nSELECT\r\n    h.report_time AS [Time],\r\n    'Memory %' AS [Series],\r\n    d.memory_utilization_percentage AS [Value]\r\nFROM sqlwatch_logger_perf_os_process_memory d\r\nINNER JOIN sqlwatch_logger_snapshot_header h\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance = @SqlInstance\r\nORDER BY h.report_time DESC\r\nLIMIT 1"
          },
          "defaultDatabase": "master",
          "statUnit": "%",
          "statThresholdKey": "SQL Memory",
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [
            {
              "operator": ">=",
              "value": 0,
              "color": "#1b5e20",
              "label": "Normal"
            },
            {
              "operator": ">=",
              "value": 85,
              "color": "#ff9800",
              "label": "Warning"
            },
            {
              "operator": ">=",
              "value": 95,
              "color": "#f44336",
              "label": "Critical"
            }
          ],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "repo.schedulers",
          "title": "Pending Queue",
          "description": null,
          "enabled": false,
          "source": "",
          "panelType": "StatCard",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 0,
            "order": 2,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "\r\nSELECT TOP 1\r\n    h.report_time AS [Time],\r\n    'Pending' AS [Series],\r\n    d.work_queue_count AS [Value]\r\nFROM dbo.sqlwatch_logger_perf_os_schedulers d WITH (NOLOCK)\r\nINNER JOIN dbo.sqlwatch_logger_snapshot_header h WITH (NOLOCK)\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\r\nORDER BY h.report_time DESC",
            "liveQueries": "\r\nSELECT\r\n    h.report_time AS [Time],\r\n    'Pending' AS [Series],\r\n    d.work_queue_count AS [Value]\r\nFROM sqlwatch_logger_perf_os_schedulers d\r\nINNER JOIN sqlwatch_logger_snapshot_header h\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance = @SqlInstance\r\nORDER BY h.report_time DESC\r\nLIMIT 1"
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": "Pending",
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [
            {
              "operator": ">=",
              "value": 0,
              "color": "#1b5e20",
              "label": "Normal"
            },
            {
              "operator": ">=",
              "value": 1,
              "color": "#f44336",
              "label": "Critical"
            }
          ],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "repo.instance_count",
          "title": "Instances",
          "description": null,
          "enabled": false,
          "source": "",
          "panelType": "StatCard",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 0,
            "order": 3,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "\r\nSELECT COUNT(DISTINCT sql_instance) AS [Value]\r\nFROM dbo.sqlwatch_config_sql_instance WITH (NOLOCK)\r\nWHERE repo_collector_is_active = 1",
            "liveQueries": "\r\nSELECT COUNT(DISTINCT sql_instance) AS [Value]\r\nFROM sqlwatch_config_sql_instance\r\nWHERE repo_collector_is_active = 1"
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "repo.details",
          "title": "Server Details",
          "description": "",
          "enabled": false,
          "source": "",
          "panelType": "TextCard",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 0,
            "order": 4,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SELECT \n    @@SERVERNAME AS ServerName,\n    --SERVERPROPERTY('Edition') AS Edition,\n    CASE ServerProperty('EngineEdition')\n \nWHEN 1  THEN 'Desktop'\nWHEN 2  THEN \n    CASE \n    WHEN CONVERT(VARCHAR(50),SERVERPROPERTY('Edition')) LIKE '%Busi%' THEN 'Business Intelligence'\n    WHEN CONVERT(VARCHAR(50),SERVERPROPERTY('Edition')) LIKE '%Developer%' THEN 'Developer'\n    ELSE 'Standard'-- (For Standard, Standard Developer, Web, and Business Intelligence.)\n    END\nWHEN 3  THEN \n-- (For Enterprise, Enterprise Developer, Developer, and Evaluation editions.)\n    CASE \n    WHEN CONVERT(VARCHAR(50),SERVERPROPERTY('Edition')) LIKE '%Developer%' THEN 'Developer'\n    WHEN CONVERT(VARCHAR(50),SERVERPROPERTY('Edition')) LIKE '%Evaluation%' THEN 'Evaluation'\n    ELSE 'Enterprise'\n    END\n\nWHEN 4  THEN 'Express'-- (For Express, Express with Tools, and Express with Advanced Services)\nWHEN 5  THEN 'SQL Database'\nWHEN 6  THEN 'Azure Synapse'-- Analytics\nWHEN 8  THEN 'Azure SQL MI'\nWHEN 9  THEN 'Azure SQL Edge'-- (For all editions of Azure SQL Edge)\nWHEN 11 THEN  'Azure Synapse serverless'-- SQL pool, or Microsoft Fabric\nWHEN 12 THEN  'Microsoft Fabric'-- SQL database in Microsoft Fabric.\n    END AS Edition\n    ,\n    (SELECT cpu_count FROM sys.dm_os_sys_info) AS VirtualCPUs,\n    (SELECT socket_count FROM sys.dm_os_sys_info) AS Sockets,\n    CASE WHEN (SELECT virtual_machine_type FROM sys.dm_os_sys_info) = 1 THEN 'VM' ELSE 'Physical' END AS VMType,\n    CAST((SELECT physical_memory_kb FROM sys.dm_os_sys_info) / 1024.0 / 1024.0 AS DECIMAL(10,2)) AS MemoryGB,\n    CAST((SELECT committed_kb FROM sys.dm_os_sys_info) / 1024.0 / 1024.0 AS DECIMAL(10,2)) AS SqlAllocated,\n    CAST((SELECT committed_target_kb FROM sys.dm_os_sys_info) / 1024.0 / 1024.0 AS DECIMAL(10,2)) AS UsedBySql,\n    '' AS MemoryState,\n    CASE \n     WHEN CONVERT(VARCHAR(128), SERVERPROPERTY ('productversion')) like '8%'    THEN '2000'\n     WHEN CONVERT(VARCHAR(128), SERVERPROPERTY ('productversion')) like '9%'    THEN '2005'\n     WHEN CONVERT(VARCHAR(128), SERVERPROPERTY ('productversion')) like '10.0%' THEN '2008'\n     WHEN CONVERT(VARCHAR(128), SERVERPROPERTY ('productversion')) like '10.5%' THEN '2008 R2'\n     WHEN CONVERT(VARCHAR(128), SERVERPROPERTY ('productversion')) like '11%'   THEN '2012'\n     WHEN CONVERT(VARCHAR(128), SERVERPROPERTY ('productversion')) like '12%'   THEN '2014'\n     WHEN CONVERT(VARCHAR(128), SERVERPROPERTY ('productversion')) like '13%'   THEN '2016'     \n     WHEN CONVERT(VARCHAR(128), SERVERPROPERTY ('productversion')) like '14%'   THEN '2017' \n     WHEN CONVERT(VARCHAR(128), SERVERPROPERTY ('productversion')) like '15%'   THEN '2019' \n     WHEN CONVERT(VARCHAR(128), SERVERPROPERTY ('productversion')) like '16%'   THEN '2022' \n     ELSE 'unknown'\n  END \n    --@@VERSION \n    AS [Version],\n    SERVERPROPERTY('ProductVersion') AS BuildNr,\n    (SELECT windows_release FROM sys.dm_os_windows_info) AS OS,\n    CASE WHEN SERVERPROPERTY('IsHadrEnabled') = 1 THEN 'Yes' ELSE 'No' END AS HADR,\n    CASE WHEN EXISTS(SELECT 1 FROM sys.server_principals WHERE name = 'sa' AND is_disabled = 0) THEN 'Enabled' ELSE 'Disabled' END AS SA,\n    '' AS [Level]",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "repository.text_server_CPU_OS",
          "title": "Server CPU and OS",
          "description": "",
          "enabled": true,
          "source": "",
          "panelType": "TextCard",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 0,
            "order": 5,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "\nSELECT \n    \n    (SELECT socket_count FROM sys.dm_os_sys_info) AS [CPU Sockets],\n    (SELECT cpu_count FROM sys.dm_os_sys_info) AS [Virtual CPU Count],\n    CASE WHEN (SELECT virtual_machine_type FROM sys.dm_os_sys_info) = 1 THEN 'VM' ELSE 'Physical' END AS [System Type],\n    (SELECT windows_release FROM sys.dm_os_windows_info) AS [Operating System]",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "repository.text_servername",
          "title": "Server",
          "description": "",
          "enabled": true,
          "source": "",
          "panelType": "TextCard",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 0,
            "order": 6,
            "spanColumns": true
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "\nSELECT \nServerName\n, Edition\n, '$ ' + CONVERT(VARCHAR(25),CONVERT(INT,CONVERT(MONEY,\nCASE Edition \nWHEN 'Business Intelligence'\nTHEN 5434  * VirtualCPUs / 2\n  \nWHEN 'Standard'\nTHEN 5434  * VirtualCPUs / 2/ 3.832\n  \nWHEN 'Enterprise'\nTHEN 5434  * VirtualCPUs / 2\nELSE  0\nEND)))\n[licensingRetailUSD]\n, [Version]\n, BuildNr\n, HADR\n, SA [sa state]\n\nFROM (\nSELECT \n    @@SERVERNAME AS ServerName,\n    --SERVERPROPERTY('Edition') AS Edition,\n    CASE ServerProperty('EngineEdition')\n \nWHEN 1  THEN 'Desktop'\nWHEN 2  THEN \n    CASE \n    WHEN CONVERT(VARCHAR(50),SERVERPROPERTY('Edition')) LIKE '%Busi%' THEN 'Business Intelligence'\n    WHEN CONVERT(VARCHAR(50),SERVERPROPERTY('Edition')) LIKE '%Developer%' THEN 'Developer'\n    ELSE 'Standard'-- (For Standard, Standard Developer, Web, and Business Intelligence.)\n    END\nWHEN 3  THEN \n-- (For Enterprise, Enterprise Developer, Developer, and Evaluation editions.)\n    CASE \n    WHEN CONVERT(VARCHAR(50),SERVERPROPERTY('Edition')) LIKE '%Developer%' THEN 'Developer'\n    WHEN CONVERT(VARCHAR(50),SERVERPROPERTY('Edition')) LIKE '%Evaluation%' THEN 'Evaluation'\n    ELSE 'Enterprise'\n    END\n\nWHEN 4  THEN 'Express'-- (For Express, Express with Tools, and Express with Advanced Services)\nWHEN 5  THEN 'SQL Database'\nWHEN 6  THEN 'Azure Synapse'-- Analytics\nWHEN 8  THEN 'Azure SQL MI'\nWHEN 9  THEN 'Azure SQL Edge'-- (For all editions of Azure SQL Edge)\nWHEN 11 THEN  'Azure Synapse serverless'-- SQL pool, or Microsoft Fabric\nWHEN 12 THEN  'Microsoft Fabric'-- SQL database in Microsoft Fabric.\n    END AS Edition\n    \n\n    ,\n    (SELECT cpu_count FROM sys.dm_os_sys_info) AS VirtualCPUs,\n    (SELECT socket_count FROM sys.dm_os_sys_info) AS Sockets,\n    CASE WHEN (SELECT virtual_machine_type FROM sys.dm_os_sys_info) = 1 THEN 'VM' ELSE 'Physical' END AS VMType,\n    CAST((SELECT physical_memory_kb FROM sys.dm_os_sys_info) / 1024.0 / 1024.0 AS DECIMAL(10,2)) AS MemoryGB,\n    CAST((SELECT committed_kb FROM sys.dm_os_sys_info) / 1024.0 / 1024.0 AS DECIMAL(10,2)) AS SqlAllocated,\n    CAST((SELECT committed_target_kb FROM sys.dm_os_sys_info) / 1024.0 / 1024.0 AS DECIMAL(10,2)) AS UsedBySql,\n    '' AS MemoryState,\n    CASE \n     WHEN CONVERT(VARCHAR(128), SERVERPROPERTY ('productversion')) like '8%'    THEN '2000'\n     WHEN CONVERT(VARCHAR(128), SERVERPROPERTY ('productversion')) like '9%'    THEN '2005'\n     WHEN CONVERT(VARCHAR(128), SERVERPROPERTY ('productversion')) like '10.0%' THEN '2008'\n     WHEN CONVERT(VARCHAR(128), SERVERPROPERTY ('productversion')) like '10.5%' THEN '2008 R2'\n     WHEN CONVERT(VARCHAR(128), SERVERPROPERTY ('productversion')) like '11%'   THEN '2012'\n     WHEN CONVERT(VARCHAR(128), SERVERPROPERTY ('productversion')) like '12%'   THEN '2014'\n     WHEN CONVERT(VARCHAR(128), SERVERPROPERTY ('productversion')) like '13%'   THEN '2016'     \n     WHEN CONVERT(VARCHAR(128), SERVERPROPERTY ('productversion')) like '14%'   THEN '2017' \n     WHEN CONVERT(VARCHAR(128), SERVERPROPERTY ('productversion')) like '15%'   THEN '2019' \n     WHEN CONVERT(VARCHAR(128), SERVERPROPERTY ('productversion')) like '16%'   THEN '2022' \n     ELSE 'unknown'\n  END \n    --@@VERSION \n    AS [Version],\n    SERVERPROPERTY('ProductVersion') AS BuildNr,\n    (SELECT windows_release FROM sys.dm_os_windows_info) AS OS,\n    CASE WHEN SERVERPROPERTY('IsHadrEnabled') = 1 THEN 'Yes' ELSE 'No' END AS HADR,\n    CASE WHEN EXISTS(SELECT 1 FROM sys.server_principals WHERE name = 'sa' AND is_disabled = 0) THEN 'Enabled' ELSE 'Disabled' END AS SA,\n    '' AS [Level]\n) T1\n   \n\n ",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 5,
          "dataGridTopRows": 0
        },
        {
          "id": "instance.ks1",
          "title": "Key Stats",
          "description": "",
          "enabled": true,
          "source": "",
          "panelType": "TextCard",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 0,
            "order": 7,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "\nselect TOP 1\n --time = pc.snapshot_time\n--,\n'CPU usage %' = sum(case \n when 1=1 and mpc.counter_name = 'Processor Time %' then pc.[cntr_value_calculated] \n --when serverproperty('EngineEdition') = 3 and mpc.counter_name = 'CPU usage %' then pc.[cntr_value_calculated] \n --when serverproperty('EngineEdition') <> 3 and mpc.counter_name = 'Processor Time %' then pc.[cntr_value_calculated]\n else null end)\n, 'Batch Requests/sec' =CONVERT(INT, avg(case when mpc.counter_name = 'Batch Requests/sec' then pc.[cntr_value_calculated] else null end))\n\n, 'Logins/sec' = CONVERT(INT,avg(case when mpc.counter_name = 'Logins/sec' then pc.[cntr_value_calculated] else null end))\n, 'Transactions/sec' = CONVERT(INT,sum(case when mpc.counter_name = 'Transactions/sec' and pc.instance_name not in ('_Total','mssqlsystemresource') then pc.[cntr_value_calculated] else null end))\n, 'User Connections' = avg(case when mpc.counter_name = 'User Connections' then pc.[cntr_value_calculated] else null end)\n, 'SQL Compilations/sec' = CONVERT(INT,avg(case when mpc.counter_name = 'SQL Compilations/sec' then pc.[cntr_value_calculated] else null end))\n, 'Availability Group Bytes' = avg(case when mpc.counter_name in ('Bytes Sent to Replica/sec','Bytes Received from Replica/sec') then pc.[cntr_value_calculated] else null end)\n ,'Connection Memory (MB)'\t\t= CONVERT(INT,avg(case when mpc.counter_name = 'Connection Memory (KB)' then pc.[cntr_value_calculated]/1024\telse null end))\n ,'Optimizer Memory (MB)'\t\t= CONVERT(INT,avg(case when mpc.counter_name = 'Optimizer Memory (KB)' then pc.[cntr_value_calculated]/1024\t\telse null end))\n ,'SQL Cache Memory (MB)'\t\t= CONVERT(INT,avg(case when mpc.counter_name = 'SQL Cache Memory (KB)' then pc.[cntr_value_calculated]/1024\t\telse null end))\n ,'Total Server Memory (MB)'\t= CONVERT(INT,avg(case when mpc.counter_name = 'Total Server Memory (KB)' then pc.[cntr_value_calculated]/1024\telse null end))\n ,'Stolen Server Memory (MB)'\t= CONVERT(INT,avg(case when mpc.counter_name = 'Stolen Server Memory (KB)' then pc.[cntr_value_calculated]/1024 else null end))\n ,'Target Server Memory (MB)'\t= CONVERT(INT,avg(case when mpc.counter_name = 'Target Server Memory (KB)' then pc.[cntr_value_calculated]/1024 else null end))\nfrom [dbo].[sqlwatch_logger_perf_os_performance_counters] pc\n\ninner join [dbo].[sqlwatch_meta_performance_counter] mpc\non pc.sql_instance = mpc.sql_instance\nand pc.performance_counter_id = mpc.performance_counter_id\n\nWHERE 1=1--snapshot_time BETWEEN @TimeFrom AND @TimeTo\n\nand pc.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\nand mpc.counter_name in ('CPU usage %'\n ,'Batch Requests/sec'\n ,'Logins/sec'\n ,'Transactions/sec'\n ,'User Connections'\n ,'SQL Compilations/sec'\n ,'Bytes Sent to Replica/sec'\n ,'Bytes Received from Replica/sec'\n ,'Processor Time %'\n ,'% Processor Time'\n \n ,'Connection Memory (KB)'\n ,'Optimizer Memory (KB)'\n ,'SQL Cache Memory (KB)'\n ,'Total Server Memory (KB)'\n ,'Stolen Server Memory (KB)'\n , 'Target Server Memory (KB)'\n )\n\ngroup by pc.snapshot_time\norder by pc.snapshot_time DESC\n\n",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "%",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "repo.checks",
          "title": "Health Checks",
          "description": null,
          "enabled": false,
          "source": "",
          "panelType": "CheckStatus",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 0,
            "order": 8,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "\r\nSELECT\r\n    d.check_status AS [Status],\r\n    COUNT(*) AS [Count]\r\nFROM dbo.sqlwatch_logger_check d WITH (NOLOCK)\r\nINNER JOIN dbo.sqlwatch_logger_snapshot_header h WITH (NOLOCK)\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\r\nGROUP BY d.check_status",
            "liveQueries": "\r\nSELECT\r\n    d.check_status AS [Status],\r\n    COUNT(*) AS [Count]\r\nFROM sqlwatch_logger_check d\r\nINNER JOIN sqlwatch_logger_snapshot_header h\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance = @SqlInstance\r\nGROUP BY d.check_status"
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "instance.ks2",
          "title": "More Key Stats",
          "description": "",
          "enabled": false,
          "source": "",
          "panelType": "TextCard",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 0,
            "order": 9,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "\nselect TOP 1\n 'Connection Memory (MB)'\t\t= CONVERT(INT,avg(case when mpc.counter_name = 'Connection Memory (KB)' then pc.[cntr_value_calculated]/1024\telse null end))\n ,'Optimizer Memory (MB)'\t\t= CONVERT(INT,avg(case when mpc.counter_name = 'Optimizer Memory (KB)' then pc.[cntr_value_calculated]/1024\t\telse null end))\n ,'SQL Cache Memory (MB)'\t\t= CONVERT(INT,avg(case when mpc.counter_name = 'SQL Cache Memory (KB)' then pc.[cntr_value_calculated]/1024\t\telse null end))\n ,'Total Server Memory (MB)'\t= CONVERT(INT,avg(case when mpc.counter_name = 'Total Server Memory (KB)' then pc.[cntr_value_calculated]/1024\telse null end))\n ,'Stolen Server Memory (MB)'\t= CONVERT(INT,avg(case when mpc.counter_name = 'Stolen Server Memory (KB)' then pc.[cntr_value_calculated]/1024 else null end))\n ,'Target Server Memory (MB)'\t= CONVERT(INT,avg(case when mpc.counter_name = 'Target Server Memory (KB)' then pc.[cntr_value_calculated]/1024 else null end))\nfrom [dbo].[sqlwatch_logger_perf_os_performance_counters] pc\n\ninner join [dbo].[sqlwatch_meta_performance_counter] mpc\non pc.sql_instance = mpc.sql_instance\nand pc.performance_counter_id = mpc.performance_counter_id\n\nWHERE 1=1--snapshot_time BETWEEN @TimeFrom AND @TimeTo\n\nand pc.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\nand mpc.counter_name in ('CPU usage %'\n ,'Batch Requests/sec'\n ,'Logins/sec'\n ,'Transactions/sec'\n ,'User Connections'\n ,'SQL Compilations/sec'\n ,'Bytes Sent to Replica/sec'\n ,'Bytes Received from Replica/sec'\n ,'Processor Time %'\n ,'% Processor Time'\n \n ,'Connection Memory (KB)'\n ,'Optimizer Memory (KB)'\n ,'SQL Cache Memory (KB)'\n ,'Total Server Memory (KB)'\n ,'Stolen Server Memory (KB)'\n , 'Target Server Memory (KB)'\n )\n\ngroup by pc.snapshot_time\norder by pc.snapshot_time DESC",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "repository.text_server_memory",
          "title": "Server Memory Usage",
          "description": "",
          "enabled": true,
          "source": "",
          "panelType": "TextCard",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 0,
            "order": 10,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "\nSELECT \n   \n    CAST((SELECT physical_memory_kb FROM sys.dm_os_sys_info) / 1024.0 / 1024.0 AS DECIMAL(10,2)) AS [System Total Memory GB],\n    CAST((SELECT committed_kb FROM sys.dm_os_sys_info) / 1024.0 / 1024.0 AS DECIMAL(10,2)) AS [Memory Allocated to SQL],\n    CAST((SELECT committed_target_kb FROM sys.dm_os_sys_info) / 1024.0 / 1024.0 AS DECIMAL(10,2)) AS [Memory Used By SQL],\n    CONVERT(INT,\n    CAST((SELECT committed_target_kb FROM sys.dm_os_sys_info) / 1024.0 / 1024.0 AS DECIMAL(10,2))\n    /\n    CAST((SELECT committed_kb FROM sys.dm_os_sys_info) / 1024.0 / 1024.0 AS DECIMAL(10,2))*100)\n    [SQL Memory usage %]\n    \n",
            "liveQueries": ""
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "instance.blocking",
          "title": "Blocking",
          "description": null,
          "enabled": true,
          "source": "",
          "panelType": "TimeSeries",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 2,
            "order": 11,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "\r\nSELECT\r\n    h.report_time AS [Time],\r\n    'Blocked Sessions' AS [Series],\r\n    COUNT(DISTINCT d.blocked_spid) AS [Value]\r\nFROM dbo.sqlwatch_logger_xes_blockers d WITH (NOLOCK)\r\nINNER JOIN dbo.sqlwatch_logger_snapshot_header h WITH (NOLOCK)\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\r\nGROUP BY h.report_time\r\nORDER BY h.report_time",
            "liveQueries": "\r\nSELECT\r\n    h.report_time AS [Time],\r\n    'Blocked Sessions' AS [Series],\r\n    COUNT(DISTINCT d.blocked_spid) AS [Value]\r\nFROM sqlwatch_logger_xes_blockers d\r\nINNER JOIN sqlwatch_logger_snapshot_header h\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance = @SqlInstance\r\nGROUP BY h.report_time\r\nORDER BY h.report_time"
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "instance.disk_space",
          "title": "Disk Space",
          "description": null,
          "enabled": true,
          "source": "",
          "panelType": "BarGauge",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 0,
            "order": 12,
            "spanColumns": true
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "\r\nSELECT\r\n    v.volume_name AS [Label],\r\n    CASE WHEN d.volume_total_space_bytes > 0\r\n        THEN CAST((1.0 - (1.0 * d.volume_free_space_bytes / d.volume_total_space_bytes)) * 100.0 AS decimal(5,1))\r\n        ELSE 0 END AS [Value],\r\n    '%' AS [Unit],\r\n    d.sql_instance AS [Instance]\r\nFROM dbo.sqlwatch_logger_disk_utilisation_volume d WITH (NOLOCK)\r\nINNER JOIN dbo.sqlwatch_logger_snapshot_header h WITH (NOLOCK)\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nINNER JOIN dbo.sqlwatch_meta_os_volume v WITH (NOLOCK)\r\n    ON v.sql_instance = d.sql_instance\r\n    AND v.sqlwatch_volume_id = d.sqlwatch_volume_id\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\r\n    AND h.snapshot_time = (\r\n        SELECT MAX(h2.snapshot_time)\r\n        FROM dbo.sqlwatch_logger_snapshot_header h2 WITH (NOLOCK)\r\n        WHERE h2.report_time BETWEEN @TimeFrom AND @TimeTo\r\n            AND h2.sql_instance = d.sql_instance\r\n            AND h2.snapshot_type_id = d.snapshot_type_id\r\n    )",
            "liveQueries": "\r\nSELECT\r\n    v.volume_name AS [Label],\r\n    CASE WHEN d.volume_total_space_bytes > 0\r\n        THEN CAST((1.0 - (1.0 * d.volume_free_space_bytes / d.volume_total_space_bytes)) * 100.0 AS REAL)\r\n        ELSE 0 END AS [Value],\r\n    '%' AS [Unit],\r\n    d.sql_instance AS [Instance]\r\nFROM sqlwatch_logger_disk_utilisation_volume d\r\nINNER JOIN sqlwatch_logger_snapshot_header h\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nINNER JOIN sqlwatch_meta_os_volume v\r\n    ON v.sql_instance = d.sql_instance\r\n    AND v.sqlwatch_volume_id = d.sqlwatch_volume_id\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance = @SqlInstance\r\n    AND h.snapshot_time = (\r\n        SELECT MAX(h2.snapshot_time)\r\n        FROM sqlwatch_logger_snapshot_header h2\r\n        WHERE h2.report_time BETWEEN @TimeFrom AND @TimeTo\r\n            AND h2.sql_instance = d.sql_instance\r\n            AND h2.snapshot_type_id = d.snapshot_type_id\r\n    )"
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": "Disk Space Used %",
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [
            {
              "operator": ">=",
              "value": 0,
              "color": "#1b5e20",
              "label": "Normal"
            },
            {
              "operator": ">=",
              "value": 80,
              "color": "#ff9800",
              "label": "Warning"
            },
            {
              "operator": ">=",
              "value": 90,
              "color": "#f44336",
              "label": "Critical"
            }
          ],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "instance.cpu",
          "title": "CPU Utilization",
          "description": null,
          "enabled": true,
          "source": "",
          "panelType": "TimeSeries",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 1,
            "order": 13,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SELECT\n    h.report_time AS [Time],\n    instance_name + ' %'  AS [Series],\n    AVG(CONVERT(MONEY,d.cntr_value_calculated)) AS [Value]\nFROM dbo.sqlwatch_logger_perf_os_performance_counters d WITH (NOLOCK)\nINNER JOIN dbo.sqlwatch_logger_snapshot_header h WITH (NOLOCK)\n    ON h.snapshot_time = d.snapshot_time\n    AND h.snapshot_type_id = d.snapshot_type_id\n    AND h.sql_instance = d.sql_instance\nINNER JOIN dbo.sqlwatch_meta_performance_counter m WITH (NOLOCK)\n    ON m.sql_instance = d.sql_instance\n    AND m.performance_counter_id = d.performance_counter_id\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\n    AND d.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\n    AND m.counter_name IN ('Processor Time %','Privileged Time %','User Time %')\n    AND m.cntr_type <> 1073939712\nGROUP BY h.report_time ,\n    instance_name",
            "liveQueries": "\r\nSELECT\r\n    h.report_time AS [Time],\r\n    m.counter_name AS [Series],\r\n    d.cntr_value_calculated AS [Value]\r\nFROM sqlwatch_logger_perf_os_performance_counters d\r\nINNER JOIN sqlwatch_logger_snapshot_header h\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nINNER JOIN sqlwatch_meta_performance_counter m\r\n    ON m.sql_instance = d.sql_instance\r\n    AND m.performance_counter_id = d.performance_counter_id\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance = @SqlInstance\r\n    AND m.counter_name IN ('Processor Time %','Privileged Time %','User Time %')\r\n    AND m.cntr_type <> 1073939712\r\nORDER BY h.report_time"
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "instance.activity",
          "title": "Activity (Batch Requests, Logins, etc.)",
          "description": null,
          "enabled": true,
          "source": "",
          "panelType": "TimeSeries",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 2,
            "order": 14,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SELECT\n    h.report_time AS [Time],\n    m.counter_name AS [Series],\n    SUM(CONVERT(MONEY,d.cntr_value_calculated)) AS [Value]\nFROM dbo.sqlwatch_logger_perf_os_performance_counters d WITH (NOLOCK)\nINNER JOIN dbo.sqlwatch_logger_snapshot_header h WITH (NOLOCK)\n    ON h.snapshot_time = d.snapshot_time\n    AND h.snapshot_type_id = d.snapshot_type_id\n    AND h.sql_instance = d.sql_instance\nINNER JOIN dbo.sqlwatch_meta_performance_counter m WITH (NOLOCK)\n    ON m.sql_instance = d.sql_instance\n    AND m.performance_counter_id = d.performance_counter_id\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\n    AND d.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\n    AND m.counter_name IN ('Batch Requests/Sec','Logins/sec','Transactions/sec','SQL Compilations/sec','User Connections')\n    AND m.cntr_type <> 1073939712\nGROUP BY h.report_time,\n    m.counter_name",
            "liveQueries": "\r\nSELECT\r\n    h.report_time AS [Time],\r\n    m.counter_name AS [Series],\r\n    d.cntr_value_calculated AS [Value]\r\nFROM sqlwatch_logger_perf_os_performance_counters d\r\nINNER JOIN sqlwatch_logger_snapshot_header h\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nINNER JOIN sqlwatch_meta_performance_counter m\r\n    ON m.sql_instance = d.sql_instance\r\n    AND m.performance_counter_id = d.performance_counter_id\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance = @SqlInstance\r\n    AND m.counter_name IN ('Batch Requests/Sec','Logins/sec','Transactions/sec','SQL Compilations/sec','User Connections')\r\n    AND m.cntr_type <> 1073939712\r\nORDER BY h.report_time"
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "instance.waits_category",
          "title": "Wait Events by Category",
          "description": null,
          "enabled": true,
          "source": "",
          "panelType": "TimeSeries",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 1,
            "order": 15,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "\r\nSELECT\r\n    h.report_time AS [Time],\r\n    ISNULL(ws.wait_category, 'Other') AS [Series],\r\n    SUM(d.wait_time_ms_delta) AS [Value]\r\nFROM dbo.sqlwatch_logger_perf_os_wait_stats d WITH (NOLOCK)\r\nINNER JOIN dbo.sqlwatch_logger_snapshot_header h WITH (NOLOCK)\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nLEFT JOIN dbo.vw_sqlwatch_meta_wait_stats_category ws WITH (NOLOCK)\r\n    ON ws.sql_instance = d.sql_instance\r\n    AND ws.wait_type_id = d.wait_type_id\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\r\nGROUP BY h.report_time, ISNULL(ws.wait_category, 'Other')\r\nHAVING SUM(d.wait_time_ms_delta) > 0\r\nORDER BY h.report_time",
            "liveQueries": "\r\nSELECT\r\n    h.report_time AS [Time],\r\n    COALESCE(cw.wait_category,\r\n        CASE\r\n            WHEN mw.wait_type LIKE 'LCK_%' THEN 'Lock'\r\n            WHEN mw.wait_type LIKE 'LATCH_%' THEN 'Latch'\r\n            WHEN mw.wait_type LIKE 'PAGELATCH_%' THEN 'Buffer Latch'\r\n            WHEN mw.wait_type LIKE 'PAGEIOLATCH_%' THEN 'Buffer IO'\r\n            WHEN mw.wait_type IN ('CXPACKET','EXCHANGE','CXCONSUMER') THEN 'CPU - Parallelism'\r\n            WHEN mw.wait_type IN ('ASYNC_NETWORK_IO','NET_WAITFOR_PACKET') THEN 'Network IO'\r\n            WHEN mw.wait_type IN ('LOGMGR','LOGBUFFER','WRITELOG') THEN 'Tran Log IO'\r\n            WHEN mw.wait_type LIKE 'HADR_%' THEN 'Always On'\r\n            ELSE 'Other'\r\n        END\r\n    ) AS [Series],\r\n    SUM(d.wait_time_ms_delta) AS [Value]\r\nFROM sqlwatch_logger_perf_os_wait_stats d\r\nINNER JOIN sqlwatch_logger_snapshot_header h\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nLEFT JOIN sqlwatch_meta_wait_stats mw\r\n    ON mw.sql_instance = d.sql_instance\r\n    AND mw.wait_type_id = d.wait_type_id\r\nLEFT JOIN sqlwatch_config_wait_stats cw\r\n    ON cw.wait_type = mw.wait_type\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance = @SqlInstance\r\nGROUP BY h.report_time, [Series]\r\nHAVING SUM(d.wait_time_ms_delta) > 0\r\nORDER BY h.report_time"
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "instance.memory",
          "title": "Memory GB and usage %",
          "description": null,
          "enabled": true,
          "source": "",
          "panelType": "TimeSeries",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 2,
            "order": 16,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SELECT\n    h.report_time AS [Time],\n    'Physical Memory In Use (GB)' AS [Series],\n    AVG(CONVERT(MONEY,d.physical_memory_in_use_kb))/1024/1024 AS [Value]\nFROM dbo.sqlwatch_logger_perf_os_process_memory d WITH (NOLOCK)\nINNER JOIN dbo.sqlwatch_logger_snapshot_header h WITH (NOLOCK)\n    ON h.snapshot_time = d.snapshot_time\n    AND h.snapshot_type_id = d.snapshot_type_id\n    AND h.sql_instance = d.sql_instance\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\n    AND d.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\n    GROUP BY h.report_time\n\nUNION ALL\n\nSELECT\n    h.report_time,\n    'Memory Utilization % of commit',\n    AVG(d.memory_utilization_percentage)\nFROM dbo.sqlwatch_logger_perf_os_process_memory d WITH (NOLOCK)\nINNER JOIN dbo.sqlwatch_logger_snapshot_header h WITH (NOLOCK)\n    ON h.snapshot_time = d.snapshot_time\n    AND h.snapshot_type_id = d.snapshot_type_id\n    AND h.sql_instance = d.sql_instance\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\n    AND d.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\nGROUP BY h.report_time",
            "liveQueries": "\r\nSELECT\r\n    h.report_time AS [Time],\r\n    'Physical Memory In Use (KB)' AS [Series],\r\n    d.physical_memory_in_use_kb AS [Value]\r\nFROM sqlwatch_logger_perf_os_process_memory d\r\nINNER JOIN sqlwatch_logger_snapshot_header h\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance = @SqlInstance\r\n\r\nUNION ALL\r\n\r\nSELECT\r\n    h.report_time,\r\n    'Memory Utilization %',\r\n    d.memory_utilization_percentage\r\nFROM sqlwatch_logger_perf_os_process_memory d\r\nINNER JOIN sqlwatch_logger_snapshot_header h\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance = @SqlInstance\r\nORDER BY [Time]"
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "instance.sessions",
          "title": "Sessions",
          "description": null,
          "enabled": true,
          "source": "",
          "panelType": "TimeSeries",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 1,
            "order": 17,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "\nSELECT\n    h.report_time AS [Time],\n    'Running' AS [Series]\n    , MAX(d.running) AS [Value]\n    --,d.running,d.*\nFROM dbo.sqlwatch_logger_dm_exec_sessions_stats d WITH (NOLOCK)\nINNER JOIN dbo.sqlwatch_logger_snapshot_header h WITH (NOLOCK)\n    ON h.snapshot_time = d.snapshot_time\n    AND h.snapshot_type_id = d.snapshot_type_id\n    AND h.sql_instance = d.sql_instance\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\n    AND d.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\n    AND d.type = 1\nGROUP BY h.report_time\n\nUNION ALL\n\nSELECT h.report_time, 'Sleeping'\n, MAX(d.sleeping)\nFROM dbo.sqlwatch_logger_dm_exec_sessions_stats d WITH (NOLOCK)\nINNER JOIN dbo.sqlwatch_logger_snapshot_header h WITH (NOLOCK)\n    ON h.snapshot_time = d.snapshot_time\n    AND h.snapshot_type_id = d.snapshot_type_id\n    AND h.sql_instance = d.sql_instance\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\n    AND d.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\n    AND d.type = 1\nGROUP BY h.report_time\nUNION ALL\n\nSELECT h.report_time, 'Dormant'\n, MAX(d.dormant)\nFROM dbo.sqlwatch_logger_dm_exec_sessions_stats d WITH (NOLOCK)\nINNER JOIN dbo.sqlwatch_logger_snapshot_header h WITH (NOLOCK)\n    ON h.snapshot_time = d.snapshot_time\n    AND h.snapshot_type_id = d.snapshot_type_id\n    AND h.sql_instance = d.sql_instance\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\n    AND d.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\n    AND d.type = 1\nGROUP BY h.report_time",
            "liveQueries": "\r\nSELECT\r\n    h.report_time AS [Time],\r\n    'Running' AS [Series], d.running AS [Value]\r\nFROM sqlwatch_logger_dm_exec_sessions_stats d\r\nINNER JOIN sqlwatch_logger_snapshot_header h\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance = @SqlInstance\r\n    AND d.type = 1\r\n\r\nUNION ALL\r\n\r\nSELECT h.report_time, 'Sleeping', d.sleeping\r\nFROM sqlwatch_logger_dm_exec_sessions_stats d\r\nINNER JOIN sqlwatch_logger_snapshot_header h\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance = @SqlInstance\r\n    AND d.type = 1\r\n\r\nUNION ALL\r\n\r\nSELECT h.report_time, 'Dormant', d.dormant\r\nFROM sqlwatch_logger_dm_exec_sessions_stats d\r\nINNER JOIN sqlwatch_logger_snapshot_header h\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance = @SqlInstance\r\n    AND d.type = 1\r\nORDER BY [Time]"
          },
