        {
          "id": "instance.database_stats",
          "title": "Database Stats",
          "description": null,
          "enabled": true,
          "source": "",
          "panelType": "TimeSeries",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 2,
            "order": 26,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SELECT\n    h.report_time AS [Time],\n    'Database Count' AS [Series],\n    COUNT(DISTINCT d.sqlwatch_database_id) AS [Value]\nFROM dbo.sqlwatch_logger_disk_utilisation_database d WITH (NOLOCK)\nINNER JOIN dbo.sqlwatch_logger_snapshot_header h WITH (NOLOCK)\n    ON h.snapshot_time = d.snapshot_time\n    AND h.snapshot_type_id = d.snapshot_type_id\n    AND h.sql_instance = d.sql_instance\nWHERE h.report_time > DATEADD(WEEK, -2, GETDATE())\n    AND d.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\nGROUP BY h.report_time\n\nUNION ALL\n\nSELECT\n    h.report_time,\n    'Total Size (GB)',\n    CONVERT(MONEY,SUM(ISNULL(d.database_size_bytes,0)) / 1048576.0/1024)\nFROM dbo.sqlwatch_logger_disk_utilisation_database d WITH (NOLOCK)\nINNER JOIN dbo.sqlwatch_logger_snapshot_header h WITH (NOLOCK)\n    ON h.snapshot_time = d.snapshot_time\n    AND h.snapshot_type_id = d.snapshot_type_id\n    AND h.sql_instance = d.sql_instance\nWHERE h.report_time > DATEADD(WEEK, -2, GETDATE())\n    AND d.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\nGROUP BY h.report_time\nORDER BY [Time]",
            "liveQueries": "\r\nSELECT\r\n    h.report_time AS [Time],\r\n    'Database Count' AS [Series],\r\n    COUNT(DISTINCT d.sqlwatch_database_id) AS [Value]\r\nFROM sqlwatch_logger_disk_utilisation_database d\r\nINNER JOIN sqlwatch_logger_snapshot_header h\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance = @SqlInstance\r\nGROUP BY h.report_time\r\n\r\nUNION ALL\r\n\r\nSELECT\r\n    h.report_time,\r\n    'Total Size (MB)',\r\n    SUM(COALESCE(d.database_size_bytes,0)) / 1048576.0\r\nFROM sqlwatch_logger_disk_utilisation_database d\r\nINNER JOIN sqlwatch_logger_snapshot_header h\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance = @SqlInstance\r\nGROUP BY h.report_time\r\nORDER BY [Time]"
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "instance.tempdb",
          "title": "TempDB Size (GB)",
          "description": null,
          "enabled": true,
          "source": "",
          "panelType": "TimeSeries",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 1,
            "order": 27,
            "spanColumns": false
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "SELECT\n[Time]\n,[Series]\n,SUM([Value]) [Value]\nFROM(\nSELECT\n    h.report_time AS [Time],\n    'TempDB Size (GB)' AS [Series]\n    , file_name\n    --,CONVERT(MONEY,SUM(d.size_on_disk_bytes) / 1048576.0/1024) AS [Value]\n    ,CONVERT(MONEY,MAX(d.size_on_disk_bytes) / 1048576.0/1024) [Value]\n    --, COUNT(*)\n    --, mf.*\nFROM dbo.sqlwatch_logger_perf_file_stats d WITH (NOLOCK)\nINNER JOIN dbo.sqlwatch_logger_snapshot_header h WITH (NOLOCK)\n    ON h.snapshot_time = d.snapshot_time\n    AND h.snapshot_type_id = d.snapshot_type_id\n    AND h.sql_instance = d.sql_instance\nINNER JOIN dbo.sqlwatch_meta_master_file mf WITH (NOLOCK)\n    ON mf.sql_instance = d.sql_instance\n    AND mf.sqlwatch_database_id = d.sqlwatch_database_id\n    AND mf.sqlwatch_master_file_id = d.sqlwatch_master_file_id\nINNER JOIN dbo.sqlwatch_meta_database db WITH (NOLOCK)\n    ON db.sql_instance = mf.sql_instance\n    AND db.sqlwatch_database_id = mf.sqlwatch_database_id\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\n    AND d.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\n    AND db.database_name = 'tempdb'\nGROUP BY h.report_time,file_name\n) T\nGROUP BY [Time],[Series]\nORDER BY [Time]",
            "liveQueries": "\r\nSELECT\r\n    h.report_time AS [Time],\r\n    'TempDB Size (MB)' AS [Series],\r\n    SUM(d.size_on_disk_bytes) / 1048576.0 AS [Value]\r\nFROM sqlwatch_logger_perf_file_stats d\r\nINNER JOIN sqlwatch_logger_snapshot_header h\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nINNER JOIN sqlwatch_meta_master_file mf\r\n    ON mf.sql_instance = d.sql_instance\r\n    AND mf.sqlwatch_database_id = d.sqlwatch_database_id\r\n    AND mf.sqlwatch_master_file_id = d.sqlwatch_master_file_id\r\nINNER JOIN sqlwatch_meta_database db\r\n    ON db.sql_instance = mf.sql_instance\r\n    AND db.sqlwatch_database_id = mf.sqlwatch_database_id\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance = @SqlInstance\r\n    AND db.database_name = 'tempdb'\r\nGROUP BY h.report_time\r\nORDER BY h.report_time"
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "instance.checks_history",
          "title": "Check Failures Over Time",
          "description": null,
          "enabled": true,
          "source": "",
          "panelType": "TimeSeries",
          "chartType": "Bar",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 1,
            "order": 28,
            "spanColumns": true
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "\r\nSELECT\r\n    h.report_time AS [Time],\r\n    d.check_status AS [Series],\r\n    COUNT(*) AS [Value]\r\nFROM dbo.sqlwatch_logger_check d WITH (NOLOCK)\r\nINNER JOIN dbo.sqlwatch_logger_snapshot_header h WITH (NOLOCK)\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\r\n    AND d.check_status <> 'OK'\r\nGROUP BY h.report_time, d.check_status\r\nORDER BY h.report_time",
            "liveQueries": "\r\nSELECT\r\n    h.report_time AS [Time],\r\n    d.check_status AS [Series],\r\n    COUNT(*) AS [Value]\r\nFROM sqlwatch_logger_check d\r\nINNER JOIN sqlwatch_logger_snapshot_header h\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance = @SqlInstance\r\n    AND d.check_status <> 'OK'\r\nGROUP BY h.report_time, d.check_status\r\nORDER BY h.report_time"
          },
          "defaultDatabase": "master",
          "statUnit": "",
          "statThresholdKey": null,
          "barGaugeThresholdKey": null,
          "barGaugeUnitSuffix": "%",
          "valueFormat": "",
          "colorThresholds": [],
          "dataGridIsClickable": false,
          "dataGridMaxRows": 500,
          "dataGridTopRows": 0
        },
        {
          "id": "instance.checks_detail",
          "title": "Check Details",
          "description": null,
          "enabled": true,
          "source": "",
          "panelType": "DataGrid",
          "chartType": "Line",
          "height": 250,
          "refreshIntervalSeconds": null,
          "layout": {
            "column": 1,
            "order": 29,
            "spanColumns": true
          },
          "query": {
            "source": "sqlwatch",
            "sqlServer": "\r\nSELECT\r\n    d.snapshot_time,\r\n    c.check_name,\r\n    c.check_description,\r\n    d.check_value,\r\n    d.check_status,\r\n    d.check_exec_time_ms,\r\n    d.sql_instance\r\nFROM dbo.sqlwatch_logger_check d WITH (NOLOCK)\r\nINNER JOIN dbo.sqlwatch_logger_snapshot_header h WITH (NOLOCK)\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nINNER JOIN dbo.sqlwatch_meta_check c WITH (NOLOCK)\r\n    ON c.sql_instance = d.sql_instance\r\n    AND c.check_id = d.check_id\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance IN (SELECT value FROM STRING_SPLIT(@SqlInstance, ','))\r\nORDER BY d.snapshot_time DESC",
            "liveQueries": "\r\nSELECT\r\n    d.snapshot_time,\r\n    c.check_name,\r\n    c.check_description,\r\n    d.check_value,\r\n    d.check_status,\r\n    d.check_exec_time_ms,\r\n    d.sql_instance\r\nFROM sqlwatch_logger_check d\r\nINNER JOIN sqlwatch_logger_snapshot_header h\r\n    ON h.snapshot_time = d.snapshot_time\r\n    AND h.snapshot_type_id = d.snapshot_type_id\r\n    AND h.sql_instance = d.sql_instance\r\nINNER JOIN sqlwatch_meta_check c\r\n    ON c.sql_instance = d.sql_instance\r\n    AND c.check_id = d.check_id\r\nWHERE h.report_time BETWEEN @TimeFrom AND @TimeTo\r\n    AND d.sql_instance = @SqlInstance\r\nORDER BY d.snapshot_time DESC"
          },
          "defaultDatabase": "master",
          "statUnit": "",
