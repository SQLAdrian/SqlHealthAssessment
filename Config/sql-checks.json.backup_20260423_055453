    "Severity": "Warning",
    "SqlQuery": "DECLARE @dummy INT = 1;\n\nWITH MemoryGrantQueries AS (\n  SELECT\n    q.query_id,\n    q.query_hash,\n    q.query_text_id,\n    qs.count_executions,\n    qs.avg_query_max_used_memory,\n    qs.avg_dop,\n    CASE\n      WHEN qs.avg_query_max_used_memory > 100000 THEN 'HIGH_MEMORY_USAGE'\n      ELSE 'NORMAL_USAGE'\n    END AS memory_grant_indicator\n  FROM sys.query_store_query q\n  JOIN sys.query_store_runtime_stats qs ON q.query_id = qs.plan_id\n  WHERE qs.runtime_stats_interval_id = (\n    SELECT MAX(runtime_stats_interval_id)\n    FROM sys.query_store_runtime_stats\n  )\n  AND qs.count_executions > 10\n),\nMemoryFeedbackCandidates AS (\n  SELECT\n    query_id,\n    query_hash,\n    count_executions,\n    avg_query_max_used_memory,\n    memory_grant_indicator,\n    CASE\n      WHEN avg_query_max_used_memory > 50000 THEN 'LARGE_MEMORY_GRANT - Feedback can optimize'\n      ELSE 'MONITOR - Low memory usage'\n    END AS feedback_recommendation\n  FROM MemoryGrantQueries\n  WHERE memory_grant_indicator = 'HIGH_MEMORY_USAGE'\n)\nSELECT\n  query_id,\n  query_hash,\n  count_executions,\n  CAST(avg_query_max_used_memory / 1024.0 AS DECIMAL(10,2)) AS avg_memory_mb,\n  memory_grant_indicator,\n  feedback_recommendation\nFROM MemoryFeedbackCandidates\nORDER BY avg_query_max_used_memory DESC;",
