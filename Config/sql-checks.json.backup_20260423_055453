    "Id": "CFG_292",
    "Name": "MAXDOP set in accordance with CPU count",
    "Description": "The Maximum Degree of Parallelism (MAXDOP) option controls the maximum number of processors that SQL Server can utilize when executing a query in a parallel plan. Proper configuration is critical for maintaining optimal performance and preventing resource contention, as setting it too high or too low relative to the underlying hardware architecture (e.g., Symmetric Multiprocessing (SMP), Non-Uniform Memory Access (NUMA)) can severely degrade efficiency. This check validates that MAXDOP is configured according to current industry best practices to ensure efficient resource utilization and stable performance across various server environments.",
    "Category": "Configuration",
    "Severity": "High",
    "SqlQuery": "WITH ProcedureStats AS (\n  SELECT \n    ps.object_id,\n    ps.execution_count,\n    ps.total_worker_time / 1000 / ps.execution_count AS avg_cpu_ms,\n    ps.total_logical_reads / ps.execution_count AS avg_logical_reads,\n    OBJECT_NAME(ps.object_id) AS procedure_name\n  FROM sys.dm_exec_procedure_stats ps\n  WHERE ps.database_id = DB_ID()\n    AND ps.execution_count > 10\n),\nProcedureCode AS (\n  SELECT \n    o.object_id,\n    o.name AS procedure_name,\n    m.definition,\n    CASE \n      WHEN m.definition LIKE '%SET NOCOUNT ON%' THEN 1\n      ELSE 0\n    END AS has_nocount_on,\n    LEN(m.definition) - LEN(REPLACE(m.definition, ';', '')) + 1 AS statement_count\n  FROM sys.objects o\n  JOIN sys.sql_modules m ON o.object_id = m.object_id\n  WHERE o.type = 'P'\n    AND o.is_ms_shipped = 0\n)\nSELECT \n  pc.procedure_name,\n  pc.has_nocount_on,\n  pc.statement_count,\n  ps.execution_count,\n  CAST(ps.avg_cpu_ms AS DECIMAL(10,2)) AS avg_cpu_ms,\n  ps.avg_logical_reads,\n  CASE \n    WHEN pc.has_nocount_on = 0 AND pc.statement_count > 10 THEN 'HIGH_PRIORITY - Many statements without NOCOUNT'\n    WHEN pc.has_nocount_on = 0 AND ps.execution_count > 1000 THEN 'HIGH_PRIORITY - Frequently executed without NOCOUNT'\n    WHEN pc.has_nocount_on = 0 THEN 'MEDIUM_PRIORITY - Consider adding NOCOUNT'\n    ELSE 'OPTIMAL - NOCOUNT already set'\n  END AS nocount_recommendation,\n  CASE \n    WHEN pc.has_nocount_on = 0 AND pc.statement_count > 10 THEN \n      'ALTER PROCEDURE ' + pc.procedure_name + ' ADD ''SET NOCOUNT ON;'' at the beginning'\n    ELSE NULL\n  END AS remediation_suggestion\nFROM ProcedureCode pc\nLEFT JOIN ProcedureStats ps ON pc.object_id = ps.object_id\nWHERE pc.has_nocount_on = 0\n  AND (ps.execution_count > 10 OR pc.statement_count > 5)\nORDER BY \n  CASE nocount_recommendation\n    WHEN 'HIGH_PRIORITY - Many statements without NOCOUNT' THEN 1\n    WHEN 'HIGH_PRIORITY - Frequently executed without NOCOUNT' THEN 2\n    WHEN 'MEDIUM_PRIORITY - Consider adding NOCOUNT' THEN 3\n    ELSE 4\n  END,\n  ps.execution_count DESC;",
