  {
    "Id": "CFG_044",
    "Name": "Leverage Scalar UDF Inlining via Intelligent Query Processing (IQP)",
    "Description": "This check validates the automatic inlining of Scalar User-Defined Functions (UDFs), a critical feature enabled by Intelligent Query Processing (IQP). Traditionally, UDF execution can force iterative processing, which significantly degrades query performance due to repeated context switching. By enabling inlining, SQL Server rewrites these functions into native expressions, allowing the query optimizer to execute them with parallelism and dramatically improving overall database efficiency and scalability.",
    "Category": "Configuration",
    "Severity": "High",
    "SqlQuery": "DECLARE @dummy INT = 1;\n\nWITH UDFInliningStatus AS (\n  SELECT \n    DB_NAME() AS database_name,\n    compatibility_level,\n    CASE \n      WHEN compatibility_level >= 150 THEN 'ENABLED - Scalar UDF inlining active'\n      ELSE 'DISABLED - Requires compatibility level 150+'\n    END AS inlining_status\n  FROM sys.databases\n  WHERE database_id = DB_ID()\n),\nUDFInliningCandidates AS (\n  SELECT \n    SCHEMA_NAME(o.schema_id) + '.' + o.name AS function_name,\n    m.is_inlineable,\n    m.inline_type,\n    CASE\n      WHEN m.is_inlineable = 1 THEN 'CAN_BE_INLINED'\n      ELSE 'CANNOT_BE_INLINED'\n    END AS inlining_eligibility\n  FROM sys.objects o\n  JOIN sys.sql_modules m ON o.object_id = m.object_id\n  WHERE o.type = 'FN'\n    AND o.is_ms_shipped = 0\n)\nSELECT \n  uis.database_name,\n  uis.compatibility_level,\n  uis.inlining_status,\n  uic.function_name,\n  uic.inlining_eligibility,\n  uic.inline_type,\n  CASE \n    WHEN uis.compatibility_level >= 150 AND uic.is_inlineable = 1 THEN 'OPTIMAL - UDF will be automatically inlined'\n    WHEN uis.compatibility_level >= 150 AND uic.is_inlineable = 0 THEN 'REVIEW - UDF cannot be inlined, consider rewrite'\n    WHEN uis.compatibility_level < 150 THEN 'UPGRADE_NEEDED - Enable inlining with compatibility level 150+'\n    ELSE 'UNKNOWN'\n  END AS performance_status\nFROM UDFInliningStatus uis\nCROSS JOIN UDFInliningCandidates uic\nORDER BY uic.function_name;",
