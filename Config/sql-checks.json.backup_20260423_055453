  {
    "Id": "MON_038",
    "Name": "Buffer Cache Hit Ratio Monitoring",
    "Description": "This check monitors the buffer cache hit ratio, which measures the percentage of data requests that are served from memory (the buffer pool) versus those requiring physical reads from disk. A low ratio indicates that SQL Server is frequently missing cached data and must perform expensive I/O operations to retrieve pages from storage. This condition signals severe memory pressure or inefficient query patterns, leading directly to degraded application performance and increased latency across the entire instance due to excessive disk I/O bottlenecks.",
    "Category": "Monitoring",
    "Severity": "High",
    "SqlQuery": "DECLARE @SQLVersion INT = CONVERT(INT, LEFT(CONVERT(VARCHAR(10), SERVERPROPERTY('ProductVersion')), CHARINDEX('.', CONVERT(VARCHAR(10), SERVERPROPERTY('ProductVersion'))) - 1));\nDECLARE @SQLEdition NVARCHAR(128) = CONVERT(NVARCHAR(128), SERVERPROPERTY('Edition'));\n    \nIF @SQLVersion < 15\nBEGIN\n    SELECT\n    'SKIP' as result,\n    'Memory-optimized tempdb metadata requires SQL Server 2019 or higher' as reason,\n    @SQLVersion as current_version;\n    RETURN;\n    END\n    \nIF @SQLEdition NOT IN ('Enterprise Edition', 'Developer Edition')\n    BEGIN\n    SELECT\n    'SKIP' as result,\n    'Memory-optimized tempdb metadata requires Enterprise or Developer edition' as reason,\n    @SQLEdition as current_edition;\n    RETURN;\nEND\n    \n    WITH TempDBActivity AS (\n    SELECT\n    total_tempdb_operations = COUNT(*),\n    avg_operations_per_minute = COUNT(*) / NULLIF(DATEDIFF(MINUTE, MIN(login_time), MAX(login_time)), 0),\n    tempdb_data_files = (SELECT COUNT(*) FROM tempdb.sys.database_files WHERE type_desc = 'ROWS'),\n    tempdb_size_gb = CAST(SUM(size * 8.0 / 1024 / 1024) AS DECIMAL(10,2))\n    FROM sys.dm_exec_sessions s\n    WHERE s.database_id = 2 \n    AND s.login_time >= DATEADD(HOUR, -1, GETDATE())\n),\nPAGELATCHAnalysis AS (\n    SELECT\n    tempdb_pagelatch_waits = SUM(CASE WHEN wait_type = 'PAGELATCH_UP' AND page_id BETWEEN 0x01000000 AND 0x01FFFFFF THEN waiting_tasks_count ELSE 0 END),\n    total_pagelatch_waits = SUM(waiting_tasks_count)\n    FROM sys.dm_os_wait_stats\n    WHERE wait_type LIKE 'PAGELATCH_%'\n    )\nSELECT\n    [Check_Result] = CASE\n    WHEN SERVERPROPERTY('IsTempDbMetadataMemoryOptimized') = 1 THEN 'MEMORY_OPTIMIZED_ENABLED'\n    WHEN SERVERPROPERTY('IsTempDbMetadataMemoryOptimized') = 0 AND TA.avg_operations_per_minute > 100 THEN 'RECOMMENDED_FOR_WORKLOAD'\n    WHEN SERVERPROPERTY('IsTempDbMetadataMemoryOptimized') = 0 AND PA.tempdb_pagelatch_waits > 1000 THEN 'RECOMMENDED_FOR_CONTENTION'\n    WHEN SERVERPROPERTY('IsTempDbMetadataMemoryOptimized') = 0 THEN 'OPTIONAL_CONSIDERATION'\n    ELSE 'UNKNOWN_STATUS'\n    END,\n    [Memory_Optimized_Enabled] = SERVERPROPERTY('IsTempDbMetadataMemoryOptimized'),\n    [SQL_Server_Version] = @SQLVersion,\n    [Edition] = @SQLEdition,\n    [TempDB_Data_Files] = TA.tempdb_data_files,\n    [TempDB_Size_GB] = TA.tempdb_size_gb,\n    [Avg_TempDB_Operations_Per_Minute] = TA.avg_operations_per_minute,\n    [TempDB_PAGELATCH_Waits] = PA.tempdb_pagelatch_waits,\n    [Workload_Intensity] = CASE\n    WHEN TA.avg_operations_per_minute > 500 THEN 'VERY_HIGH'\n    WHEN TA.avg_operations_per_minute > 100 THEN 'HIGH'\n    WHEN TA.avg_operations_per_minute > 25 THEN 'MODERATE'\n    ELSE 'LOW'\n    END,\n    [Contention_Level] = CASE\n    WHEN PA.tempdb_pagelatch_waits > 10000 THEN 'CRITICAL'\n    WHEN PA.tempdb_pagelatch_waits > 1000 THEN 'HIGH'\n    WHEN PA.tempdb_pagelatch_waits > 100 THEN 'MODERATE'\n    ELSE 'LOW'\n    END,\n    [Performance_Benefit] = CASE\n    WHEN SERVERPROPERTY('IsTempDbMetadataMemoryOptimized') = 1 THEN 'Eliminating tempdb system table latch contention'\n    WHEN TA.avg_operations_per_minute > 100 OR PA.tempdb_pagelatch_waits > 1000 THEN 'Significant performance improvement expected'\n    ELSE 'Moderate performance benefit possible'\n    END,\n    [Recommended_Action] = CASE\n    WHEN SERVERPROPERTY('IsTempDbMetadataMemoryOptimized') = 1 THEN 'Configuration is optimal - memory-optimized metadata enabled'\n    WHEN @SQLVersion < 15 THEN 'Upgrade to SQL Server 2019+ to enable this feature'\n    WHEN @SQLEdition NOT IN ('Enterprise Edition', 'Developer Edition') THEN 'Upgrade to Enterprise/Developer edition'\n    WHEN TA.avg_operations_per_minute > 100 OR PA.tempdb_pagelatch_waits > 1000 THEN 'Enable memory-optimized tempdb metadata for performance'\n    ELSE 'Consider enabling for future workload growth'\n    END\nFROM TempDBActivity TA\nCROSS JOIN PAGELATCHAnalysis PA;",
