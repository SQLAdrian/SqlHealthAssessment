  {
    "Id": "CFG_043",
    "Name": "Avoid Scalar UDFs in WHERE/SELECT — Use Inline TVFs or Rewrite as Joins",
    "Description": "This check validates that complex business logic is not implemented using Scalar User-Defined Functions (UDFs) within WHERE clauses or SELECT statements. Using scalar UDFs in this manner forces the SQL Server query engine into row-by-row processing (RBAR), which severely limits parallelism and causes significant performance degradation, making queries inefficient and non-scalable for large datasets.",
    "Category": "Configuration",
    "Severity": "High",
    "SqlQuery": "DECLARE @dummy INT = 1;\n\nWITH UDFUsage AS (\n  SELECT\n    qs.object_id,\n    OBJECT_NAME(qs.object_id) AS object_name,\n    qs.execution_count,\n    qs.total_worker_time / 1000 / qs.execution_count AS avg_cpu_ms,\n    qs.total_logical_reads / qs.execution_count AS avg_logical_reads\n  FROM sys.dm_exec_function_stats qs\n  WHERE qs.database_id = DB_ID()\n    AND qs.execution_count > 10\n),\nUDFDetails AS (\n  SELECT \n    SCHEMA_NAME(o.schema_id) + '.' + o.name AS function_name,\n    o.object_id,\n    m.definition,\n    CASE \n      WHEN m.definition LIKE '%SELECT %FROM%' THEN 'DATA_ACCESSING_UDF'\n      WHEN m.definition LIKE '%WHILE %' OR m.definition LIKE '%CURSOR%' THEN 'COMPLEX_UDF'\n      WHEN LEN(m.definition) > 1000 THEN 'LARGE_UDF'\n      ELSE 'SIMPLE_UDF'\n    END AS udf_type,\n    LEN(m.definition) AS code_length\n  FROM sys.objects o\n  JOIN sys.sql_modules m ON o.object_id = m.object_id\n  WHERE o.type = 'FN'\n    AND o.is_ms_shipped = 0\n)\nSELECT \n  ud.function_name,\n  ud.udf_type,\n  ud.code_length,\n  uu.execution_count,\n  CAST(uu.avg_cpu_ms AS DECIMAL(10,2)) AS avg_cpu_ms,\n  uu.avg_logical_reads,\n  CASE \n    WHEN ud.udf_type IN ('DATA_ACCESSING_UDF', 'COMPLEX_UDF') AND uu.execution_count > 100 THEN 'CRITICAL - High impact scalar UDF'\n    WHEN ud.udf_type = 'LARGE_UDF' AND uu.avg_cpu_ms > 10 THEN 'HIGH - Expensive scalar UDF'\n    WHEN uu.avg_cpu_ms > 5 AND uu.execution_count > 50 THEN 'MEDIUM - Moderate impact scalar UDF'\n    WHEN uu.execution_count > 10 THEN 'LOW - Monitor scalar UDF usage'\n    ELSE 'UNKNOWN - Limited usage data'\n  END AS performance_impact,\n  CASE \n    WHEN ud.udf_type IN ('DATA_ACCESSING_UDF', 'COMPLEX_UDF') THEN \n      'Convert to inline TVF or rewrite as JOIN - scalar UDFs prevent parallelism'\n    WHEN ud.udf_type = 'LARGE_UDF' THEN \n      'Consider simplifying logic or converting to computed column'\n    ELSE 'Monitor performance and usage patterns'\n  END AS recommendation\nFROM UDFDetails ud\nLEFT JOIN UDFUsage uu ON ud.object_id = uu.object_id\nWHERE uu.execution_count > 0 OR ud.udf_type IN ('DATA_ACCESSING_UDF', 'COMPLEX_UDF', 'LARGE_UDF')\nORDER BY ISNULL(uu.avg_cpu_ms, 0) DESC;",
