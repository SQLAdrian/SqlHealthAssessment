    "Id": "BKP_001",
    "Name": "Complete and Current Database Backup Chains",
    "Description": "This check validates that a complete, current, and secure backup chain exists for critical databases. Regular full backups are foundational to data recovery, ensuring the Recovery Point Objective (RPO) is met by minimizing data loss. Best practices mandate not only automated scheduling but also rigorous testing of restores, implementing encryption for stored backups, and managing differential/log backups correctly to maintain a viable disaster recovery plan.",
    "Category": "Backup",
    "Severity": "Critical",
    "SqlQuery": "SELECT\n    d.name AS database_name,\n    CASE\n        WHEN d.recovery_model = 3 THEN 'SIMPLE - No log backups needed'\n        WHEN EXISTS (\n            SELECT 1 FROM msdb.dbo.backupset b\n            WHERE b.database_name = d.name\n            AND b.type = 'D'\n            AND b.backup_finish_date > DATEADD(DAY, -7, GETDATE())\n        ) THEN 'PASS - Full backup within 7 days'\n        WHEN EXISTS (\n            SELECT 1 FROM msdb.dbo.backupset b\n            WHERE b.database_name = d.name\n            AND b.type = 'I'\n            AND b.backup_finish_date > DATEADD(DAY, -7, GETDATE())\n        ) THEN 'PASS - Differential backup within 7 days'\n        ELSE 'FAIL - No recent full or differential backup'\n    END AS result,\n    CASE\n        WHEN d.recovery_model = 3 THEN CONCAT(d.name, ': Simple recovery - log backups not required')\n        WHEN EXISTS (\n            SELECT 1 FROM msdb.dbo.backupset b\n            WHERE b.database_name = d.name\n            AND b.type = 'D'\n            AND b.backup_finish_date > DATEADD(DAY, -7, GETDATE())\n        ) THEN CONCAT(d.name, ': Full backup found within 7 days')\n        WHEN EXISTS (\n            SELECT 1 FROM msdb.dbo.backupset b\n            WHERE b.database_name = d.name\n            AND b.type = 'I'\n            AND b.backup_finish_date > DATEADD(DAY, -7, GETDATE())\n        ) THEN CONCAT(d.name, ': Differential backup found within 7 days')\n        ELSE CONCAT(d.name, ': CRITICAL - No backup found in last 7 days')\n    END AS message,\n    d.recovery_model_desc,\n    MAX(b.backup_finish_date) AS last_backup_date\nFROM sys.databases d\nLEFT JOIN msdb.dbo.backupset b ON b.database_name = d.name AND b.type IN ('D', 'I')\nWHERE d.database_id > 4  -- Exclude system databases\n    AND d.state = 0  -- Online databases only\n    AND d.is_read_only = 0  -- Exclude read-only databases\nGROUP BY d.name, d.recovery_model, d.recovery_model_desc\nORDER BY d.name;",
