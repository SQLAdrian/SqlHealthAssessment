  {
    "Id": "CFG_246",
    "Name": "Index Overhead Management and Optimization",
    "Description": "This check validates the existence, usage frequency, and structural integrity of database indexes. Indexes are crucial for optimizing query performance (read operations), but poorly managed or unused indexes introduce significant overhead during write operations (INSERT, UPDATE, DELETE). The assessment determines if the potential read-speed benefits outweigh the increased maintenance cost, storage footprint, and transaction logging associated with dormant structures.",
    "Category": "Configuration",
    "Severity": "Warning",
    "SqlQuery": "DECLARE @cnt INT;\nSELECT @cnt = COUNT(*) FROM (\nWITH IndexUsage AS (\n  SELECT \n    ius.object_id,\n    ius.index_id,\n    ius.user_seeks,\n    ius.user_scans,\n    ius.user_lookups,\n    ius.user_updates,\n    ius.last_user_seek,\n    ius.last_user_scan,\n    ius.last_user_lookup,\n    ius.last_user_update,\n    CASE \n      WHEN ius.user_seeks + ius.user_scans + ius.user_lookups = 0 AND ius.user_updates > 0 THEN 'PURE_OVERHEAD'\n      WHEN ius.user_seeks + ius.user_scans + ius.user_lookups = 0 AND ius.user_updates = 0 THEN 'COMPLETELY_UNUSED'\n      WHEN ius.user_updates > (ius.user_seeks + ius.user_scans + ius.user_lookups) * 5 THEN 'HIGH_MAINTENANCE_LOW_BENEFIT'\n      WHEN ius.user_seeks + ius.user_scans + ius.user_lookups > 0 THEN 'USED_INDEX'\n      ELSE 'UNKNOWN'\n    END AS usage_assessment\n  FROM sys.dm_db_index_usage_stats ius\n  WHERE ius.database_id = DB_ID()\n),\nIndexDetails AS (\n  SELECT \n    OBJECT_NAME(i.object_id) AS table_name,\n    i.name AS index_name,\n    i.type_desc,\n    i.is_primary_key,\n    i.is_unique,\n    SIZE_MB = (SUM(a.total_pages) * 8.0 / 1024),\n    iu.user_seeks,\n    iu.user_scans,\n    iu.user_lookups,\n    iu.user_updates,\n    iu.usage_assessment,\n    iu.last_user_update\n  FROM sys.indexes i\n  JOIN sys.objects o ON i.object_id = o.object_id\n  JOIN sys.partitions p ON i.object_id = p.object_id AND i.index_id = p.index_id\n  JOIN sys.allocation_units a ON p.partition_id = a.container_id\n  LEFT JOIN IndexUsage iu ON i.object_id = iu.object_id AND i.index_id = iu.index_id\n  WHERE o.is_ms_shipped = 0\n    AND i.is_primary_key = 0\n    AND i.is_unique = 0\n    AND i.type IN (1, 2)\n  GROUP BY OBJECT_NAME(i.object_id), i.name, i.type_desc, i.is_primary_key, i.is_unique,\n           iu.user_seeks, iu.user_scans, iu.user_lookups, iu.user_updates, iu.usage_assessment, iu.last_user_update\n)\nSELECT \n  table_name,\n  index_name,\n  type_desc,\n  CAST(SIZE_MB AS DECIMAL(10,2)) AS size_mb,\n  user_seeks,\n  user_scans,\n  user_lookups,\n  user_updates,\n  usage_assessment,\n  last_user_update,\n  CASE \n    WHEN usage_assessment IN ('PURE_OVERHEAD', 'COMPLETELY_UNUSED') THEN 'DROP_CANDIDATE'\n    WHEN usage_assessment = 'HIGH_MAINTENANCE_LOW_BENEFIT' THEN 'REVIEW_CANDIDATE'\n    ELSE 'KEEP_INDEX'\n  END AS recommendation,\n  CASE \n    WHEN usage_assessment IN ('PURE_OVERHEAD', 'COMPLETELY_UNUSED') THEN \n      'DROP INDEX [' + index_name + '] ON [' + table_name + '];'\n    ELSE NULL\n  END AS drop_script\nFROM IndexDetails\nWHERE usage_assessment IN ('PURE_OVERHEAD', 'COMPLETELY_UNUSED', 'HIGH_MAINTENANCE_LOW_BENEFIT')\nORDER BY \n  CASE usage_assessment\n    WHEN 'PURE_OVERHEAD' THEN 1\n    WHEN 'COMPLETELY_UNUSED' THEN 2\n    WHEN 'HIGH_MAINTENANCE_LOW_BENEFIT' THEN 3\n    ELSE 4\n  END,\n  SIZE_MB DESC;) AS t;\nSELECT\n    CASE WHEN @cnt = 0 THEN 'PASS' ELSE 'FAIL' END AS result,\n    CASE WHEN @cnt = 0 THEN 'No issues found' ELSE CONCAT(@cnt, ' issue(s) detected') END AS message;",
