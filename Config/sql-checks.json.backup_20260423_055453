    "SqlQuery": "DECLARE @sql_version INT = CONVERT(INT, LEFT(CONVERT(VARCHAR(10), SERVERPROPERTY('ProductVersion')), CHARINDEX('.', CONVERT(VARCHAR(10), SERVERPROPERTY('ProductVersion'))) - 1));\nDECLARE @edition NVARCHAR(128) = CAST(SERVERPROPERTY('Edition') AS NVARCHAR(128));\nDECLARE @is_enabled BIT = CAST(SERVERPROPERTY('IsHadrEnabled') AS BIT);\nSELECT\nCASE\nWHEN @sql_version < 13 OR (@edition NOT LIKE '%Enterprise%' AND @edition NOT LIKE '%Developer%') THEN 'SKIP'\nWHEN @is_enabled = 0 THEN 'FAIL'\nWHEN NOT EXISTS (SELECT 1 FROM sys.availability_groups) THEN 'INFO'\nWHEN EXISTS (SELECT 1 FROM sys.dm_hadr_automatic_seeding WHERE current_state = 'FAILED') THEN 'FAIL'\nELSE 'PASS'\nEND AS result,\nCASE\nWHEN @sql_version < 13 OR (@edition NOT LIKE '%Enterprise%' AND @edition NOT LIKE '%Developer%') THEN 'Automatic seeding not supported on this version/edition'\nWHEN @is_enabled = 0 THEN 'Always On is not enabled'\nWHEN NOT EXISTS (SELECT 1 FROM sys.availability_groups) THEN 'No availability groups configured'\nWHEN EXISTS (SELECT 1 FROM sys.dm_hadr_automatic_seeding WHERE current_state = 'FAILED') THEN 'Automatic seeding failures detected'\nELSE 'Automatic seeding is functioning properly'\nEND AS message;",
