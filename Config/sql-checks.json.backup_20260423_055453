  {
    "Id": "PRF_015",
    "Name": "Ensure Database Statistics Are Current for Optimal Query Planning",
    "Description": "This check validates that database statistics are regularly maintained and up-to-date. The Query Optimizer relies heavily on accurate statistics to estimate data distribution, cardinality, and index selectivity when generating execution plans. If statistics become stale due to significant data modifications (INSERT, UPDATE, DELETE) or large batch operations, the optimizer may choose suboptimal query paths (e.g., table scans instead of efficient index seeks), leading to severe application performance degradation and potential service instability. While SQL Server includes automatic update mechanisms, manual intervention using FULLSCAN updates is often necessary for critical tables or after major ETL processes to ensure optimal query execution plans are consistently generated.|\nIt is crucial to monitor the freshness of statistics as part of routine database maintenance procedures.",
    "Category": "Performance",
    "Severity": "Warning",
    "SqlQuery": "DECLARE @cnt INT;\nSELECT @cnt = COUNT(*) FROM (\nWITH StatisticsInfo AS (\n  SELECT \n    OBJECT_NAME(s.object_id) AS table_name,\n    s.name AS stats_name,\n    sp.last_updated,\n    sp.modification_counter,\n    sp.rows,\n    sp.rows_sampled,\n    CASE \n      WHEN sp.rows_sampled = sp.rows THEN 100\n      ELSE CAST(sp.rows_sampled * 100.0 / sp.rows AS DECIMAL(5,2))\n    END AS sample_percent,\n    DATEDIFF(DAY, sp.last_updated, GETDATE()) AS days_old,\n    CASE \n      WHEN sp.modification_counter > sp.rows * 0.2 THEN 'HIGH_MODIFICATIONS'\n      WHEN sp.modification_counter > sp.rows * 0.1 THEN 'MODERATE_MODIFICATIONS'\n      ELSE 'LOW_MODIFICATIONS'\n    END AS modification_level\n  FROM sys.stats s\n  CROSS APPLY sys.dm_db_stats_properties(s.object_id, s.stats_id) sp\n  WHERE sp.rows > 0\n    AND s.object_id > 100\n    AND s.auto_created = 0 \n),\nStatisticsRecommendations AS (\n  SELECT \n    table_name,\n    stats_name,\n    days_old,\n    sample_percent,\n    modification_level,\n    CASE \n      WHEN days_old > 30 OR modification_level = 'HIGH_MODIFICATIONS' THEN 'FULLSCAN_UPDATE'\n      WHEN days_old > 7 AND modification_level = 'MODERATE_MODIFICATIONS' THEN 'SAMPLE_UPDATE'\n      WHEN sample_percent < 50 THEN 'INCREASE_SAMPLE'\n      ELSE 'CURRENT_OK'\n    END AS maintenance_recommendation,\n    CASE \n      WHEN days_old > 30 OR modification_level = 'HIGH_MODIFICATIONS' THEN \n        'UPDATE STATISTICS [' + table_name + '] ([' + stats_name + ']) WITH FULLSCAN;'\n      WHEN days_old > 7 AND modification_level = 'MODERATE_MODIFICATIONS' THEN \n        'UPDATE STATISTICS [' + table_name + '] ([' + stats_name + ']) WITH SAMPLE 50 PERCENT;'\n      WHEN sample_percent < 50 THEN \n        'UPDATE STATISTICS [' + table_name + '] ([' + stats_name + ']) WITH SAMPLE 80 PERCENT;'\n      ELSE NULL\n    END AS maintenance_script\n  FROM StatisticsInfo\n)\nSELECT \n  table_name,\n  stats_name,\n  days_old,\n  sample_percent,\n  modification_level,\n  maintenance_recommendation,\n  maintenance_script,\n  CASE maintenance_recommendation\n    WHEN 'FULLSCAN_UPDATE' THEN 'HIGH_PRIORITY - Schedule FULLSCAN update'\n    WHEN 'SAMPLE_UPDATE' THEN 'MEDIUM_PRIORITY - Consider sample update'\n    WHEN 'INCREASE_SAMPLE' THEN 'LOW_PRIORITY - Increase sampling rate'\n    ELSE 'MONITOR - Statistics are current'\n  END AS action_priority\nFROM StatisticsRecommendations\nWHERE maintenance_recommendation <> 'CURRENT_OK'\nORDER BY \n  CASE maintenance_recommendation\n    WHEN 'FULLSCAN_UPDATE' THEN 1\n    WHEN 'SAMPLE_UPDATE' THEN 2\n    WHEN 'INCREASE_SAMPLE' THEN 3\n    ELSE 4\n  END,\n  days_old DESC;) AS t;\nSELECT\n    CASE WHEN @cnt = 0 THEN 'PASS' ELSE 'FAIL' END AS result,\n    CASE WHEN @cnt = 0 THEN 'No issues found' ELSE CONCAT(@cnt, ' issue(s) detected') END AS message;",
