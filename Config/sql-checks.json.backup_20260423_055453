  {
    "Id": "CFG_283",
    "Name": "Auto-Update Statistics should be enabled for Optimal Query Performance",
    "Description": "The Query Optimizer relies heavily on accurate stored statistics to estimate data distribution and cardinality, which is fundamental for generating efficient query execution plans. If these statistics become outdated due to significant changes in the underlying data (inserts, updates, deletes), the optimizer may choose suboptimal index scans or join methods, leading to severe performance degradation and plan regression. Enabling Auto Update Statistics ensures that SQL Server proactively maintains necessary statistical information across most workloads, minimizing manual intervention while preserving query efficiency.",
    "Category": "Configuration",
    "Severity": "High",
    "SqlQuery": "WITH DatabaseStats AS (\n  SELECT \n    d.name AS database_name,\n    d.is_auto_update_stats_on,\n    d.is_auto_update_stats_async_on,\n    d.database_id\n  FROM sys.databases d\n  WHERE d.database_id > 4\n),\nQueryWorkload AS (\n  SELECT \n    DB_NAME() AS database_name,\n    COUNT(*) AS query_count_24h,\n    AVG(total_elapsed_time) / 1000.0 AS avg_query_duration_ms,\n    MAX(total_elapsed_time) / 1000.0 AS max_query_duration_ms,\n    CASE \n      WHEN AVG(total_elapsed_time) / 1000.0 < 100 THEN 'FAST_OLTP'\n      WHEN AVG(total_elapsed_time) / 1000.0 < 1000 THEN 'MODERATE_OLTP'\n      ELSE 'OLAP_OR_REPORTING'\n    END AS workload_characterization\n  FROM sys.dm_exec_query_stats\n  WHERE last_execution_time >= DATEADD(HOUR, -24, GETDATE())\n  GROUP BY DB_NAME()\n),\nStatsUpdatePatterns AS (\n  SELECT \n    DB_NAME() AS database_name,\n    COUNT(*) AS total_statistics,\n    AVG(DATEDIFF(DAY, sp.last_updated, GETDATE())) AS avg_stats_age_days,\n    SUM(CASE WHEN DATEDIFF(DAY, sp.last_updated, GETDATE()) > 7 THEN 1 ELSE 0 END) AS stale_stats_count\n  FROM sys.stats s\n  CROSS APPLY sys.dm_db_stats_properties(s.object_id, s.stats_id) sp\n  WHERE s.object_id > 100\n  GROUP BY DB_NAME()\n)\nSELECT \n  ds.database_name,\n  ds.is_auto_update_stats_on,\n  ds.is_auto_update_stats_async_on,\n  qw.workload_characterization,\n  qw.avg_query_duration_ms,\n  sp.avg_stats_age_days,\n  sp.stale_stats_count,\n  CASE \n    WHEN ds.is_auto_update_stats_async_on = 1 THEN 'ASYNC_ENABLED - Optimal for OLTP'\n    WHEN qw.workload_characterization LIKE '%OLTP%' AND ds.is_auto_update_stats_on = 1 AND ds.is_auto_update_stats_async_on = 0 THEN \n      'ENABLE_ASYNC - Prevent compilation stalls in OLTP'\n    WHEN qw.workload_characterization = 'OLAP_OR_REPORTING' AND ds.is_auto_update_stats_async_on = 0 THEN \n      'KEEP_SYNC - Acceptable for reporting workloads'\n    WHEN ds.is_auto_update_stats_on = 0 THEN 'ENABLE_AUTO_UPDATE_FIRST'\n    ELSE 'REVIEW_CONFIGURATION'\n  END AS recommendation,\n  CASE \n    WHEN qw.workload_characterization LIKE '%OLTP%' AND ds.is_auto_update_stats_async_on = 0 THEN \n      'ALTER DATABASE [' + ds.database_name + '] SET AUTO_UPDATE_STATISTICS_ASYNC ON;'\n    ELSE NULL\n  END AS implementation_script\nFROM DatabaseStats ds\nLEFT JOIN QueryWorkload qw ON ds.database_name = qw.database_name\nLEFT JOIN StatsUpdatePatterns sp ON ds.database_name = sp.database_name\nORDER BY \n  CASE recommendation\n    WHEN 'ASYNC_ENABLED - Optimal for OLTP' THEN 4\n    WHEN 'ENABLE_ASYNC - Prevent compilation stalls in OLTP' THEN 1\n    WHEN 'KEEP_SYNC - Acceptable for reporting workloads' THEN 3\n    WHEN 'ENABLE_AUTO_UPDATE_FIRST' THEN 2\n    ELSE 5\n  END,\n  ds.database_name;",
