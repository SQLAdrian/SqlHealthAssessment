  {
    "Id": "CFG_002",
    "Name": "Set MAXDOP based on NUMA node core count — use cores per NUMA node",
    "Description": "MAXDOP (max degree of parallelism) controls the maximum number of CPU cores that can be used for parallel query execution in SQL Server. The default value of 0 allows unlimited parallelism, which is highly discouraged on modern, high-core systems as it can lead to excessive CXPACKET waits, memory grant pressure, and severe resource contention. Proper configuration requires understanding the server's NUMA (Non-Uniform Memory Access) topology. Best practices recommend setting MAXDOP based on the cores per NUMA node to balance parallelism benefits against system stability and optimal performance.",
    "Category": "Configuration",
    "Severity": "High",
    "SqlQuery": "DECLARE @maxdop INT;\nDECLARE @numa_nodes INT;\nDECLARE @total_cpus INT;\nDECLARE @cpus_per_numa INT;\nDECLARE @recommended INT;\nDECLARE @result NVARCHAR(10);\nDECLARE @message NVARCHAR(4000);\n\nSELECT @maxdop = CAST(value_in_use AS INT)\nFROM sys.configurations\nWHERE name = 'max degree of parallelism';\n\nSELECT @total_cpus = cpu_count\nFROM sys.dm_os_sys_info;\n\nSELECT @numa_nodes = COUNT(*)\nFROM sys.dm_os_nodes;\n\nIF @numa_nodes = 0 SET @numa_nodes = 1;  \n\nSET @cpus_per_numa = @total_cpus / @numa_nodes;\nSET @recommended = CASE WHEN @cpus_per_numa <= 8 THEN @cpus_per_numa ELSE 8 END;\n\nIF @maxdop = 0\nBEGIN\n    SET @result = 'FAIL';\n    SET @message = 'MAXDOP is set to 0 (unlimited) — should be configured based on NUMA node cores.';\nEND\nELSE IF @maxdop > @recommended\nBEGIN\n    SET @result = 'FAIL';\n    SET @message = CONCAT('MAXDOP is set to ', @maxdop, ', which exceeds the recommended maximum of ', @recommended, ' for this system (', @cpus_per_numa, ' cores per NUMA node).');\nEND\nELSE IF @maxdop < 1\nBEGIN\n    SET @result = 'FAIL';\n    SET @message = CONCAT('MAXDOP is set to ', @maxdop, ' — must be at least 1.');\nEND\nELSE\nBEGIN\n    SET @result = 'PASS';\n    SET @message = CONCAT('MAXDOP is set to ', @maxdop, ', which is within the recommended range of 1-', @recommended, ' for this system (', @cpus_per_numa, ' cores per NUMA node).');\nEND;\n\nSELECT @result AS result, @message AS message;",
