  {
    "Id": "GEN_041",
    "Name": "Database Mail Configuration Check for Operational Visibility",
    "Description": "This check validates the best practice of storing large binary objects (BLOBs) using dedicated file system mechanisms, such as FILESTREAM or external data sources. Storing massive files directly within standard database columns (like VARBINARY(MAX)) can severely degrade performance by consuming excessive buffer pool memory and increasing transaction log overhead. Proper separation ensures optimal resource utilization, improves scalability, and enhances security by isolating large unstructured data from the core relational database structure.",
    "Category": "Availability",
    "Severity": "High",
    "SqlQuery": "WITH BLOBColumns AS (\n  SELECT \n    SCHEMA_NAME(o.schema_id) AS schema_name,\n    OBJECT_NAME(c.object_id) AS table_name,\n    c.name AS column_name,\n    c.is_filestream,\n    CASE \n      WHEN c.is_filestream = 1 THEN 'FILESTREAM'\n      ELSE 'VARBINARY(MAX)'\n    END AS storage_method,\n    o.create_date,\n    o.modify_date\n  FROM sys.columns c\n  JOIN sys.objects o ON c.object_id = o.object_id\n  WHERE c.user_type_id = TYPE_ID('varbinary')\n    AND c.max_length = -1\n    AND o.is_ms_shipped = 0\n    AND o.type = 'U'\n),\nTableSize AS (\n  SELECT \n    SCHEMA_NAME(o.schema_id) + '.' + OBJECT_NAME(p.object_id) AS table_name,\n    SUM(a.total_pages) * 8 / 1024 / 1024 AS size_gb,\n    SUM(p.rows) AS row_count\n  FROM sys.partitions p\n  JOIN sys.objects o ON p.object_id = o.object_id\n  JOIN sys.allocation_units a ON p.partition_id = a.container_id\n  WHERE o.is_ms_shipped = 0\n    AND o.type = 'U'\n  GROUP BY SCHEMA_NAME(o.schema_id) + '.' + OBJECT_NAME(p.object_id)\n)\nSELECT \n  bc.schema_name,\n  bc.table_name,\n  bc.column_name,\n  bc.storage_method,\n  ts.size_gb,\n  ts.row_count,\n  CASE \n    WHEN bc.storage_method = 'VARBINARY(MAX)' AND ts.size_gb > 10 THEN 'HIGH - Large table with VARBINARY(MAX), consider FILESTREAM'\n    WHEN bc.storage_method = 'VARBINARY(MAX)' AND ts.size_gb > 1 THEN 'MEDIUM - Medium table with VARBINARY(MAX), evaluate FILESTREAM'\n    WHEN bc.storage_method = 'FILESTREAM' THEN 'OPTIMAL - FILESTREAM properly configured'\n    ELSE 'REVIEW - Assess BLOB usage patterns'\n  END AS recommendation_priority,\n  CASE \n    WHEN bc.storage_method = 'VARBINARY(MAX)' THEN \n      'Consider migrating to FILESTREAM for better performance with large BLOBs'\n    WHEN bc.storage_method = 'FILESTREAM' THEN \n      'FILESTREAM configuration is optimal for large BLOB data'\n    ELSE 'Monitor BLOB usage and performance'\n  END AS action_recommended\nFROM BLOBColumns bc\nLEFT JOIN TableSize ts ON bc.schema_name + '.' + bc.table_name = ts.table_name\nORDER BY \n  CASE recommendation_priority\n    WHEN 'HIGH - Large table with VARBINARY(MAX), consider FILESTREAM' THEN 1\n    WHEN 'MEDIUM - Medium table with VARBINARY(MAX), evaluate FILESTREAM' THEN 2\n    WHEN 'OPTIMAL - FILESTREAM properly configured' THEN 3\n    ELSE 4\n  END,\n  ts.size_gb DESC;",
