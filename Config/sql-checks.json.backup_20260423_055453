    "Description": "Stored procedures configured to execute automatically when SQL Server starts up (via the 'scan for startup procs' configuration option) pose a significant security risk. These procedures run with elevated permissions, often before full authentication and authorization contexts are established. If undocumented or unnecessary code is present, it can create hidden persistence mechanisms, enabling unauthorized actions or backdoors even if other security layers are intact. Reviewing these procedures is critical for maintaining the integrity of the SQL Server instance.",
    "Category": "Surface_Area",
    "Severity": "High",
    "SqlQuery": "WITH StartupProcedures AS (\n  SELECT SCHEMA_NAME(sp.schema_id) + '.' + sp.name AS procedure_name,\n    sp.object_id,\n    sp.create_date,\n    sp.modify_date,\n    dp.name AS owner_name,\n    sp.is_ms_shipped,\n    CASE \n      WHEN OBJECTPROPERTY(sp.object_id, 'ExecIsStartup') = 1 THEN 1\n      ELSE 0\n    END AS is_startup_procedure\n  FROM sys.procedures sp\n  JOIN sys.database_principals dp ON sp.principal_id = dp.principal_id\n  WHERE OBJECTPROPERTY(sp.object_id, 'ExecIsStartup') = 1\n),\nProcedureSecurity AS (\n  SELECT sp.object_id,\n    COUNT(dp.permission_name) AS explicit_permissions,\n    STRING_AGG(dp.permission_name, ', ') AS permission_list\n  FROM sys.database_permissions dp\n  JOIN sys.procedures sp ON dp.major_id = sp.object_id\n  WHERE dp.class = 1 \n    AND OBJECTPROPERTY(sp.object_id, 'ExecIsStartup') = 1\n  GROUP BY sp.object_id\n),\nProcedureActivity AS (\n  SELECT qs.object_id,\n    SUM(qs.execution_count) AS total_executions,\n    AVG(qs.total_worker_time / qs.execution_count) / 1000 AS avg_execution_time_ms,\n    MAX(qs.last_execution_time) AS last_execution\n  FROM sys.dm_exec_procedure_stats qs\n  WHERE OBJECTPROPERTY(qs.object_id, 'ExecIsStartup') = 1\n    AND qs.database_id = DB_ID('master')\n  GROUP BY qs.object_id\n)\nSELECT sp.procedure_name,\n  sp.owner_name,\n  sp.create_date,\n  sp.modify_date,\n  sp.is_ms_shipped,\n  pa.total_executions,\n  CAST(pa.avg_execution_time_ms AS DECIMAL(10,2)) AS avg_execution_time_ms,\n  pa.last_execution,\n  ps.explicit_permissions,\n  ps.permission_list,\n  CASE \n    WHEN sp.is_ms_shipped = 1 THEN 'MICROSOFT_SYSTEM_PROCEDURE - Generally safe'\n    WHEN sp.owner_name = 'sa' OR sp.owner_name LIKE 'dbo%' THEN 'HIGH_PRIVILEGE_OWNER - Review carefully'\n    WHEN pa.total_executions > 100 THEN 'FREQUENTLY_EXECUTED - Monitor performance impact'\n    WHEN DATEDIFF(DAY, sp.create_date, GETDATE()) > 365 THEN 'LEGACY_PROCEDURE - Review necessity'\n    WHEN ps.explicit_permissions > 0 THEN 'EXPLICIT_PERMISSIONS - Verify appropriateness'\n    ELSE 'STANDARD_PROCEDURE - Review documentation'\n  END AS security_assessment,\n  CASE \n    WHEN sp.is_ms_shipped = 1 THEN 'System procedure - no action needed'\n    WHEN sp.owner_name = 'sa' THEN 'High-risk ownership - consider changing owner'\n    WHEN pa.total_executions IS NULL THEN 'Never executed - review necessity'\n    WHEN DATEDIFF(DAY, sp.create_date, GETDATE()) > 365 THEN 'Legacy procedure - document or remove'\n    ELSE 'Active procedure - ensure proper documentation and monitoring'\n  END AS recommendation\nFROM StartupProcedures sp\nLEFT JOIN ProcedureSecurity ps ON sp.object_id = ps.object_id\nLEFT JOIN ProcedureActivity pa ON sp.object_id = pa.object_id\nORDER BY \n  CASE security_assessment\n    WHEN 'HIGH_PRIVILEGE_OWNER - Review carefully' THEN 1\n    WHEN 'FREQUENTLY_EXECUTED - Monitor performance impact' THEN 2\n    WHEN 'LEGACY_PROCEDURE - Review necessity' THEN 3\n    WHEN 'EXPLICIT_PERMISSIONS - Verify appropriateness' THEN 4\n    ELSE 5\n  END;",
