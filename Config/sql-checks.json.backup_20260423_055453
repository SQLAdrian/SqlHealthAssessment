  {
    "Id": "MON_005",
    "Name": "Enable Query Store on all production databases (READ_WRITE mode)",
    "Description": "Query Store is a critical performance management feature that captures query execution plans and runtime statistics within the database. It enables proactive monitoring by detecting plan regressions, establishing reliable performance baselines, and allowing for controlled plan forcing. Implementing Query Store in READ_WRITE mode ensures continuous monitoring of query behavior, which is essential for maintaining application Service Level Agreements (SLAs) and optimizing resource utilization over time, particularly in high-volume OLTP scenarios where row mode execution efficiency is paramount.",
    "Category": "Monitoring",
    "Severity": "High",
    "SqlQuery": "DECLARE @dummy INT = 1;\n\nWITH QueryStoreStatus AS (\n  SELECT\n    d.name AS database_name,\n    d.is_query_store_on,\n    CASE\n      WHEN d.name LIKE '%prod%' OR d.name LIKE '%production%' OR d.name LIKE '%live%' THEN 'PRODUCTION'\n      WHEN d.name LIKE '%test%' OR d.name LIKE '%dev%' OR d.name LIKE '%staging%' THEN 'NON_PRODUCTION'\n      ELSE 'UNKNOWN'\n    END AS environment_type\n  FROM sys.databases d\n  WHERE d.database_id > 4\n),\nQueryStoreDetails AS (\n  SELECT \n    DB_NAME() AS database_name,\n    qsr.desired_state_desc,\n    qsr.actual_state_desc,\n    qsr.current_storage_size_mb,\n    qsr.max_storage_size_mb,\n    qsr.stale_query_threshold_days,\n    qsr.query_capture_mode_desc,\n    qsr.size_based_cleanup_mode_desc,\n    qsr.wait_stats_capture_mode_desc\n  FROM sys.database_query_store_options qsr\n  WHERE DB_ID() > 4\n)\nSELECT\n  qss.database_name,\n  qss.is_query_store_on,\n  qss.environment_type,\n  qsd.current_storage_size_mb,\n  qsd.max_storage_size_mb,\n  qsd.query_capture_mode_desc,\n  qsd.stale_query_threshold_days,\n  CASE\n    WHEN qss.environment_type = 'PRODUCTION' AND qss.is_query_store_on = 1 THEN 'OPTIMAL - Production with Query Store enabled'\n    WHEN qss.environment_type = 'PRODUCTION' AND qss.is_query_store_on = 0 THEN 'CRITICAL - Production database without Query Store'\n    WHEN qss.environment_type = 'NON_PRODUCTION' AND qss.is_query_store_on = 1 THEN 'GOOD - Non-production with Query Store'\n    WHEN qss.environment_type = 'NON_PRODUCTION' AND qss.is_query_store_on = 0 THEN 'INFO - Non-production without Query Store (acceptable)'\n    ELSE 'REVIEW - Assess Query Store requirements'\n  END AS recommendation,\n  CASE\n    WHEN qss.environment_type = 'PRODUCTION' AND qss.is_query_store_on = 0 THEN\n      'ALTER DATABASE [' + qss.database_name + '] SET QUERY_STORE = ON;'\n    ELSE NULL\n  END AS implementation_script\nFROM QueryStoreStatus qss\nLEFT JOIN QueryStoreDetails qsd ON qss.database_name = qsd.database_name\nORDER BY qss.database_name;",
