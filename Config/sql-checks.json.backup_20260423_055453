    "SqlQuery": "DECLARE @sql_version INT = CONVERT(INT, LEFT(CONVERT(VARCHAR(10), SERVERPROPERTY('ProductVersion')), CHARINDEX('.', CONVERT(VARCHAR(10), SERVERPROPERTY('ProductVersion'))) - 1));\nDECLARE @edition NVARCHAR(128) = CAST(SERVERPROPERTY('Edition') AS NVARCHAR(128));\nDECLARE @is_enabled BIT = CAST(SERVERPROPERTY('IsHadrEnabled') AS BIT);\nSELECT\nCASE\nWHEN @sql_version < 11 OR (@edition NOT LIKE '%Enterprise%' AND @edition NOT LIKE '%Developer%') THEN 'SKIP'\nWHEN @is_enabled = 0 THEN 'FAIL'\nWHEN NOT EXISTS (SELECT 1 FROM sys.availability_groups) THEN 'INFO'\nWHEN EXISTS (SELECT 1 FROM sys.dm_hadr_availability_group_states WHERE synchronization_health != 2 OR primary_recovery_health != 1 OR secondary_recovery_health NOT IN (1, NULL)) THEN 'FAIL'\nELSE 'PASS'\nEND AS result,\nCASE\nWHEN @sql_version < 11 OR (@edition NOT LIKE '%Enterprise%' AND @edition NOT LIKE '%Developer%') THEN 'Always On not supported on this version/edition'\nWHEN @is_enabled = 0 THEN 'Always On is not enabled'\nWHEN NOT EXISTS (SELECT 1 FROM sys.availability_groups) THEN 'No availability groups configured'\nWHEN EXISTS (SELECT 1 FROM sys.dm_hadr_availability_group_states WHERE synchronization_health != 2 OR primary_recovery_health != 1 OR secondary_recovery_health NOT IN (1, NULL)) THEN 'Availability group health issues detected'\nELSE 'All availability groups are healthy'\nEND AS message;",
