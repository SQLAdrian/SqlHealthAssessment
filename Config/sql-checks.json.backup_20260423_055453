    "SqlQuery": "DECLARE @dummy INT = 1;\n\nWITH QueryHintAnalysis AS (\n  SELECT\n    q.query_id,\n    q.query_text_id,\n    qsh.query_hint_id,\n    qsh.query_hint_text,\n    qsh.source,\n    q.query_hash,\n    qs.count_executions,\n    qs.avg_duration,\n    qs.avg_cpu_time\n  FROM sys.query_store_query_hints qsh\n  JOIN sys.query_store_query q ON qsh.query_id = q.query_id\n  LEFT JOIN sys.query_store_runtime_stats qs ON q.query_id = qs.plan_id\n  WHERE qs.runtime_stats_interval_id = (\n    SELECT MAX(runtime_stats_interval_id)\n    FROM sys.query_store_runtime_stats\n  )\n)\nSELECT\n  query_id,\n  query_hint_text,\n  source,\n  count_executions,\n  CAST(avg_duration / 1000.0 AS DECIMAL(10,2)) AS avg_duration_ms,\n  CAST(avg_cpu_time / 1000.0 AS DECIMAL(10,2)) AS avg_cpu_time_ms\nFROM QueryHintAnalysis\nORDER BY query_id, query_hint_id;",
