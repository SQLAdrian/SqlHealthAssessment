  {
    "Id": "CFG_280",
    "Name": "Optimize TempDB File Count and Sizing to Prevent Contention",
    "Description": "This check validates the configuration regarding statistics updates, specifically monitoring for reliance on asynchronous auto-update methods. The Query Optimizer relies heavily on accurate statistics to estimate cardinality and generate optimal execution plans. While automatic updates are convenient, relying solely on asynchronous processes can lead to stale or inaccurate statistical information, particularly after large data loads or significant write operations. This inaccuracy can cause the database engine to select suboptimal query plans over time, leading to gradual performance degradation and potential bottlenecks in transactional workloads.",
    "Category": "Configuration",
    "Severity": "High",
    "SqlQuery": "DECLARE @SQLVersion INT = CONVERT(INT, LEFT(CONVERT(VARCHAR(10), SERVERPROPERTY('ProductVersion')), CHARINDEX('.', CONVERT(VARCHAR(10), SERVERPROPERTY('ProductVersion'))) - 1));\nDECLARE @SQLEdition NVARCHAR(128) = CONVERT(NVARCHAR(128), SERVERPROPERTY('Edition'));\n\nIF @SQLVersion < 10\nBEGIN\n    SELECT\n        'SKIP' as result,\n        'TempDB file configuration requires SQL Server 2008 or higher' as reason,\n        @SQLVersion as current_version;\n    RETURN;\nEND\n\nDECLARE @LogicalCPUs INT = (SELECT cpu_count FROM sys.dm_os_sys_info);\nDECLARE @PhysicalMemoryGB INT = (SELECT total_physical_memory_kb / 1024 / 1024 FROM sys.dm_os_sys_memory);\n\nDECLARE @OptimalFileCount INT = CASE\n    WHEN @LogicalCPUs <= 8 THEN @LogicalCPUs\n    WHEN @LogicalCPUs > 8 AND @LogicalCPUs <= 16 THEN 8\n    WHEN @LogicalCPUs > 16 THEN 8 + CEILING((@LogicalCPUs - 8) / 4.0) * 4\n    ELSE 4  -- Minimum\nEND;\n\nWITH TempDBFileAnalysis AS (\n    SELECT\n        file_id,\n        name,\n        physical_name,\n        size_mb = CAST(size * 8.0 / 1024 AS DECIMAL(15,2)),\n        max_size_mb = CAST(CASE WHEN max_size = -1 THEN NULL ELSE max_size * 8.0 / 1024 END AS DECIMAL(15,2)),\n        growth_mb = CAST(growth * 8.0 / 1024 AS DECIMAL(15,2)),\n        is_percent_growth = CAST(growth AS VARCHAR(10)) + CASE WHEN is_percent_growth = 1 THEN '%' ELSE ' MB' END,\n        used_mb = CAST(FILEPROPERTY(name, 'SpaceUsed') * 8.0 / 1024 AS DECIMAL(15,2))\n    FROM tempdb.sys.database_files\n    WHERE type_desc = 'ROWS'\n)\nSELECT\n    [Check_Result] = CASE\n        WHEN (SELECT COUNT(*) FROM TempDBFileAnalysis) = @OptimalFileCount THEN 'OPTIMAL_FILE_COUNT'\n        WHEN (SELECT COUNT(*) FROM TempDBFileAnalysis) < @OptimalFileCount THEN 'INSUFFICIENT_FILES'\n        WHEN (SELECT COUNT(*) FROM TempDBFileAnalysis) > @OptimalFileCount THEN 'EXCESSIVE_FILES'\n        WHEN (SELECT COUNT(*) FROM TempDBFileAnalysis) = 1 AND @LogicalCPUs > 1 THEN 'SINGLE_FILE_CONTENTION_RISK'\n        ELSE 'REVIEW_FILE_CONFIGURATION'\n    END,\n    [Current_File_Count] = (SELECT COUNT(*) FROM TempDBFileAnalysis),\n    [Optimal_File_Count] = @OptimalFileCount,\n    [Logical_CPUs] = @LogicalCPUs,\n    [Physical_Memory_GB] = @PhysicalMemoryGB,\n    [File_Size_Equal] = CASE\n        WHEN (SELECT COUNT(DISTINCT size_mb) FROM TempDBFileAnalysis) = 1 THEN 'YES'\n        ELSE 'NO - Files have different sizes'\n    END,\n    [Total_TempDB_Size_MB] = (SELECT SUM(size_mb) FROM TempDBFileAnalysis),\n    [Average_File_Size_MB] = (SELECT AVG(size_mb) FROM TempDBFileAnalysis),\n    [Largest_File_Size_MB] = (SELECT MAX(size_mb) FROM TempDBFileAnalysis),\n    [Smallest_File_Size_MB] = (SELECT MIN(size_mb) FROM TempDBFileAnalysis),\n    [SQL_Version] = @SQLVersion,\n    [Edition] = @SQLEdition,\n    [Performance_Impact] = CASE\n        WHEN (SELECT COUNT(*) FROM TempDBFileAnalysis) = @OptimalFileCount THEN 'Optimal - no allocation contention'\n        WHEN (SELECT COUNT(*) FROM TempDBFileAnalysis) = 1 AND @LogicalCPUs > 1 THEN 'High risk - PAGELATCH_UP contention likely'\n        WHEN (SELECT COUNT(*) FROM TempDBFileAnalysis) < @OptimalFileCount THEN 'Medium risk - potential allocation contention'\n        ELSE 'Low risk - acceptable configuration'\n    END,\n    [Contention_Risk_Level] = CASE\n        WHEN (SELECT COUNT(*) FROM TempDBFileAnalysis) = 1 AND @LogicalCPUs > 8 THEN 'CRITICAL'\n        WHEN (SELECT COUNT(*) FROM TempDBFileAnalysis) = 1 AND @LogicalCPUs > 4 THEN 'HIGH'\n        WHEN (SELECT COUNT(*) FROM TempDBFileAnalysis) < @OptimalFileCount THEN 'MEDIUM'\n        ELSE 'LOW'\n    END,\n    [Recommended_Action] = CASE\n        WHEN (SELECT COUNT(*) FROM TempDBFileAnalysis) = @OptimalFileCount THEN 'Configuration is optimal - no action needed'\n        WHEN (SELECT COUNT(*) FROM TempDBFileAnalysis) = 1 AND @LogicalCPUs > 1 THEN 'Add multiple tempdb files immediately to prevent contention'\n        ELSE 'Adjust tempdb file count to match optimal configuration'\n    END\nFROM (SELECT 1 as dummy) d;",
