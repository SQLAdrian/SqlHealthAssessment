  {
    "Id": "BKP_008",
    "Name": "Enforce FULL Recovery Model and Scheduled Log Backups for Point-in-Time Recovery (PITR)",
    "Description": "This check validates that the SQL Server database is configured to use the FULL recovery model and maintains a scheduled, regular log backup routine. The transaction log records every modification made to the database; therefore, consistent log backups are mandatory for achieving Point-in-Time Recovery (PITR). Without this capability, data loss cannot be reliably minimized, potentially violating defined Recovery Point Objectives (RPO) and severely impacting business continuity.",
    "Category": "Backup",
    "Severity": "High",
    "SqlQuery": "SELECT\n  ba.database_name,\n  ba.recovery_model_desc,\n  ba.full_backups_7days,\n  ba.log_backups_7days,\n  ba.last_full_backup,\n  ba.last_log_backup,\n  ba.minutes_since_last_log,\n  lg.log_size_mb,\n  CASE\n    WHEN ba.recovery_model_desc = 'FULL' AND ba.minutes_since_last_log > 60 THEN 'CRITICAL - No recent log backup (>1 hour)'\n    WHEN ba.recovery_model_desc = 'FULL' AND ba.minutes_since_last_log > 15 THEN 'WARNING - Log backup overdue (>15 min)'\n    WHEN ba.recovery_model_desc = 'FULL' AND ba.log_backups_7days > 0 THEN 'GOOD - Regular log backups'\n    WHEN ba.recovery_model_desc = 'FULL' AND ba.log_backups_7days = 0 THEN 'CRITICAL - FULL recovery with no log backups'\n    WHEN ba.recovery_model_desc IN ('SIMPLE', 'BULK_LOGGED') THEN 'INFO - Log backups not required'\n    ELSE 'UNKNOWN'\n  END AS backup_status,\n  CASE\n    WHEN ba.recovery_model_desc = 'FULL' AND ba.minutes_since_last_log > 60 THEN\n      'Implement automated log backups every 15-60 minutes based on RPO requirements'\n    WHEN ba.recovery_model_desc = 'FULL' AND ba.minutes_since_last_log > 15 THEN\n      'Increase log backup frequency or investigate backup job failures'\n    ELSE 'Current backup strategy appropriate'\n  END AS recommendation\nFROM (\n  SELECT\n    d.name AS database_name,\n    d.recovery_model_desc,\n    COUNT(CASE WHEN b.type = 'D' THEN 1 END) AS full_backups_7days,\n    COUNT(CASE WHEN b.type = 'L' THEN 1 END) AS log_backups_7days,\n    MAX(CASE WHEN b.type = 'D' THEN b.backup_finish_date END) AS last_full_backup,\n    MAX(CASE WHEN b.type = 'L' THEN b.backup_finish_date END) AS last_log_backup,\n    AVG(CASE WHEN b.type = 'L' THEN b.backup_size END) AS avg_log_backup_size_mb,\n    DATEDIFF(MINUTE, MAX(CASE WHEN b.type = 'L' THEN b.backup_finish_date END), GETDATE()) AS minutes_since_last_log\n  FROM sys.databases d\n  LEFT JOIN msdb.dbo.backupset b ON d.name = b.database_name\n    AND b.backup_finish_date >= DATEADD(DAY, -7, GETDATE())\n  WHERE d.database_id > 4\n  GROUP BY d.name, d.recovery_model_desc\n) ba\nLEFT JOIN (\n  SELECT\n    DB_NAME(mf.database_id) AS database_name,\n    mf.size * 8 / 1024 AS log_size_mb,\n    mf.growth * 8 / 1024 AS growth_mb,\n    CASE mf.is_percent_growth WHEN 1 THEN 'PERCENT' ELSE 'FIXED' END AS growth_type\n  FROM sys.master_files mf\n  WHERE mf.type_desc = 'LOG'\n    AND mf.database_id > 4\n) lg ON ba.database_name = lg.database_name\nORDER BY\n  CASE\n    WHEN ba.recovery_model_desc = 'FULL' AND ba.minutes_since_last_log > 60 THEN 1\n    WHEN ba.recovery_model_desc = 'FULL' AND ba.log_backups_7days = 0 THEN 2\n    WHEN ba.recovery_model_desc = 'FULL' AND ba.minutes_since_last_log > 15 THEN 3\n    ELSE 4\n  END,\n  ba.minutes_since_last_log DESC",
