  {
    "Id": "CFG_036",
    "Name": "In SQL 2022, Evaluate ORDER BY in Index Creation for Sorted Scan Elimination",
    "Description": "This check validates the use of ORDER BY within index creation statements, a feature introduced in SQL Server 2022. Utilizing this capability allows developers to physically pre-sort data within the index structure. This optimization is critical because it can eliminate expensive sort operators from query execution plans that require ordered results (e.g., for reporting or analytical queries), significantly improving performance and reducing CPU overhead.",
    "Category": "Configuration",
    "Severity": "High",
    "SqlQuery": "DECLARE @dummy INT = 1;\n\nWITH IndexSortAnalysis AS (\n  SELECT \n    OBJECT_NAME(i.object_id) AS table_name,\n    i.name AS index_name,\n    i.type_desc,\n    CASE \n      WHEN EXISTS (\n        SELECT 1 FROM sys.index_columns ic\n        WHERE ic.object_id = i.object_id \n          AND ic.index_id = i.index_id \n          AND ic.is_descending_key = 1\n      ) THEN 'DESCENDING_KEYS'\n      ELSE 'ASCENDING_KEYS'\n    END AS key_sort_direction,\n    CASE \n      WHEN i.has_filter = 1 THEN 'FILTERED_INDEX'\n      ELSE 'REGULAR_INDEX'\n    END AS index_type,\n    \n    CASE \n      WHEN EXISTS (\n        SELECT 1 FROM sys.dm_exec_query_stats qs\n        CROSS APPLY sys.dm_exec_sql_text(qs.sql_handle) st\n        CROSS APPLY sys.dm_exec_query_plan(qs.plan_handle) qp\n        WHERE st.text LIKE '%' + OBJECT_NAME(i.object_id) + '%'\n          AND qp.query_plan.exist('//Sort') = 1\n          AND qs.execution_count > 5\n      ) THEN 'POTENTIAL_BENEFIT'\n      ELSE 'NO_OBVIOUS_BENEFIT'\n    END AS sort_elimination_potential\n  FROM sys.indexes i\n  WHERE i.object_id > 100\n    AND i.type IN (1, 2)\n )\nSELECT\n  isa.table_name,\n  isa.index_name,\n  isa.key_sort_direction,\n  isa.index_type,\n  isa.sort_elimination_potential\nFROM IndexSortAnalysis isa\nWHERE isa.sort_elimination_potential = 'POTENTIAL_BENEFIT'\nORDER BY isa.table_name;",
