    "Name": "In SQL 2022+, Enable Parameter Sensitive Plan Optimization (PSP) to Prevent Performance Degradation",
    "Description": "This check validates the implementation and enablement of Parameter Sensitive Plan Optimization (PSP) in SQL Server 2022 and later versions. PSP is a critical performance feature designed to mitigate issues caused by parameter sniffing, where a single cached execution plan becomes suboptimal when querying data with highly variable distributions. By automatically generating and maintaining multiple active cached plans for the same parameterized statement, PSP ensures consistent query performance and stability regardless of the specific parameters used at runtime.",
    "Category": "Configuration",
    "Severity": "High",
    "SqlQuery": "DECLARE @dummy INT = 1;\n\nWITH PSPCandidateQueries AS (\n  SELECT \n    q.query_id,\n    q.query_hash,\n    q.query_text_id,\n    q.count_compiles,\n    q.initial_compile_start_time,\n    q.last_compile_start_time,\n    q.avg_compile_duration,\n    q.last_execution_time,\n    qs.count_executions,\n    qs.avg_duration,\n    qs.avg_cpu_time,\n    qs.avg_logical_io_reads,\n    qs.avg_query_max_used_memory\n  FROM sys.query_store_query q\n  JOIN sys.query_store_runtime_stats qs ON q.query_id = qs.plan_id\n  WHERE qs.runtime_stats_interval_id = (\n    SELECT MAX(runtime_stats_interval_id)\n    FROM sys.query_store_runtime_stats\n  )\n)\nSELECT \n  query_id,\n  query_hash,\n  count_compiles,\n  count_executions,\n  CAST(avg_duration / 1000.0 AS DECIMAL(10,2)) AS avg_duration_ms,\n  CAST(avg_cpu_time / 1000.0 AS DECIMAL(10,2)) AS avg_cpu_time_ms,\n  avg_logical_io_reads,\n  avg_query_max_used_memory,\n  CASE \n    WHEN count_compiles > count_executions * 0.1 THEN 'HIGH_COMPILE_RATIO - PSP likely beneficial'\n    WHEN count_compiles > count_executions * 0.05 THEN 'MODERATE_COMPILE_RATIO - PSP may help'\n    ELSE 'LOW_COMPILE_RATIO - PSP may not be needed'\n  END AS psp_benefit_assessment\nFROM PSPCandidateQueries\nORDER BY count_compiles DESC, avg_duration DESC;",
