# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.cs text diff=csharp
*.razor text
*.sql text
*.json text
*.xml text
*.xaml text

# Scripts
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
*.sh text eol=lf

# Documentation
*.md text
*.txt text

# Binary files
*.dll binary
*.exe binary
*.png binary
*.jpg binary
*.ico binary
*.svg binary
*.dacpac binary
*.db binary
