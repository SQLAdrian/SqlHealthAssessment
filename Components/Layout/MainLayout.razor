<!--/* In the name of God, the Merciful, the Compassionate */-->
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Web
@using SqlHealthAssessment.Components.Shared
@using SqlHealthAssessment.Data
@using Radzen.Blazor
@inject SqlHealthAssessment.Data.Services.KeyboardShortcutService ShortcutSvc
@inject SqlHealthAssessment.Data.UserSettingsService UserSettings
@inject SqlHealthAssessment.Data.ServerConnectionManager ConnectionManager
@inject SqlHealthAssessment.Data.AutoUpdateService AutoUpdate
@inject SqlHealthAssessment.Data.Services.NotificationChannelService ChannelService
@implements IDisposable

<!-- Skip link for screen readers -->
<a href="#main-content" class="skip-link">Skip to main content</a>

<div class="print-header" aria-hidden="true">
    <span class="print-header-brand"><i class="fa-solid fa-heart-pulse"></i> SQL Health Assessment</span>
    <span class="print-header-date" id="print-header-date"></span>
</div>
<div class="print-footer" aria-hidden="true">
    <span class="print-footer-label">SQL Health Assessment — Internal Use Only</span>
    <span class="print-footer-page">Page <span class="print-page-num"></span></span>
</div>

@if (_afterFirstRender)
{
    <ErrorBoundary>
        <ChildContent>
            <RadzenComponents />
        </ChildContent>
        <ErrorContent Context="ex">
            @{ LogErrorToConsole(ex); }
        </ErrorContent>
    </ErrorBoundary>
}

<div class="app-container" tabindex="0" role="application" aria-label="SQL Health Assessment Application" @onkeydown="HandleKeyDown">
    <ToastContainer />
    <ShortcutsDialog IsVisible="@showShortcuts" OnClose="@(() => showShortcuts = false)" />
    <OnboardingWizard IsVisible="@_showOnboarding" OnComplete="OnOnboardingComplete" />
    <ReleaseNotesModal IsVisible="@_showReleaseNotes" OnClose="OnReleaseNotesClosed" />
    <ServerModeToggle />

    @* ── Update available banner ── *@
    @if (_updateAvailable && _updateInfo != null)
    {
        <div style="position:fixed;top:0;left:0;right:0;z-index:2000;background:var(--accent);color:#fff;
                    display:flex;align-items:center;justify-content:center;gap:12px;
                    padding:7px 16px;font-size:13px;box-shadow:0 2px 6px rgba(0,0,0,0.3);">
            <i class="fa-solid fa-circle-arrow-up"></i>
            <span>Update available: <strong>v@(_updateInfo.Version)</strong></span>
            <a href="/settings" style="color:#fff;font-weight:600;text-decoration:underline;"
               @onclick="() => _updateAvailable = false">Go to Settings to update</a>
            <button @onclick="() => _updateAvailable = false"
                    style="background:transparent;border:none;color:#fff;cursor:pointer;margin-left:8px;font-size:16px;line-height:1;"
                    title="Dismiss">&#x2715;</button>
        </div>
        <div style="height:36px;"></div>  @* spacer so content isn't hidden under the banner *@
    }

    @* ── Maintenance mode banner ── *@
    @if (_maintenanceActive)
    {
        <div style="position:fixed;top:@(_updateAvailable && _updateInfo != null ? "36px" : "0");left:0;right:0;z-index:1999;
                    background:#7c5a00;color:#ffe082;
                    display:flex;align-items:center;justify-content:center;gap:12px;
                    padding:7px 16px;font-size:13px;box-shadow:0 2px 6px rgba(0,0,0,0.3);">
            <i class="fa-solid fa-wrench"></i>
            <span><strong>Maintenance mode active</strong>@(_maintenanceUntilText)</span>
            <a href="/alerting-config" style="color:#ffe082;font-weight:600;text-decoration:underline;">
                End early →
            </a>
        </div>
        <div style="height:36px;"></div>
    }

    <Router AppAssembly="@typeof(MainLayout).Assembly">
    <Found Context="routeData">
        <div class="app-layout" role="main" aria-label="Main content area">
            <NavMenu />
            <div class="app-content" id="main-content" role="content" aria-label="Page content">
                <ErrorBoundary>
                    <ChildContent>
                        <div class="page-fade-in" @key="Navigation.Uri">
                            <RouteView RouteData="@routeData" />
                        </div>
                    </ChildContent>
                    <ErrorContent Context="ex">
                        <div class="error-boundary" role="alert" aria-live="assertive">
                            <h3>An error occurred</h3>
                            <p>@ex.Message</p>
                        </div>
                        @{ LogErrorToConsole(ex); }
                    </ErrorContent>
                </ErrorBoundary>
            </div>
        </div>
    </Found>
    <NotFound>
        <div class="app-layout" role="alert" aria-live="polite">
            <NavMenu />
            <div class="app-content">
                <div class="not-found">
                    <h2>Page not found</h2>
                    <p>The page you're looking for doesn't exist.</p>
                </div>
            </div>
        </div>
    </NotFound>
</Router>
</div>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = null!;
    [Inject] private IJSRuntime JS { get; set; } = null!;
    private bool showShortcuts = false;
    private bool _afterFirstRender = false;
    private bool _showOnboarding    = false;
    private bool _showReleaseNotes  = false;
    private bool _updateAvailable   = false;
    private UpdateInfo? _updateInfo;
    private bool _maintenanceActive = false;
    private string _maintenanceUntilText = "";
    private System.Timers.Timer? _maintenanceTimer;

    protected override void OnInitialized()
    {
        // Show onboarding wizard whenever there are no servers configured
        if (ConnectionManager.GetConnections().Count == 0)
        {
            _showOnboarding = true;
        }
        else
        {
            // Show release notes when version has changed since last seen (if user hasn't disabled it)
            var currentVersion = GetCurrentVersion();
            if (!string.IsNullOrEmpty(currentVersion)
                && UserSettings.GetLastSeenVersion() != currentVersion
                && UserSettings.GetShowReleaseNotesOnUpdate())
                _showReleaseNotes = true;
        }

        // Kick off a background update check; banner appears if a newer version is found
        AutoUpdate.OnUpdateAvailable += OnUpdateFound;
        AutoUpdate.StartBackgroundCheck();

        // Poll maintenance window state every 30 seconds
        RefreshMaintenanceState();
        _maintenanceTimer = new System.Timers.Timer(30_000);
        _maintenanceTimer.Elapsed += (_, _) => _ = InvokeAsync(() => { RefreshMaintenanceState(); StateHasChanged(); });
        _maintenanceTimer.AutoReset = true;
        _maintenanceTimer.Start();
    }

    private void RefreshMaintenanceState()
    {
        var windows = ChannelService.GetAlertWindows();
        _maintenanceActive = windows.IsMaintenanceActive;
        if (!_maintenanceActive)
        {
            _maintenanceUntilText = "";
            return;
        }
        if (windows.IsManualMaintenanceActive && windows.MaintenanceActiveUntil.HasValue)
            _maintenanceUntilText = $" — all alerts suppressed until {windows.MaintenanceActiveUntil.Value:HH:mm}";
        else
            _maintenanceUntilText = " — scheduled window";
    }

    private static string GetCurrentVersion()
    {
        try
        {
            var path = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Config", "version.json");
            if (!File.Exists(path))
                path = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "config", "version.json");
            if (!File.Exists(path)) return "";
            var doc = System.Text.Json.JsonDocument.Parse(File.ReadAllText(path));
            return doc.RootElement.TryGetProperty("version", out var v) ? v.GetString() ?? "" : "";
        }
        catch { return ""; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _afterFirstRender = true;
            StateHasChanged();
        }
        await Task.CompletedTask;
    }

    private void OnOnboardingComplete()
    {
        _showOnboarding = false;
        UserSettings.SetOnboardingComplete(true);

        // After onboarding, check if a "What's new" notice is also pending
        // (happens on first-ever install where LastSeenVersion was never set)
        var currentVersion = GetCurrentVersion();
        if (!string.IsNullOrEmpty(currentVersion)
            && UserSettings.GetLastSeenVersion() != currentVersion
            && UserSettings.GetShowReleaseNotesOnUpdate())
            _showReleaseNotes = true;

        StateHasChanged();
    }

    private void OnReleaseNotesClosed(bool dontShowAgain)
    {
        _showReleaseNotes = false;
        var version = GetCurrentVersion();
        if (!string.IsNullOrEmpty(version))
            UserSettings.SetLastSeenVersion(version);
        if (dontShowAgain)
            UserSettings.SetShowReleaseNotesOnUpdate(false);
        StateHasChanged();
    }

    private void OnUpdateFound(UpdateInfo info)
    {
        _updateInfo      = info;
        _updateAvailable = true;
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AutoUpdate.OnUpdateAvailable -= OnUpdateFound;
        _maintenanceTimer?.Stop();
        _maintenanceTimer?.Dispose();
    }

    private async void LogErrorToConsole(Exception ex)
    {
        try
        {
            await JS.InvokeVoidAsync("blazorErrorLogger.logError", ex.Message, ex.StackTrace);
        }
        catch (Exception jsEx)
        {
            // JS interop unavailable (server mode or WebView2 not ready) — non-fatal
            Console.WriteLine($"[MainLayout] blazorErrorLogger unavailable: {jsEx.Message}");
        }
    }

    private void HandleKeyDown(KeyboardEventArgs args)
    {
        // ? for shortcuts help
        if (args.Key == "?" && !args.CtrlKey && !args.AltKey)
        {
            showShortcuts = !showShortcuts;
            return;
        }

        // Esc to close dialogs
        if (args.Key == "Escape")
        {
            showShortcuts = false;
            return;
        }

        if (args.CtrlKey)
        {
            var key = args.Key;

            // Ctrl+R — Run/Scan on active page
            if (key is "r" or "R")
            {
                _ = ShortcutSvc.TriggerRun();
                return;
            }

            // Ctrl+P — PDF export on active page
            if (key is "p" or "P")
            {
                _ = ShortcutSvc.TriggerExportPdf();
                return;
            }

            // Ctrl+E — CSV export on active page
            if (key is "e" or "E")
            {
                _ = ShortcutSvc.TriggerExportCsv();
                return;
            }

            // Ctrl+1-9 for quick navigation
            string? route = key switch
            {
                "1" => "/",
                "2" => "/instance",
                "3" => "/checks",
                "4" => "/fullaudit",
                "5" => "/health",
                "6" => "/settings",
                "7" => "/dashboard-editor",
                "8" => "/servers",
                "9" => "/bulkeditchecks",
                "h" or "H" => "/health",
                "q" or "Q" => "/checks",
                _ => null
            };

            if (route != null)
                Navigation.NavigateTo(route);
        }
    }
}
