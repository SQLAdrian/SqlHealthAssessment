<!--/* In the name of God, the Merciful, the Compassionate */-->
@using Microsoft.AspNetCore.Components.Routing
@using SqlHealthAssessment.Data
@using SqlHealthAssessment.Data.Models
@inject AutoUpdateService UpdateService
@inject DatabaseAvailabilityService DbAvailability
@inject DashboardConfigService DashboardConfig
@inject ServerConnectionManager ConnectionManager
@inject UserSettingsService UserSettings
@inject SqlHealthAssessment.Data.Services.ThemeService ThemeSvc
@inject IJSRuntime JS
@implements IAsyncDisposable


<div class="nav-menu w-60 min-w-60 bg-app-bg-secondary border-r border-app-border flex flex-col py-3 overflow-y-auto max-h-screen">
    <div class="px-4 pb-4 border-b border-app-border mb-2 flex items-center gap-2">
        <span class="text-lg text-app-accent"><i class="fa-solid fa-heart-pulse"></i></span>
        <span class="text-base font-semibold text-app-text-primary">SQL Health Assessment</span>
    </div>
    <nav>
        <br />
        <div class="px-3 py-1 text-xs font-bold uppercase tracking-wider text-app-text-secondary mt-2 border-t border-app-border">Audits</div>
        <br />
<NavLink href="/quickcheck" class="nav-link" title="Ctrl+0">
            <span class="w-4 inline-flex items-center justify-center text-sm"><i class="fa-solid fa-bolt-lightning"></i></span> Quick Check
        </NavLink>
        <NavLink href="/fullaudit" class="nav-link" title="Ctrl+4">
            <span class="w-4 inline-flex items-center justify-center text-sm"><i class="fa-solid fa-clipboard-check"></i></span> Full Audit
        </NavLink>
        <NavLink href="/vulnerabilityassessment" class="nav-link">
            <span class="w-4 inline-flex items-center justify-center text-sm"><i class="fa-solid fa-shield-halved"></i></span> Vulnerability Assessment
        </NavLink>
        @* Config-driven Audits dashboards *@
        @foreach (var dashboard in DashboardConfig.Config.Dashboards
            .Where(d => d.Enabled && d.NavCategory == "Audits")
            .OrderBy(d => d.NavOrder))
        {
            <NavLink href="@dashboard.Route" class="nav-link">
                @NavIcon(dashboard.NavIcon) @dashboard.NavTitle
            </NavLink>
        }

        <br />
        <div class="px-3 py-1 text-xs font-bold uppercase tracking-wider text-app-text-secondary mt-2 border-t border-app-border">Live</div>
        <br />

        @* Dynamic dashboards — master DB, Dashboards category only (excludes Tools, Audits, etc.) *@
        @foreach (var dashboard in DashboardConfig.Config.Dashboards
            .Where(d => d.Enabled && d.NavCategory == "Dashboards" && d.DefaultDatabase == "master")
            .OrderBy(d => d.NavOrder))
        {
            <NavLink href="@($"/dashboard/{dashboard.Id}")" class="nav-link">
                @NavIcon(dashboard.NavIcon) @dashboard.NavTitle
            </NavLink>
        }
        <NavLink href="/bestpractice" class="nav-link">
            <span class="w-4 inline-flex items-center justify-center text-sm"><i class="fa-solid fa-list-check"></i></span> BP Checks
        </NavLink>

        <br />
        <div class="px-3 py-1 text-xs font-bold uppercase tracking-wider text-app-text-secondary mt-2 border-t border-app-border">SQLWATCH</div>
        <br />
        @if (_SQLWATCHExists)
        {
            @foreach (var dashboard in DashboardConfig.Config.Dashboards
                .Where(d => d.Enabled && d.DefaultDatabase == "SQLWATCH")
                .OrderBy(d => d.NavOrder))
            {
                <NavLink href="@($"/dashboard/{dashboard.Id}")" class="nav-link">
                    @NavIcon(dashboard.NavIcon) @dashboard.NavTitle
                </NavLink>
            }
        }
        else
        {
            <span class="block px-4 py-1 text-xs text-app-text-muted italic">SQLWATCH database not installed</span>
        }

        <br />
        <div class="px-3 py-1 text-xs font-bold uppercase tracking-wider text-app-text-secondary mt-2 border-t border-app-border">PerformanceMonitor</div>
        <br />
        @if (_performanceMonitorExists)
        {
            @foreach (var dashboard in DashboardConfig.Config.Dashboards
                .Where(d => d.Enabled && d.DefaultDatabase == "PerformanceMonitor")
                .OrderBy(d => d.NavOrder))
            {
                <NavLink href="@($"/dashboard/{dashboard.Id}")" class="nav-link">
                    @NavIcon(dashboard.NavIcon) @dashboard.NavTitle
                </NavLink>
            }
        }
        else
        {
            <span class="block px-4 py-1 text-xs text-app-text-muted italic">PerformanceMonitor database not installed</span>
        }

        <br />
        <div class="px-3 py-1 text-xs font-bold uppercase tracking-wider text-app-text-secondary mt-2 border-t border-app-border">Monitoring new server</div>
        <br />
        <NavLink href="/deploysqlwatch" class="nav-link">
            <span class="w-4 inline-flex items-center justify-center text-sm"><i class="fa-solid fa-eye"></i></span> SQLWATCH
        </NavLink>
        <NavLink href="/deploydarlingPM" class="nav-link">
            <span class="w-4 inline-flex items-center justify-center text-sm"><i class="fa-solid fa-chart-simple"></i></span> Darling Perf Monitor
        </NavLink>

        <br />
        <div class="px-3 py-1 text-xs font-bold uppercase tracking-wider text-app-text-secondary mt-2 border-t border-app-border">Tools</div>
        <br />
        <NavLink href="/plan-analysis" class="nav-link">
            <span class="w-4 inline-flex items-center justify-center text-sm"><i class="fa-solid fa-diagram-project"></i></span> Plan Analyzer
        </NavLink>
        @if (ShowToolsSection)
        {
            <NavLink href="/xevents" class="nav-link">
                <span class="w-4 inline-flex items-center justify-center text-sm"><i class="fa-solid fa-list-check"></i></span> XEvent / Profiler
            </NavLink>
        }

        <br />
        <br />
        <div class="px-3 py-1 text-xs font-bold uppercase tracking-wider text-app-text-secondary mt-2 border-t border-app-border">Configure</div>
        <br />

        <NavLink href="/settings" class="nav-link" title="Ctrl+6">
            <span class="w-4 inline-flex items-center justify-center text-sm"><i class="fa-solid fa-gear"></i></span> Settings
        </NavLink>
        <NavLink href="/dashboard-editor" class="nav-link" title="Ctrl+7">
            <span class="w-4 inline-flex items-center justify-center text-sm"><i class="fa-solid fa-table-columns"></i></span> Dashboard Editor
        </NavLink>
        <NavLink href="/servers" class="nav-link" title="Ctrl+8">
            <span class="w-4 inline-flex items-center justify-center text-sm"><i class="fa-solid fa-server"></i></span> Servers
        </NavLink>
        <NavLink href="/alerts" class="nav-link">
            <span class="w-4 inline-flex items-center justify-center text-sm"><i class="fa-solid fa-bell"></i></span> Alerting
        </NavLink>
        <NavLink href="/alerting-config" class="nav-link">
            <span class="w-4 inline-flex items-center justify-center text-sm"><i class="fa-solid fa-envelope"></i></span> Notifications
        </NavLink>
        <NavLink href="/scheduled-tasks" class="nav-link">
            <span class="w-4 inline-flex items-center justify-center text-sm"><i class="fa-solid fa-clock"></i></span> Scheduled Tasks
        </NavLink>
        <NavLink href="/service-management" class="nav-link">
            <span class="w-4 inline-flex items-center justify-center text-sm"><i class="fa-solid fa-microchip"></i></span> Service & Updates
        </NavLink>
        <NavLink href="/guide" class="nav-link">
            <span class="w-4 inline-flex items-center justify-center text-sm"><i class="fa-solid fa-map"></i></span> Guide
        </NavLink>
        <NavLink href="/about" class="nav-link">
            <span class="w-4 inline-flex items-center justify-center text-sm"><i class="fa-solid fa-info-circle"></i></span> About
        </NavLink>
    </nav>
    <div class="mt-auto border-t border-app-border">
        <div class="p-3 text-center">
            <small class="text-2xs text-app-text-secondary">Ctrl+1-9: Quick Nav</small>
        </div>
    </div>
</div>

@code {
    // Set to true once XEvent/Profiler, Schema Compare, and Dependency Walker pages are ready
    private const bool ShowToolsSection = false;

    private bool _performanceMonitorExists = false;
    private bool _SQLWATCHExists = false;

    // ── Radzen theme ──────────────────────────────────────────────────────
    private string _radzenTheme = "dark";

    private async void OnThemeChanged(ChangeEventArgs e)
    {
        _radzenTheme = e.Value?.ToString() ?? "dark";
        UserSettings.SetRadzenUiTheme(_radzenTheme);
        ThemeSvc.SetTheme(_radzenTheme);
        try { await JS.InvokeVoidAsync("radzenTheme.setTheme", _radzenTheme); } catch { }
    }

    protected override async Task OnInitializedAsync()
    {
        _radzenTheme = UserSettings.GetRadzenUiTheme();
        ThemeSvc.SetTheme(_radzenTheme);
        ConnectionManager.OnConnectionChanged += OnServerChanged;
        await RefreshDbFlags();
    }

    private bool _themeApplied = false;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_themeApplied)
        {
            _themeApplied = true;
            try { await JS.InvokeVoidAsync("radzenTheme.setTheme", _radzenTheme); } catch { }
        }
    }

    private void OnServerChanged()
    {
        DbAvailability.InvalidateCache();
        _ = InvokeAsync(async () =>
        {
            await RefreshDbFlags();
            StateHasChanged();
        });
    }

    private async Task RefreshDbFlags()
    {
        _performanceMonitorExists = await DbAvailability.DatabaseExistsAsync("PerformanceMonitor");
        _SQLWATCHExists = await DbAvailability.DatabaseExistsAsync("SQLWATCH");
    }

    private RenderFragment NavIcon(string? icon) => builder =>
    {
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", "nav-icon");
        if (icon?.StartsWith("fa-") == true)
        {
            builder.OpenElement(2, "i");
            builder.AddAttribute(3, "class", icon);
            builder.CloseElement();
        }
        else
        {
            builder.AddContent(2, icon);
        }
        builder.CloseElement();
    };

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        ConnectionManager.OnConnectionChanged -= OnServerChanged;
        await ValueTask.CompletedTask;
    }
}
