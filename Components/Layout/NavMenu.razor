                        <span class="nav-icon"><i class="fa-brands fa-windows"></i></span><span class="nav-link-text"> dbatools</span>
                    </NavLink>
                }
                <NavLink href="@RouteConstants.Environment" class="nav-link">
                    <span class="nav-icon"><i class="fa-solid fa-network-wired"></i></span><span class="nav-link-text"> Environment View</span>
