                    </a>
                    <a class="nav-report-item" href="https://github.com/SQLAdrian/SQLTriage/discussions/new?category=ideas" target="_blank" @onclick="() => _showReportMenu = false">
                        <i class="fa-regular fa-lightbulb"></i>
