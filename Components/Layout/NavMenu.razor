                @if (_experimentalMode)
                {
                    <NavLink href="@RouteConstants.Capacity" class="nav-link">
                        <span class="nav-icon"><i class="fa-solid fa-chart-line"></i></span><span class="nav-link-text"> Capacity Planning</span>
                    </NavLink>
                    <NavLink href="@RouteConstants.CodeHotspots" class="nav-link">
                        <span class="nav-icon"><i class="fa-solid fa-fire"></i></span><span class="nav-link-text"> Code Hotspots</span>
                    </NavLink>
