</div>

@if (_showNoPantsModal)
{
    <div class="panel-maximize-overlay" style="z-index:9999;">
        <div class="query-plan-modal-content" style="max-width:560px;" @onclick:stopPropagation>
            <div class="panel-maximize-header" style="background:linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);">
                <span class="panel-maximize-title">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" style="display:inline;vertical-align:middle;margin-right:6px;">
                        <path d="M4 4h16v2l-2 14h-4l-1-8h-2l-1 8H6L4 6V4zm2 2v.5l1.8 12.5h2.4l1-8h1.6l1 8h2.4L18 6.5V6H6z"/>
                    </svg>
                    No-Pants Mode
                </span>
                <button class="panel-maximize-close" @onclick="CancelNoPantsModal" title="Cancel">✕</button>
            </div>
            <div style="padding:20px;color:var(--text-primary);line-height:1.6;">
                <p style="font-size:14px;margin-bottom:12px;">
                    <strong style="color:#f59e0b;">&#9888; You are about to enable No-Pants Mode.</strong>
                </p>
                <p style="font-size:13px;margin-bottom:12px;">
                    This will reveal controls that allow you to make <strong style="color:#ef4444;">direct modifications to your SQL Server instances</strong> —
                    including killing sessions, forcing failovers, rebuilding indexes, updating configurations, and other operations
                    that can impact production workloads.
                </p>
                <p style="font-size:13px;margin-bottom:12px;">
                    These actions are <em>irreversible</em> once executed. There is no undo button. There is no safety net.
                    Just you, your SQL Servers, and whatever courage (or recklessness) brought you here.
                </p>
                <p style="font-size:13px;margin-bottom:12px;padding:10px;border-radius:6px;background:rgba(220,38,38,0.08);border:1px solid rgba(220,38,38,0.25);">
                    <strong style="color:#ef4444;">&#128274; SQL safety checks will be disabled.</strong>
                    The Check Validator will allow execution of INSERT, UPDATE, DELETE, DROP, TRUNCATE, EXEC, and other
                    potentially destructive queries against your servers. Use with extreme caution.
                </p>
                <p style="font-size:13px;margin-bottom:16px;padding:10px;border-radius:6px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);">
                    I either know what I'm doing, or I'm brave enough to find out. Who even needs pants when you're a DBA?
                    Show me the controls that let me make changes to my servers. I accept full responsibility for any and all
                    actions I take while in No-Pants Mode, and I understand that no one else is to blame if something goes sideways.
                </p>
                <div style="display:flex;gap:10px;justify-content:flex-end;">
                    <button class="btn-secondary" style="padding:8px 16px;border-radius:6px;cursor:pointer;" @onclick="CancelNoPantsModal">
                        Keep My Pants On
                    </button>
                    <button style="padding:8px 20px;border-radius:6px;cursor:pointer;background:#dc2626;color:white;border:1px solid #b91c1c;font-weight:600;"
                            @onclick="AcceptNoPantsDisclaimer">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="currentColor" style="display:inline;vertical-align:middle;margin-right:4px;">
                            <path d="M4 4h16v2l-2 14h-4l-1-8h-2l-1 8H6L4 6V4zm2 2v.5l1.8 12.5h2.4l1-8h1.6l1 8h2.4L18 6.5V6H6z"/>
                        </svg>
                        Who Needs Pants
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // Set to true once XEvent/Profiler, Schema Compare, and Dependency Walker pages are ready


    private bool _performanceMonitorExists = false;
    private bool _SQLWATCHExists = false;

    // ── Sidebar collapse ─────────────────────────────────────────────────
    private bool _collapsed = false;
    private void ToggleCollapse() => _collapsed = !_collapsed;

    // ── No-Pants Mode ────────────────────────────────────────────────────
    private bool _noPantsMode = false;
    private bool _showNoPantsModal = false;

    private void ToggleNoPantsMode()
    {
        if (!RbacService.HasPermission(UserState.Role, "run_scripts"))
            return;

        if (!_noPantsMode)
        {
            if (!UserSettings.GetNoPantsDisclaimerAccepted())
            {
                _showNoPantsModal = true;
                return;
            }
            _noPantsMode = true;
            UserSettings.SetNoPantsMode(true);
            AuditLog.LogSecurityEvent(
                $"No-Pants Mode ENABLED by {Environment.UserName}",
                AuditSeverity.Warning,
                new Dictionary<string, string> { ["User"] = Environment.UserName, ["Action"] = "Enabled" });
        }
        else
        {
            _noPantsMode = false;
            UserSettings.SetNoPantsMode(false);
            AuditLog.LogSecurityEvent(
                $"No-Pants Mode DISABLED by {Environment.UserName}",
                AuditSeverity.Info,
                new Dictionary<string, string> { ["User"] = Environment.UserName, ["Action"] = "Disabled" });
        }
    }

    private void AcceptNoPantsDisclaimer()
    {
        _showNoPantsModal = false;
        _noPantsMode = true;
        UserSettings.SetNoPantsDisclaimerAccepted(true);
        UserSettings.SetNoPantsMode(true);
        AuditLog.LogSecurityEvent(
            $"No-Pants Mode disclaimer ACCEPTED and ENABLED by {Environment.UserName}",
            AuditSeverity.Warning,
            new Dictionary<string, string> { ["User"] = Environment.UserName, ["Action"] = "DisclaimerAccepted" });
    }

    private void CancelNoPantsModal()
    {
        _showNoPantsModal = false;
    }

    // ── Report / Feedback popover ────────────────────────────────────────
    private bool _showReportMenu = false;
    private void ToggleReportMenu() => _showReportMenu = !_showReportMenu;

    // ── Experimental Mode ─────────────────────────────────────────────────
    private bool _experimentalMode = false;
    private bool _showMaturityRoadmap = false;

    private void ToggleExperimentalMode()
    {
        _experimentalMode = !_experimentalMode;
        UserSettings.SetExperimentalMode(_experimentalMode);
    }

    protected override async Task OnInitializedAsync()
    {
        _noPantsMode         = UserSettings.GetNoPantsMode();
        _experimentalMode    = UserSettings.GetExperimentalMode();
        _showMaturityRoadmap = UserSettings.GetShowMaturityRoadmap();
        ConnectionManager.OnConnectionChanged          += OnServerChanged;
        ConnectionHealth.OnStatusChanged               += OnHealthChanged;
        UserSettings.OnShowMaturityRoadmapChanged      += OnMaturityRoadmapChanged;
        InstanceSelector.OnInstanceChanged             += OnInstanceChanged;
        await RefreshDbFlags();
    }

    private void OnMaturityRoadmapChanged(bool enabled)
    {
        _showMaturityRoadmap = enabled;
        InvokeAsync(StateHasChanged);
    }

    private void OnHealthChanged() => InvokeAsync(StateHasChanged);

    private void OnServerChanged()
    {
        DbAvailability.InvalidateCache();
        _ = InvokeAsync(async () =>
        {
            await RefreshDbFlags();
            StateHasChanged();
        });
    }

    private void OnInstanceChanged(string instanceName)
    {
        DbAvailability.InvalidateCache();
        _ = InvokeAsync(async () =>
        {
            await RefreshDbFlags();
            StateHasChanged();
        });
    }

    private async Task RefreshDbFlags()
    {
        var pmTask = DbAvailability.DatabaseExistsAsync("PerformanceMonitor");
        var swTask = DbAvailability.DatabaseExistsAsync("SQLWATCH");
        await Task.WhenAll(pmTask, swTask);
        _performanceMonitorExists = pmTask.Result;
        _SQLWATCHExists = swTask.Result;
    }

    private RenderFragment NavIcon(string? icon) => builder =>
    {
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", "nav-icon");
        if (icon?.StartsWith("fa-") == true)
        {
            builder.OpenElement(2, "i");
            builder.AddAttribute(3, "class", icon);
            builder.CloseElement();
        }
        else
        {
            builder.AddContent(2, icon);
        }
        builder.CloseElement();
    };

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        ConnectionManager.OnConnectionChanged     -= OnServerChanged;
        ConnectionHealth.OnStatusChanged           -= OnHealthChanged;
        UserSettings.OnShowMaturityRoadmapChanged  -= OnMaturityRoadmapChanged;
        InstanceSelector.OnInstanceChanged         -= OnInstanceChanged;
        await ValueTask.CompletedTask;
    }
}
