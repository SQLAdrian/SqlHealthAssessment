<!--/* In the name of God, the Merciful, the Compassionate */-->
@*
    Tiny SVG sparkline. Pass either:
      • Values — numeric series for a smooth line chart, or
      • PassFlags — bool series (true=pass) for a discrete dot chart.

    Width/Height default to a row-friendly 80x18. Stroke and dot
    colors use canonical CSS vars (--green/--red) so colour-blind mode
    auto-remaps via wwwroot/css/Accessibility.css.
*@

@if (HasData)
{
    <svg width="@Width" height="@Height" viewBox="0 0 @Width @Height"
         class="sparkline" role="img" aria-label="@(AriaLabel ?? "Trend sparkline")">
        @if (PassFlags != null && PassFlags.Count > 0)
        {
            @* Dot chart: one dot per sample, green=pass, red=fail. *@
            @for (var i = 0; i < PassFlags.Count; i++)
            {
                var cx = PassFlags.Count == 1 ? Width / 2.0 : (i * (Width - 6.0) / (PassFlags.Count - 1)) + 3;
                var cy = Height / 2.0;
                var fill = PassFlags[i] ? "var(--green)" : "var(--red)";
                <circle cx="@cx.ToString("F1")" cy="@cy.ToString("F1")" r="2.5" fill="@fill" />
            }
        }
        else if (Values != null && Values.Count > 1)
        {
            @* Line chart: polyline of normalised values. *@
            <polyline fill="none" stroke="var(--accent, #4a9eff)" stroke-width="1.5"
                      points="@BuildLinePoints()" />
        }
    </svg>
}

@code {
    [Parameter] public List<bool>? PassFlags { get; set; }
    [Parameter] public List<double>? Values { get; set; }
    [Parameter] public int Width { get; set; } = 80;
    [Parameter] public int Height { get; set; } = 18;
    [Parameter] public string? AriaLabel { get; set; }

    private bool HasData =>
        (PassFlags != null && PassFlags.Count > 0) ||
        (Values != null && Values.Count > 1);

    private string BuildLinePoints()
    {
        if (Values == null || Values.Count < 2) return "";
        var min = Values.Min();
        var max = Values.Max();
        var range = max - min;
        if (range <= 0) range = 1;

        var sb = new System.Text.StringBuilder();
        for (var i = 0; i < Values.Count; i++)
        {
            var x = (i * (Width - 4.0) / (Values.Count - 1)) + 2;
            var norm = (Values[i] - min) / range;
            var y = Height - 2 - (norm * (Height - 4));
            if (i > 0) sb.Append(' ');
            sb.Append(x.ToString("F1"));
            sb.Append(',');
            sb.Append(y.ToString("F1"));
        }
        return sb.ToString();
    }
}
