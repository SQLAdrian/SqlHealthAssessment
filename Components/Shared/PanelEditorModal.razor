@* In the name of God, the Merciful, the Compassionate *@
@using SqlHealthAssessment.Data.Models

@if (IsVisible && _working != null)
{
    <div class="modal-overlay" @onclick="Cancel">
    <div class="modal section-editor-modal" @onclick:stopPropagation>

        <div class="modal-header">
            <h3><i class="fa-solid fa-gear"></i> Configure Panel</h3>
            <button class="modal-close" @onclick="Cancel"><i class="fa-solid fa-xmark"></i></button>
        </div>

        @* ── Tab bar ──────────────────────────────────────────────────────── *@
        <div class="sed-tabs">
            <button class="sed-tab @(_tab == 0 ? "sed-tab--active" : "")" @onclick="() => _tab = 0">
                <i class="fa-solid fa-table-columns"></i> Panel Config
            </button>
            <button class="sed-tab @(_tab == 1 ? "sed-tab--active" : "")" @onclick="() => _tab = 1">
                <i class="fa-solid fa-code"></i> SQL Query
            </button>
        </div>

        <div class="sed-body">

            @* ── Tab 0: Panel display config ──────────────────────────────── *@
            @if (_tab == 0)
            {
                <div class="form-section">
                    <h4>Basic</h4>
                    <div class="form-group">
                        <label>Panel Title</label>
                        <input type="text" @bind="_working.Title" @bind:event="oninput" placeholder="Panel title" />
                    </div>
                    <div class="form-group">
                        <label>Description</label>
                        <textarea @bind="_working.Description" @bind:event="oninput" rows="2" placeholder="Shown below chart"></textarea>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Default Database</label>
                            <input type="text" @bind="_working.DefaultDatabase" @bind:event="oninput" placeholder="master" />
                        </div>
                        <div class="form-group" style="flex:0 0 auto; display:flex; align-items:center; gap:6px; padding-bottom:2px;">
                            <input type="checkbox" @bind="_working.Enabled" id="ped-enabled" />
                            <label for="ped-enabled" style="margin:0;">Enabled</label>
                        </div>
                    </div>
                </div>

                <div class="form-section">
                    <h4>Display</h4>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Panel Type</label>
                            <select @bind="_working.PanelType">
                                <option value="TimeSeries">Time Series Chart</option>
                                <option value="StatCard">Stat Card</option>
                                <option value="DeltaStatCard">Delta Stat Card (per/sec)</option>
                                <option value="BarGauge">Bar Gauge</option>
                                <option value="DataGrid">Data Grid</option>
                                <option value="CheckStatus">Check Status</option>
                                <option value="TextCard">Text Card</option>
                            </select>
                        </div>
                        @if (_working.PanelType == "TimeSeries")
                        {
                            <div class="form-group">
                                <label>Chart Type</label>
                                <select @bind="_working.ChartType">
                                    <option value="Line">Line</option>
                                    <option value="Bar">Bar</option>
                                    <option value="Area">Area</option>
                                </select>
                            </div>
                        }
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Height (px)</label>
                            <input type="number" @bind="_working.Height" min="100" max="800" />
                        </div>
                        <div class="form-group">
                            <label>Refresh (sec)</label>
                            <input type="number" @bind="_working.RefreshIntervalSeconds" min="5" max="3600" placeholder="None" />
                        </div>
                    </div>
                </div>

                <div class="form-section">
                    <h4>Layout</h4>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Column</label>
                            <select @bind="_working.Layout.Column">
                                <option value="0">Special (Stats / Gauges)</option>
                                <option value="1">Left Column</option>
                                <option value="2">Right Column</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label><input type="checkbox" @bind="_working.Layout.SpanColumns" /> Span Full Width</label>
                    </div>
                </div>

                @if (_working.PanelType == "StatCard" || _working.PanelType == "DeltaStatCard")
                {
                    <div class="form-section">
                        <h4>Stat Card Settings</h4>
                        <div class="form-row">
                            <div class="form-group">
                                <label>Unit</label>
                                <input type="text" @bind="_working.StatUnit" placeholder="%, MB, etc." />
                            </div>
                            <div class="form-group">
                                <label>Threshold Key</label>
                                <input type="text" @bind="_working.StatThresholdKey" placeholder="cpu, memory…" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Value Format</label>
                            @ValueFormatSelect(_working)
                        </div>
                    </div>
                }

                @if (_working.PanelType == "BarGauge")
                {
                    <div class="form-section">
                        <h4>Bar Gauge Settings</h4>
                        <div class="form-row">
                            <div class="form-group">
                                <label>Threshold Key</label>
                                <input type="text" @bind="_working.BarGaugeThresholdKey" />
                            </div>
                            <div class="form-group">
                                <label>Unit Suffix</label>
                                <input type="text" @bind="_working.BarGaugeUnitSuffix" placeholder="%" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Value Format</label>
                            @ValueFormatSelect(_working)
                        </div>
                    </div>
                }

                @if (_working.PanelType == "DataGrid")
                {
                    <div class="form-section">
                        <h4>Data Grid Settings</h4>
                        <div class="form-row">
                            <div class="form-group">
                                <label><input type="checkbox" @bind="_working.DataGridIsClickable" /> Clickable Rows (query plan)</label>
                            </div>
                            <div class="form-group">
                                <label>Max Rows</label>
                                <input type="number" @bind="_working.DataGridMaxRows" min="10" max="10000" />
                            </div>
                        </div>
                    </div>
                }
            }

            @* ── Tab 1: SQL query ─────────────────────────────────────────── *@
            @if (_tab == 1)
            {
                <div class="form-section">
                    <h4>SQL Server Query</h4>
                    <div class="sed-query-hint">
                        <i class="fa-solid fa-lightbulb"></i>
                        Use <strong>@@SqlInstance</strong>, <strong>@@DateFrom</strong>, <strong>@@DateTo</strong> as parameters.
                        The query should return data matching the selected panel type
                        (e.g. a <strong>time</strong> column + metric columns for TimeSeries; a single value row for StatCard).
                    </div>
                    <div class="form-group">
                        <textarea @bind="_working.Query.SqlServer" @bind:event="oninput"
                                  rows="20" placeholder="SELECT ..."
                                  style="font-family: 'Consolas', monospace; font-size: 12px; resize: vertical;"></textarea>
                        <small>Query runs against the dashboard's default database context unless overridden above.</small>
                    </div>
                </div>
            }

        </div>

        <div class="modal-footer sed-footer">
            <button class="btn btn-secondary" @onclick="Cancel">Cancel</button>
            <button class="btn btn-primary" @onclick="Confirm">
                <i class="fa-solid fa-check"></i> Save Panel
            </button>
        </div>
    </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public PanelDefinition? Panel { get; set; }
    [Parameter] public EventCallback<PanelDefinition> OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private PanelDefinition? _working;
    private int _tab = 0;

    protected override void OnParametersSet()
    {
        if (IsVisible && Panel != null && (_working == null || _working.Id != Panel.Id))
        {
            _working = Clone(Panel);
            _tab = 0;
        }
    }

    private async Task Confirm()
    {
        if (_working == null) return;
        await OnSave.InvokeAsync(_working);
    }

    private async Task Cancel()
    {
        _working = null;
        await OnCancel.InvokeAsync();
    }

    private static PanelDefinition Clone(PanelDefinition p) => new()
    {
        Id                     = p.Id,
        Title                  = p.Title,
        Description            = p.Description,
        Enabled                = p.Enabled,
        Source                 = p.Source,
        PanelType              = p.PanelType,
        ChartType              = p.ChartType,
        Height                 = p.Height,
        RefreshIntervalSeconds = p.RefreshIntervalSeconds,
        Layout                 = new PanelLayout { Column = p.Layout.Column, Order = p.Layout.Order, SpanColumns = p.Layout.SpanColumns },
        Query                  = new QueryPair   { Source = p.Query.Source, SqlServer = p.Query.SqlServer },
        DefaultDatabase        = p.DefaultDatabase,
        StatUnit               = p.StatUnit,
        StatThresholdKey       = p.StatThresholdKey,
        BarGaugeThresholdKey   = p.BarGaugeThresholdKey,
        BarGaugeUnitSuffix     = p.BarGaugeUnitSuffix,
        ValueFormat            = p.ValueFormat,
        DataGridIsClickable    = p.DataGridIsClickable,
        DataGridMaxRows        = p.DataGridMaxRows,
        DataGridTopRows        = p.DataGridTopRows,
        ActionColumn           = p.ActionColumn,
        ActionColumnMode       = p.ActionColumnMode,
        ColorThresholds        = p.ColorThresholds.Select(t => new ColorThresholdRule
            { Operator = t.Operator, Value = t.Value, Color = t.Color, Label = t.Label }).ToList(),
    };

    private RenderFragment ValueFormatSelect(PanelDefinition p) => __builder =>
    {
        <select @bind="p.ValueFormat">
            <option value="">Default (no formatting)</option>
            <option value="N0">Integer (1,234)</option>
            <option value="N1">1 Decimal (1,234.5)</option>
            <option value="N2">2 Decimals (1,234.56)</option>
            <option value="P0">Percent 0 (100%)</option>
            <option value="P1">Percent 1 (99.9%)</option>
            <option value="P2">Percent 2 (99.99%)</option>
            <option value="C0">Currency 0 ($1,234)</option>
            <option value="C2">Currency 2 ($1,234.56)</option>
            <option value="0.## GB">GB (1.23 GB)</option>
            <option value="0.## MB">MB (1.23 MB)</option>
            <option value="0.## TB">TB (1.23 TB)</option>
            <option value="0.## ms">Milliseconds (123 ms)</option>
            <option value="0.## s">Seconds (1.23 s)</option>
        </select>
    };
}
