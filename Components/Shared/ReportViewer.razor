@using SqlHealthAssessment.Data.Services
@using Microsoft.AspNetCore.Components.Web
@using System.Data
@using System.IO
@inject RdlReportService RdlReportService
@inject NavigationManager Navigation

<div class="report-viewer-container">
    @if (_isLoading)
    {
        <div class="loading-overlay">
            <div class="loading-spinner"></div>
            <p>Loading report...</p>
        </div>
    }
    else if (_reportBytes != null)
    {
        <div class="report-display">
            <iframe 
                src="@_reportUrl" 
                width="100%" 
                height="800px" 
                style="border: none;">
            </iframe>
        </div>
    }
    else if (_errorMessage != null)
    {
        <div class="alert alert-danger">
            <strong>Error loading report:</strong> @_errorMessage
        </div>
    }
    else
    {
        <div class="report-placeholder">
            <p>No report loaded. Please select a report and data source.</p>
        </div>
    }
</div>

@code {
    [Parameter] public string ReportName { get; set; }
    [Parameter] public Dictionary<string, DataTable> DataSources { get; set; } = new();
    [Parameter] public Dictionary<string, string> Parameters { get; set; } = new();

    private byte[] _reportBytes;
    private string _reportUrl;
    private string _errorMessage;
    private bool _isLoading = false;

    protected override async Task OnParametersSetAsync()
    {
        await LoadReportAsync();
    }

    private async Task LoadReportAsync()
    {
        if (string.IsNullOrEmpty(ReportName))
            return;

        _isLoading = true;
        _errorMessage = null;
        _reportBytes = null;
        _reportUrl = null;

        try
        {
            var rdlFileName = ReportName + ".rdl";
            _reportBytes = await Task.Run(() => 
                RdlReportService.GeneratePdfReport(rdlFileName, DataSources, Parameters));

            var base64 = Convert.ToBase64String(_reportBytes);
            _reportUrl = $"data:application/pdf;base64,{base64}";
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }
}