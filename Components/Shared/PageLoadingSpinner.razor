<!-- In the name of God, the Merciful, the Compassionate -->
<div class="loading-container" style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:@(MinHeight)px;padding:48px 24px;gap:16px;">
    <div class="loading-spinner" style="width:40px;height:40px;border:3px solid var(--border-color, #333);border-top:3px solid var(--accent, #007acc);border-radius:50%;animation:spin 0.8s linear infinite;"></div>
    @if (!string.IsNullOrEmpty(Message))
    {
        <p style="color:var(--text-muted, #888);font-size:14px;margin:0;">@Message</p>
    }
</div>

<!-- Styles extracted to wwwroot/css/PageLoadingSpinner.css 2026-05-11 (CLAUDE.md convention). -->

@code {
    [Parameter] public string Message { get; set; } = "Loading...";
    [Parameter] public int MinHeight { get; set; } = 300;
}
