{
  "profiles": {
    "WPF Desktop": {
      "commandName": "Project",
      "environmentVariables": {
        "DOTNET_ENVIRONMENT": "Development"
      },
      "hotReloadEnabled": false
    },
    "Kestrel Server": {
      "commandName": "Project",
      "commandLineArgs": "--server",
      "launchBrowser": true,
      "launchUrl": "https://localhost:5001",
      "applicationUrl": "https://localhost:5001;http://localhost:5000",
      "environmentVariables": {
        "DOTNET_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:5001;http://localhost:5000"
      }
    },
    "Kestrel Server (Production)": {
      "commandName": "Project",
      "commandLineArgs": "--server --no-browser",
      "applicationUrl": "https://0.0.0.0:5001",
      "environmentVariables": {
        "DOTNET_ENVIRONMENT": "Production",
        "ASPNETCORE_URLS": "https://0.0.0.0:5001"
      }
    },
    "Docker": {
      "commandName": "Docker",
      "dockerfileRunArguments": "-p 5001:5001",
      "environmentVariables": {
        "DOTNET_ENVIRONMENT": "Production"
      }
    }
  }
}
